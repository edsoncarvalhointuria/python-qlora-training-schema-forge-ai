from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst CourseGradeSchema = z.object({\\n  course_code: z.string().openapi({ description: 'The unique code identifying the course', example: 'CS101' }),\\n  course_name: z.string().openapi({ description: 'The official name of the course', example: 'Introduction to Computer Science' }),\\n  grade: z.string().openapi({ description: 'Final grade earned for the course', example: 'A' })\\n}).openapi({ description: 'A completed course with grade information' });\\n\\nconst SemesterRecordSchema = z.object({\\n  semester_name: z.string().openapi({ description: 'The academic semester name', example: 'Fall 2022' }),\\n  gpa: z.number().openapi({ description: 'GPA achieved in the semester', example: 3.75 }),\\n  credits_earned: z.number().int().openapi({ description: 'Total credits earned in the semester', example: 15 }),\\n  courses: z.array(CourseGradeSchema).openapi({ description: 'List of courses completed in the semester' })\\n}).openapi({ description: 'Academic record for a single completed semester' });\\n\\nconst AcademicHistorySchema = z.object({\\n  completed_semesters: z.array(SemesterRecordSchema).openapi({ description: 'Array of completed semesters with their academic records' }),\\n  cumulative_gpa: z.number().openapi({ description: 'Overall GPA across all completed semesters', example: 3.8 }),\\n  total_credits: z.number().int().openapi({ description: 'Total credits accumulated', example: 31 })\\n}).openapi({ description: 'Aggregate academic history information' });\\n\\nconst CurrentCourseSchema = z.object({\\n  course_code: z.string().openapi({ description: 'Code for the current enrolled course', example: 'CS301' }),\\n  course_name: z.string().openapi({ description: 'Name of the current enrolled course', example: 'Operating Systems' }),\\n  instructor: z.string().openapi({ description: 'Name of the course instructor', example: 'Dr. Emily Smith' }),\\n  schedule: z.string().openapi({ description: 'Scheduled meeting days and times', example: 'Mon-Wed 10:00-11:30' }),\\n  credits: z.number().int().openapi({ description: 'Credit value of the course', example: 3 })\\n}).openapi({ description: 'Information about a currently enrolled course' });\\n\\nconst FinancialStatusSchema = z.object({\\n  tuition_balance: z.number().openapi({ description: 'Outstanding tuition balance in USD', example: 1200.50 }),\\n  last_payment_date: z.string().regex(/^\\\\d{4}-\\\\d{2}-\\\\d{2}$/).openapi({ description: 'Date of the last tuition payment in ISO format', example: '2024-04-15' }),\\n  payment_status: z.enum(['Paid', 'Pending', 'Overdue']).openapi({ description: 'Current payment status of tuition fees', example: 'Pending' }),\\n  scholarship_applied: z.boolean().openapi({ description: 'Indicates if a scholarship is applied on account', example: true }),\\n  scholarship_amount: z.number().optional().openapi({ description: 'Amount of scholarship awarded in USD', example: 3000 })\\n}).openapi({ description: 'Current financial status of the student regarding tuition' });\\n\\nexport const StudentDashboardSchema = z.object({\\n  student_id: z.string().openapi({ description: 'Unique identifier for the student', example: 'S123456789' }),\\n  full_name: z.string().openapi({ description: 'Full legal name of the student', example: 'Alice Johnson' }),\\n  academic_history: AcademicHistorySchema,\\n  current_courses: z.array(CurrentCourseSchema).openapi({ description: 'List of courses student is currently enrolled in' }),\\n  financial_status: FinancialStatusSchema\\n}).openapi({ title: 'University Student Dashboard Response', description: 'Comprehensive data model for a university student dashboard including academic records, current courses, and financial tuition details' });\"\n}"
