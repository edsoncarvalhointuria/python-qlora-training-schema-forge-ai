a = z.object({\\n  seat_upgrades: z.array(z.string()).openapi({ description: 'List of selected seat upgrades', example: ['Extra Legroom', 'Window Seat'] }),\\n  meal_type: z.string().openapi({ description: 'Selected meal preference', example: 'Vegetarian' })\\n}).openapi({ description: 'Passenger service preferences' });\\n\\nexport const FlightBookingConfirmationSchema = z.object({\\n  booking_id: z.string().openapi({ description: 'Unique booking reference number', example: 'BK-9928374' }),\\n  passenger: PassengerSchema,\\n  itinerary: ItinerarySchema,\\n  preferences: PreferencesSchema\\n}).openapi({ title: 'Flight Booking Confirmation', description: 'Complete flight booking confirmation object including passenger, itinerary, and preferences' });\"\n}"
