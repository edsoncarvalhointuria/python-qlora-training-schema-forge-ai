
"{\n  \"raw_json\": {\n    \"order_id\": \"ord_4587\",\n    \"items\": [\n      {\n        \"product_id\": \"prd_1234\",\n        \"name\": \"Wireless Mouse\",\n        \"quantity\": 2,\n        \"price\": 25.99,\n        \"weight_kg\": 0.2\n      },\n      {\n        \"product_id\": \"prd_5678\",\n        \"name\": \"Mechanical Keyboard\",\n        \"quantity\": 1,\n        \"price\": 89.99,\n        \"weight_kg\": 1.2\n      }\n    ],\n    \"shipping_address\": {\n      \"recipient_name\": \"Ana Silva\",\n      \"street\": \"Av. Brasil, 1000\",\n      \"city\": \"São Paulo\",\n      \"state\": \"SP\",\n      \"postal_code\": \"01000-000\",\n      \"country\": \"Brazil\"\n    },\n    \"payment\": {\n      \"transaction_id\": \"txn_7744\",\n      \"amount\": 141.97,\n      \"currency\": \"BRL\",\n      \"method\": \"credit_card\",\n      \"status\": \"approved\",\n      \"paid_at\": \"2024-06-10T14:20:00Z\"\n    },\n    \"_links\": {\n      \"self\": \"/api/orders/ord_4587\",\n      \"tracking\": \"/api/orders/ord_4587/tracking\"\n    }\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst HalLinksSchema = z.object({\\n  self: z.string().url().openapi({ description: 'Canonical URL of the resource / URL canônica do recurso', example: '/api/orders/ord_4587' }),\\n  tracking: z.string().url().openapi({ description: 'Link para rastreamento do pedido / Tracking link of the order', example: '/api/orders/ord_4587/tracking' })\\n}).openapi({ description: 'Standard HATEOAS navigation links' });\\n\\nconst PhysicalItemSchema = z.object({\\n  product_id: z.string().openapi({ description: 'Identificador único do produto / Unique product identifier', example: 'prd_1234' }),\\n  name: z.string().openapi({ description: 'Nome do produto / Name of the product', example: 'Wireless Mouse' }),\\n  quantity: z.number().int().min(1).openapi({ description: 'Quantidade comprada do produto / Quantity of the product purchased', example: 2 }),\\n  price: z.number().openapi({ description: 'Preço unitário do produto em BRL / Unit price of the product in BRL', example: 25.99 }),\\n  weight_kg: z.number().positive().openapi({ description: 'Peso do produto em quilogramas / Weight of the product in kilograms', example: 0.2 })\\n}).openapi({ description: 'Physical item included in the order' });\\n\\nconst ShippingAddressSchema = z.object({\\n  recipient_name: z.string().openapi({ description: 'Nome do destinatário para entrega / Recipient name for delivery', example: 'Ana Silva' }),\\n  street: z.string().openapi({ description: 'Endereço de rua / Street address', example: 'Av. Brasil, 1000' }),\\n  city: z.string().openapi({ description: 'Cidade de entrega / Delivery city', example: 'São Paulo' }),\\n  state: z.string().openapi({ description: 'Estado de entrega / Delivery state', example: 'SP' }),\\n  postal_code: z.string().openapi({ description: 'CEP / Postal code', example: '01000-000' }),\\n  country: z.string().openapi({ description: 'País de entrega / Delivery country', example: 'Brazil' })\\n}).openapi({ description: 'Endereço para envio dos itens físicos / Address for shipping the physical items' });\\n\\nconst PaymentTransactionSchema = z.object({\\n  transaction_id: z.string().openapi({ description: 'Identificador da transação de pagamento / Payment transaction identifier', example: 'txn_7744' }),\\n  amount: z.number().openapi({ description: 'Valor total pago na transação / Total amount paid in the transaction', example: 141.97 }),\\n  currency: z.string().length(3).openapi({ description: 'Código da moeda ISO 4217 / ISO 4217 currency code', example: 'BRL' }),\\n  method: z.enum(['credit_card', 'paypal', 'bank_transfer']).openapi({ description: 'Método de pagamento utilizado / Payment method used', example: 'credit_card' }),\\n  status: z.enum(['pending', 'approved', 'declined']).openapi({ description: 'Status da transação / Transaction status', example: 'approved' }),\\n  paid_at: z.string().datetime().openapi({ description: 'Timestamp da confirmação do pagamento / Payment confirmation timestamp', example: '2024-06-10T14:20:00Z' })\\n}).openapi({ description: 'Detalhes da transação financeira associada ao pedido / Financial transaction details associated with the order' });\\n\\nexport const EcommerceOrderResponseSchema = z.object({\\n  order_id: z.string().openapi({ description: 'Identificador único do pedido / Unique order identifier', example: 'ord_4587' }),\\n  items: z.array(PhysicalItemSchema).min(1).openapi({ description: 'Lista de itens físicos pedidos / List of physical items ordered' }),\\n  shipping_address: ShippingAddressSchema.openapi({ description: 'Detalhes do endereço de entrega / Shipping address details' }),\\n  payment: PaymentTransactionSchema.openapi({ description: 'Informações da transação de pagamento / Payment transaction information' }),\\n  _links: HalLinksSchema\\n}).openapi({ title: 'E-commerce Order Response', description: 'Resposta detalhada de um pedido e-commerce contendo itens físicos, endereço de entrega, pagamento e links HAL / Detailed e-commerce order response including physical items, shipping address, payment, and HAL links' });\"\n}"
"{\n  \"raw_json\": {\n    \"order_id\": \"ORD123456789\",\n    \"items\": [\n      {\n        \"item_id\": \"SKU987654321\",\n        \"name\": \"Wireless Bluetooth Headphones\",\n        \"quantity\": 2,\n        \"price_per_unit\": 59.99,\n        \"weight_kg\": 0.25,\n        \"dimensions_cm\": {\n          \"length\": 20,\n          \"width\": 15,\n          \"height\": 5\n        }\n      },\n      {\n        \"item_id\": \"SKU123456789\",\n        \"name\": \"Portable Power Bank\",\n        \"quantity\": 1,\n        \"price_per_unit\": 29.99,\n        \"weight_kg\": 0.3,\n        \"dimensions_cm\": {\n          \"length\": 10,\n          \"width\": 7,\n          \"height\": 2\n        }\n      }\n    ],\n    \"shipping_address\": {\n      \"recipient_name\": \"John Doe\",\n      \"street_address\": \"123 Elm Street\",\n      \"city\": \"Springfield\",\n      \"state\": \"IL\",\n      \"postal_code\": \"62704\",\n      \"country\": \"USA\",\n      \"phone_number\": \"+1-217-555-0100\"\n    },\n    \"payment_transaction\": {\n      \"transaction_id\": \"TXN789654123\",\n      \"payment_method\": \"Credit Card\",\n      \"amount\": 149.97,\n      \"currency\": \"USD\",\n      \"status\": \"Completed\",\n      \"processed_at\": \"2024-06-15T14:25:35Z\"\n    },\n    \"_links\": {\n      \"self\": {\n        \"href\": \"https://api.example.com/orders/ORD123456789\",\n        \"title\": \"Current order\"\n      },\n      \"tracking\": {\n        \"href\": \"https://tracking.example.com/track/ORD123456789\",\n        \"title\": \"Shipment tracking\"\n      }\n    }\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst DimensionsSchema = z.object({\\n  length: z.number().openapi({ description: 'Length in centimeters', example: 20 }),\\n  width: z.number().openapi({ description: 'Width in centimeters', example: 15 }),\\n  height: z.number().openapi({ description: 'Height in centimeters', example: 5 })\\n}).openapi({ description: 'Physical dimensions of the item' });\\n\\nconst ItemSchema = z.object({\\n  item_id: z.string().openapi({ description: 'Unique identifier for the item', example: 'SKU987654321' }),\\n  name: z.string().openapi({ description: 'Name of the product', example: 'Wireless Bluetooth Headphones' }),\\n  quantity: z.number().int().positive().openapi({ description: 'Quantity of the item ordered', example: 2 }),\\n  price_per_unit: z.number().nonnegative().openapi({ description: 'Price per single unit in order currency', example: 59.99 }),\\n  weight_kg: z.number().positive().openapi({ description: 'Weight of a single unit in kilograms', example: 0.25 }),\\n  dimensions_cm: DimensionsSchema\\n}).openapi({ description: 'An individual physical item in the order' });\\n\\nconst ShippingAddressSchema = z.object({\\n  recipient_name: z.string().openapi({ description: 'Name of the person receiving the shipment', example: 'John Doe' }),\\n  street_address: z.string().openapi({ description: 'Street and number for shipping', example: '123 Elm Street' }),\\n  city: z.string().openapi({ description: 'City of the shipping address', example: 'Springfield' }),\\n  state: z.string().openapi({ description: 'State or province of the shipping address', example: 'IL' }),\\n  postal_code: z.string().openapi({ description: 'Postal or ZIP code', example: '62704' }),\\n  country: z.string().openapi({ description: 'Country of the shipping address', example: 'USA' }),\\n  phone_number: z.string().openapi({ description: 'Contact phone number for delivery', example: '+1-217-555-0100' })\\n}).openapi({ description: 'Shipping address for the order' });\\n\\nconst PaymentTransactionSchema = z.object({\\n  transaction_id: z.string().openapi({ description: 'Unique payment transaction identifier', example: 'TXN789654123' }),\\n  payment_method: z.string().openapi({ description: 'Method used for payment', example: 'Credit Card' }),\\n  amount: z.number().nonnegative().openapi({ description: 'Total amount paid in the specified currency', example: 149.97 }),\\n  currency: z.string().length(3).openapi({ description: 'ISO 4217 currency code', example: 'USD' }),\\n  status: z.string().openapi({ description: 'Current status of the payment transaction', example: 'Completed' }),\\n  processed_at: z.string().datetime().openapi({ description: 'ISO 8601 timestamp when the payment was processed', example: '2024-06-15T14:25:35Z' })\\n}).openapi({ description: 'Details of the payment transaction for the order' });\\n\\nconst LinkSchema = z.object({\\n  href: z.string().url().openapi({ description: 'URL for the linked resource', example: 'https://api.example.com/orders/ORD123456789' }),\\n  title: z.string().openapi({ description: 'Human-readable title for the link', example: 'Current order' })\\n}).openapi({ description: 'A HAL link object pointing to a related resource' });\\n\\nconst LinksSchema = z.object({\\n  self: LinkSchema,\\n  tracking: LinkSchema.optional().openapi({ description: 'Link to order shipment tracking URL' })\\n}).openapi({ description: 'HAL _links containing related URLs for the order' });\\n\\nexport const OrderResponseSchema = z.object({\\n  order_id: z.string().openapi({ description: 'Unique identifier for the order', example: 'ORD123456789' }),\\n  items: z.array(ItemSchema).nonempty().openapi({ description: 'List of physical items included in the order' }),\\n  shipping_address: ShippingAddressSchema,\\n  payment_transaction: PaymentTransactionSchema,\\n  _links: LinksSchema\\n}).openapi({ title: 'E-Commerce Order Response', description: 'Response schema for an e-commerce order with items, shipment, payment, and hypermedia links' });\"\n}"
"{\n  \"raw_json\": {\n    \"order_id\": \"order_12345\",\n    \"items\": [\n      {\n        \"item_id\": \"item_987\",\n        \"name\": \"Wireless Mouse\",\n        \"quantity\": 2,\n        \"unit_price\": 25.99,\n        \"weight_kg\": 0.15\n      },\n      {\n        \"item_id\": \"item_654\",\n        \"name\": \"USB Keyboard\",\n        \"quantity\": 1,\n        \"unit_price\": 45.5,\n        \"weight_kg\": 0.85\n      }\n    ],\n    \"shipping_address\": {\n      \"recipient_name\": \"John Doe\",\n      \"street\": \"123 Market St\",\n      \"city\": \"San Francisco\",\n      \"state\": \"CA\",\n      \"postal_code\": \"94103\",\n      \"country\": \"USA\",\n      \"phone\": \"+1-415-555-1234\"\n    },\n    \"payment_transaction\": {\n      \"transaction_id\": \"txn_78910\",\n      \"payment_method\": \"credit_card\",\n      \"amount\": 97.48,\n      \"currency\": \"USD\",\n      \"status\": \"completed\",\n      \"processed_at\": \"2024-06-15T13:45:30Z\"\n    },\n    \"_links\": {\n      \"self\": {\n        \"href\": \"https://api.store.com/orders/order_12345\",\n        \"title\": \"Order itself\"\n      },\n      \"tracking\": {\n        \"href\": \"https://api.shipping.com/track/track_456\",\n        \"title\": \"Tracking information\"\n      }\n    }\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst ItemSchema = z.object({\\n  item_id: z.string().openapi({ description: 'Unique identifier of the purchased item', example: 'item_987' }),\\n  name: z.string().openapi({ description: 'Name or title of the item', example: 'Wireless Mouse' }),\\n  quantity: z.number().int().positive().openapi({ description: 'Quantity of this item ordered', example: 2 }),\\n  unit_price: z.number().positive().openapi({ description: 'Price per one unit of the item in the order currency', example: 25.99 }),\\n  weight_kg: z.number().positive().openapi({ description: 'Weight of single item unit in kilograms', example: 0.15 })\\n}).openapi({ description: 'Physical item details in the order' });\\n\\nconst ShippingAddressSchema = z.object({\\n  recipient_name: z.string().openapi({ description: 'Full name of the person receiving the shipment', example: 'John Doe' }),\\n  street: z.string().openapi({ description: 'Street address including number and street name', example: '123 Market St' }),\\n  city: z.string().openapi({ description: 'City for the shipment destination', example: 'San Francisco' }),\\n  state: z.string().openapi({ description: 'State or region for the shipment', example: 'CA' }),\\n  postal_code: z.string().openapi({ description: 'Postal or ZIP code of the shipment address', example: '94103' }),\\n  country: z.string().openapi({ description: 'Country of the destination address', example: 'USA' }),\\n  phone: z.string().openapi({ description: 'Contact phone number associated with the shipping address', example: '+1-415-555-1234' })\\n}).openapi({ description: 'Destination address for physical order delivery' });\\n\\nconst PaymentTransactionSchema = z.object({\\n  transaction_id: z.string().openapi({ description: 'Unique payment processor transaction identifier', example: 'txn_78910' }),\\n  payment_method: z.enum(['credit_card', 'paypal', 'bank_transfer']).openapi({ description: 'Method used for the payment process', example: 'credit_card' }),\\n  amount: z.number().positive().openapi({ description: 'Total payment amount processed', example: 97.48 }),\\n  currency: z.string().length(3).openapi({ description: 'ISO 4217 currency code for the payment', example: 'USD' }),\\n  status: z.enum(['pending', 'completed', 'failed', 'refunded']).openapi({ description: 'Current status of the payment transaction', example: 'completed' }),\\n  processed_at: z.string().datetime().openapi({ description: 'Timestamp when the payment was processed in ISO 8601 format', example: '2024-06-15T13:45:30Z' })\\n}).openapi({ description: 'Details about the payment transaction for the order' });\\n\\nconst LinkObjectSchema = z.object({\\n  href: z.string().url().openapi({ description: 'URL for the linked resource', example: 'https://api.store.com/orders/order_12345' }),\\n  title: z.string().optional().openapi({ description: 'Human-readable title for the link', example: 'Order itself' })\\n}).openapi({ description: 'Individual HAL link object containing URL and optional description' });\\n\\nconst LinksSchema = z.object({\\n  self: LinkObjectSchema.openapi({ description: 'Link to the order resource itself' }),\\n  tracking: LinkObjectSchema.openapi({ description: 'Link to shipment tracking information' })\\n}).openapi({ description: 'HAL _links object providing navigational URLs' });\\n\\nexport const EcommerceOrderResponseSchema = z.object({\\n  order_id: z.string().openapi({ description: 'Unique identifier for the order', example: 'order_12345' }),\\n  items: z.array(ItemSchema).openapi({ description: 'List of physical items included in the order' }),\\n  shipping_address: ShippingAddressSchema.openapi({ description: 'Shipping destination details for the order' }),\\n  payment_transaction: PaymentTransactionSchema.openapi({ description: 'Payment transaction information for the order' }),\\n  _links: LinksSchema.openapi({ description: 'HAL formatted links related to the order' })\\n}).openapi({ title: 'E-commerce Order Response', description: 'Detailed response of an e-commerce order including items, shipping, payment, and HAL links' });\"\n}"
"{\n  \"raw_json\": {\n    \"order_id\": \"ord_987654321\",\n    \"items\": [\n      {\n        \"product_id\": \"prod_12345\",\n        \"name\": \"Tênis esportivo\",\n        \"quantity\": 2,\n        \"unit_price\": 299.9,\n        \"weight_kg\": 0.75\n      },\n      {\n        \"product_id\": \"prod_67890\",\n        \"name\": \"Camiseta de algodão\",\n        \"quantity\": 1,\n        \"unit_price\": 89.5,\n        \"weight_kg\": 0.2\n      }\n    ],\n    \"shipping_address\": {\n      \"street\": \"Rua das Flores, 123\",\n      \"city\": \"São Paulo\",\n      \"state\": \"SP\",\n      \"postal_code\": \"01234-567\",\n      \"country\": \"Brasil\"\n    },\n    \"payment\": {\n      \"transaction_id\": \"txn_54321abc\",\n      \"method\": \"cartão de crédito\",\n      \"amount\": 689.3,\n      \"currency\": \"BRL\",\n      \"status\": \"pago\"\n    },\n    \"_links\": {\n      \"self\": { \"href\": \"https://api.loja.com/orders/ord_987654321\" },\n      \"tracking\": { \"href\": \"https://api.transportadora.com/track/ord_987654321\" }\n    }\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst ItemSchema = z.object({\\n  product_id: z.string().openapi({ description: 'ID único do produto', example: 'prod_12345' }),\\n  name: z.string().openapi({ description: 'Nome do produto', example: 'Tênis esportivo' }),\\n  quantity: z.number().int().min(1).openapi({ description: 'Quantidade de itens deste produto na ordem', example: 2 }),\\n  unit_price: z.number().min(0).openapi({ description: 'Preço unitário do produto em reais', example: 299.9 }),\\n  weight_kg: z.number().min(0).openapi({ description: 'Peso do produto em quilogramas', example: 0.75 })\\n}).openapi({ description: 'Detalhes do item físico no pedido' });\\n\\nconst ShippingAddressSchema = z.object({\\n  street: z.string().openapi({ description: 'Logradouro e número', example: 'Rua das Flores, 123' }),\\n  city: z.string().openapi({ description: 'Cidade do endereço de entrega', example: 'São Paulo' }),\\n  state: z.string().openapi({ description: 'Estado ou unidade federativa', example: 'SP' }),\\n  postal_code: z.string().openapi({ description: 'CEP do endereço de entrega', example: '01234-567' }),\\n  country: z.string().openapi({ description: 'País do endereço de entrega', example: 'Brasil' })\\n}).openapi({ description: 'Endereço de envio dos produtos' });\\n\\nconst PaymentSchema = z.object({\\n  transaction_id: z.string().openapi({ description: 'Identificador da transação de pagamento', example: 'txn_54321abc' }),\\n  method: z.string().openapi({ description: 'Método de pagamento utilizado', example: 'cartão de crédito' }),\\n  amount: z.number().min(0).openapi({ description: 'Valor total pago em reais', example: 689.3 }),\\n  currency: z.string().openapi({ description: 'Moeda utilizada na transação', example: 'BRL' }),\\n  status: z.enum(['pendente', 'pago', 'cancelado']).openapi({ description: 'Status atual do pagamento', example: 'pago' })\\n}).openapi({ description: 'Detalhes da transação de pagamento' });\\n\\nconst HalLinkSchema = z.object({\\n  href: z.string().url().openapi({ description: 'URL do link HAL', example: 'https://api.loja.com/orders/ord_987654321' })\\n}).openapi({ description: 'Representação de um link HAL' });\\n\\nconst HalLinksSchema = z.object({\\n  self: HalLinkSchema,\\n  tracking: HalLinkSchema\\n}).openapi({ description: 'Links HAL para navegação e rastreamento' });\\n\\nexport const OrderResponseSchema = z.object({\\n  order_id: z.string().openapi({ description: 'ID único do pedido', example: 'ord_987654321' }),\\n  items: z.array(ItemSchema).openapi({ description: 'Lista de itens físicos do pedido' }),\\n  shipping_address: ShippingAddressSchema,\\n  payment: PaymentSchema,\\n  _links: HalLinksSchema\\n}).openapi({ title: 'Resposta do Pedido', description: 'Detalhes completos de um pedido e seu status' });\"\n}"
"{\n  \"raw_json\": {\n    \"user\": {\n      \"id\": \"usr_789\",\n      \"fullName\": \"Lucas Silva\",\n      \"email\": \"lucas.silva@example.com\",\n      \"phoneNumber\": \"+5511998765432\",\n      \"dateOfBirth\": \"1990-05-15\"\n    },\n    \"wallet\": {\n      \"currency\": \"BRL\",\n      \"currentBalance\": 2530.75\n    },\n    \"transactions\": [\n      {\n        \"transactionId\": \"txn_001\",\n        \"date\": \"2024-06-10T14:23:00Z\",\n        \"type\": \"credit\",\n        \"amount\": 1500,\n        \"description\": \"Depósito recebido\",\n        \"status\": \"completed\",\n        \"counterparty\": {\n          \"name\": \"Empresa ABC\",\n          \"account\": \"123456789\",\n          \"bank\": \"Banco do Brasil\"\n        }\n      },\n      {\n        \"transactionId\": \"txn_002\",\n        \"date\": \"2024-06-09T09:15:30Z\",\n        \"type\": \"debit\",\n        \"amount\": 125.25,\n        \"description\": \"Compra no Supermercado XYZ\",\n        \"status\": \"completed\",\n        \"counterparty\": {\n          \"name\": \"Supermercado XYZ\",\n          \"account\": \"987654321\",\n          \"bank\": \"Itaú\"\n        }\n      },\n      {\n        \"transactionId\": \"txn_003\",\n        \"date\": \"2024-06-08T17:45:10Z\",\n        \"type\": \"debit\",\n        \"amount\": 45.5,\n        \"description\": \"Pagamento de serviço - Netflix\",\n        \"status\": \"pending\",\n        \"counterparty\": {\n          \"name\": \"Netflix Ltda.\",\n          \"account\": \"453212345\",\n          \"bank\": \"Bradesco\"\n        }\n      }\n    ]\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst UserProfileSchema = z.object({\\n  id: z.string().openapi({ description: 'Identificador único do usuário', example: 'usr_789' }),\\n  fullName: z.string().openapi({ description: 'Nome completo do usuário', example: 'Lucas Silva' }),\\n  email: