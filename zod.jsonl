Nome do produto', example: 'Camiseta Azul' }),\\n  quantity: z.number().int().positive().openapi({ description: 'Quantidade de unidades do produto', example: 2 }),\\n  unit_price: z.number().positive().openapi({ description: 'Preço unitário do produto em reais', example: 49.9 }),\\n  weight_kg: z.number().positive().openapi({ description: 'Peso unitário do produto em quilogramas', example: 0.3 })\\n}).openapi({ description: 'Detalhes de um item físico na ordem' });\\n\\nconst ShippingAddressSchema = z.object({\\n  recipient_name: z.string().openapi({ description: 'Nome do destinatário para entrega', example: 'Maria Silva' }),\\n  street: z.string().openapi({ description: 'Endereço da rua', example: 'Av. Paulista, 1000' }),\\n  city: z.string().openapi({ description: 'Cidade do endereço de entrega', example: 'São Paulo' }),\\n  state: z.string().openapi({ description: 'Estado do endereço de entrega', example: 'SP' }),\\n  zip_code: z.string().openapi({ description: 'Código postal ou CEP do endereço', example: '01310-100' }),\\n  country: z.string().openapi({ description: 'País do endereço de entrega', example: 'Brasil' })\\n}).openapi({ description: 'Endereço físico de entrega' });\\n\\nconst PaymentTransactionSchema = z.object({\\n  transaction_id: z.string().openapi({ description: 'Identificador único da transação de pagamento', example: 'txn_5678' }),\\n  method: z.string().openapi({ description: 'Método de pagamento utilizado', example: 'Cartão de Crédito' }),\\n  status: z.string().openapi({ description: 'Status atual da transação', example: 'Aprovado' }),\\n  amount: z.number().positive().openapi({ description: 'Valor total pago na transação', example: 399.79 }),\\n  currency: z.string().length(3).openapi({ description: 'Código da moeda ISO 4217', example: 'BRL' }),\\n  paid_at: z.string().datetime().openapi({ description: 'Data e hora em que o pagamento foi efetuado', example: '2024-06-01T15:22:30Z' })\\n}).openapi({ description: 'Detalhes da transação de pagamento' });\\n\\nexport const EcommerceOrderResponseSchema = z.object({\\n  order_id: z.string().openapi({ description: 'Identificador único do pedido', example: 'ord_1234' }),\\n  items: z.array(ItemSchema).openapi({ description: 'Lista de itens físicos incluídos na ordem' }),\\n  shipping_address: ShippingAddressSchema.openapi({ description: 'Endereço para envio dos itens' }),\\n  payment_transaction: PaymentTransactionSchema.openapi({ description: 'Informações sobre o pagamento realizado' }),\\n  _links: HalLinksSchema.openapi({ description: 'Links HAL para navegação e rastreamento' })\\n}).openapi({ title: 'Resposta de Ordem do E-commerce', description: 'Detalhes completos do pedido incluindo itens, endereço, pagamento e links para acompanhamento' });\"\n}"
"{\n  \"raw_json\": {\n    \"order_id\": \"ord_123456\",\n    \"items\": [\n      {\n        \"product_id\": \"prod_987\",\n        \"name\": \"Bluetooth Headphones\",\n        \"quantity\": 2,\n        \"price_per_unit\": 59.99,\n        \"weight_kg\": 0.25\n      },\n      {\n        \"product_id\": \"prod_654\",\n        \"name\": \"Wireless Mouse\",\n        \"quantity\": 1,\n        \"price_per_unit\": 24.49,\n        \"weight_kg\": 0.1\n      }\n    ],\n    \"shipping_address\": {\n      \"recipient_name\": \"Alice Johnson\",\n      \"street\": \"123 Elm Street\",\n      \"city\": \"Springfield\",\n      \"state\": \"IL\",\n      \"zip\": \"62701\",\n      \"country\": \"USA\"\n    },\n    \"payment_transaction\": {\n      \"transaction_id\": \"txn_7890\",\n      \"amount\": 144.47,\n      \"currency\": \"USD\",\n      \"method\": \"Credit Card\",\n      \"status\": \"Completed\",\n      \"timestamp\": \"2024-06-15T10:42:00Z\"\n    },\n    \"_links\": {\n      \"self\": { \"href\": \"https://api.shop.com/orders/ord_123456\" },\n      \"tracking\": { \"href\": \"https://tracking.shipper.com/TRK123456789\" },\n      \"customer\": { \"href\": \"https://api.shop.com/customers/cust_321\" }\n    }\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst ItemSchema = z.object({\\n  product_id: z.string().openapi({ description: 'Unique identifier of the product', example: 'prod_987' }),\\n  name: z.string().openapi({ description: 'Name of the product', example: 'Bluetooth Headphones' }),\\n  quantity: z.number().int().positive().openapi({ description: 'Number of units ordered', example: 2 }),\\n  price_per_unit: z.number().nonnegative().openapi({ description: 'Price per single unit in USD', example: 59.99 }),\\n  weight_kg: z.number().nonnegative().openapi({ description: 'Weight of the product in kilograms', example: 0.25 })\\n}).openapi({ description: 'Single physical item in the order' });\\n\\nconst AddressSchema = z.object({\\n  recipient_name: z.string().openapi({ description: 'Name of the recipient for shipping', example: 'Alice Johnson' }),\\n  street: z.string().openapi({ description: 'Street address for shipment', example: '123 Elm Street' }),\\n  city: z.string().openapi({ description: 'City part of the shipping address', example: 'Springfield' }),\\n  state: z.string().openapi({ description: 'State or province part of the shipping address', example: 'IL' }),\\n  zip: z.string().openapi({ description: 'Postal or ZIP code', example: '62701' }),\\n  country: z.string().openapi({ description: 'Country name', example: 'USA' })\\n}).openapi({ description: 'Shipping address for the order' });\\n\\nconst PaymentTransactionSchema = z.object({\\n  transaction_id: z.string().openapi({ description: 'Unique identifier for the payment transaction', example: 'txn_7890' }),\\n  amount: z.number().nonnegative().openapi({ description: 'Total amount paid in the given currency', example: 144.47 }),\\n  currency: z.string().length(3).openapi({ description: 'ISO 4217 currency code', example: 'USD' }),\\n  method: z.string().openapi({ description: 'Payment method used by the customer', example: 'Credit Card' }),\\n  status: z.enum(['Pending', 'Completed', 'Failed', 'Refunded']).openapi({ description: 'Status of the payment transaction', example: 'Completed' }),\\n  timestamp: z.string().datetime().openapi({ description: 'ISO 8601 timestamp when payment was processed', example: '2024-06-15T10:42:00Z' })\\n}).openapi({ description: 'Details about the payment transaction for the order' });\\n\\nconst LinkObjectSchema = z.object({\\n  href: z.string().url().openapi({ description: 'URL for the relation link', example: 'https://api.shop.com/orders/ord_123456' })\\n}).openapi({ description: 'Hyperlink reference object' });\\n\\nconst LinksSchema = z.object({\\n  self: LinkObjectSchema.openapi({ description: 'Link to this order resource' }),\\n  tracking: LinkObjectSchema.openapi({ description: 'Link to the shipment tracking page' }),\\n  customer: LinkObjectSchema.openapi({ description: 'Link to the associated customer resource' })\\n}).openapi({ description: 'HAL _links object containing navigational hyperlinks' });\\n\\nexport const OrderResponseSchema = z.object({\\n  order_id: z.string().openapi({ description: 'Unique identifier of the order', example: 'ord_123456' }),\\n  items: z.array(ItemSchema).openapi({ description: 'List of physical items ordered' }),\\n  shipping_address: AddressSchema.openapi({ description: 'Shipping destination address' }),\\n  payment_transaction: PaymentTransactionSchema.openapi({ description: 'Payment transaction detail attached to the order' }),\\n  _links: LinksSchema.openapi({ description: 'HAL hypermedia links for the order resource' })\\n}).openapi({\\n  title: 'E-commerce Order Response',\\n  description: 'Complete details of an order including items, payment, shipping, and hypermedia links'\\n});\"\n}"
