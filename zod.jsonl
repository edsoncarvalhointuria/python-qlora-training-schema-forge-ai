ample: 'Dra. Maria Oliveira' }),\\n  crm: z.string().openapi({ description: 'Registro profissional do médico', example: '123456-SP' }),\\n  digital_signature_hash: z.string().openapi({ description: 'Hash da assinatura digital do laudo', example: 'sha256:a1b2c3d4...' })\\n}).openapi({ description: 'Dados do profissional responsável pela validação' });\\n\\nexport const LabResultSchema = z.object({\\n  test_id: z.string().openapi({ description: 'Identificador único do exame laboratorial', example: 'LAB-99283' }),\\n  patient: PatientSchema,\\n  biomarkers: z.array(BiomarkerSchema).openapi({ description: 'Lista de biomarcadores analisados' }),\\n  pathologist: PathologistSchema\\n}).openapi({ title: 'Resultado de Exame Laboratorial', description: 'Estrutura completa de um laudo de exame com dados do paciente, biomarcadores e assinatura' });\"\n}"
