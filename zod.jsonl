heck_id: z.string().openapi({ description: 'Unique ID for this inventory check session', example: 'invchk_202406' }),\\n  timestamp: z.string().openapi({ description: 'ISO 8601 timestamp of the inventory check', example: '2024-06-07T14:30:00Z' }),\\n  warehouse: WarehouseSchema,\\n  products: z.array(ProductSchema).openapi({ description: 'List of products with technical and stock details' })\\n}).openapi({ title: 'ERP Inventory Check Response', description: 'Response containing warehouse info, product technical specs, and stock levels across regions' });\"\n}"
