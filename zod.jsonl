rrency: z.string().openapi({ description: 'ISO 4217 currency code', example: 'USD' })\\n}).openapi({ description: 'Breakdown of claim costs' });\\n\\nexport const ClaimStatusSchema = z.object({\\n  claim_id: z.string().openapi({ description: 'Unique identifier for the insurance claim', example: 'CLM-9928374' }),\\n  status: z.enum(['PENDING', 'PROCESSED', 'DENIED']).openapi({ description: 'Current status of the claim', example: 'PROCESSED' }),\\n  provider: ProviderSchema,\\n  procedures: z.array(ProcedureSchema).openapi({ description: 'List of procedures included in the claim' }),\\n  financial_summary: FinancialSummarySchema\\n}).openapi({ title: 'Health Insurance Claim Status', description: 'Comprehensive status response for a medical insurance claim' });\"\n}"
