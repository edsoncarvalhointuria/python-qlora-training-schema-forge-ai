tatResponseSchema = z.object({\\n  device_id: z.string().openapi({ description: 'Identificador único do termostato', example: 'thermo-living-001' }),\\n  status: ThermostatStatusSchema,\\n  health: DeviceHealthSchema,\\n  usage_history: z.array(UsageRecordSchema).openapi({ description: 'Histórico recente de consumo de energia' })\\n}).openapi({ title: 'Status do Termostato', description: 'Resposta completa contendo telemetria e histórico do termostato inteligente' });\"\n}"
