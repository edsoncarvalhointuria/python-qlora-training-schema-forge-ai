"{\n  \"raw_json\": {\n    \"order_id\": \"ORD123456789\",\n    \"items\": [\n      {\n        \"product_id\": \"PROD9876\",\n        \"name\": \"Wireless Bluetooth Headphones\",\n        \"quantity\": 2,\n        \"price_per_unit\": 59.99,\n        \"weight_kg\": 0.25\n      },\n      {\n        \"product_id\": \"PROD1234\",\n        \"name\": \"Portable Charger 10000mAh\",\n        \"quantity\": 1,\n        \"price_per_unit\": 29.95,\n        \"weight_kg\": 0.3\n      }\n    ],\n    \"shipping_address\": {\n      \"recipient_name\": \"John Doe\",\n      \"street\": \"123 Elm Street\",\n      \"city\": \"Springfield\",\n      \"state\": \"IL\",\n      \"postal_code\": \"62704\",\n      \"country\": \"USA\",\n      \"phone_number\": \"+1-217-555-0123\"\n    },\n    \"payment_transaction\": {\n      \"transaction_id\": \"TXN789654321\",\n      \"payment_method\": \"credit_card\",\n      \"amount\": 149.93,\n      \"currency\": \"USD\",\n      \"status\": \"completed\",\n      \"processed_at\": \"2024-05-28T14:30:00Z\"\n    },\n    \"_links\": {\n      \"self\": {\n        \"href\": \"https://api.example.com/orders/ORD123456789\"\n      },\n      \"tracking\": {\n        \"href\": \"https://shipping.example.com/track/ORD123456789\"\n      }\n    }\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst ItemSchema = z.object({\\n  product_id: z.string().openapi({ description: 'Unique identifier for the product', example: 'PROD9876' }),\\n  name: z.string().openapi({ description: 'Name of the product', example: 'Wireless Bluetooth Headphones' }),\\n  quantity: z.number().int().min(1).openapi({ description: 'Quantity of the product ordered', example: 2 }),\\n  price_per_unit: z.number().openapi({ description: 'Price per individual unit in USD', example: 59.99 }),\\n  weight_kg: z.number().positive().openapi({ description: 'Weight of one unit in kilograms', example: 0.25 })\\n}).openapi({ description: 'Details of a single physical item in the order' });\\n\\nconst ShippingAddressSchema = z.object({\\n  recipient_name: z.string().openapi({ description: 'Name of the person receiving the order', example: 'John Doe' }),\\n  street: z.string().openapi({ description: 'Street address for delivery', example: '123 Elm Street' }),\\n  city: z.string().openapi({ description: 'City of the shipping address', example: 'Springfield' }),\\n  state: z.string().openapi({ description: 'State or province', example: 'IL' }),\\n  postal_code: z.string().openapi({ description: 'Postal or ZIP code', example: '62704' }),\\n  country: z.string().openapi({ description: 'Country name', example: 'USA' }),\\n  phone_number: z.string().openapi({ description: 'Contact phone number for delivery', example: '+1-217-555-0123' })\\n}).openapi({ description: 'Physical shipping address for the order' });\\n\\nconst PaymentTransactionSchema = z.object({\\n  transaction_id: z.string().openapi({ description: 'Unique payment transaction identifier', example: 'TXN789654321' }),\\n  payment_method: z.enum(['credit_card', 'paypal', 'bank_transfer']).openapi({ description: 'Method used for payment', example: 'credit_card' }),\\n  amount: z.number().openapi({ description: 'Total amount paid in the specified currency', example: 149.93 }),\\n  currency: z.string().length(3).openapi({ description: 'ISO 4217 currency code', example: 'USD' }),\\n  status: z.enum(['pending', 'completed', 'failed', 'refunded']).openapi({ description: 'Current status of the payment', example: 'completed' }),\\n  processed_at: z.string().refine(val => !isNaN(Date.parse(val)), { message: 'Invalid ISO 8601 date string' }).openapi({ description: 'Timestamp when the payment was processed (ISO 8601)', example: '2024-05-28T14:30:00Z' })\\n}).openapi({ description: 'Details related to the payment transaction' });\\n\\nconst HalLinkSchema = z.object({\\n  href: z.string().url().openapi({ description: 'URI for HAL link', example: 'https://api.example.com/orders/ORD123456789' })\\n}).openapi({ description: 'Hypertext Application Language (HAL) link object' });\\n\\nconst HalLinksSchema = z.object({\\n  self: HalLinkSchema,\\n  tracking: HalLinkSchema\\n}).openapi({ description: 'Collection of HAL links related to the order' });\\n\\nexport const EcommerceOrderResponseSchema = z.object({\\n  order_id: z.string().openapi({ description: 'Unique identifier for the order', example: 'ORD123456789' }),\\n  items: z.array(ItemSchema).nonempty().openapi({ description: 'List of physical items included in the order' }),\\n  shipping_address: ShippingAddressSchema,\\n  payment_transaction: PaymentTransactionSchema,\\n  _links: HalLinksSchema\\n}).openapi({ title: 'E-commerce Order Response', description: 'Response schema for an e-commerce order including items, shipping, payment, and HAL links' });\"\n}"
"{\n  \"raw_json\": {\n    \"user_profile\": {\n      \"user_id\": \"user_78910\",\n      \"full_name\": \"John Doe\",\n      \"email\": \"johndoe@example.com\",\n      \"phone_number\": \"+1234567890\",\n      \"date_of_birth\": \"1990-04-15\"\n    },\n    \"wallet\": {\n      \"currency\": \"USD\",\n      \"current_balance\": 2543.75,\n      \"last_updated\": \"2024-06-01T14:25:30Z\"\n    },\n    \"recent_transactions\": [\n      {\n        \"transaction_id\": \"tx_001\",\n        \"date\": \"2024-05-30T10:15:00Z\",\n        \"amount\": -45.00,\n        \"currency\": \"USD\",\n        \"transaction_type\": \"debit\",\n        \"description\": \"Grocery Shopping\",\n        \"merchant\": {\n          \"name\": \"SuperMart\",\n          \"category\": \"Retail\",\n          \"location\": \"New York, NY\"\n        }\n      },\n      {\n        \"transaction_id\": \"tx_002\",\n        \"date\": \"2024-05-29T08:20:00Z\",\n        \"amount\": 1500.00,\n        \"currency\": \"USD\",\n        \"transaction_type\": \"credit\",\n        \"description\": \"Salary Deposit\",\n        \"merchant\": null\n      },\n      {\n        \"transaction_id\": \"tx_003\",\n        \"date\": \"2024-05-28T14:00:00Z\",\n        \"amount\": -120.50,\n        \"currency\": \"USD\",\n        \"transaction_type\": \"debit\",\n        \"description\": \"Electricity Bill Payment\",\n        \"merchant\": {\n          \"name\": \"PowerGrid\",\n          \"category\": \"Utilities\",\n          \"location\": \"Online\"\n        }\n      }\n    ]\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst UserProfileSchema = z.object({\\n  user_id: z.string().openapi({ description: 'Unique identifier for the user', example: 'user_78910' }),\\n  full_name: z.string().openapi({ description: 'Full name of the user', example: 'John Doe' }),\\n  email: z.string().email().openapi({ description: 'Email address of the user', example: 'johndoe@example.com' }),\\n  phone_number: z.string().openapi({ description: 'User phone number in international format', example: '+1234567890' }),\\n  date_of_birth: z.string().regex(/^\\\\d{4}-\\\\d{2}-\\\\d{2}$/).openapi({ description: 'User date of birth in ISO 8601 date format', example: '1990-04-15' })\\n}).openapi({ description: 'Profile details of the digital wallet user' });\\n\\nconst WalletSchema = z.object({\\n  currency: z.string().length(3).openapi({ description: 'Currency code in ISO 4217 format', example: 'USD' }),\\n  current_balance: z.number().openapi({ description: 'Current balance amount in wallet', example: 2543.75 }),\\n  last_updated: z.string().datetime().openapi({ description: 'Timestamp of the last balance update in ISO 8601 format', example: '2024-06-01T14:25:30Z' })\\n}).openapi({ description: 'Current wallet balance information' });\\n\\nconst MerchantSchema = z.object({\\n  name: z.string().openapi({ description: 'Name of the merchant/payee', example: 'SuperMart' }),\\n  category: z.string().openapi({ description: 'Category of the merchant', example: 'Retail' }),\\n  location: z.string().openapi({ description: 'Physical or online location of the merchant', example: 'New York, NY' })\\n}).openapi({ description: 'Merchant details associated with a transaction' });\\n\\nconst TransactionSchema = z.object({\\n  transaction_id: z.string().openapi({ description: 'Unique identifier for the transaction', example: 'tx_001' }),\\n  date: z.string().datetime().openapi({ description: 'Date and time when the transaction occurred in ISO 8601 format', example: '2024-05-30T10:15:00Z' }),\\n  amount: z.number().openapi({ description: 'Amount of the transaction; negative for debits, positive for credits', example: -45.00 }),\\n  currency: z.string().length(3).openapi({ description: 'Currency code in ISO 4217 format for the transaction', example: 'USD' }),\\n  transaction_type: z.enum(['debit', 'credit']).openapi({ description: 'Type of transaction', example: 'debit' }),\\n  description: z.string().openapi({ description: 'Description or memo of the transaction', example: 'Grocery Shopping' }),\\n  merchant: MerchantSchema.nullable().openapi({ description: 'Associated merchant details for the transaction, if applicable', example: { name: 'SuperMart', category: 'Retail', location: 'New York, NY' } })\\n}).openapi({ description: 'Details of a single transaction in the wallet statement' });\\n\\nexport const DigitalWalletStatementSchema = z.object({\\n  user_profile: UserProfileSchema,\\n  wallet: WalletSchema,\\n  recent_transactions: z.array(TransactionSchema).max(3).openapi({ description: 'List of the last three recent transactions' })\\n}).openapi({ title: 'Digital Wallet Statement', description: 'A statement showing the user profile, current wallet balance, and last 3 recent transactions' });\"\n}"
"{\n  \"raw_json\": {\n    \"invoice_id\": \"inv_20240615_789\",\n    \"billing_cycle\": {\n      \"start_date\": \"2024-05-01\",\n      \"end_date\": \"2024-05-31\"\n    },\n    \"company\": {\n      \"company_id\": \"comp_324\",\n      \"name\": \"Bright Future SaaS Ltd.\",\n      \"address\": {\n        \"street\": \"123 Cloud Ave\",\n        \"city\": \"Metropolis\",\n        \"state\": \"CA\",\n        \"postal_code\": \"94016\",\n        \"country\": \"USA\"\n      },\n      \"contact_email\": \"billing@brightfuture.com\",\n      \"phone\": \"+1-555-1234-567\"\n    },\n    \"taxes\": [\n      {\n        \"tax_name\": \"VAT\",\n        \"tax_rate_percent\": 15.0,\n        \"tax_amount\": 30.75\n      },\n      {\n        \"tax_name\": \"Service Tax\",\n        \"tax_rate_percent\": 5.0,\n        \"tax_amount\": 10.25\n      }\n    ],\n    \"discount_coupons\": [\n      {\n        \"coupon_code\": \"SPRING2024\",\n        \"description\": \"Spring promotion discount\",\n        \"discount_amount\": 20.0\n      },\n      {\n        \"coupon_code\": \"LOYALTY10\",\n        \"description\": \"10% loyalty discount\",\n        \"discount_amount\": 10.0\n      }\n    ],\n    \"subtotal_amount\": 205.0,\n    \"total_amount\": 215.0,\n    \"currency\": \"USD\"\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst AddressSchema = z.object({\\n  street: z.string().openapi({ description: 'Street address of the company', example: '123 Cloud Ave' }),\\n  city: z.string().openapi({ description: 'City where the company is located', example: 'Metropolis' }),\\n  state: z.string().openapi({ description: 'State or province of the company', example: 'CA' }),\\n  postal_code: z.string().openapi({ description: 'Postal or ZIP code', example: '94016' }),\\n  country: z.string().openapi({ description: 'Country of the company headquarters', example: 'USA' })\\n}).openapi({ description: 'Company address details' });\\n\\nconst CompanySchema = z.object({\\n  company_id: z.string().openapi({ description: 'Unique identifier of the company', example: 'comp_324' }),\\n  name: z.string().openapi({ description: 'Full name of the company', example: 'Bright Future SaaS Ltd.' }),\\n  address: AddressSchema,\\n  contact_email: z.string().email().openapi({ description: 'Contact email for billing or support', example: 'billing@brightfuture.com' }),\\n  phone: z.string().openapi({ description: 'Contact phone number of the company', example: '+1-555-1234-567' })\\n}).openapi({ description: 'Details about the company issuing the invoice' });\\n\\nconst BillingCycleSchema = z.object({\\n  start_date: z.string().regex(/^\\\\d{4}-\\\\d{2}-\\\\d{2}$/).openapi({ description: \\\"Start date of the billing cycle in ISO format (YYYY-MM-DD)\\\", example: '2024-05-01' }),\\n  end_date: z.string().regex(/^\\\\d{4}-\\\\d{2}-\\\\d{2}$/).openapi({ description: \\\"End date of the billing cycle in ISO format (YYYY-MM-DD)\\\", example: '2024-05-31' })\\n}).openapi({ description: 'Period covered by the billing cycle' });\\n\\nconst TaxBreakdownSchema = z.object({\\n  tax_name: z.string().openapi({ description: 'Name of the tax', example: 'VAT' }),\\n  tax_rate_percent: z.number().openapi({ description: 'Tax rate as a percentage', example: 15.0 }),\\n  tax_amount: z.number().openapi({ description: 'Monetary amount of tax applied', example: 30.75 })\\n}).openapi({ description: 'Breakdown of a single tax applied to the invoice' });\\n\\nconst DiscountCouponSchema = z.object({\\n  coupon_code: z.string().openapi({ description: 'Code identifying the discount coupon', example: 'SPRING2024' }),\\n  description: z.string().openapi({ description: 'Description or reason for the coupon', example: 'Spring promotion discount' }),\\n  discount_amount: z.number().openapi({ description: 'Amount discounted by this coupon', example: 20.0 })\\n}).openapi({ description: 'Details of an applied discount coupon' });\\n\\nexport const InvoiceResponseSchema = z.object({\\n  invoice_id: z.string().openapi({ description: 'Unique identifier of the invoice', example: 'inv_20240615_789' }),\\n  billing_cycle: BillingCycleSchema,\\n  company: CompanySchema,\\n  taxes: z.array(TaxBreakdownSchema).openapi({ description: 'List of all taxes applied to the invoice' }),\\n  discount_coupons: z.array(DiscountCouponSchema).openapi({ description: 'List of all discount coupons applied' }),\\n  subtotal_amount: z.number().openapi({ description: 'Subtotal amount before taxes and discounts', example: 205.0 }),\\n  total_amount: z.number().openapi({ description: 'Final total amount after taxes and discounts', example: 215.0 }),\\n  currency: z.string().openapi({ description: 'Currency code in ISO 4217 format', example: 'USD' })\\n}).openapi({ title: 'SaaS Subscription Invoice Response', description: 'Response schema for a SaaS subscription invoice including billing, company, taxes, and discounts' });\"\n}"
