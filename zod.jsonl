ption: 'Status atual do pagamento', example: 'approved' }),\\n  paid_at: z.string().datetime().openapi({ description: 'Data e hora do pagamento efetuado', example: '2024-06-15T14:23:30Z' })\\n}).openapi({ description: 'Detalhes da transação de pagamento' });\\n\\nconst HalLinkSchema = z.object({\\n  href: z.string().url().openapi({ description: 'URL do recurso referenciado', example: 'https://api.ecommerce.com/orders/ORD123456789' }),\\n  title: z.string().openapi({ description: 'Título ou descrição legível do link', example: 'Pedido atual' })\\n}).openapi({ description: 'Link HAL para navegação/HATEOAS' });\\n\\nconst HalLinksSchema = z.object({\\n  self: HalLinkSchema,\\n  tracking: HalLinkSchema\\n}).openapi({ description: 'Conjunto de links HAL relacionados ao pedido' });\\n\\nexport const OrderResponseSchema = z.object({\\n  order_id: z.string().openapi({ description: 'Identificador único do pedido', example: 'ORD123456789' }),\\n  items: z.array(PhysicalItemSchema).openapi({ description: 'Lista dos itens físicos do pedido' }),\\n  shipping_address: ShippingAddressSchema,\\n  payment: PaymentTransactionSchema,\\n  _links: HalLinksSchema\\n}).openapi({ title: 'Resposta de Pedido de E-commerce', description: 'Estrutura da resposta de um pedido contendo itens, endereço, pagamento e links HAL' });\"\n}"
"{\n  \"raw_json\": {\n    \"invoice_id\": \"INV-2024-000123\",\n    \"billing_cycle\": {\n      \"start_date\": \"2024-05-01\",\n      \"end_date\": \"2024-05-31\"\n    },\n    \"company\": {\n      \"company_id\": \"comp_987654\",\n      \"name\": \"Tech Innovations LLC\",\n      \"address\": {\n        \"street\": \"1234 Silicon Avenue\",\n        \"city\": \"San Francisco\",\n        \"state\": \"CA\",\n        \"postal_code\": \"94107\",\n        \"country\": \"USA\"\n      },\n      \"contact_email\": \"billing@techinnovations.com\"\n    },\n    \"taxes\": [\n      {\n        \"tax_type\": \"VAT\",\n        \"rate_percent\": 15,\n        \"amount\": 75.00\n      },\n      {\n        \"tax_type\": \"Service Tax\",\n        \"rate_percent\": 5,\n        \"amount\": 25.00\n      }\n    ],\n    \"discount_coupons\": [\n      {\n        \"coupon_code\": \"SPRINGSALE20\",\n        \"description\": \"20% off Spring Promotion\",\n        \"discount_amount\": 40.00\n      },\n      {\n        \"coupon_code\": \"LOYALTY10\",\n        \"description\": \"10% Loyalty Discount\",\n        \"discount_amount\": 20.00\n      }\n    ],\n    \"total_amount_due\": 440.00,\n    \"currency\": \"USD\",\n    \"issued_date\": \"2024-06-01\",\n    \"due_date\": \"2024-06-15\"\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst AddressSchema = z.object({\\n  street: z.string().openapi({ description: 'Street address of the company', example: '1234 Silicon Avenue' }),\\n  city: z.string().openapi({ description: 'City of the company address', example: 'San Francisco' }),\\n  state: z.string().openapi({ description: 'State or province of the company address', example: 'CA' }),\\n  postal_code: z.string().openapi({ description: 'Postal code or ZIP code', example: '94107' }),\\n  country: z.string().openapi({ description: 'Country of the company address', example: 'USA' })\\n}).openapi({ description: 'Physical address details of the company' });\\n\\nconst CompanySchema = z.object({\\n  company_id: z.string().openapi({ description: 'Unique identifier for the company', example: 'comp_987654' }),\\n  name: z.string().openapi({ description: 'Official name of the company', example: 'Tech Innovations LLC' }),\\n  address: AddressSchema.openapi({ description: 'Postal address of the company' }),\\n  contact_email: z.string().email().openapi({ description: 'Contact email for billing inquiries', example: 'billing@techinnovations.com' })\\n}).openapi({ description: 'Details about the subscriber company' });\\n\\nconst BillingCycleSchema = z.object({\\n  start_date: z.string().regex(/^\\\\\\\\d{4}-\\\\\\\\d{2}-\\\\\\\\d{2}$/).openapi({ description: 'Start date of the billing cycle (YYYY-MM-DD)', example: '2024-05-01' }),\\n  end_date: z.string().regex(/^\\\\\\\\d{4}-\\\\\\\\d{2}-\\\\\\\\d{2}$/).openapi({ description: 'End date of the billing cycle (YYYY-MM-DD)', example: '2024-05-31' })\\n}).openapi({ description: 'The billing period for the invoice' });\\n\\nconst TaxBreakdownSchema = z.object({\\n  tax_type: z.string().openapi({ description: 'Type or category of the tax', example: 'VAT' }),\\n  rate_percent: z.number().openapi({ description: 'Tax rate percentage applied', example: 15 }),\\n  amount: z.number().openapi({ description: 'Monetary amount of this tax applied', example: 75.00 })\\n}).openapi({ description: 'Detailed breakdown of taxes applied' });\\n\\nconst DiscountCouponSchema = z.object({\\n  coupon_code: z.string().openapi({ description: 'Code of the applied discount coupon', example: 'SPRINGSALE20' }),\\n  description: z.string().openapi({ description: 'Description of the discount promotion', example: '20% off Spring Promotion' }),\\n  discount_amount: z.number().openapi({ description: 'Monetary value of the discount applied', example: 40.00 })\\n}).openapi({ description: 'Representation of an applied discount coupon' });\\n\\nexport const SaaSSubscriptionInvoiceSchema = z.object({\\n  invoice_id: z.string().openapi({ description: 'Unique identifier for the invoice', example: 'INV-2024-000123' }),\\n  billing_cycle: BillingCycleSchema.openapi({ description: 'The billing period covered by this invoice' }),\\n  company: CompanySchema.openapi({ description: 'Information about the subscriber company' }),\\n  taxes: z.array(TaxBreakdownSchema).openapi({ description: 'List of tax components applied to the invoice' }),\\n  discount_coupons: z.array(DiscountCouponSchema).optional().openapi({ description: 'List of discount coupons applied' }),\\n  total_amount_due: z.number().openapi({ description: 'Total amount due after taxes and discounts', example: 440.00 }),\\n  currency: z.string().openapi({ description: 'Currency code of the invoice amounts', example: 'USD' }),\\n  issued_date: z.string().regex(/^\\\\\\\\d{4}-\\\\\\\\d{2}-\\\\\\\\d{2}$/).openapi({ description: 'Date the invoice was issued (YYYY-MM-DD)', example: '2024-06-01' }),\\n  due_date: z.string().regex(/^\\\\\\\\d{4}-\\\\\\\\d{2}-\\\\\\\\d{2}$/).openapi({ description: 'Payment due date for the invoice (YYYY-MM-DD)', example: '2024-06-15' })\\n}).openapi({ title: 'SaaS Subscription Invoice Response', description: 'Details of a SaaS subscription invoice including billing cycle, company details, taxes, and discounts' });\"\n}"
