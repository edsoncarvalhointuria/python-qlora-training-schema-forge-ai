Dr. Sarah Smith' }),\\n  license_id: z.string().openapi({ description: 'Professional medical license identifier', example: 'LIC-8829' }),\\n  signature_hash: z.string().openapi({ description: 'Digital cryptographic signature hash', example: 'sha256:a1b2c3d4e5f6' })\\n}).openapi({ description: 'Digital signature details of the reviewing pathologist' });\\n\\nexport const LabResultSchema = z.object({\\n  test_id: z.string().openapi({ description: 'Unique laboratory test identifier', example: 'lab_99283' }),\\n  patient: PatientSchema,\\n  biomarkers: z.array(BiomarkerSchema).openapi({ description: 'List of blood biomarkers analyzed' }),\\n  pathologist: PathologistSignatureSchema\\n}).openapi({ title: 'Laboratory Test Result', description: 'Comprehensive hospital laboratory test report including patient data, biomarkers, and pathologist validation' });\"\n}"
