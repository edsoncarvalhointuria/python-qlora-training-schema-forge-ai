().openapi({ description: 'Descrição detalhada da transação', example: 'Depósito recebido' }),\\n  status: TransactionStatusEnum,\\n  counterparty: CounterpartySchema\\n}).openapi({ description: 'Detalhes individuais de uma transação financeira' });\\n\\nexport const DigitalWalletStatementSchema = z.object({\\n  user: UserProfileSchema,\\n  wallet: WalletSchema,\\n  transactions: z.array(TransactionSchema).max(3).openapi({ description: 'Lista das últimas 3 transações recentes' })\\n}).openapi({ title: 'Extrato da Carteira Digital', description: 'Extrato contendo saldo atual, perfil do usuário e últimas transações' });\"\n}"
