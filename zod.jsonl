().openapi({ description: 'Registro profissional do médico', example: '123456-SP' }),\\n  timestamp: z.string().datetime().openapi({ description: 'Data e hora da assinatura digital', example: '2023-10-27T10:00:00Z' })\\n}).openapi({ description: 'Assinatura digital do profissional responsável' });\\n\\nexport const LaboratoryResultSchema = z.object({\\n  patient: PatientSchema,\\n  biomarkers: z.array(BiomarkerSchema).openapi({ description: 'Lista de biomarcadores analisados' }),\\n  signature: DigitalSignatureSchema\\n}).openapi({ title: 'Resultado de Exame Laboratorial', description: 'Estrutura completa de um laudo de exame com dados do paciente, biomarcadores e assinatura' });\"\n}"
