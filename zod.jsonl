es, CA' }),\\n  scheduled_arrival: z.string().openapi({ description: 'Scheduled arrival time in ISO 8601 format', example: '2024-06-25T10:30:00Z' }),\\n  actual_arrival: z.string().nullable().openapi({ description: 'Actual arrival time if arrived, otherwise null', example: '2024-06-25T10:45:00Z' }),\\n  status: z.enum(['pending', 'arrived', 'delayed']).openapi({ description: 'Current status of the stop', example: 'delayed' })\\n}).openapi({ description: 'Individual stop details in the route' });\\n\\nconst FleetTrackingResponseSchema = z.object({\\n  truck_id: z.string().openapi({ description: 'Unique identifier of the delivery truck', example: 'truck_123' }),\\n  location: LocationSchema,\\n  speed_kph: z.number().openapi({ description: 'Current speed of the truck in kilometers per hour', example: 65.5 }),\\n  driver: DriverSchema,\\n  route_stops: z.array(RouteStopSchema).openapi({ description: 'Array of scheduled stops in the truck route' })\\n}).openapi({ title: 'Fleet Truck Tracking Response', description: 'Current status and route information of a delivery truck' });\"\n}"
