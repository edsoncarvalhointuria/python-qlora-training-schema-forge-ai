\\n  street: z.string().openapi({ description: 'Street address of the warehouse', example: '123 Industrial Park' }),\\n  city: z.string().openapi({ description: 'City where the warehouse is located', example: 'Metropolis' }),\\n  state: z.string().openapi({ description: 'State or province of the warehouse', example: 'CA' }),\\n  postal_code: z.string().openapi({ description: 'Postal or ZIP code', example: '90210' }),\\n  country: z.string().openapi({ description: 'Country of the warehouse', example: 'USA' })\\n}).openapi({ description: 'Address details of the warehouse' });\\n\\nconst ContactSchema = z.object({\\n  phone: z.string().openapi({ description: 'Phone contact number of the warehouse', example: '+1-555-123-4567' }),\\n  email: z.string().email().openapi({ description: 'Email contact at the warehouse', example: 'contact@centraldc.example.com' })\\n}).openapi({ description: 'Contact information for the warehouse' });\\n\\nconst WarehouseSchema = z.object({\\n  warehouse_id: z.string().openapi({ description: 'Unique identifier for the warehouse', example: 'wh_102' }),\\n  name: z.string().openapi({ description: 'Name of the warehouse', example: 'Central Distribution Center' }),\\n  address: AddressSchema,\\n  contact: ContactSchema\\n}).openapi({ description: 'Metadata about the warehouse location and contact' });\\n\\nconst DimensionsSchema = z.object({\\n  length: z.number().openapi({ description: 'Length in centimeters', example: 30 }),\\n  width: z.number().openapi({ description: 'Width in centimeters', example: 10 }),\\n  height: z.number().openapi({ description: 'Height in centimeters', example: 25 })\\n}).openapi({ description: 'Physical dimensions of the product' });\\n\\nconst TechnicalSpecsBaseSchema = z.object({\\n  weight_kg: z.number().openapi({ description: 'Weight in kilograms', example: 3.5 }),\\n  dimensions_cm: DimensionsSchema,\\n  power_source: z.enum(['electric', 'hydraulic', 'manual']).openapi({ description: 'Type of power source for the