rimary instructor', example: 'Dr. Smith' })\\n}).openapi({ description: 'Details of an individual enrolled course' });\\n\\nconst FinancialStatusSchema = z.object({\\n  balance_due: z.number().openapi({ description: 'Outstanding tuition balance', example: 1500.5 }),\\n  currency: z.string().length(3).openapi({ description: 'ISO currency code', example: 'USD' }),\\n  payment_deadline: z.string().datetime().openapi({ description: 'Due date for the current balance', example: '2023-12-15T00:00:00Z' })\\n}).openapi({ description: 'Current financial standing and tuition status' });\\n\\nexport const StudentDashboardSchema = z.object({\\n  student_id: z.string().openapi({ description: 'Unique university student identifier', example: 'STU-99283' }),\\n  personal_info: PersonalInfoSchema,\\n  academic_history: AcademicHistorySchema,\\n  enrolled_courses: z.array(CourseSchema).openapi({ description: 'List of courses currently enrolled in' }),\\n  financial_status: FinancialStatusSchema\\n}).openapi({ title: 'Student Dashboard', description: 'Comprehensive student academic and financial dashboard' });\"\n}"
