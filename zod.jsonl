"{\n  \"raw_json\": {\n    \"test_id\": \"LAB-99283-X\",\n    \"patient\": {\n      \"id\": \"PAT-5501\",\n      \"full_name\": \"John Doe\",\n      \"dob\": \"1985-05-12\"\n    },\n    \"biomarkers\": [\n      {\n        \"name\": \"Hemoglobin\",\n        \"value\": 14.2,\n        \"unit\": \"g/dL\",\n        \"reference_range\": { \"min\": 13.5, \"max\": 17.5 }\n      }\n    ],\n    \"pathologist\": {\n      \"name\": \"Dr. Sarah Smith\",\n      \"license_id\": \"MED-9982\",\n      \"signature_hash\": \"sha256:a1b2c3d4e5f6\"\n    }\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst PatientSchema = z.object({\\n  id: z.string().openapi({ description: 'Unique identifier for the patient', example: 'PAT-5501' }),\\n  full_name: z.string().openapi({ description: 'Full legal name of the patient', example: 'John Doe' }),\\n  dob: z.string().datetime().openapi({ description: 'Date of birth in ISO 8601 format', example: '1985-05-12' })\\n}).openapi({ description: 'Demographic information of the patient' });\\n\\nconst ReferenceRangeSchema = z.object({\\n  min: z.number().openapi({ description: 'Lower bound of the normal range', example: 13.5 }),\\n  max: z.number().openapi({ description: 'Upper bound of the normal range', example: 17.5 })\\n}).openapi({ description: 'Clinical reference range for the biomarker' });\\n\\nconst BiomarkerSchema = z.object({\\n  name: z.string().openapi({ description: 'Name of the blood biomarker', example: 'Hemoglobin' }),\\n  value: z.number().openapi({ description: 'Measured value of the biomarker', example: 14.2 }),\\n  unit: z.string().openapi({ description: 'Measurement unit', example: 'g/dL' }),\\n  reference_range: ReferenceRangeSchema\\n}).openapi({ description: 'Individual blood test result entry' });\\n\\nconst PathologistSignatureSchema = z.object({\\n  name: z.string().openapi({ description: 'Full name of the reviewing pathologist', example: 'Dr. Sarah Smith' }),\\n  license_id: z.string().openapi({ description: 'Professional medical license identifier', example: 'MED-9982' }),\\n  signature_hash: z.string().openapi({ description: 'Digital cryptographic signature hash', example: 'sha256:a1b2c3d4e5f6' })\\n}).openapi({ description: 'Digital signature and credentials of the reviewing pathologist' });\\n\\nexport const LaboratoryResultSchema = z.object({\\n  test_id: z.string().openapi({ description: 'Unique laboratory test report identifier', example: 'LAB-99283-X' }),\\n  patient: PatientSchema,\\n  biomarkers: z.array(BiomarkerSchema).openapi({ description: 'List of blood biomarkers analyzed' }),\\n  pathologist: PathologistSignatureSchema\\n}).openapi({ title: 'Laboratory Test Result', description: 'Comprehensive hospital laboratory report containing patient data, biomarkers, and pathologist validation' });\"\n}"
