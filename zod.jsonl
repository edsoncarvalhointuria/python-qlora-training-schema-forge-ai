ion: 'Tempo de funcionamento do termostato em minutos no dia', example: 120 })\\n}).openapi({ description: 'Entrada individual do histórico de uso diário' });\\n\\nconst UsageHistorySchema = z.array(UsageHistoryEntrySchema).openapi({ description: 'Histórico diário de uso do termostato' });\\n\\nexport const ThermostatStatusSchema = z.object({\\n  device_id: z.string().openapi({ description: 'ID único do dispositivo termostato', example: 'thermo_01' }),\\n  current_temperature_celsius: z.number().openapi({ description: 'Temperatura atual medida pelo termostato em graus Celsius', example: 22.5 }),\\n  target_temperature_celsius: z.number().openapi({ description: 'Temperatura alvo definida para o termostato em graus Celsius', example: 24 }),\\n  health: HealthStatusSchema,\\n  usage_history: UsageHistorySchema\\n}).openapi({ title: 'Status do Termostato IoT', description: 'Resposta com o estado atual e histórico de um termostato inteligente' });\"\n}"
