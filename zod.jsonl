"{\n  \"raw_json\": {\n    \"table_number\": 12,\n    \"customer\": {\n      \"name\": \"John Doe\",\n      \"dietary_restrictions\": {\n        \"vegan\": false,\n        \"gluten_free\": true,\n        \"nut_allergy\": true,\n        \"other\": \"Lactose intolerant\"\n      }\n    },\n    \"pre_ordered_items\": [\n      { \"item_id\": \"dish_101\", \"name\": \"Grilled Chicken Salad\", \"quantity\": 2 },\n      { \"item_id\": \"dish_205\", \"name\": \"Gluten-Free Pasta\", \"quantity\": 1 }\n    ]\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst DietaryRestrictionsSchema = z.object({\\n  vegan: z.boolean().openapi({ description: 'Indicates if the customer follows a vegan diet', example: false }),\\n  gluten_free: z.boolean().openapi({ description: 'Indicates if the customer requires gluten-free food', example: true }),\\n  nut_allergy: z.boolean().openapi({ description: 'Indicates if the customer has a nut allergy', example: true }),\\n  other: z.string().optional().openapi({ description: 'Other dietary restrictions described by the customer', example: 'Lactose intolerant' })\\n}).openapi({ description: 'Customer dietary restriction details' });\\n\\nconst CustomerSchema = z.object({\\n  name: z.string().openapi({ description: 'Full name of the customer', example: 'John Doe' }),\\n  dietary_restrictions: DietaryRestrictionsSchema\\n}).openapi({ description: 'Details about the customer making the reservation' });\\n\\nconst PreOrderedItemSchema = z.object({\\n  item_id: z.string().openapi({ description: 'Unique identifier for the pre-ordered menu item', example: 'dish_101' }),\\n  name: z.string().openapi({ description: 'Name of the pre-ordered menu item', example: 'Grilled Chicken Salad' }),\\n  quantity: z.number().min(1).openapi({ description: 'Quantity of this item pre-ordered', example: 2 })\\n}).openapi({ description: 'Single pre-ordered menu item'