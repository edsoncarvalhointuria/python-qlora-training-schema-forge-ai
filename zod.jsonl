RL' }),\\n  paid_at: z.string().refine(val => !isNaN(Date.parse(val)), { message: 'Deve ser uma data ISO válida' }).openapi({ description: 'Data e hora do pagamento (ISO 8601)', example: '2024-06-10T14:30:30Z' })\\n}).openapi({ description: 'Detalhes da transação de pagamento' });\\n\\nconst HalLinkSchema = z.object({\\n  href: z.string().url().openapi({ description: 'URL do recurso vinculado', example: 'https://api.ecommerce.com/orders/ord_10234' })\\n}).openapi({ description: 'Link HAL para navegação' });\\n\\nconst HalLinksSchema = z.object({\\n  self: HalLinkSchema,\\n  tracking: HalLinkSchema\\n}).openapi({ description: 'Links HAL para recursos relacionados' });\\n\\nexport const OrderResponseSchema = z.object({\\n  order_id: z.string().openapi({ description: 'Identificador único do pedido', example: 'ord_10234' }),\\n  items: z.array(ItemSchema).min(1).openapi({ description: 'Lista de itens físicos do pedido' }),\\n  shipping_address: ShippingAddressSchema,\\n  payment: PaymentSchema,\\n  _links: HalLinksSchema\\n}).openapi({\\n  title: 'Resposta do Pedido',\\n  description: 'Detalhes completos do pedido incluindo itens, endereço, pagamento e links de rastreamento'\\n});\"\n}"
"{\n  \"raw_json\": {\n    \"user_profile\": {\n      \"user_id\": \"usr_123456\",\n      \"full_name\": \"Carlos Eduardo Silva\",\n      \"email\": \"carlos.silva@example.com\",\n      \"phone_number\": \"+5511999998888\",\n      \"registered_at\": \"2023-01-15T08:30:00Z\"\n    },\n    \"current_balance\": 2540.75,\n    \"currency\": \"BRL\",\n    \"recent_transactions\": [\n      {\n        \"transaction_id\": \"txn_98765\",\n        \"date\": \"2024-06-10T14:23:00Z\",\n        \"type\": \"debit\",\n        \"amount\": 350.00,\n        \"description\": \"Pagamento de conta de energia\",\n        \"status\": \"completed\"\n      },\n      {\n        \"transaction_id\": \"txn_98766\",\n        \"date\": \"2024-06-09T18:50:00Z\",\n        \"type\": \"credit\",\n        \"amount\": 1200.00,\n        \"description\": \"Transferência recebida de João\",\n        \"status\": \"completed\"\n      },\n      {\n        \"transaction_id\": \"txn_98767\",\n        \"date\": \"2024-06-08T12:15:00Z\",\n        \"type\": \"debit\",\n        \"amount\": 125.50,\n        \"description\": \"Compra no supermercado\",\n        \"status\": \"pending\"\n      }\n    ]\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst UserProfileSchema = z.object({\\n  user_id: z.string().openapi({ description: 'Identificador único do usuário na plataforma', example: 'usr_123456' }),\\n  full_name: z.string().openapi({ description: 'Nome completo do usuário', example: 'Carlos Eduardo Silva' }),\\n  email: z.string().email().openapi({ description: 'Endereço de e-mail do usuário', example: 'carlos.silva@example.com' }),\\n  phone_number: z.string().openapi({ description: 'Número de telefone do usuário com código de país', example: '+5511999998888' }),\\n  registered_at: z.string().refine(val => !isNaN(Date.parse(val)), { message: 'Deve ser um formato ISO 8601 válido' })\\n    .openapi({ description: 'Data e hora em que o usuário se registrou (formato ISO 8601)', example: '2023-01-15T08:30:00Z' })\\n}).openapi({ description: 'Detalhes do perfil do usuário da carteira digital' });\\n\\nconst TransactionSchema = z.object({\\n  transaction_id: z.string().openapi({ description: 'Identificador único da transação', example: 'txn_98765' }),\\n  date: z.string().refine(val => !isNaN(Date.parse(val)), { message: 'Deve ser um formato ISO 8601 válido' })\\n    .openapi({ description: 'Data e hora da transação (formato ISO 8601)', example: '2024-06-10T14:23:00Z' }),\\n  type: z.enum(['debit', 'credit']).openapi({ description: 'Tipo da transação', example: 'debit' }),\\n  amount: z.number().openapi({ description: 'Valor monetário da transação', example: 350.00 }),\\n  description: z.string().openapi({ description: 'Descrição detalhada da transação', example: 'Pagamento de conta de energia' }),\\n  status: z.enum(['pending', 'completed', 'failed']).openapi({ description: 'Status atual da transação', example: 'completed' })\\n}).openapi({ description: 'Registro de uma transação financeira na carteira digital' });\\n\\nexport const WalletStatementSchema = z.object({\\n  user_profile: UserProfileSchema,\\n  current_balance: z.number().openapi({ description: 'Saldo atual disponível na carteira digital', example: 2540.75 }),\\n  currency: z.string().length(3).openapi({ description: 'Código da moeda conforme ISO 4217', example: 'BRL' }),\\n  recent_transactions: z.array(TransactionSchema).max(3).openapi({ description: 'Lista dos 3 registros de transações financeiras mais recentes' })\\n}).openapi({ title: 'Extrato da Carteira Digital', description: 'Representa o extrato com saldo atual, perfil do usuário e últimas transações' });\"\n}"
"{\n  \"raw_json\": {\n    \"invoice_id\": \"inv_7890\",\n    \"billing_cycle\": {\n      \"start_date\": \"2024-05-01\",\n      \"end_date\": \"2024-05-31\"\n    },\n    \"company\": {\n      \"company_id\": \"comp_456\",\n      \"company_name\": \"Tech Innovators LLC\",\n      \"address\": {\n        \"street\": \"123 Innovation Drive\",\n        \"city\": \"San Francisco\",\n        \"state\": \"CA\",\n        \"postal_code\": \"94107\",\n        \"country\": \"USA\"\n      },\n      \"contact_email\": \"billing@techinnovators.com\"\n    },\n    \"taxes\": [\n      {\n        \"tax_type\": \"VAT\",\n        \"tax_rate\": 0.2,\n        \"amount\": 40.00\n      },\n      {\n        \"tax_type\": \"Service Tax\",\n        \"tax_rate\": 0.05,\n        \"amount\": 10.00\n      }\n    ],\n    \"discount_coupons\": [\n      {\n        \"coupon_code\": \"SPRING2024\",\n        \"description\": \"Spring season promotional discount\",\n        \"discount_amount\": 15.00\n      },\n      {\n        \"coupon_code\": \"LOYALTY10\",\n        \"description\": \"Loyalty discount for returning customer\",\n        \"discount_amount\": 10.00\n      }\n    ],\n    \"total_amount_due\": 225.00\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst AddressSchema = z.object({\\n  street: z.string().openapi({ description: 'Street address of the company', example: '123 Innovation Drive' }),\\n  city: z.string().openapi({ description: 'City where the company is located', example: 'San Francisco' }),\\n  state: z.string().openapi({ description: 'State or region of the company address', example: 'CA' }),\\n  postal_code: z.string().openapi({ description: 'Postal or zip code', example: '94107' }),\\n  country: z.string().openapi({ description: 'Country of the company address', example: 'USA' })\\n}).openapi({ description: 'Company address details' });\\n\\nconst CompanySchema = z.object({\\n  company_id: z.string().openapi({ description: 'Unique identifier for the company', example: 'comp_456' }),\\n  company_name: z.string().openapi({ description: 'Official name of the company', example: 'Tech Innovators LLC' }),\\n  address: AddressSchema,\\n  contact_email: z.string().email().openapi({ description: 'Contact email for billing inquiries', example: 'billing@techinnovators.com' })\\n}).openapi({ description: 'Details of the invoiced company' });\\n\\nconst BillingCycleSchema = z.object({\\n  start_date: z.string().regex(/^\\\\d{4}-\\\\d{2}-\\\\d{2}$/).openapi({ description: 'Start date of the billing cycle (YYYY-MM-DD)', example: '2024-05-01' }),\\n  end_date: z.string().regex(/^\\\\d{4}-\\\\d{2}-\\\\d{2}$/).openapi({ description: 'End date of the billing cycle (YYYY-MM-DD)', example: '2024-05-31' })\\n}).openapi({ description: 'The billing cycle covered by the invoice' });\\n\\nconst TaxEntrySchema = z.object({\\n  tax_type: z.string().openapi({ description: 'Type or category of tax applied', example: 'VAT' }),\\n  tax_rate: z.number().min(0).max(1).openapi({ description: 'Tax rate as decimal fraction', example: 0.2 }),\\n  amount: z.number().openapi({ description: 'Amount charged for this tax', example: 40.00 })\\n}).openapi({ description: 'Individual tax charge details' });\\n\\nconst DiscountCouponSchema = z.object({\\n  coupon_code: z.string().openapi({ description: 'Code identifying the discount coupon', example: 'SPRING2024' }),\\n  description: z.string().openapi({ description: 'Description of the discount coupon', example: 'Spring season promotional discount' }),\\n  discount_amount: z.number().openapi({ description: 'Amount discounted using this coupon', example: 15.00 })\\n}).openapi({ description: 'Details of a discount coupon applied to the invoice' });\\n\\nexport const SaaSSubscriptionInvoiceSchema = z.object({\\n  invoice_id: z.string().openapi({ description: 'Unique identifier for the invoice', example: 'inv_7890' }),\\n  billing_cycle: BillingCycleSchema,\\n  company: CompanySchema,\\n  taxes: z.array(TaxEntrySchema).openapi({ description: 'List of taxes applied to the invoice' }),\\n  discount_coupons: z.array(DiscountCouponSchema).openapi({ description: 'List of discount coupons applied to the invoice' }),\\n  total_amount_due: z.number().openapi({ description: 'Total amount due after taxes and discounts', example: 225.00 })\\n}).openapi({ title: 'SaaS Subscription Invoice', description: 'Response schema for a SaaS subscription invoice including billing, company details, taxes, and discounts' });\"\n}"
