"{\n  \"raw_json\": {\n    \"truck_id\": \"TRK123456\",\n    \"location\": {\n      \"latitude\": 40.712776,\n      \"longitude\": -74.005974,\n      \"timestamp\": \"2024-06-01T14:30:00Z\"\n    },\n    \"speed_kmh\": 65.5,\n    \"driver\": {\n      \"driver_id\": \"DRV78910\",\n      \"name\": \"John Doe\",\n      \"phone\": \"+1234567890\",\n      \"license_number\": \"D1234567\",\n      \"experience_years\": 5\n    },\n    \"route_stops\": [\n      {\n        \"stop_id\": \"STP1001\",\n        \"location\": {\n          \"latitude\": 40.73061,\n          \"longitude\": -73.935242\n        },\n        \"eta\": \"2024-06-01T15:10:00Z\",\n        \"status\": \"pending\",\n        \"notes\": \"Handle with care\"\n      },\n      {\n        \"stop_id\": \"STP1002\",\n        \"location\": {\n          \"latitude\": 40.650002,\n          \"longitude\": -73.949997\n        },\n        \"eta\": \"2024-06-01T16:30:00Z\",\n        \"status\": \"completed\",\n        \"notes\": null\n      }\n    ]\n  },\n  \"zod_code\": \"import { z } from 'zod';\\nimport { extendZodWithOpenApi } from '@asteasolutions/zod-to-openapi';\\n\\nextendZodWithOpenApi(z);\\n\\nconst CoordinatesSchema = z.object({\\n  latitude: z.number().min(-90).max(90).openapi({ description: 'Latitude of the location in decimal degrees', example: 40.712776 }),\\n  longitude: z.number().min(-180).max(180).openapi({ description: 'Longitude of the location in decimal degrees', example: -74.005974 })\\n}).openapi({ description: 'Geographical coordinates' });\\n\\nconst LocationWithTimestampSchema = CoordinatesSchema.extend({\\n  timestamp: z.string().datetime().openapi({ description: 'ISO 8601 timestamp of the location record', example: '2024-06-01T14:30:00Z' })\\n}).openapi({ description: 'Location coordinates with timestamp' });\\n\\nconst DriverInfoSchema = z.object({\\n  driver_id: z.string().openapi({ description: 'Unique identifier for the driver', example: 'DRV78910' }),\\n  name: z.string().openapi({ descrip