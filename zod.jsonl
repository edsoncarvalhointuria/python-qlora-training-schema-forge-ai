).openapi({ description: 'Individual energy usage entry' });\\n\\nexport const ThermostatResponseSchema = z.object({\\n  device_id: z.string().openapi({ description: 'Unique identifier for the thermostat device', example: 'th-9928-x' }),\\n  status: ThermostatStatusSchema,\\n  health: DeviceHealthSchema,\\n  usage_history: z.array(UsageRecordSchema).openapi({ description: 'List of recent energy consumption records' })\\n}).openapi({ title: 'Thermostat Status Response', description: 'Comprehensive status and telemetry data for a smart thermostat' });\"\n}"
