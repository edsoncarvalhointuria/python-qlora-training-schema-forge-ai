: 'João Silva' }),\\n  street: z.string().openapi({ description: 'Rua e número do endereço de entrega', example: 'Rua das Flores, 123' }),\\n  city: z.string().openapi({ description: 'Cidade do endereço de entrega', example: 'Belo Horizonte' }),\\n  state: z.string().openapi({ description: 'Estado do endereço de entrega', example: 'MG' }),\\n  zip: z.string().openapi({ description: 'CEP do endereço de entrega', example: '30140-010' }),\\n  country: z.string().openapi({ description: 'País do endereço de entrega', example: 'Brasil' })\\n}).openapi({ description: 'Endereço físico para envio do pedido' });\\n\\nconst PaymentSchema = z.object({\\n  transaction_id: z.string().openapi({ description: 'Identificador da transação de pagamento', example: 'txn_789321' }),\\n  method: z.string().openapi({ description: 'Método de pagamento utilizado', example: 'Cartão de Crédito' }),\\n  amount: z.number().openapi({ description: 'Valor cobrado na transação em reais', example: 205.3 }),\\n  currency: z.string().openapi({ description: 'Código da moeda', example: 'BRL' }),\\n  status: z.string().openapi({ description: 'Status atual do pagamento', example: 'Pago' })\\n}).openapi({ description: 'Detalhes da transação de pagamento do pedido' });\\n\\nconst HalLinkSchema = z.object({\\n  href: z.string().url().openapi({ description: 'URL do recurso HAL', example: 'https://api.loja.com/orders/ord_123456' })\\n}).openapi({ description: 'Link HAL para navegação e recursos relacionados' });\\n\\nconst HalLinksSchema = z.object({\\n  self: HalLinkSchema.openapi({ description: 'Link para o próprio pedido' }),\\n  tracking: HalLinkSchema.openapi({ description: 'Link para rastreamento do pedido' })\\n}).openapi({ description: 'Coleção de links HAL associados ao pedido' });\\n\\nexport const OrderResponseSchema = z.object({\\n  order_id: z.string().openapi({ description: 'Identificador único do pedido', example: 'ord_123456' }),\\n  items: z.array(ItemSchema).openapi({ description: 'Lista de itens físicos contidos no pedido' }),\\n  shipping_address: ShippingAddressSchema.openapi({ description: 'Endereço para entrega dos itens' }),\\n  payment: PaymentSchema.openapi({ description: 'Informações da transação de pagamento associada ao pedido' }),\\n  _links: HalLinksSchema.openapi({ description: 'Links HAL para recursos relacionados ao pedido' })\\n}).openapi({ title: 'Resposta de Pedido da Loja', description: 'Resposta detalhada de um pedido de e-commerce incluindo itens, endereço, pagamento e links HAL' });\"\n}"
