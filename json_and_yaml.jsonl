"{\n  \"raw_json\": {\n    \"patient_id\": \"pat_12345\",\n    \"vital_signs\": {\n      \"heart_rate\": 72,\n      \"blood_pressure\": \"120/80\",\n      \"temperature_celsius\": 36.7,\n      \"respiratory_rate\": 16\n    },\n    \"current_medications\": [\n      {\n        \"name\": \"Aspirin\",\n        \"dosage_mg\": 100,\n        \"frequency_per_day\": 1\n      },\n      {\n        \"name\": \"Lisinopril\",\n        \"dosage_mg\": 10,\n        \"frequency_per_day\": 2\n      }\n    ],\n    \"attending_doctor\": {\n      \"doctor_id\": \"doc_987\",\n      \"name\": \"Dr. Jane Smith\",\n      \"specialization\": \"Cardiology\",\n      \"contact_email\": \"jane.smith@hospital.org\"\n    }\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Hospital Patient Medical Record Summary API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"VitalSigns\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Patient's vital signs with measurements\\\",\\n        \\\"properties\\\": {\\n          \\\"heart_rate\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Heart beats per minute\\\",\\n            \\\"example\\\": 72\\n          },\\n          \\\"blood_pressure\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Systolic and diastolic blood pressure in mmHg\\\",\\n            \\\"example\\\": \\\"120/80\\\"\\n          },\\n          \\\"temperature_celsius\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Body temperature in degrees Celsius\\\",\\n            \\\"example\\\": 36.7\\n          },\\n          \\\"respiratory_rate\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of breaths per minute\\\",\\n            \\\"example\\\": 16\\n          }\\n        },\\n        \\\"required\\\": [\\\"heart_rate\\\", \\\"blood_pressure\\\", \\\"temperature_celsius\\\", \\\"respiratory_rate\\\"]\\n      },\\n      \\\"Medication\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"A single medication entry including dosage and frequency\\\",\\n        \\\"properties\\\": {\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the medication\\\",\\n            \\\"example\\\": \\\"Aspirin\\\"\\n          },\\n          \\\"dosage_mg\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Dosage amount in milligrams\\\",\\n            \\\"example\\\": 100\\n          },\\n          \\\"frequency_per_day\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"How many times the medication is taken per day\\\",\\n            \\\"example\\\": 1\\n          }\\n        },\\n        \\\"required\\\": [\\\"name\\\", \\\"dosage_mg\\\", \\\"frequency_per_day\\\"]\\n      },\\n      \\\"DoctorProfile\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the attending doctor\\\",\\n        \\\"properties\\\": {\\n          \\\"doctor_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the doctor\\\",\\n            \\\"example\\\": \\\"doc_987\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Full name of the doctor\\\",\\n            \\\"example\\\": \\\"Dr. Jane Smith\\\"\\n          },\\n          \\\"specialization\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Medical specialty of the doctor\\\",\\n            \\\"example\\\": \\\"Cardiology\\\"\\n          },\\n          \\\"contact_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"Contact email address of the doctor\\\",\\n            \\\"example\\\": \\\"jane.smith@hospital.org\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"doctor_id\\\", \\\"name\\\", \\\"specialization\\\", \\\"contact_email\\\"]\\n      },\\n      \\\"PatientMedicalRecordSummary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Summary of a hospital patient's medical record including vital signs, medications, and attending doctor\\\",\\n        \\\"properties\\\": {\\n          \\\"patient_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the patient\\\",\\n            \\\"example\\\": \\\"pat_12345\\\"\\n          },\\n          \\\"vital_signs\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/VitalSigns\\\"\\n          },\\n          \\\"current_medications\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of current medications the patient is taking\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Medication\\\"\\n            }\\n          },\\n          \\\"attending_doctor\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DoctorProfile\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"patient_id\\\", \\\"vital_signs\\\", \\\"current_medications\\\", \\\"attending_doctor\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n  },\\n  \\\"schemas\\\": {}\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"truck_id\": \"TRK12345\",\n    \"location\": {\n      \"latitude\": 40.712776,\n      \"longitude\": -74.005974\n    },\n    \"speed_kmph\": 65,\n    \"driver\": {\n      \"driver_id\": \"DRV987\",\n      \"name\": \"John Doe\",\n      \"license_number\": \"D1234567\"\n    },\n    \"stops\": [\n      {\n        \"stop_id\": \"STP001\",\n        \"address\": \"123 Main St, New York, NY\",\n        \"scheduled_time\": \"2024-06-15T08:30:00Z\",\n        \"status\": \"completed\"\n      },\n      {\n        \"stop_id\": \"STP002\",\n        \"address\": \"456 Elm St, Newark, NJ\",\n        \"scheduled_time\": \"2024-06-15T10:00:00Z\",\n        \"status\": \"pending\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Logistics Fleet Tracking\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    GPSLocation:\\n      type: object\\n      description: 'GPS coordinates indicating the current location of the truck'\\n      properties:\\n        latitude:\\n          type: number\\n          format: float\\n          description: 'Latitude of the truck location in decimal degrees'\\n          example: 40.712776\\n        longitude:\\n          type: number\\n          format: float\\n          description: 'Longitude of the truck location in decimal degrees'\\n          example: -74.005974\\n    DriverInfo:\\n      type: object\\n      description: 'Information about the driver currently operating the truck'\\n      properties:\\n        driver_id:\\n          type: string\\n          description: 'Unique identifier for the driver'\\n          example: 'DRV987'\\n        name:\\n          type: string\\n          description: 'Full name of the driver'\\n          example: 'John Doe'\\n        license_number:\\n          type: string\\n          description: 'Driver''s license number'\\n          example: 'D1234567'\\n    StopDetail:\\n      type: object\\n      description: 'Details about a single stop on the delivery route'\\n      properties:\\n        stop_id:\\n          type: string\\n          description: 'Unique identifier for the stop'\\n          example: 'STP001'\\n        address:\\n          type: string\\n          description: 'Full address of the stop'\\n          example: '123 Main St, New York, NY'\\n        scheduled_time:\\n          type: string\\n          format: date-time\\n          description: 'Scheduled time for the stop in ISO 8601 format'\\n          example: '2024-06-15T08:30:00Z'\\n        status:\\n          type: string\\n          description: 'Current status of the stop on the route'\\n          example: 'completed'\\n    TruckTrackingResponse:\\n      type: object\\n      description: 'Response detailing the current status and routing information of a delivery truck'\\n      properties:\\n        truck_id:\\n          type: string\\n          description: 'Unique identifier for the delivery truck'\\n          example: 'TRK12345'\\n        location:\\n          $ref: '#/components/schemas/GPSLocation'\\n        speed_kmph:\\n          type: integer\\n          description: 'Current speed of the truck in kilometers per hour'\\n          example: 65\\n        driver:\\n          $ref: '#/components/schemas/DriverInfo'\\n        stops:\\n          type: array\\n          description: 'Array of stops scheduled on the truck''s route'\\n          items:\\n            $ref: '#/components/schemas/StopDetail'\\n\"\n}"
"{\n  \"raw_json\": {\n    \"current_temperature\": 21.5,\n    \"target_temperature\": 23,\n    \"device_health\": {\n      \"battery_level\": 87,\n      \"wifi_signal_strength\": -65\n    },\n    \"usage_history\": [\n      {\n        \"date\": \"2024-04-22\",\n        \"hours_active\": 8.5\n      },\n      {\n        \"date\": \"2024-04-21\",\n        \"hours_active\": 7.0\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Smart Thermostat Status Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"DeviceHealth\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Battery and WiFi health status of the thermostat device\\\",\\n        \\\"properties\\\": {\\n          \\\"battery_level\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Remaining battery percentage\\\",\\n            \\\"example\\\": 87\\n          },\\n          \\\"wifi_signal_strength\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"WiFi signal strength in dBm\\\",\\n            \\\"example\\\": -65\\n          }\\n        },\\n        \\\"required\\\": [\\\"battery_level\\\", \\\"wifi_signal_strength\\\"]\\n      },\\n      \\\"UsageRecord\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Historical usage record for the thermostat\\\",\\n        \\\"properties\\\": {\\n          \\\"date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"Date of the usage record\\\",\\n            \\\"example\\\": \\\"2024-04-22\\\"\\n          },\\n          \\\"hours_active\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"description\\\": \\\"Number of hours thermostat was active on this date\\\",\\n            \\\"example\\\": 8.5\\n          }\\n        },\\n        \\\"required\\\": [\\\"date\\\", \\\"hours_active\\\"]\\n      },\\n      \\\"ThermostatStatusResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Current status and historical data for a smart home thermostat\\\",\\n        \\\"properties\\\": {\\n          \\\"current_temperature\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"description\\\": \\\"Current ambient temperature measured by the thermostat in Celsius\\\",\\n            \\\"example\\\": 21.5\\n          },\\n          \\\"target_temperature\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"description\\\": \\\"Desired target temperature set on the thermostat in Celsius\\\",\\n            \\\"example\\\": 23\\n          },\\n          \\\"device_health\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DeviceHealth\\\"\\n          },\\n          \\\"usage_history\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of historical usage records\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/UsageRecord\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"current_temperature\\\", \\\"target_temperature\\\", \\\"device_health\\\", \\\"usage_history\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
