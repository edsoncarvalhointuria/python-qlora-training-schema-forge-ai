"{\n  \"raw_json\": {\n    \"total_monthly_spend\": 12500.75,\n    \"costs\": [\n      {\n        \"service\": \"compute\",\n        \"amount\": 7500.50,\n        \"details\": [\n          {\n            \"resource\": \"vm_instance\",\n            \"usage_hours\": 320,\n            \"cost\": 4800.00\n          },\n          {\n            \"resource\": \"container_runtime\",\n            \"usage_hours\": 100,\n            \"cost\": 2700.50\n          }\n        ]\n      },\n      {\n        \"service\": \"storage\",\n        \"amount\": 5000.25,\n        \"details\": [\n          {\n            \"resource\": \"block_storage\",\n            \"usage_gb\": 2000,\n            \"cost\": 3000.00\n          },\n          {\n            \"resource\": \"object_storage\",\n            \"usage_gb\": 5000,\n            \"cost\": 2000.25\n          }\n        ]\n      }\n    ],\n    \"forecasts\": {\n      \"next_month_spend\": 13000.00,\n      \"growth_rate_percent\": 4.0\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Cloud Infrastructure Billing Dashboard\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CostDetailCompute:\\n      type: object\\n      description: Detalhes do custo dos recursos de computação\\n      properties:\\n        resource:\\n          type: string\\n          description: Nome do recurso de computação\\n          example: vm_instance\\n        usage_hours:\\n          type: integer\\n          description: Horas de uso do recurso\\n          example: 320\\n        cost:\\n          type: number\\n          description: Custo associado ao recurso\\n          example: 4800.0\\n    CostDetailStorage:\\n      type: object\\n      description: Detalhes do custo dos recursos de armazenamento\\n      properties:\\n        resource:\\n          type: string\\n          description: Nome do recurso de armazenamento\\n          example: block_storage\\n        usage_gb:\\n          type: integer\\n          description: Quantidade de arm