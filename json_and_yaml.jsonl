ctor\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Dados do inspetor da alfândega\\\",\\n        \\\"properties\\\": {\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome do inspetor\\\",\\n            \\\"example\\\": \\\"João Silva\\\"\\n          },\\n          \\\"badge_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Número da identificação do inspetor\\\",\\n            \\\"example\\\": \\\"BR-998877\\\"\\n          }\\n        }\\n      },\\n      \\\"CustomsClearance\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Status do processo de liberação alfandegária do contêiner\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Status atual da liberação na alfândega\\\",\\n            \\\"example\\\": \\\"Cleared\\\"\\n          },\\n          \\\"cleared_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora da liberação alfandegária\\\",\\n            \\\"example\\\": \\\"2024-06-16T14:45:00Z\\\"\\n          },\\n          \\\"inspector\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Inspector\\\"\\n          }\\n        }\\n      },\\n      \\\"EnvironmentalReading\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Leituras ambientais coletadas dentro do contêiner\\\",\\n        \\\"properties\\\": {\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Momento em que a leitura foi realizada\\\",\\n            \\\"example\\\": \\\"2024-06-15T09:00:00Z\\\"\\n          },\\n          \\\"temperature_celsius\\\": {\\n            \\\"type\\