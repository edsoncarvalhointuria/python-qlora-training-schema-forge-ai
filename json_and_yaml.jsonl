urrent status of the tuition payment'\\n          example: 'Partial Payment'\\n    StudentDashboardResponse:\\n      type: object\\n      description: 'The overall response object for the student dashboard containing academic and financial information'\\n      properties:\\n        studentId:\\n          type: string\\n          description: 'Unique identifier for the student'\\n          example: 'S12345678'\\n        fullName:\\n          type: string\\n          description: 'Student’s full name'\\n          example: 'John Doe'\\n        academicHistory:\\n          $ref: '#/components/schemas/AcademicHistory'\\n        currentEnrolledCourses:\\n          type: array\\n          description: 'List of courses the student is currently enrolled in'\\n          items:\\n            $ref: '#/components/schemas/EnrolledCourse'\\n        financialStatus:\\n          $ref: '#/components/schemas/FinancialStatus'\\n\"\n}"
