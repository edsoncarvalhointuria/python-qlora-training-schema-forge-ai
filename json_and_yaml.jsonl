   },\\n          \\\"pricing_breakdown\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/PricingBreakdown\\\"\\n          },\\n          \\\"amenities_requested\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of amenities requested for the room\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Amenity\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n}"
