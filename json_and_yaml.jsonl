te\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"State or region\\\",\\n            \\\"example\\\": \\\"CA\\\"\\n          },\\n          \\\"postal_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Postal or ZIP code\\\",\\n            \\\"example\\\": \\\"94105\\\"\\n          },\\n          \\\"country\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Country of the address\\\",\\n            \\\"example\\\": \\\"USA\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"street\\\", \\\"city\\\", \\\"state\\\", \\\"postal_code\\\", \\\"country\\\"]\\n      },\\n      \\\"Company\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the billing company\\\",\\n        \\\"properties\\\": {\\n          \\\"company_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the company\\\",\\n            \\\"example\\\": \\\"comp_500\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the company\\\",\\n            \\\"example\\\": \\\"Innovatech LLC\\\"\\n          },\\n          \\\"address\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Address\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"company_id\\\", \\\"name\\\", \\\"address\\\"]\\n      },\\n      \\\"BillingCycle\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Start and end dates for the billing cycle\\\",\\n        \\\"properties\\\": {\\n          \\\"start_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"Start date of the billing cycle\\\",\\n            \\\"example\\\": \\\"2024-05-01\\\"\\n          },\\n          \\\"end_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"End date of the billing cycle\\\",\\n            \\\"example\\\": \\\"2024-05-31\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"start_date\\\", \\\"end_date\\\"]\\n      },\\n      \\\"Tax\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Individual tax details\\\",\\n        \\\"properties\\\": {\\n          \\\"tax_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name or type of tax\\\",\\n            \\\"example\\\": \\\"State Tax\\\"\\n          },\\n          \\\"tax_rate\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Tax rate as a percentage\\\",\\n            \\\"example\\\": 8.5\\n          },\\n          \\\"tax_amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Monetary amount of the tax\\\",\\n            \\\"example\\\": 12.75\\n          }\\n        },\\n        \\\"required\\\": [\\\"tax_name\\\", \\\"tax_rate\\\", \\\"tax_amount\\\"]\\n      },\\n      \\\"DiscountCoupon\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Coupon applied to the invoice\\\",\\n        \\\"properties\\\": {\\n          \\\"code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Coupon code\\\",\\n            \\\"example\\\": \\\"SPRING2024\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Description of the coupon benefit\\\",\\n            \\\"example\\\": \\\"Spring season promotional discount\\\"\\n          },\\n          \\\"discount_amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Amount discounted by the coupon\\\",\\n            \\\"example\\\": 10.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"code\\\", \\\"description\\\", \\\"discount_amount\\\"]\\n      },\\n      \\\"Invoice\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Full SaaS subscription invoice details\\\",\\n        \\\"properties\\\": {\\n          \\\"invoice_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique invoice identifier\\\",\\n            \\\"example\\\": \\\"inv_1001\\\"\\n          },\\n          \\\"billing_cycle\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BillingCycle\\\"\\n          },\\n          \\\"company\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Company\\\"\\n          },\\n          \\\"taxes\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of tax breakdowns applied\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Tax\\\"\\n            }\\n          },\\n          \\\"discount_coupons\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of applied discount coupons\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/DiscountCoupon\\\"\\n            }\\n          },\\n          \\\"total_amount_due\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total amount due including taxes and discounts\\\",\\n            \\\"example\\\": 137.25\\n          },\\n          \\\"currency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Currency code using ISO 4217 standard\\\",\\n            \\\"example\\\": \\\"USD\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"invoice_id\\\", \\\"billing_cycle\\\", \\\"company\\\", \\\"taxes\\\", \\\"discount_coupons\\\", \\\"total_amount_due\\\", \\\"currency\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"paths\\\": {},\\n  \\\"info\\\": {}\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"title\": \"Inception\",\n    \"runtime_minutes\": 148,\n    \"director\": {\n      \"id\": \"dir_001\",\n      \"name\": \"Christopher Nolan\"\n    },\n    \"cast\": [\n      {\n        \"id\": \"actor_001\",\n        \"name\": \"Leonardo DiCaprio\",\n        \"role\": \"Dom Cobb\"\n      },\n      {\n        \"id\": \"actor_002\",\n        \"name\": \"Joseph Gordon-Levitt\",\n        \"role\": \"Arthur\"\n      },\n      {\n        \"id\": \"actor_003\",\n        \"name\": \"Ellen Page\",\n        \"role\": \"Ariadne\"\n      }\n    ],\n    \"_links\": {\n      \"self\": {\n        \"href\": \"https://api.streamingplatform.com/movies/inception\"\n      },\n      \"related\": [\n        {\n          \"href\": \"https://api.streamingplatform.com/movies/interstellar\",\n          \"title\": \"Interstellar\"\n        },\n        {\n          \"href\": \"https://api.streamingplatform.com/movies/memento\",\n          \"title\": \"Memento\"\n        }\n      ]\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Streaming Platform Movie API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Director:\\n      type: object\\n      description: 'Director details object'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier for the director'\\n          example: 'dir_001'\\n        name:\\n          type: string\\n          description: 'Full name of the director'\\n          example: 'Christopher Nolan'\\n    CastMember:\\n      type: object\\n      description: 'Cast member details including role in the movie'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier for the actor'\\n          example: 'actor_001'\\n        name:\\n          type: string\\n          description: 'Full name of the actor'\\n          example: 'Leonardo DiCaprio'\\n        role:\\n          type: string\\n          description: 'Role played by the actor in the movie'\\n          example: 'Dom Cobb'\\n    Link:\\n      type: object\\n      description: 'Hypermedia link object with URL and optional title'\\n      properties:\\n        href:\\n          type: string\\n          format: uri\\n          description: 'URL reference for the link'\\n          example: 'https://api.streamingplatform.com/movies/inception'\\n        title:\\n          type: string\\n          description: 'Optional title of the linked resource'\\n          example: 'Inception'\\n    LinksCollection:\\n      type: object\\n      description: 'HATEOAS links for the movie resource'\\n      properties:\\n        self:\\n          $ref: '#/components/schemas/Link'\\n        related:\\n          type: array\\n          description: 'Array of related movies links'\\n          items:\\n            $ref: '#/components/schemas/Link'\\n    Movie:\\n      type: object\\n      description: 'Movie resource with details and hypermedia links'\\n      properties:\\n        title:\\n          type: string\\n          description: 'Title of the movie'\\n          example: 'Inception'\\n        runtime_minutes:\\n          type: integer\\n          description: 'Runtime duration of the movie in minutes'\\n          example: 148\\n        director:\\n          $ref: '#/components/schemas/Director'\\n        cast:\\n          type: array\\n          description: 'List of cast members appearing in the movie'\\n          items:\\n            $ref: '#/components/schemas/CastMember'\\n        _links:\\n          $ref: '#/components/schemas/LinksCollection'\"\n}"
