t\\\",\\n            \\\"example\\\": \\\"Morning Jazz Vibes\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Descrição detalhada da playlist\\\",\\n            \\\"example\\\": \\\"Energetic and smooth jazz tunes to start your day.\\\"\\n          },\\n          \\\"creator\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n          },\\n          \\\"pagination\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Pagination\\\"\\n          },\\n          \\\"tracks\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de faixas na página corrente\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Track\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {}\\n}\"\n}"
