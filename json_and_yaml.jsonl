n\\\": \\\"International Standard Book Number identifier.\\\",\\n            \\\"example\\\": \\\"9780134610993\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"title\\\", \\\"author\\\", \\\"edition\\\", \\\"isbn\\\"]\\n      },\\n      \\\"WeeklyModule\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a weekly module including topics covered and reading list.\\\",\\n        \\\"properties\\\": {\\n          \\\"week\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"The sequential week number of the module.\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"module_title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Title of the weekly module.\\\",\\n            \\\"example\\\": \\\"Foundations of AI\\\"\\n          },\\n          \\\"topics\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of topics covered in the module.\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\"\\n            },\\n            \\\"example\\\": [\\\"History of AI\\\", \\\"Intelligent agents\\\", \\\"Problem solving\\\"]\\n          },\\n          \\\"reading_list\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Required textbook reading list for the module.\\\",\\n            \\\"items\\\": {\\\"$ref\\\": \\\"#/components/schemas/ReadingItem\\\"}\\n          }\\n        },\\n        \\\"required\\\": [\\\"week\\\", \\\"module_title\\\", \\\"topics\\\", \\\"reading_list\\\"]\\n      },\\n      \\\"CourseSyllabus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"The complete course syllabus including professor info, modules, and required readings.\\\",\\n        \\\"properties\\\": {\\n          \\\"course_title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description