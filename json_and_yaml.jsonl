"{\n  \"raw_json\": {\n    \"reservation_id\": \"resv_456\",\n    \"room_type\": \"Deluxe Suite\",\n    \"pricing_breakdown\": [\n      {\n        \"date\": \"2024-07-01\",\n        \"base_rate\": 200.00,\n        \"taxes\": 20.00,\n        \"fees\": 5.00,\n        \"total\": 225.00\n      },\n      {\n        \"date\": \"2024-07-02\",\n        \"base_rate\": 200.00,\n        \"taxes\": 20.00,\n        \"fees\": 5.00,\n        \"total\": 225.00\n      }\n    ],\n    \"requested_amenities\": [\n      {\n        \"amenity_type\": \"Crib\",\n        \"quantity\": 1,\n        \"notes\": \"Portable crib requested\"\n      },\n      {\n        \"amenity_type\": \"Extra Bed\",\n        \"quantity\": 2,\n        \"notes\": \"For children under 12\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Hotel Reservation Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PricingDetail\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detailed pricing information for a single night\\\",\\n        \\\"properties\\\": {\\n          \\\"date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"Date for the pricing breakdown\\\",\\n            \\\"example\\\": \\\"2024-07-01\\\"\\n          },\\n          \\\"base_rate\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Base room rate for the night in USD\\\",\\n            \\\"example\\\": 200.00\\n          },\\n          \\\"taxes\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total taxes applied for the night in USD\\\",\\n            \\\"example\\\": 20.00\\n          },\\n          \\\"fees\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Additional fees for the night in USD\\\",\\n            \\\"example\\\": 5.00\\n          },\\n          \\\"total\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total cost for the night including base rate, taxes, and fees in USD\\\",\\n            \\\"example\\\": 225.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"date\\\", \\\"base_rate\\\", \\\"taxes\\\", \\\"fees\\\", \\\"total\\\"]\\n      },\\n      \\\"AmenityRequest\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"An amenity requested for the room\\\",\\n        \\\"properties\\\": {\\n          \\\"amenity_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of amenity requested\\\",\\n            \\\"example\\\": \\\"Crib\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of amenities requested\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"notes\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Additional notes or specifications for the amenity\\\",\\n            \\\"example\\\": \\\"Portable crib requested\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"amenity_type\\\", \\\"quantity\\\"]\\n      },\\n      \\\"ReservationResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Hotel reservation with room and pricing details\\\",\\n        \\\"properties\\\": {\\n          \\\"reservation_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the reservation\\\",\\n            \\\"example\\\": \\\"resv_456\\\"\\n          },\\n          \\\"room_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of room reserved\\\",\\n            \\\"example\\\": \\\"Deluxe Suite\\\"\\n          },\\n          \\\"pricing_breakdown\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"An array of nightly pricing details\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/PricingDetail\\\"\\n            }\\n          },\\n          \\\"requested_amenities\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of amenities requested by the guest\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/AmenityRequest\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"reservation_id\\\", \\\"room_type\\\", \\\"pricing_breakdown\\\", \\\"requested_amenities\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
