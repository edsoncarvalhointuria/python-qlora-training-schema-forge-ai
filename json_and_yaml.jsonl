            \\\"description\\\": \\\"Unique identifier of the buyer company\\\",\\n            \\\"example\\\": \\\"COMP-7890\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Full name of the buyer company\\\",\\n            \\\"example\\\": \\\"Acme Wholesale Ltd.\\\"\\n          },\\n          \\\"address\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Physical address of the company\\\",\\n            \\\"example\\\": \\\"123 Industrial Way, Commerce City, CA 90210\\\"\\n          },\\n          \\\"contact_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Primary contact email for procurement\\\",\\n            \\\"example\\\": \\\"procurement@acmewholesale.com\\\"\\n          },\\n          \\\"contact_phone\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Primary contact phone number\\\",\\n            \\\"example\\\": \\\"+1-310-555-0199\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"company_id\\\", \\\"name\\\", \\\"address\\\", \\\"contact_email\\\", \\\"contact_phone\\\"]\\n      },\\n      \\\"DiscountTier\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Defines a bulk purchase quantity range and associated discount percentage\\\",\\n        \\\"properties\\\": {\\n          \\\"min_quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Minimum quantity to qualify for this discount tier\\\",\\n            \\\"example\\\": 50\\n          },\\n          \\\"max_quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Maximum quantity for this discount tier\\\",\\n            \\\"example\\\": 99\\n          },\\n          \\\"discount_percent\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Discount percentage applied for this tier\\\",\\n            \\\"example\\\": 5.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"min_quantity\\\", \\\"max_quantity\\\", \\\"discount_percent\\\"]\\n      },\\n      \\\"Item\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a bulk item in the invoice with tiered discounts\\\",\\n        \\\"properties\\\": {\\n          \\\"item_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the item\\\",\\n            \\\"example\\\": \\\"ITEM-1001\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name and brief detail of the product\\\",\\n            \\\"example\\\": \\\"Premium Office Chair\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantity of the item ordered\\\",\\n            \\\"example\\\": 150\\n          },\\n          \\\"unit_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Unit price per item before discount\\\",\\n            \\\"example\\\": 120.00\\n          },\\n          \\\"discount_tiers\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of discount tiers applicable based on quantity\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/DiscountTier\\\" }\\n          },\\n          \\\"applied_discount_percent\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Discount percent actually applied based on ordered quantity\\\",\\n            \\\"example\\\": 10.0\\n          },\\n          \\\"total_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Final total price for the item after discount\\\",\\n            \\\"example\\\": 16200.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"item_id\\\", \\\"description\\\", \\\"quantity\\\", \\\"unit_price\\\", \\\"discount_tiers\\\", \\\"applied_discount_percent\\\", \\\"total_price\\\"]\\n      },\\n      \\\"FreightTerms\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Shipping and freight details including terms and costs\\\",\\n        \\\"properties\\\": {\\n          \\\"shipping_method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Incoterms used for shipping\\\",\\n            \\\"example\\\": \\\"FOB\\\"\\n          },\\n          \\\"carrier\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the freight carrier company\\\",\\n            \\\"example\\\": \\\"Speedy Freight Co.\\\"\\n          },\\n          \\\"estimated_delivery_days\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Estimated number of days for delivery\\\",\\n            \\\"example\\\": 7\\n          },\\n          \\\"shipping_cost\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Cost charged for freight shipping\\\",\\n            \\\"example\\\": 350.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"shipping_method\\\", \\\"carrier\\\", \\\"estimated_delivery_days\\\", \\\"shipping_cost\\\"]\\n      },\\n      \\\"Invoice\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Wholesale order invoice including buyer profile, items with tiered discounts, and freight terms\\\",\\n        \\\"properties\\\": {\\n          \\\"invoice_id\\\": {\\n            \\\"type\\\": \\\"s