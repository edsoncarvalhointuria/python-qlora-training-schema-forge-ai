"{\n  \"raw_json\": {\n    \"studentId\": \"S12345678\",\n    \"fullName\": \"John Doe\",\n    \"academicHistory\": {\n      \"completedCourses\": [\n        {\n          \"courseCode\": \"CS101\",\n          \"courseName\": \"Introduction to Computer Science\",\n          \"grade\": \"A\",\n          \"semester\": \"Fall 2022\"\n        },\n        {\n          \"courseCode\": \"MATH201\",\n          \"courseName\": \"Calculus II\",\n          \"grade\": \"B+\",\n          \"semester\": \"Spring 2023\"\n        }\n      ],\n      \"gpa\": 3.7\n    },\n    \"currentEnrolledCourses\": [\n      {\n        \"courseCode\": \"CS202\",\n        \"courseName\": \"Data Structures\",\n        \"instructor\": \"Dr. Alice Smith\",\n        \"schedule\": \"Mon/Wed 10:00-11:30\"\n      },\n      {\n        \"courseCode\": \"ENG101\",\n        \"courseName\": \"English Literature\",\n        \"instructor\": \"Prof. Robert Brown\",\n        \"schedule\": \"Tue/Thu 14:00-15:30\"\n      }\n    ],\n    \"financialStatus\": {\n      \"tuitionPaid\": 6000,\n      \"tuitionDue\": 1500,\n      \"dueDate\": \"2024-07-15\",\n      \"status\": \"Partial Payment\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: University Student Dashboard Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CompletedCourse:\\n      type: object\\n      description: 'A course that the student has completed'\\n      properties:\\n        courseCode:\\n          type: string\\n          description: 'The code identifier for the course'\\n          example: 'CS101'\\n        courseName:\\n          type: string\\n          description: 'The full name of the completed course'\\n          example: 'Introduction to Computer Science'\\n        grade:\\n          type: string\\n          description: 'The grade obtained in the course'\\n          example: 'A'\\n        semester:\\n          type: string\\n          description: 'The academic semester when the course was completed'\\n   