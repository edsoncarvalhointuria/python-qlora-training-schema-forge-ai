tring\\\",\\n            \\\"description\\\": \\\"Unique identifier for the track\\\",\\n            \\\"example\\\": \\\"track_001\\\"\\n          },\\n          \\\"title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Title of the track\\\",\\n            \\\"example\\\": \\\"Ocean Breeze\\\"\\n          },\\n          \\\"artist\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the artist or group\\\",\\n            \\\"example\\\": \\\"Smooth Sounds\\\"\\n          },\\n          \\\"album\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Album name the track belongs to\\\",\\n            \\\"example\\\": \\\"Relaxation Essentials\\\"\\n          },\\n          \\\"duration_seconds\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Length of the track in seconds\\\",\\n            \\\"example\\\": 245\\n          },\\n          \\\"audio_specs\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/AudioSpecs\\\"\\n          }\\n        }\\n      },\\n      \\\"Pagination\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Pagination details for the tracks list\\\",\\n        \\\"properties\\\": {\\n          \\\"page\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Current page number\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"page_size\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of tracks per page\\\",\\n            \\\"example\\\": 2\\n          },\\n          \\\"total_pages\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Total number of pages available\\\",\\n            \\\"example\\\": 5\\n          },\\n          \\\"total_tracks\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n        