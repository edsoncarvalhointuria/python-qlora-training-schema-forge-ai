"{\n  \"raw_json\": {\n    \"patient\": {\n      \"patient_id\": \"P123456789\",\n      \"name\": \"Jane Doe\",\n      \"age\": 29,\n      \"gender\": \"Female\"\n    },\n    \"blood_biomarkers\": [\n      {\n        \"biomarker_name\": \"Hemoglobin\",\n        \"value\": 13.8,\n        \"units\": \"g/dL\",\n        \"normal_range\": {\n          \"min\": 12.0,\n          \"max\": 16.0\n        }\n      },\n      {\n        \"biomarker_name\": \"White Blood Cell Count\",\n        \"value\": 6.3,\n        \"units\": \"10^9/L\",\n        \"normal_range\": {\n          \"min\": 4.0,\n          \"max\": 11.0\n        }\n      }\n    ],\n    \"pathologist_signature\": {\n      \"name\": \"Dr. John Smith\",\n      \"date\": \"2024-06-20T15:30:00Z\",\n      \"digital_signature\": \"a3dcb4d229de6fde0db5686dee47145d\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Hospital Laboratory Test Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PatientDemographics:\\n      type: object\\n      description: 'Patient demographic information'\\n      properties:\\n        patient_id:\\n          type: string\\n          description: 'Unique identifier for the patient'\\n          example: 'P123456789'\\n        name:\\n          type: string\\n          description: 'Full name of the patient'\\n          example: 'Jane Doe'\\n        age:\\n          type: integer\\n          description: 'Age of the patient in years'\\n          example: 29\\n        gender:\\n          type: string\\n          description: 'Gender of the patient'\\n          example: 'Female'\\n    NormalRange:\\n      type: object\\n      description: 'Normal value range for a biomarker'\\n      properties:\\n        min:\\n          type: number\\n          description: 'Minimum normal value'\\n          example: 12.0\\n        max:\\n          type: number\\n          description: 'Maximum normal value'\\n          example: 16.0\\n    BloodBiomarker:\\n      type: object\\n      description: 'Blood biomarker measurement with normal range'\\n      properties:\\n        biomarker_name:\\n          type: string\\n          description: 'Name of the blood biomarker'\\n          example: 'Hemoglobin'\\n        value:\\n          type: number\\n          description: 'Measured value of the biomarker'\\n          example: 13.8\\n        units:\\n          type: string\\n          description: 'Units of the biomarker measurement'\\n          example: 'g/dL'\\n        normal_range:\\n          $ref: '#/components/schemas/NormalRange'\\n    PathologistSignature:\\n      type: object\\n      description: 'Digital signature details of the reviewing pathologist'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Full name of the pathologist'\\n          example: 'Dr. John Smith'\\n        date:\\n          type: string\\n          format: date-time\\n          description: 'Date and time when the result was signed'\\n          example: '2024-06-20T15:30:00Z'\\n        digital_signature:\\n          type: string\\n          description: 'Hexadecimal string representing the digital signature'\\n          example: 'a3dcb4d229de6fde0db5686dee47145d'\\n    LabTestResult:\\n      type: object\\n      description: 'Complete laboratory test result including patient demographics, blood biomarkers and pathologist digital signature'\\n      properties:\\n        patient:\\n          $ref: '#/components/schemas/PatientDemographics'\\n        blood_biomarkers:\\n          type: array\\n          description: 'List of blood biomarker measurements'\\n          items:\\n            $ref: '#/components/schemas/BloodBiomarker'\\n        pathologist_signature:\\n          $ref: '#/components/schemas/PathologistSignature'\\n\"\n}"
