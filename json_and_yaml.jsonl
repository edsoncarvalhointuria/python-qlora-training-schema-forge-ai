"{\n  \"raw_json\": {\n    \"user_profile\": {\n      \"user_id\": \"user_1001\",\n      \"full_name\": \"Jane Doe\",\n      \"email\": \"jane.doe@example.com\",\n      \"phone_number\": \"+1234567890\"\n    },\n    \"current_balance\": 2540.75,\n    \"currency\": \"USD\",\n    \"recent_transactions\": [\n      {\n        \"transaction_id\": \"txn_9001\",\n        \"date\": \"2024-06-01T14:20:00Z\",\n        \"amount\": -120.5,\n        \"currency\": \"USD\",\n        \"description\": \"Grocery shopping\",\n        \"merchant\": {\n          \"name\": \"SuperMart\",\n          \"category\": \"Groceries\"\n        }\n      },\n      {\n        \"transaction_id\": \"txn_9002\",\n        \"date\": \"2024-05-30T09:15:00Z\",\n        \"amount\": 500,\n        \"currency\": \"USD\",\n        \"description\": \"Salary deposit\",\n        \"merchant\": null\n      },\n      {\n        \"transaction_id\": \"txn_9003\",\n        \"date\": \"2024-05-29T18:05:00Z\",\n        \"amount\": -50.75,\n        \"currency\": \"USD\",\n        \"description\": \"Internet bill payment\",\n        \"merchant\": {\n          \"name\": \"FastNet ISP\",\n          \"category\": \"Utilities\"\n        }\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Digital Wallet Statement\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Merchant:\\n      type: object\\n      description: 'Details of the merchant involved in the transaction'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Name of the merchant'\\n          example: 'SuperMart'\\n        category:\\n          type: string\\n          description: 'Category of the merchant business'\\n          example: 'Groceries'\\n    Transaction:\\n      type: object\\n      description: 'A recent transaction in the wallet statement'\\n      properties:\\n        transaction_id:\\n          type: string\\n          description: 'Unique identifier of the transaction'\\n          example: 'txn_9001'\\n        date:\\n          type: string\\n          format: date-time\\n          description: 'ISO 8601 datetime of the transaction'\\n          example: '2024-06-01T14:20:00Z'\\n        amount:\\n          type: number\\n          description: 'Amount of the transaction, positive for credits and negative for debits'\\n          example: -120.5\\n        currency:\\n          type: string\\n          description: 'Currency code of the transaction amount'\\n          example: 'USD'\\n        description:\\n          type: string\\n          description: 'Explanation or memo of the transaction'\\n          example: 'Grocery shopping'\\n        merchant:\\n          anyOf:\\n            - $ref: '#/components/schemas/Merchant'\\n            - type: 'null'\\n          description: 'Merchant details, null if not applicable'\\n    UserProfile:\\n      type: object\\n      description: 'User profile details linked to the wallet'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'user_1001'\\n        full_name:\\n          type: string\\n          description: 'User full name'\\n          example: 'Jane Doe'\\n        email:\\n          type: string\\n          description: 'Email address of the user'\\n          example: 'jane.doe@example.com'\\n        phone_number:\\n          type: string\\n          description: 'Contact phone number of the user'\\n          example: '+1234567890'\\n    WalletStatement:\\n      type: object\\n      description: 'Digital wallet statement including balance, profile, and recent transactions'\\n      properties:\\n        user_profile:\\n          $ref: '#/components/schemas/UserProfile'\\n        current_balance:\\n          type: number\\n          description: 'Current available balance in the wallet'\\n          example: 2540.75\\n        currency:\\n          type: string\\n          description: 'Currency code for the balance'\