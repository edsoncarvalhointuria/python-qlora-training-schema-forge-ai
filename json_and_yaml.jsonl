cription\\\": \\\"ISBN number of the textbook\\\",\\n            \\\"example\\\": \\\"978-0134875460\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"title\\\", \\\"authors\\\", \\\"edition\\\", \\\"isbn\\\"]\\n      },\\n      \\\"WeeklyModule\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a weekly course module including topic and readings\\\",\\n        \\\"properties\\\": {\\n          \\\"week_number\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"The sequential number of the week in the course\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"topic\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Main topic covered during the week\\\",\\n            \\\"example\\\": \\\"Foundations of Computing\\\"\\n          },\\n          \\\"summary\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Short description of the week's content\\\",\\n            \\\"example\\\": \\\"Introduction to computing concepts and history.\\\"\\n          },\\n          \\\"reading_list\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of textbooks required for this week\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Textbook\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"week_number\\\", \\\"topic\\\", \\\"summary\\\", \\\"reading_list\\\"]\\n      },\\n      \\\"CourseSyllabus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Complete syllabus details of a university course\\\",\\n        \\\"properties\\\": {\\n          \\\"course_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the course\\\",\\n            \\\"example\\\": \\\"CS101\\\"\\n          },\\n          \\\"course_title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Official course title\\\",\\n            \\\"example\\\": \\\"Introduction to Computer Science\\\"\\n          },\\n          \\\"professor\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Professor\\\"\\n          },\\n          \\\"weekly_modules\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of weekly modules in the course\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/WeeklyModule\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"course_id\\\", \\\"course_title\\\", \\\"professor\\\", \\\"weekly_modules\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {}\\n}\"\n}"
