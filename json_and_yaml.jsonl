 inspector\\\",\\n            \\\"example\\\": \\\"John Doe\\\"\\n          },\\n          \\\"badge_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Badge number of the inspector\\\",\\n            \\\"example\\\": \\\"ID987654\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"name\\\", \\\"badge_number\\\"]\\n      },\\n      \\\"CustomsClearance\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Current customs clearance status for the container\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Clearance status\\\",\\n            \\\"example\\\": \\\"cleared\\\"\\n          },\\n          \\\"last_update\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Timestamp of the last update\\\",\\n            \\\"example\\\": \\\"2024-04-20T14:30:00Z\\\"\\n          },\\n          \\\"inspector\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Inspector\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"status\\\", \\\"last_update\\\", \\\"inspector\\\"]\\n      },\\n      \\\"EnvironmentalReading\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Environmental reading of the container's internal conditions\\\",\\n        \\\"properties\\\": {\\n          \\\"type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of environmental measurement\\\",\\n            \\\"example\\\": \\\"temperature\\\"\\n          },\\n          \\\"value\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"description\\\": \\\"Measured value\\\",\\n            \\\"example\\\": 5.6\\n          },\\n          \\\"unit\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Measurement unit\\\",\\n            \\\"example\\\": \\\"Celsius\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Time when the measurement was taken\\\",\\n            \\\"example\\\": \\\"2024-04-20T13:00:00Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"type\\\", \\\"value\\\", \\\"unit\\\", \\\"timestamp\\\"]\\n      },\\n      \\\"ContainerTrackingResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response showing container tracking details including location, customs, and environment\\\",\\n        \\\"properties\\\": {\\n          \\\"container_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the shipping container\\\",\\n            \\\"example\\\": \\\"CONT1234567\\\"\\n          },\\n          \\\"current_location\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Location\\\"\\n          },\\n          \\\"customs_clearance\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/CustomsClearance\\\"\\n          },\\n          \\\"environmental_readings\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of environmental measurements inside the container\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/EnvironmentalReading\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"container_id\\\", \\\"current_location\\\", \\\"customs_clearance\\\", \\\"environmental_readings\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"order_id\": \"ord_12345\",\n    \"status\": \"Out for delivery\",\n    \"courier\": {\n      \"id\": \"cr_987\",\n      \"name\": \"Alice Johnson\",\n      \"real_time_location\": {\n        \"latitude\": 40.712776,\n        \"longitude\": -74.005974,\n        \"last_updated\": \"2024-06-15T14:23:30Z\"\n      }\n    },\n    \"restaurant\": {\n      \"id\": \"rest_456\",\n      \"name\": \"Green Garden\",\n      \"address\": \"123 Veggie Lane, New York, NY 10001\",\n      \"contact_number\": \"+1-212-555-0199\"\n    },\n    \"ordered_dishes\": [\n      {\n        \"id\": \"dish_101\",\n        \"name\": \"Quinoa Salad\",\n        \"quantity\": 2,\n        \"dietary_notes\": [\"Gluten-Free\", \"Vegan\"]\n      },\n      {\n        \"id\": \"dish_102\",\n        \"name\": \"Spicy Tofu Stir-fry\",\n        \"quantity\": 1,\n        \"dietary_notes\": [\"Vegan\", \"High Protein\"]\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Food Delivery Order Status\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    RealTimeLocation:\\n      type: object\\n      description: 'Current geographic coordinates and the last update timestamp of the courier''s location'\\n      properties:\\n        latitude:\\n          type: number\\n          format: float\\n          description: 'Latitude of the courier''s current location'\\n          example: 40.712776\\n        longitude:\\n          type: number\\n          format: float\\n          description: 'Longitude of the courier''s current location'\\n          example: -74.005974\\n        last_updated:\\n          type: string\\n          format: date-time\\n          description: 'Timestamp of the last location update in ISO 8601 format'\\n          example: '2024-06-15T14:23:30Z'\\n    Courier:\\n      type: object\\n      description: 'Delivery courier details including real-time location'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier for the courier'\\n          example: 'cr_987'\\n        name:\\n          type: string\\n          description: 'Full name of the courier'\\n          example: 'Alice Johnson'\\n        real_time_location:\\n          $ref: '#/components/schemas/RealTimeLocation'\\n    Restaurant:\\n      type: object\\n      description: 'Profile of the restaurant fulfilling the order'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique restaurant identifier'\\n          example: 'rest_456'\\n        name:\\n          type: string\\n          description: 'Name of the restaurant'\\n          example: 'Green Garden'\\n        address:\\n          type: string\\n          description: 'Physical address of the restaurant'\\n          example: '123 Veggie Lane, New York, NY 10001'\\n        contact_number:\\n          type: string\\n          description: 'Contact phone number of the restaurant'\\n          example: '+1-212-555-0199'\\n    OrderedDish:\\n      type: object\\n      description: 'Information about a single dish ordered including dietary notes'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique dish identifier'\\n          example: 'dish_101'\\n        name:\\n          type: string\\n          description: 'Name of the ordered dish'\\n          example: 'Quinoa Salad'\\n        quantity:\\n          type: integer\\n          description: 'Number of portions ordered'\\n          example: 2\\n        dietary_notes:\\n          type: array\\n          description: 'List of special dietary tags for the dish'\\n          items:\\n            type: string\\n          example: ['Gluten-Free', 'Vegan']\\n    OrderStatusResponse:\\n      type: object\\n      description: 'Complete order status response with courier location, restaurant info, and ordered dishes'\\n      properties:\\n        order_id:\\n          type: string\\n          description: 'Unique order identifier'\\n          example: 'ord_12345'\\n        status:\\n          type: string\\n          description: 'Current status of the order'\\n          example: 'Out for delivery'\\n        courier:\\n          $ref: '#/components/schemas/Courier'\\n        restaurant:\\n          $ref: '#/components/schemas/Restaurant'\\n        ordered_dishes:\\n          type: array\\n          description: 'List of dishes included in the order'\\n          items:\\n            $ref: '#/components/schemas/OrderedDish'\"\n}"
