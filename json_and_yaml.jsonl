     type: object\\n      description: 'Root response structure for the university student dashboard'\\n      properties:\\n        student_id:\\n          type: string\\n          description: 'Unique identifier of the student'\\n          example: 'S12345678'\\n        name:\\n          type: string\\n          description: 'Full name of the student'\\n          example: 'Alice Johnson'\\n        academic_history:\\n          $ref: '#/components/schemas/AcademicHistory'\\n        current_enrolled_courses:\\n          type: array\\n          description: 'List of currently enrolled courses'\\n          items:\\n            $ref: '#/components/schemas/EnrolledCourse'\\n        financial_status:\\n          $ref: '#/components/schemas/FinancialStatus'\\n\"\n}"
