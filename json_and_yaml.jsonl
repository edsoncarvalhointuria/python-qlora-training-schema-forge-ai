"{\n  \"raw_json\": {\n    \"course_id\": \"CS101\",\n    \"course_title\": \"Introduction to Computer Science\",\n    \"professor\": {\n      \"name\": \"Dr. Emily Zhang\",\n      \"academic_background\": \"Ph.D. in Computer Science from MIT, specializing in artificial intelligence.\",\n      \"email\": \"emily.zhang@university.edu\"\n    },\n    \"weekly_modules\": [\n      {\n        \"week_number\": 1,\n        \"topic\": \"Foundations of Computing\",\n        \"summary\": \"Introduction to computing concepts and history.\",\n        \"reading_list\": [\n          {\n            \"title\": \"Computer Science: An Overview\",\n            \"authors\": [\"J. Glenn Brookshear\"],\n            \"edition\": \"12th\",\n            \"isbn\": \"978-0134875460\"\n          }\n        ]\n      },\n      {\n        \"week_number\": 2,\n        \"topic\": \"Programming Basics\",\n        \"summary\": \"Variables, data types, and control structures.\",\n        \"reading_list\": [\n          {\n            \"title\": \"Python Programming: An Introduction to Computer Science\",\n            \"authors\": [\"John Zelle\"],\n            \"edition\": \"3rd\",\n            \"isbn\": \"978-1590282755\"\n          },\n          {\n            \"title\": \"Automate the Boring Stuff with Python\",\n            \"authors\": [\"Al Sweigart\"],\n            \"edition\": \"2nd\",\n            \"isbn\": \"978-1593279929\"\n          }\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"University Course Syllabus API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Professor\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about the course professor including academic history and contact\\\",\\n        \\\"properties\\\": {\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n   