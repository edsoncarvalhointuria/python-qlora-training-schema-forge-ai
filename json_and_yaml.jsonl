"{\n  \"raw_json\": {\n    \"vital_signs\": {\n      \"heart_rate\": 78,\n      \"blood_pressure\": \"120/80\",\n      \"temperature_celsius\": 36.7,\n      \"respiratory_rate\": 16\n    },\n    \"current_medications\": [\n      {\n        \"name\": \"Amoxicillin\",\n        \"dosage\": \"500mg\",\n        \"frequency\": \"Every 8 hours\"\n      },\n      {\n        \"name\": \"Paracetamol\",\n        \"dosage\": \"650mg\",\n        \"frequency\": \"Every 6 hours\"\n      }\n    ],\n    \"attending_doctor\": {\n      \"doctor_id\": \"doc_1234\",\n      \"name\": \"Dr. Emily Stone\",\n      \"specialization\": \"Internal Medicine\",\n      \"contact_number\": \"+1-555-123-4567\"\n    }\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Hospital Patient Medical Record Summary\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"VitalSigns\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Patient's vital signs recorded during medical examination\\\",\\n        \\\"properties\\\": {\\n          \\\"heart_rate\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Heart rate in beats per minute\\\",\\n            \\\"example\\\": 78\\n          },\\n          \\\"blood_pressure\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Blood pressure measurement in mmHg\\\",\\n            \\\"example\\\": \\\"120/80\\\"\\n          },\\n          \\\"temperature_celsius\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Body temperature in degrees Celsius\\\",\\n            \\\"example\\\": 36.7\\n          },\\n          \\\"respiratory_rate\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of breaths per minute\\\",\\n            \\\"example\\\": 16\\n          }\\n        },\\n        \\\"required\\\": [\\\"heart_rate\\\", \\\"blood_pressure\\\", \\\"temperature_celsius\\\", \\\"respiratory_rate\\\"]\\n      },\\n      \\\"Medication\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details about a single medication currently prescribed\\\",\\n        \\\"properties\\\": {\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the medication\\\",\\n            \\\"example\\\": \\\"Amoxicillin\\\"\\n          },\\n          \\\"dosage\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Dosage amount of the medication\\\",\\n            \\\"example\\\": \\\"500mg\\\"\\n          },\\n          \\\"frequency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Frequency of medication intake\\\",\\n            \\\"example\\\": \\\"Every 8 hours\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"name\\\", \\\"dosage\\\", \\\"frequency\\\"]\\n      },\\n      \\\"DoctorProfile\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about the attending doctor's professional profile\\\",\\n        \\\"properties\\\": {\\n          \\\"doctor_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the doctor\\\",\\n            \\\"example\\\": \\\"doc_1234\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Full name of the doctor\\\",\\n            \\\"example\\\": \\\"Dr. Emily Stone\\\"\\n          },\\n          \\\"specialization\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Medical specialization of the doctor\\\",\\n            \\\"example\\\": \\\"Internal Medicine\\\"\\n          },\\n          \\\"contact_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Contact number of the doctor\\\",\\n            \\\"example\\\": \\\"+1-555-123-4567\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"doctor_id\\\", \\\"name\\\", \\\"specialization\\\", \\\"contact_number\\\"]\\n      },\\n      \\\"PatientMedicalRecord\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Summary of a hospital patient's medical record including vital signs, current medications, and attending doctor\\\",\\n        \\\"properties\\\": {\\n          \\\"vital_signs\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/VitalSigns\\\"\\n          },\\n          \\\"current_medications\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of medications currently prescribed to the patient\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Medication\\\"\\n            },\\n            \\\"example\\\": [\\n              {\\n                \\\"name\\\": \\\"Amoxicillin\\\",\\n                \\\"dosage\\\": \\\"500mg\\\",\\n                \\\"frequency\\\": \\\"Every 8 hours\\\"\\n              },\\n              {\\n                \\\"name\\\": \\\"Paracetamol\\\",\\n                \\\"dosage\\\": \\\"650mg\\\",\\n                \\\"frequency\\\": \\\"Every 6 hours\\\"\\n              }\\n            ]\\n          },\\n          \\\"attending_doctor\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DoctorProfile\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"vital_signs\\\", \\\"current_medications\\\", \\\"attending_doctor\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"truck\": {\n      \"id\": \"truck_12345\",\n      \"location\": {\n        \"latitude\": 40.712776,\n        \"longitude\": -74.005974\n      },\n      \"speed_kmph\": 65.5,\n      \"driver\": {\n        \"id\": \"drv_67890\",\n        \"name\": \"Alice Johnson\",\n        \"license_number\": \"D1234567\"\n      },\n      \"route_stops\": [\n        {\n          \"stop_id\": \"stop_001\",\n          \"name\": \"Warehouse A\",\n          \"address\": \"100 Industrial Rd, New York, NY\",\n          \"eta\": \"2024-06-10T09:30:00Z\"\n        },\n        {\n          \"stop_id\": \"stop_002\",\n          \"name\": \"Retail Store B\",\n          \"address\": \"250 Market St, New York, NY\",\n          \"eta\": \"2024-06-10T11:00:00Z\"\n        }\n      ]\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Logistics Fleet Tracking API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Location:\\n      type: object\\n      description: 'GPS coordinates of a location'\\n      properties:\\n        latitude:\\n          type: number\\n          format: double\\n          description: 'Latitude coordinate in decimal degrees'\\n          example: 40.712776\\n        longitude:\\n          type: number\\n          format: double\\n          description: 'Longitude coordinate in decimal degrees'\\n          example: -74.005974\\n    Driver:\\n      type: object\\n      description: 'Information about the truck driver'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique driver identifier'\\n          example: drv_67890\\n        name:\\n          type: string\\n          description: 'Full name of the driver'\\n          example: Alice Johnson\\n        license_number:\\n          type: string\\n          description: 'Driver license number'\\n          example: D1234567\\n    RouteStop:\\n      type: object\\n      description: 'A stop in the delivery route'\\n      properties:\\n        stop_id:\\n          type: string\\n          description: 'Unique identifier for the stop'\\n          example: stop_001\\n        name:\\n          type: string\\n          description: 'Name of the stop location'\\n          example: Warehouse A\\n        address:\\n          type: string\\n          description: 'Physical address of the stop'\\n          example: 100 Industrial Rd, New York, NY\\n        eta:\\n          type: string\\n          format: date-time\\n          description: 'Estimated time of arrival at the stop in UTC'\\n          example: 2024-06-10T09:30:00Z\\n    Truck:\\n      type: object\\n      description: 'Details of the delivery truck and its current status'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier for the truck'\\n          example: truck_12345\\n        location:\\n          $ref: '#/components/schemas/Location'\\n        speed_kmph:\\n          type: number\\n          format: float\\n          description: 'Current speed of the truck in kilometers per hour'\\n          example: 65.5\\n        driver:\\n          $ref: '#/components/schemas/Driver'\\n        route_stops:\\n          type: array\\n          description: 'List of stops on the truck\\'s delivery route'\\n          items:\\n            $ref: '#/components/schemas/RouteStop'\\n    FleetTrackingResponse:\\n      type: object\\n      description: 'Response containing current tracking information of a delivery truck'\\n      properties:\\n        truck:\\n          $ref: '#/components/schemas/Truck'\"\n}"
"{\n  \"raw_json\": {\n    \"current_temperature\": 22.5,\n    \"target_temperature\": 24,\n    \"device_health\": {\n      \"battery_level\": 85,\n      \"wifi_signal_strength\": -70\n    },\n    \"usage_history\": [\n      {\n        \"date\": \"2024-04-24\",\n        \"hours_active\": 6.5\n      },\n      {\n        \"date\": \"2024-04-23\",\n        \"hours_active\": 7.2\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Smart Thermostat Status Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"DeviceHealth\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações sobre o nível da bateria e a qualidade do sinal Wi-Fi do dispositivo\\\",\\n        \\\"properties\\\": {\\n          \\\"battery_level\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Nível atual da bateria em porcentagem\\\",\\n            \\\"example\\\": 85\\n          },\\n          \\\"wifi_signal_strength\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Força do sinal Wi-Fi em dBm\\\",\\n            \\\"example\\\": -70\\n          }\\n        }\\n      },\\n      \\\"UsageEntry\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Registro do uso histórico do termostato por dia\\\",\\n        \\\"properties\\\": {\\n          \\\"date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"Data do registro de uso\\\",\\n            \\\"example\\\": \\\"2024-04-24\\\"\\n          },\\n          \\\"hours_active\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Quantidade de horas que o termostato esteve ativo nesse dia\\\",\\n            \\\"example\\\": 6.5\\n          }\\n        }\\n      },\\n      \\\"ThermostatStatusResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta com o status atual e histórico do termostato inteligente\\\",\\n        \\\"properties\\\": {\\n          \\\"current_temperature\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Temperatura atual detectada pelo termostato em graus Celsius\\\",\\n            \\\"example\\\": 22.5\\n          },\\n          \\\"target_temperature\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Temperatura alvo configurada para o termostato em graus Celsius\\\",\\n            \\\"example\\\": 24\\n          },\\n          \\\"device_health\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DeviceHealth\\\",\\n            \\\"description\\\": \\\"Informações de saúde do dispositivo como bateria e conexão Wi-Fi\\\"\\n          },\\n          \\\"usage_history\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista histórica de uso diário do termostato\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/UsageEntry\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"student_id\": \"stu_202456\",\n    \"name\": \"John Doe\",\n    \"academic_history\": {\n      \"completed_courses\": [\n        {\n          \"course_id\": \"CS101\",\n          \"course_name\": \"Introduction to Computer Science\",\n          \"grade\": \"A\",\n          \"term\": \"Fall 2023\"\n        },\n        {\n          \"course_id\": \"MATH201\",\n          \"course_name\": \"Calculus II\",\n          \"grade\": \"B+\",\n          \"term\": \"Spring 2024\"\n        }\n      ],\n      \"gpa\": 3.75\n    },\n    \"current_courses\": [\n      {\n        \"course_id\": \"CS301\",\n        \"course_name\": \"Algorithms\",\n        \"instructor\": \"Dr. Smith\",\n        \"credits\": 3\n      },\n      {\n        \"course_id\": \"ENG102\",\n        \"course_name\": \"English Literature\",\n        \"instructor\": \"Prof. Johnson\",\n        \"credits\": 2\n      }\n    ],\n    \"financial_status\": {\n      \"tuition_due\": 1500.00,\n      \"due_date\": \"2024-07-15\",\n      \"payment_status\": \"Partial\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: University Student Dashboard\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CompletedCourse:\\n      type: object\\n      description: 'Representation of a completed course in academic history'\\n      properties:\\n        course_id:\\n          type: string\\n          description: 'Unique identifier of the course'\\n          example: 'CS101'\\n        course_name:\\n          type: string\\n          description: 'Name of the completed course'\\n          example: 'Introduction to Computer Science'\\n        grade:\\n          type: string\\n          description: 'Grade achieved in the course'\\n          example: 'A'\\n        term:\\n          type: string\\n          description: 'Academic term when the course was completed'\\n          example: 'Fall 2023'\\n    AcademicHistory:\\n      type: object\\n      description: 'Student academic completion records and GPA'\\n      properties:\\n        completed_courses:\\n          type: array\\n          description: 'List of courses the student has completed'\\n          items:\\n            $ref: '#/components/schemas/CompletedCourse'\\n        gpa:\\n          type: number\\n          format: float\\n          description: 'Cumulative grade point average'\\n          example: 3.75\\n    CurrentCourse:\\n      type: object\\n      description: 'Course information for currently enrolled courses'\\n      properties:\\n        course_id:\\n          type: string\\n          description: 'Unique identifier of the current course'\\n          example: 'CS301'\\n        course_name:\\n          type: string\\n          description: 'Name of the current course'\\n          example: 'Algorithms'\\n        instructor:\\n          type: string\\n          description: 'Name of the course instructor'\\n          example: 'Dr. Smith'\\n        credits:\\n          type: integer\\n          description: 'Number of credits for the course'\\n          example: 3\\n    FinancialStatus:\\n      type: object\\n      description: 'Current tuition payment status details'\\n      properties:\\n        tuition_due:\\n          type: number\\n          format: float\\n          description: 'Amount of tuition currently due'\\n          example: 1500.00\\n        due_date:\\n          type: string\\n          format: date\\n          description: 'Deadline for tuition payment'\\n          example: '2024-07-15'\\n        payment_status:\\n          type: string\\n          description: 'Current payment status of tuition'\\n          example: 'Partial'\\n    StudentDashboard:\\n      type: object\\n      description: 'Dashboard overview of a university student'\\n      properties:\\n        student_id:\\n          type: string\\n          description: 'Unique identifier for the student'\\n          example: 'stu_202456'\\n        name:\\n          type: string\\n          description: 'Full name of the student'\\n          example: 'John Doe'\\n        academic_history:\\n          $ref: '#/components/schemas/AcademicHistory'\\n        current_courses:\\n          type: array\\n          description: 'Array of courses the student is currently enrolled in'\\n          items:\\n            $ref: '#/components/schemas/CurrentCourse'\\n        financial_status:\\n          $ref: '#/components/schemas/FinancialStatus'\\npaths: {}\\n\"\n}"
