rio\\\",\\n        \\\"properties\\\": {\\n          \\\"posts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de postagens no feed\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Post\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"posts\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"$ref\\\": \\\"#/components/schemas/UserFeedResponse\\\"\\n}\"\n}"
