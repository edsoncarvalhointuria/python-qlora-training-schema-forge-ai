e vezes que o jogador foi eliminado'\\n          example: 5\\n        assists:\\n          type: integer\\n          description: 'Número de assistências feitas pelo jogador'\\n          example: 7\\n    MatchEvent:\\n      type: object\\n      description: 'Evento chave ocorrido durante a partida com seu timestamp'\\n      properties:\\n        timestamp:\\n          type: string\\n          description: 'Horário do evento no formato mm:ss'\\n          example: '00:05:12'\\n        event:\\n          type: string\\n          description: 'Descrição textual do evento ocorrido'\\n          example: 'First blood by Raul'\\n        team:\\n          type: string\\n          description: 'Equipe relacionada ao evento'\\n          example: 'team_alpha'\\n    MatchSummary:\\n      type: object\\n      description: 'Resumo completo de uma partida de e-sports competitiva'\\n      properties:\\n        team_scores:\\n          $ref: '#/components/schemas/TeamScores'\\n        players_stats:\\n          type: array\\n          description: 'Lista de estatísticas dos jogadores'\\n          items:\\n            $ref: '#/components/schemas/PlayerStats'\\n        match_timeline:\\n          type: array\\n          description: 'Linha do tempo com eventos importantes da partida'\\n          items:\\n            $ref: '#/components/schemas/MatchEvent'\\n\"\n}"
