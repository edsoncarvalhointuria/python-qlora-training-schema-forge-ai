"{\n  \"raw_json\": {\n    \"current_temperature\": 22.5,\n    \"target_temperature\": 24.0,\n    \"device_health\": {\n      \"battery_level\": 85,\n      \"wifi_signal_strength\": -67\n    },\n    \"usage_history\": [\n      {\n        \"date\": \"2024-04-20\",\n        \"energy_consumed_kwh\": 3.2,\n        \"hours_active\": 8\n      },\n      {\n        \"date\": \"2024-04-19\",\n        \"energy_consumed_kwh\": 2.9,\n        \"hours_active\": 7.5\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Smart Thermostat Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"DeviceHealth\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Status of the thermostat's battery and WiFi connectivity\\\",\\n        \\\"properties\\\": {\\n          \\\"battery_level\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Current battery level percentage\\\",\\n            \\\"example\\\": 85\\n          },\\n          \\\"wifi_signal_strength\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"WiFi signal strength in dBm\\\",\\n            \\\"example\\\": -67\\n          }\\n        },\\n        \\\"required\\\": [\\\"battery_level\\\", \\\"wifi_signal_strength\\\"]\\n      },\\n      \\\"UsageEntry\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Daily usage and energy consumption record\\\",\\n        \\\"properties\\\": {\\n          \\\"date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"Date of the usage record\\\",\\n            \\\"example\\\": \\\"2024-04-20\\\"\\n          },\\n          \\\"energy_consumed_kwh\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\