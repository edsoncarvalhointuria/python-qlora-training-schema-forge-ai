'Trusted Appraisals Inc.'\\n    MortgageLoanApplicationResponse:\\n      type: object\\n      description: 'Response object for mortgage loan application details'\\n      properties:\\n        applicant_credit_score:\\n          type: integer\\n          description: 'Credit score of the loan applicant'\\n          example: 720\\n        property_valuation:\\n          $ref: '#/components/schemas/PropertyValuation'\\n        required_compliance_documents:\\n          type: array\\n          description: 'List of required documents for compliance'\\n          items:\\n            $ref: '#/components/schemas/Document'\\n\"\n}"
