e\\\": 5.2 },\\n          \\\"humidity_percentage\\\": { \\\"type\\\": \\\"integer\\\", \\\"description\\\": \\\"Humidity percentage inside the container\\\", \\\"example\\\": 75 }\\n        },\\n        \\\"required\\\": [\\\"timestamp\\\", \\\"temperature_celsius\\\", \\\"humidity_percentage\\\"]\\n      },\\n      \\\"ContainerTrackingResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response containing detailed tracking information of a global shipping container\\\",\\n        \\\"properties\\\": {\\n          \\\"container_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique identifier for the shipping container\\\", \\\"example\\\": \\\"CONT1234567\\\" },\\n          \\\"current_port\\\": { \\\"$ref\\\": \\\"#/components/schemas/PortLocation\\\" },\\n          \\\"customs_clearance\\\": { \\\"$ref\\\": \\\"#/components/schemas/CustomsClearanceStatus\\\" },\\n          \\\"environmental_readings\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of environmental sensor readings inside the container\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/EnvironmentalReading\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"container_id\\\", \\\"current_port\\\", \\\"customs_clearance\\\", \\\"environmental_readings\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"queryParameters\\\": {},\\n  \\\"parameters\\\": {},\\n  \\\"responses\\\": {},\\n  \\\"security\\\": [],\\n  \\\"tags\\\": [],\\n  \\\"externalDocs\\\": {},\\n  \\\"rootSchema\\\": { \\\"$ref\\\": \\\"#/components/schemas/ContainerTrackingResponse\\\" }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"order_id\": \"ORD123456\",\n    \"status\": \"Out for delivery\",\n    \"courier\": {\n      \"courier_id\": \"CR56789\",\n      \"name\": \"Alice Johnson\",\n      \"location\": {\n        \"latitude\": 40.712776,\n        \"longitude\": -74.005974,\n        \"timestamp\": \"2024-06-01T15:23:45Z\"\n      }\n    },\n    \"restaurant\": {\n      \"restaurant_id\": \"RST98765\",\n      \"name\": \"Green Garden Vegan Bistro\",\n      \"address\": \"123 Elm Street, New York, NY\",\n      \"contact_number\": \"+1234567890\",\n      \"rating\": 4.8\n    },\n    \"ordered_dishes\": [\n      {\n        \"dish_id\": \"DISH1001\",\n        \"name\": \"Quinoa Salad\",\n        \"quantity\": 2,\n        \"special_dietary_notes\": \"Gluten-free, vegan\"\n      },\n      {\n        \"dish_id\": \"DISH1002\",\n        \"name\": \"Tofu Stir Fry\",\n        \"quantity\": 1,\n        \"special_dietary_notes\": \"Contains soy, vegan\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Food Delivery Order Status\\n  version: '1.0.0'\\ncomponents:\\n  schemas:\\n    Location:\\n      type: object\\n      description: 'Real-time geolocation data of the courier'\\n      properties:\\n        latitude:\\n          type: number\\n          description: 'Latitude coordinate of the courier location'\\n          example: 40.712776\\n        longitude:\\n          type: number\\n          description: 'Longitude coordinate of the courier location'\\n          example: -74.005974\\n        timestamp:\\n          type: string\\n          format: date-time\\n          description: 'Timestamp of the location update in ISO 8601 format'\\n          example: '2024-06-01T15:23:45Z'\\n    Courier:\\n      type: object\\n      description: 'Information about the delivery courier'\\n      properties:\\n        courier_id:\\n          type: string\\n          description: 'Unique identifier for the courier'\\n          example: 'CR56789'\\n        na