"{\n  \"raw_json\": {\n    \"artist_profile\": {\n      \"artist_name\": \"Ana Souza\",\n      \"biography\": \"Cantora e compositora brasileira, conhecida por suas músicas de MPB e samba.\",\n      \"debut_year\": 2010,\n      \"top_streamed_tracks\": [\n        {\n          \"track_title\": \"Noite de Verão\",\n          \"streams\": 12500000,\n          \"duration_seconds\": 210\n        },\n        {\n          \"track_title\": \"Luar do Sertão\",\n          \"streams\": 9800000,\n          \"duration_seconds\": 195\n        }\n      ],\n      \"upcoming_tour\": {\n        \"tour_name\": \"Turnê Brasil 2024\",\n        \"dates\": [\n          {\n            \"city\": \"Rio de Janeiro\",\n            \"venue\": \"Maracanãzinho\",\n            \"date\": \"2024-08-15\"\n          },\n          {\n            \"city\": \"São Paulo\",\n            \"venue\": \"Allianz Parque\",\n            \"date\": \"2024-08-22\"\n          }\n        ]\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Perfil do Artista de Plataforma de Música Streaming\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Track:\\n      type: object\\n      description: 'Informações sobre uma faixa musical de sucesso'\\n      properties:\\n        track_title:\\n          type: string\\n          description: 'Título da faixa'\\n          example: 'Noite de Verão'\\n        streams:\\n          type: integer\\n          description: 'Número total de reproduções da faixa'\\n          example: 12500000\\n        duration_seconds:\\n          type: integer\\n          description: 'Duração da faixa em segundos'\\n          example: 210\\n    ConcertDate:\\n      type: object\\n      description: 'Informações sobre uma apresentação em uma cidade durante a turnê'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Cidade onde o show será realizado'\\n          example: 'Rio de Janeiro'\\n        venue:\\n          type: string\\n          description: 'Local do show'\\n          example: 'Maracanãzinho'\\n        date:\\n          type: string\\n          format: date\\n          description: 'Data do show no formato ano-mês-dia'\\n          example: '2024-08-15'\\n    UpcomingTour:\\n      type: object\\n      description: 'Detalhes da turnê com datas de shows agendados'\\n      properties:\\n        tour_name:\\n          type: string\\n          description: 'Nome da turnê'\\n          example: 'Turnê Brasil 2024'\\n        dates:\\n          type: array\\n          description: 'Lista de datas e locais dos shows'\\n          items:\\n            $ref: '#/components/schemas/ConcertDate'\\n    ArtistProfile:\\n      type: object\\n      description: 'Perfil completo do artista contendo dados biográficos, faixas populares e turnê'\\n      properties:\\n        artist_name:\\n          type: string\\n          description: 'Nome do artista'\\n          example: 'Ana Souza'\\n        biography:\\n          type: string\\n          description: 'Biografia resumida do artista'\\n          example: 'Cantora e compositora brasileira, conhecida por suas músicas de MPB e samba.'\\n        debut_year:\\n          type: integer\\n          description: 'Ano de início da carreira do artista'\\n          example: 2010\\n        top_streamed_tracks:\\n          type: array\\n          description: 'Lista das faixas mais reproduzidas'\\n          items:\\n            $ref: '#/components/schemas/Track'\\n        upcoming_tour:\\n          $ref: '#/components/schemas/UpcomingTour'\\n  schemas:\\n    Root:\\n      type: object\\n      description: 'Objeto raiz contendo o perfil do artista'\\n      properties:\\n        artist_profile:\\n          $ref: '#/components/schemas/ArtistProfile'\"\n}"
