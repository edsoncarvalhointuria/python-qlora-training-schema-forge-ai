e: array\\n          description: 'Detailed cost breakdown by resource types within the service'\\n          items:\\n            $ref: '#/components/schemas/CostBreakdownItem'\\n    ProjectedForecast:\\n      type: object\\n      description: 'Forecast of next month costs and growth rate'\\n      properties:\\n        next_month_estimate:\\n          type: number\\n          format: float\\n          description: 'Estimated cloud spend for the next month in USD'\\n          example: 13000.00\\n        growth_rate_percent:\\n          type: number\\n          format: float\\n          description: 'Projected growth rate percentage compared to current month'\\n          example: 5.3\\n    BillingDashboardResponse:\\n      type: object\\n      description: 'Response containing total spend, detailed service costs, and forecast data'\\n      properties:\\n        total_monthly_spend:\\n          type: number\\n          format: float\\n          description: 'Total cloud spend for the current month in USD'\\n          example: 12345.67\\n        costs_by_service:\\n          type: array\\n          description: 'Array of costs broken down by cloud services'\\n          items:\\n            $ref: '#/components/schemas/ServiceCost'\\n        projected_forecast:\\n          $ref: '#/components/schemas/ProjectedForecast'\"\n}"
