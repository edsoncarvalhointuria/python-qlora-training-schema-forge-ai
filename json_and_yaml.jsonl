"{\n  \"raw_json\": {\n    \"artist_profile\": {\n      \"artist_id\": \"art_12345\",\n      \"name\": \"Luz da Noite\",\n      \"biography\": \"Cantora e compositora brasileira conhecida por sua voz suave e letras poéticas.\",\n      \"top_streamed_tracks\": [\n        {\n          \"track_id\": \"trk_001\",\n          \"title\": \"Brisa de Verão\",\n          \"streams\": 2543210,\n          \"duration_seconds\": 215\n        },\n        {\n          \"track_id\": \"trk_002\",\n          \"title\": \"Coração Aberto\",\n          \"streams\": 1987654,\n          \"duration_seconds\": 189\n        }\n      ],\n      \"upcoming_concert_tour\": {\n        \"tour_name\": \"Tour Luz e Som\",\n        \"dates\": [\n          {\n            \"city\": \"Rio de Janeiro\",\n            \"venue\": \"Circo Voador\",\n            \"date\": \"2024-09-15\"\n          },\n          {\n            \"city\": \"São Paulo\",\n            \"venue\": \"Audio Club\",\n            \"date\": \"2024-09-22\"\n          }\n        ]\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Artist Profile API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Track:\\n      type: object\\n      description: 'Detalhes de uma faixa musical'\\n      properties:\\n        track_id:\\n          type: string\\n          description: 'Identificador único da faixa'\\n          example: 'trk_001'\\n        title:\\n          type: string\\n          description: 'Título da música'\\n          example: 'Brisa de Verão'\\n        streams:\\n          type: integer\\n          description: 'Número total de reproduções da faixa'\\n          example: 2543210\\n        duration_seconds:\\n          type: integer\\n          description: 'Duração da faixa em segundos'\\n          example: 215\\n    ConcertDate:\\n      type: object\\n      description: 'Informações sobre uma data específica do show'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Cidade onde o show será realizado'\\n          example: 'Rio de Janeiro'\\n        venue:\\n          type: string\\n          description: 'Local do show'\\n          example: 'Circo Voador'\\n        date:\\n          type: string\\n          format: date\\n          description: 'Data do show no formato AAAA-MM-DD'\\n          example: '2024-09-15'\\n    ConcertTour:\\n      type: object\\n      description: 'Detalhes da turnê de concertos'\\n      properties:\\n        tour_name:\\n          type: string\\n          description: 'Nome oficial da turnê'\\n          example: 'Tour Luz e Som'\\n        dates:\\n          type: array\\n          description: 'Lista das datas e locais dos shows'\\n          items:\\n            $ref: '#/components/schemas/ConcertDate'\\n    ArtistProfile:\\n      type: object\\n      description: 'Perfil completo do artista na plataforma'\\n      properties:\\n        artist_id:\\n          type: string\\n          description: 'Identificador único do artista'\\n          example: 'art_12345'\\n        name:\\n          type: string\\n          description: 'Nome do artista'\\n          example: 'Luz da Noite'\\n        biography:\\n          type: string\\n          description: 'Biografia resumida do artista'\\n          example: 'Cantora e compositora brasileira conhecida por sua voz suave e letras poéticas.'\\n        top_streamed_tracks:\\n          type: array\\n          description: 'Lista das faixas mais reproduzidas'\\n          items:\\n            $ref: '#/components/schemas/Track'\\n        upcoming_concert_tour:\\n          $ref: '#/components/schemas/ConcertTour'\\n  schemas:\\n    ArtistProfileResponse:\\n      type: object\\n      description: 'Resposta contendo o perfil completo do artista'\\n      properties:\\n        artist_profile:\\n          $ref: '#/components/schemas/ArtistProfile'\"\n}"
