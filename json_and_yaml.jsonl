          }\\n        }\\n      },\\n      \\\"Comment\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Comentário em um post\\\",\\n        \\\"properties\\\": {\\n          \\\"comment_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do comentário\\\",\\n            \\\"example\\\": \\\"comm_101\\\"\\n          },\\n          \\\"commenter\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n          },\\n          \\\"comment_text\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Texto do comentário\\\",\\n            \\\"example\\\": \\\"Looks amazing, wish I was there!\\\"\\n          },\\n          \\\"commented_at\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora do comentário\\\",\\n            \\\"example\\\": \\\"2024-05-20T16:00:00Z\\\"\\n          }\\n        }\\n      },\\n      \\\"Post\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Publicação no feed do usuário\\\",\\n        \\\"properties\\\": {\\n          \\\"post_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único da publicação\\\",\\n            \\\"example\\\": \\\"post_001\\\"\\n          },\\n          \\\"author\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n          },\\n          \\\"content\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Conteúdo textual da publicação\\\",\\n            \\\"example\\\": \\\"Enjoying the sunny weather today!\\\"\\n          },\\n          \\\"created_at\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora da publicação\\\",\\n            \\\"example\\\": \\\"2024-05-20T15:30:00Z\\\"\\n          },\\n          \\\"comments\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de comentários\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Comment\\\"\\n            }\\n          },\\n          \\\"liked_by\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Usuários que curtiram a publicação\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n            }\\n          }\\n        }\\n      },\\n      \\\"UserFeedResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta do feed do usuário com múltiplas publicações\\\",\\n        \\\"properties\\\": {\\n          \\\"posts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array de publicações do feed\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Post\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": { }\\n}\"\n}"
