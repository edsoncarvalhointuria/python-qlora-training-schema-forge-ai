"{\n  \"raw_json\": {\n    \"truck_id\": \"truck_1234\",\n    \"location\": {\n      \"latitude\": 40.712776,\n      \"longitude\": -74.005974\n    },\n    \"speed_kmph\": 65.5,\n    \"driver\": {\n      \"driver_id\": \"driver567\",\n      \"name\": \"John Doe\",\n      \"contact_number\": \"+1234567890\"\n    },\n    \"route_stops\": [\n      {\n        \"stop_id\": \"stop001\",\n        \"address\": \"123 Main St, New York, NY\",\n        \"scheduled_arrival\": \"2024-06-27T09:00:00Z\",\n        \"actual_arrival\": \"2024-06-27T08:55:30Z\"\n      },\n      {\n        \"stop_id\": \"stop002\",\n        \"address\": \"456 Elm St, Newark, NJ\",\n        \"scheduled_arrival\": \"2024-06-27T10:30:00Z\",\n        \"actual_arrival\": null\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Logistics Fleet Tracking\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Coordinates:\\n      type: object\\n      description: 'Geographical coordinates representing a location'\\n      properties:\\n        latitude:\\n          type: number\\n          description: 'Latitude of the location in decimal degrees'\\n          example: 40.712776\\n        longitude:\\n          type: number\\n          description: 'Longitude of the location in decimal degrees'\\n          example: -74.005974\\n    DriverInfo:\\n      type: object\\n      description: 'Information about the delivery truck driver'\\n      properties:\\n        driver_id:\\n          type: string\\n          description: 'Unique identifier for the driver'\\n          example: 'driver567'\\n        name:\\n          type: string\\n          description: 'Full name of the driver'\\n          example: 'John Doe'\\n        contact_number:\\n          type: string\\n          description: 'Contact phone number of the driver'\\n          example: '+1234567890'\\n    RouteStop:\\n      type: object\\n      description: 'Details of a stop in the delivery route'\\n      properties:\\n        stop_id: