erSnippet\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações básicas do usuário para identificação\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do usuário\\\",\\n            \\\"example\\\": \\\"user_123\\\"\\n          },\\n          \\\"username\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome de usuário na plataforma\\\",\\n            \\\"example\\\": \\\"joaosilva\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"user_id\\\", \\\"username\\\"]\\n      },\\n      \\\"Comment\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Comentário feito em um post\\\",\\n        \\\"properties\\\": {\\n          \\\"comment_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do comentário\\\",\\n            \\\"example\\\": \\\"comm_1001\\\"\\n          },\\n          \\\"author\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n          },\\n          \\\"content\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Texto do comentário\\\",\\n            \\\"example\\\": \\\"Que foto incrível, João!\\\"\\n          },\\n          \\\"created_at\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora de criação do comentário no formato ISO 8601\\\",\\n            \\\"example\\\": \\\"2024-06-10T15:00:00Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"comment_id\\\", \\\"author\\\", \\\"content\\\", \\\"created_at\\\"]\\n      },\\n      \\\"Post\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Publicação feita por um usuário na plataforma\\\",\\n        \\\"properties\\\": {\\n          \\\"post_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do post\\\",\\n            \\\"example\\\": \\\"post_001\\\"\\n          },\\n          \\\"author\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n          },\\n          \\\"content\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Conteúdo textual do post\\\",\\n            \\\"example\\\": \\\"Hoje o dia está lindo! Aproveitando para caminhar no parque.\\\"\\n          },\\n          \\\"created_at\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora de criação do post no formato ISO 8601\\\",\\n            \\\"example\\\": \\\"2024-06-10T14:23:00Z\\\"\\n          },\\n          \\\"comments\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de comentários associados ao post\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Comment\\\"\\n            }\\n          },\\n          \\\"liked_by\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Usuários que curtiram o post\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"post_id\\\", \\\"author\\\", \\\"content\\\", \\\"created_at\\\", \\\"comments\\\", \\\"liked_by\\\"]\\n      },\\n      \\\"UserFeedResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta contendo um feed de posts do usuário\\\",\\n        \\\"properties\\\": {\\n          \\\"posts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array de publicações no feed\\\",\\n            \\\"items\\\": {\\