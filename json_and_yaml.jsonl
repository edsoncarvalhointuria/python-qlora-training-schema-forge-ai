"{\n  \"raw_json\": {\n    \"course_code\": \"CSCI-550\",\n    \"course_title\": \"Advanced Algorithms\",\n    \"professor\": {\n      \"name\": \"Dr. Emily Carter\",\n      \"academic_background\": {\n        \"degrees\": [\n          {\n            \"degree\": \"PhD in Computer Science\",\n            \"institution\": \"MIT\",\n            \"year\": 2012\n          },\n          {\n            \"degree\": \"MSc in Applied Mathematics\",\n            \"institution\": \"Stanford University\",\n            \"year\": 2007\n          }\n        ],\n        \"research_interests\": [\n          \"Algorithm design\",\n          \"Computational complexity\",\n          \"Parallel computing\"\n        ]\n      }\n    },\n    \"weekly_modules\": [\n      {\n        \"week\": 1,\n        \"topic\": \"Introduction to Algorithm Analysis\",\n        \"objectives\": [\n          \"Understand time and space complexity\",\n          \"Learn asymptotic notation\"\n        ],\n        \"reading_list\": [\n          {\n            \"title\": \"Introduction to Algorithms\",\n            \"author\": \"Cormen, Leiserson, Rivest, Stein\",\n            \"edition\": \"3rd\",\n            \"publisher\": \"MIT Press\",\n            \"year\": 2009\n          }\n        ]\n      },\n      {\n        \"week\": 2,\n        \"topic\": \"Divide and Conquer Techniques\",\n        \"objectives\": [\n          \"Master recursion and recurrence relations\",\n          \"Analyze examples like Merge Sort and Quick Sort\"\n        ],\n        \"reading_list\": [\n          {\n            \"title\": \"Introduction to Algorithms\",\n            \"author\": \"Cormen, Leiserson, Rivest, Stein\",\n            \"edition\": \"3rd\",\n            \"publisher\": \"MIT Press\",\n            \"year\": 2009\n          },\n          {\n            \"title\": \"Algorithm Design\",\n            \"author\": \"Kleinberg and Tardos\",\n            \"edition\": \"1st\",\n            \"publisher\": \"Pearson\",\n            