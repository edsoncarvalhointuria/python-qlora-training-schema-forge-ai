perties:\\n        procedure_id:\\n          type: string\\n          description: 'Unique identifier of the procedure'\\n          example: 'PROC12345'\\n        procedure_name:\\n          type: string\\n          description: 'Name of the dental procedure performed'\\n          example: 'Dental Filling'\\n        date:\\n          type: string\\n          format: date\\n          description: 'Date when the procedure was performed'\\n          example: '2023-10-15'\\n        tooth_affected:\\n          type: string\\n          description: 'Identifier of the tooth that was treated'\\n          example: 'M1'\\n        notes:\\n          type: string\\n          description: 'Additional notes or comments about the procedure'\\n          example: 'Composite resin filling, no complications'\\n    CleaningMetadata:\\n      type: object\\n      description: 'Additional information for upcoming cleaning appointments'\\n      properties:\\n        duration_minutes:\\n          type: integer\\n          description: 'Estimated duration of the cleaning session in minutes'\\n          example: 45\\n        dentist:\\n          type: string\\n          description: 'Name of the dentist responsible for the cleaning'\\n          example: 'Dr. Jane Smith'\\n        special_instructions:\\n          type: string\\n          description: 'Any special instructions or notes for the cleaning'\\n          example: 'Patient sensitive to fluoride'\\n    UpcomingCleaning:\\n      type: object\\n      description: 'Information about the patient\\\\'s upcoming dental cleaning'\\n      properties:\\n        next_cleaning_date:\\n          type: string\\n          format: date\\n          description: 'Scheduled date of the next cleaning'\\n          example: '2024-07-15'\\n        cleaning_type:\\n          type: string\\n          description: 'Type of cleaning procedure scheduled'\\n          example: 'Regular Prophylaxis'\\n        metadata:\\n          $ref: '#/components/schemas/CleaningMetadata'\\n    PatientHistory:\\n      type: object\\n      description: 'Comprehensive patient dental history including tooth chart, past procedures, and upcoming cleanings'\\n      properties:\\n        tooth_chart:\\n          $ref: '#/components/schemas/ToothChart'\\n        past_procedures:\\n          type: array\\n          description: 'List of previous dental procedures undergone by the patient'\\n          items:\\n            $ref: '#/components/schemas/Procedure'\\n        upcoming_cleanings:\\n          $ref: '#/components/schemas/UpcomingCleaning'\\n\"\n}"
