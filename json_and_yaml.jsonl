": \\\"post_001\\\"\\n          },\\n          \\\"author\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n          },\\n          \\\"content\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Text content of the post\\\",\\n            \\\"example\\\": \\\"Loving the new features!\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Timestamp of when the post was created\\\",\\n            \\\"example\\\": \\\"2024-06-10T08:30:00Z\\\"\\n          },\\n          \\\"comments\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of comments on the post\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Comment\\\"\\n            }\\n          },\\n          \\\"liked_by\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of users who liked the post\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"post_id\\\", \\\"author\\\", \\\"content\\\", \\\"timestamp\\\", \\\"comments\\\", \\\"liked_by\\\"]\\n      },\\n      \\\"UserFeedResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response containing an array of posts in the user feed\\\",\\n        \\\"properties\\\": {\\n          \\\"posts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of posts\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Post\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"posts\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  }\\n}\"\n}"
