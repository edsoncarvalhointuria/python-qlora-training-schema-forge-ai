"{\n  \"raw_json\": {\n    \"patient\": {\n      \"id\": \"pat_9876\",\n      \"name\": \"John Doe\",\n      \"date_of_birth\": \"1980-05-14\",\n      \"gender\": \"Male\"\n    },\n    \"test_results\": [\n      {\n        \"biomarker\": \"Hemoglobin\",\n        \"value\": 14.2,\n        \"units\": \"g/dL\",\n        \"normal_range\": {\n          \"min\": 13.5,\n          \"max\": 17.5\n        }\n      },\n      {\n        \"biomarker\": \"White Blood Cell Count\",\n        \"value\": 6.8,\n        \"units\": \"10^9/L\",\n        \"normal_range\": {\n          \"min\": 4.0,\n          \"max\": 11.0\n        }\n      },\n      {\n        \"biomarker\": \"Platelets\",\n        \"value\": 250,\n        \"units\": \"10^9/L\",\n        \"normal_range\": {\n          \"min\": 150,\n          \"max\": 400\n        }\n      }\n    ],\n    \"signed_by\": {\n      \"pathologist_id\": \"path_1234\",\n      \"name\": \"Dr. Alice Smith\",\n      \"signature_image_url\": \"https://hospital.example.com/signatures/path_1234.png\",\n      \"signed_at\": \"2024-04-15T14:30:00Z\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Hospital Laboratory Test Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PatientDemographics:\\n      type: object\\n      description: 'Patient demographic details'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique patient identifier'\\n          example: 'pat_9876'\\n        name:\\n          type: string\\n          description: 'Full patient name'\\n          example: 'John Doe'\\n        date_of_birth:\\n          type: string\\n          format: date\\n          description: 'Patient date of birth'\\n          example: '1980-05-14'\\n        gender:\\n          type: string\\n          description: 'Patient gender'\\n          example: 'Male'\\n    NormalRange:\\n      type: object\\n      description: 'Normal range for a biomarker'\\n      properties:\\n        min:\\n          type: number\\n          description: 'Minimum normal value'\\n          example: 13.5\\n        max:\\n          type: number\\n          description: 'Maximum normal value'\\n          example: 17.5\\n    BiomarkerResult:\\n      type: object\\n      description: 'Single biomarker test result'\\n      properties:\\n        biomarker:\\n          type: string\\n          description: 'Name of the biomarker'\\n          example: 'Hemoglobin'\\n        value:\\n          type: number\\n          description: 'Measured value of the biomarker'\\n          example: 14.2\\n        units:\\n          type: string\\n          description: 'Units used for the biomarker value'\\n          example: 'g/dL'\\n        normal_range:\\n          $ref: '#/components/schemas/NormalRange'\\n    PathologistSignature:\\n      type: object\\n      description: 'Digital signature details of the reviewing pathologist'\\n      properties:\\n        pathologist_id:\\n          type: string\\n          description: 'Unique identifier of the pathologist'\\n          example: 'path_1234'\\n        name:\\n          type: string\\n          description: 'Full name of the pathologist'\\n          example: 'Dr. Alice Smith'\\n        signature_image_url:\\n          type: string\\n          format: uri\\n          description: 'URL to the pathologist’s digital signature image'\\n          example: 'https://hospital.example.com/signatures/path_1234.png'\\n        signed_at:\\n          type: string\\n          format: date-time\\n          description: 'Timestamp when the signature was applied'\\n          example: '2024-04-15T14:30:00Z'\\n    LabTestResultResponse:\\n      type: object\\n      description: 'Complete laboratory test result including patient info, biomarkers, and digital signature'\\n      properties:\\n        patient:\\n          $ref: '#/components/schemas/PatientDemographics'\\n        test_results:\\n          type: array\\n          description: 'Array of blood biomarker results'\\n          items:\\n            $ref: '#/components/schemas/BiomarkerResult'\\n        signed_by:\\n          $ref: '#/components/schemas/PathologistSignature'\"\n}"
