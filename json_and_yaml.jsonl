"{\n  \"raw_json\": {\n    \"student_id\": \"stu_12345\",\n    \"courses\": [\n      {\n        \"course_id\": \"course_101\",\n        \"completion_percentage\": 85.5,\n        \"quizzes\": [\n          {\n            \"quiz_id\": \"quiz_1\",\n            \"score\": 92\n          },\n          {\n            \"quiz_id\": \"quiz_2\",\n            \"score\": 88\n          }\n        ],\n        \"certificates\": [\n          {\n            \"certificate_id\": \"cert_101\",\n            \"title\": \"Introduction to Programming\",\n            \"date_unlocked\": \"2024-05-20\"\n          }\n        ]\n      },\n      {\n        \"course_id\": \"course_102\",\n        \"completion_percentage\": 45.0,\n        \"quizzes\": [\n          {\n            \"quiz_id\": \"quiz_1\",\n            \"score\": 70\n          },\n          {\n            \"quiz_id\": \"quiz_2\",\n            \"score\": 75\n          }\n        ],\n        \"certificates\": []\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Student Progress Report API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    QuizScore:\\n      type: object\\n      description: 'Individual quiz score details'\\n      properties:\\n        quiz_id:\\n          type: string\\n          description: 'Unique identifier for the quiz'\\n          example: 'quiz_1'\\n        score:\\n          type: integer\\n          description: 'Score obtained in the quiz'\\n          example: 92\\n    Certificate:\\n      type: object\\n      description: 'Details of an unlocked digital certificate'\\n      properties:\\n        certificate_id:\\n          type: string\\n          description: 'Unique identifier for the certificate'\\n          example: 'cert_101'\\n        title:\\n          type: string\\n          description: 'Title of the certificate'\\n          example: 'Introduction to Programming'\\n        date_unlocked:\\n          type: string\\n          format: date\\n          description: 'Date when the certificate was unlocked'\\n          example: '2024-05-20'\\n    CourseProgress:\\n      type: object\\n      description: 'Progress details for a specific course'\\n      properties:\\n        course_id:\\n          type: string\\n          description: 'Unique identifier of the course'\\n          example: 'course_101'\\n        completion_percentage:\\n          type: number\\n          format: float\\n          description: 'Percentage of course completion'\\n          example: 85.5\\n        quizzes:\\n          type: array\\n          description: 'List of quiz scores for the course'\\n          items:\\n            $ref: '#/components/schemas/QuizScore'\\n        certificates:\\n          type: array\\n          description: 'List of unlocked digital certificates for the course'\\n          items:\\n            $ref: '#/components/schemas/Certificate'\\n    StudentProgressReport:\\n      type: object\\n      description: 'Overall student progress report encompassing multiple courses'\\n      properties:\\n        student_id:\\n          type: string\\n          description: 'Unique identifier for the student'\\n          example: 'stu_12345'\\n        courses:\\n          type: array\\n          description: 'Collection of course progress details'\\n          items:\\n            $ref: '#/components/schemas/CourseProgress'\\n\"\n}"
