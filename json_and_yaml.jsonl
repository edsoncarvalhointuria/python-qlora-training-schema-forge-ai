arity organization\\\",\\n            \\\"example\\\": \\\"Helping Hands Foundation\\\"\\n          },\\n          \\\"receipt_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Receipt identifier for the donation\\\",\\n            \\\"example\\\": \\\"RCPT987654321\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"organization\\\", \\\"receipt_id\\\"]\\n      },\\n      \\\"DeductionDetails\\\": {\\n        \\\"oneOf\\\": [\\n          { \\\"$ref\\\": \\\"#/components/schemas/DeductionDetailsMortgage\\\" },\\n          { \\\"$ref\\\": \\\"#/components/schemas/DeductionDetailsCharity\\\" }\\n        ],\\n        \\\"description\\\": \\\"Specific details about the deduction depending on type\\\"\\n      },\\n      \\\"Deduction\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"A single deduction entry declared by the citizen\\\",\\n        \\\"properties\\\": {\\n          \\\"type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of deduction\\\",\\n            \\\"example\\\": \\\"Mortgage Interest\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Monetary amount of the deduction\\\",\\n            \\\"example\\\": 7500\\n          },\\n          \\\"details\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DeductionDetails\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"type\\\", \\\"amount\\\", \\\"details\\\"]\\n      },\\n      \\\"TaxResult\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Final tax calculation result\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tax outcome status, indicating refund or debt\\\",\\n            \\\"example\\\": \