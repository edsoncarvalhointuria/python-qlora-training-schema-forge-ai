ade final da moeda após aplicação dos multiplicadores\\\",\\n            \\\"example\\\": 1500\\n          }\\n        },\\n        \\\"required\\\": [\\\"currency_type\\\", \\\"base_amount\\\", \\\"promotional_multiplier\\\", \\\"final_amount\\\"]\\n      },\\n      \\\"UnlockedItem\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes de um item cosmético desbloqueado\\\",\\n        \\\"properties\\\": {\\n          \\\"item_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do item desbloqueado\\\",\\n            \\\"example\\\": \\\"cos_001\\\"\\n          },\\n          \\\"item_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome do item cosmético\\\",\\n            \\\"example\\\": \\\"Golden Helmet\\\"\\n          },\\n          \\\"rarity\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Classificação de raridade do item\\\",\\n            \\\"example\\\": \\\"legendary\\\"\\n          },\\n          \\\"acquisition_method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Método pelo qual o item foi adquirido\\\",\\n            \\\"example\\\": \\\"purchase\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"item_id\\\", \\\"item_name\\\", \\\"rarity\\\", \\\"acquisition_method\\\"]\\n      },\\n      \\\"MicrotransactionReceipt\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Recibo detalhado da compra microtransacional no jogo móvel\\\",\\n        \\\"properties\\\": {\\n          \\\"receipt_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do recibo\\\",\\n            \\\"example\\\": \\\"rcpt_202406\\\"\\n          },\\n          \\\"player_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do jogador\\\",\\n            \\\"example\\\": \\\"player_12345\\\"\\n          },\\n          \\\"purchase_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora da compra\\\",\\n            \\\"example\\\": \\\"2024-06-21T15:35:10Z\\\"\\n          },\\n          \\\"virtual_currency\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/VirtualCurrency\\\"\\n          },\\n          \\\"unlocked_items\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de itens cosméticos desbloqueados na compra\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/UnlockedItem\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"receipt_id\\\", \\\"player_id\\\", \\\"purchase_date\\\", \\\"virtual_currency\\\", \\\"unlocked_items\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
