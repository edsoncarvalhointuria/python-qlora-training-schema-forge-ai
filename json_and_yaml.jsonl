.0.0\\ninfo:\\n  title: E-Sports Match Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    TeamScores:\\n      type: object\\n      description: 'Scores achieved by each team in the match'\\n      properties:\\n        team_alpha:\\n          type: integer\\n          description: 'Score of Team Alpha'\\n          example: 16\\n        team_bravo:\\n          type: integer\\n          description: 'Score of Team Bravo'\\n          example: 12\\n    PlayerStatistic:\\n      type: object\\n      description: 'Statistics for an individual player during the match'\\n      properties:\\n        player_name:\\n          type: string\\n          description: 'Name of the player'\\n          example: 'ShadowFox'\\n        kills:\\n          type: integer\\n          description: 'Number of kills by the player'\\n          example: 22\\n        deaths:\\n          type: integer\\n          description: 'Number of times the player died'\\n          example: 5\\n        assists:\\n          type: integer\\n          description: 'Number of assists by the player'\\n          example: 8\\n    MatchEvent:\\n      type: object\\n      description: 'A key event that happened during the match timeline'\\n      properties:\\n        timestamp:\\n          type: string\\n          description: 'The time when the event occurred in the match'\\n          example: '00:02:15'\\n        event_type:\\n          type: string\\n          description: 'The type of the event'\\n          example: 'First Blood'\\n        description:\\n          type: string\\n          description: 'Detailed description of the event'\\n          example: 'ShadowFox secured the first kill against DragonSlayer near the mid lane.'\\n    MatchSummary:\\n      type: object\\n      description: 'Summary of a competitive e-sports match'\\n      properties:\\n        team_scores:\\n          $ref: '#/components/schemas/TeamScores'\\n        player_statistics:\\n          type: array\\n          description: 'Array of player statistics for the match'\\n          items:\\n            $ref: '#/components/schemas/PlayerStatistic'\\n        match_timeline:\\n          type: array\\n          description: 'Timeline of key events that occurred in the match'\\n          items:\\n            $ref: '#/components/schemas/MatchEvent'\\n    RootResponse:\\n      type: object\\n      description: 'Root schema for e-sports match summary response'\\n      properties:\\n        match_summary:\\n          $ref: '#/components/schemas/MatchSummary'\\n\"\n}"
