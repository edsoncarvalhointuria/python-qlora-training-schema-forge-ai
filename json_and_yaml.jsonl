rity_level\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Severity level of the threat\\\",\\n            \\\"example\\\": \\\"High\\\"\\n          },\\n          \\\"affected_entities\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of affected entities including their IP addresses\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/AffectedEntity\\\"\\n            }\\n          },\\n          \\\"mitigation_protocols\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Recommended mitigation protocols to address the threat\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/MitigationProtocol\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"alert_id\\\", \\\"severity_level\\\", \\\"affected_entities\\\", \\\"mitigation_protocols\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"components\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"parameters\\\": {},\\n  \\\"responses\\\": {},\\n  \\\"securitySchemes\\\": {},\\n  \\\"requestBodies\\\": {},\\n  \\\"rootSchema\\\": {\\n    \\\"$ref\\\": \\\"#/components/schemas/ThreatAlert\\\"\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"total_monthly_spend\": 12500.75,\n    \"costs_by_service\": [\n      {\n        \"service_name\": \"Compute\",\n        \"cost_items\": [\n          {\n            \"resource_id\": \"vm-123\",\n            \"description\": \"Virtual Machine instance\",\n            \"amount\": 5000.50\n          },\n          {\n            \"resource_id\": \"container-456\",\n            \"description\": \"Container service\",\n            \"amount\": 2000.00\n          }\n        ],\n        \"total_cost\": 7000.50\n      },\n      {\n        \"service_name\": \"Storage\",\n        \"cost_items\": [\n          {\n            \"resource_id\": \"storage-xyz\",\n            \"description\": \"Block storage\",\n            \"amount\": 3000.00\n          },\n          {\n            \"resource_id\": \"backup-abc\",\n            \"description\": \"Backup storage\",\n            \"amount\": 2500.25\n          }\n        ],\n        \"total_cost\": 5500.25\n      }\n    ],\n    \"forecast\": {\n      \"next_month_estimate\": 13000.00,\n      \"trend\": \"increasing\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Cloud Infrastructure Billing Dashboard\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CostItem:\\n      type: object\\n      description: 'Details about individual cost items for resources'\\n      properties:\\n        resource_id:\\n          type: string\\n          description: 'Unique identifier for the resource'\\n          example: 'vm-123'\\n        description:\\n          type: string\\n          description: 'Description of the resource cost item'\\n          example: 'Virtual Machine instance'\\n        amount:\\n          type: number\\n          format: float\\n          description: 'Cost amount for the resource'\\n          example: 5000.50\\n    ServiceCost:\\n      type: object\\n      description: 'Cost breakdown for a cloud service'\\n      properties:\\n        service_name:\\n          type: string\\n          description: 'Name of the cloud service'\\n          example: 'Compute'\\n        cost_items:\\n          type: array\\n          description: 'List of cost items under the service'\\n          items:\\n            $ref: '#/components/schemas/CostItem'\\n        total_cost:\\n          type: number\\n          format: float\\n          description: 'Total cost for the service'\\n          example: 7000.50\\n    Forecast:\\n      type: object\\n      description: 'Projected cloud spending forecast details'\\n      properties:\\n        next_month_estimate:\\n          type: number\\n          format: float\\n          description: 'Estimated spend for next month'\\n          example: 13000.00\\n        trend:\\n          type: string\\n          description: 'Spending trend direction'\\n          example: 'increasing'\\n    BillingDashboard:\\n      type: object\\n      description: 'Overall cloud infrastructure billing dashboard response'\\n      properties:\\n        total_monthly_spend:\\n          type: number\\n          format: float\\n          description: 'Total cloud spend for the current month'\\n          example: 12500.75\\n        costs_by_service:\\n          type: array\\n          description: 'Costs broken down by individual cloud services'\\n          items:\\n            $ref: '#/components/schemas/ServiceCost'\\n        forecast:\\n          $ref: '#/components/schemas/Forecast'\"\n}"
"{\n  \"raw_json\": {\n    \"citizen_id\": \"12345678900\",\n    \"declared_income\": 85000.75,\n    \"deductions\": [\n      {\n        \"type\": \"Health Expenses\",\n        \"amount\": 2000.50,\n        \"documents_provided\": [\n          {\n            \"document_type\": \"Medical Invoice\",\n            \"document_number\": \"INV123456\"\n          },\n          {\n            \"document_type\": \"Prescription\",\n            \"document_number\": \"RX78910\"\n          }\n        ]\n      },\n      {\n        \"type\": \"Education Expenses\",\n        \"amount\": 1500.00,\n        \"documents_provided\": [\n          {\n            \"document_type\": \"Tuition Receipt\",\n            \"document_number\": \"REC202304\"\n          }\n        ]\n      }\n    ],\n    \"final_tax_status\": {\n      \"status\": \"refund\",\n      \"amount\": 1250.25\n    }\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Avaliação de Declaração de Imposto\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Document\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Documento apresentado como comprovação para deduções\\\",\\n        \\\"properties\\\": {\\n          \\\"document_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo do documento apresentado\\\",\\n            \\\"example\\\": \\\"Medical Invoice\\\"\\n          },\\n          \\\"document_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Número identificador do documento\\\",\\n            \\\"example\\\": \\\"INV123456\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"document_type\\\", \\\"document_number\\\"]\\n      },\\n      \\\"Deduction\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações sobre uma dedução válida