"{\n  \"raw_json\": {\n    \"course_title\": \"Introduction to Computer Science\",\n    \"professor\": {\n      \"name\": \"Dr. Maria Silva\",\n      \"academic_background\": \"Ph.D. in Computer Science from USP\",\n      \"email\": \"maria.silva@university.edu.br\"\n    },\n    \"modules\": [\n      {\n        \"week\": 1,\n        \"topic\": \"Fundamentals of Programming\",\n        \"readings\": [\n          {\n            \"title\": \"Introduction to Algorithms\",\n            \"author\": \"Cormen et al.\",\n            \"isbn\": \"9780262033848\"\n          }\n        ]\n      },\n      {\n        \"week\": 2,\n        \"topic\": \"Data Structures\",\n        \"readings\": [\n          {\n            \"title\": \"Data Structures and Algorithms in Java\",\n            \"author\": \"Goodrich et al.\",\n            \"isbn\": \"9781118771334\"\n          },\n          {\n            \"title\": \"Algorithms Unlocked\",\n            \"author\": \"Cormen\",\n            \"isbn\": \"9780262518802\"\n          }\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"University Course Syllabus Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Reading\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes do livro texto requerido para leitura\\\",\\n        \\\"properties\\\": {\\n          \\\"title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Título do livro\\\",\\n            \\\"example\\\": \\\"Introduction to Algorithms\\\"\\n          },\\n          \\\"author\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Autor do livro\\\",\\n            \\\"example\\\": \\\"Cormen et al.\\\"\\n          },\\n          \\\"isbn\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"descriptio