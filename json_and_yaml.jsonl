\": \\\"Detalhamento do preço por cada noite\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/PricingBreakdownItem\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"base_rate\\\", \\\"taxes\\\", \\\"fees\\\", \\\"total_per_night\\\", \\\"breakdown\\\"]\\n      },\\n      \\\"HotelReservation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta detalhada do sistema de reservas de hotel\\\",\\n        \\\"properties\\\": {\\n          \\\"reservation_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único da reserva\\\",\\n            \\\"example\\\": \\\"res_456\\\"\\n          },\\n          \\\"room_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo do quarto reservado\\\",\\n            \\\"example\\\": \\\"Deluxe Suite\\\"\\n          },\\n          \\\"pricing\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Pricing\\\"\\n          },\\n          \\\"amenities\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de amenidades solicitadas para o quarto\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/Amenity\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"reservation_id\\\", \\\"room_type\\\", \\\"pricing\\\", \\\"amenities\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
