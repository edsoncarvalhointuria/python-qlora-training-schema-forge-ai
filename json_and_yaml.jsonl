loat\\\",\\n            \\\"description\\\": \\\"Processor speed in GHz\\\",\\n            \\\"example\\\": 3.8\\n          },\\n          \\\"cores\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of processor cores\\\",\\n            \\\"example\\\": 8\\n          },\\n          \\\"architecture\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Processor architecture\\\",\\n            \\\"example\\\": \\\"x86_64\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"processor_speed_ghz\\\", \\\"cores\\\", \\\"architecture\\\"]\\n      },\\n      \\\"TechnicalSpecificationsSSD\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Technical specifications for an SSD product\\\",\\n        \\\"properties\\\": {\\n          \\\"capacity_tb\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Storage capacity in terabytes\\\",\\n            \\\"example\\\": 2\\n          },\\n          \\\"interface\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Interface type of the SSD\\\",\\n            \\\"example\\\": \\\"NVMe\\\"\\n          },\\n          \\\"form_factor\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Physical form factor of the SSD\\\",\\n            \\\"example\\\": \\\"M.2\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"capacity_tb\\\", \\\"interface\\\", \\\"form_factor\\\"]\\n      },\\n      \\\"StockLevels\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Stock levels across different geographic regions\\\",\\n        \\\"properties\\\": {\\n          \\\"north_america\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Stock level in North America region\\\",\\n            \\\"exa