tchen ticket including table and orders grouped by stations'\\n      properties:\\n        table_number:\\n          type: integer\\n          description: 'Table number associated with the order'\\n          example: 12\\n        stations:\\n          type: array\\n          description: 'Array of kitchen stations with their orders'\\n          items:\\n            $ref: '#/components/schemas/StationOrder'\\n        allergy_warnings:\\n          type: array\\n          description: 'List of allergy warnings relevant to this order'\\n          items:\\n            type: string\\n            description: 'An allergy allergen to be aware of'\\n            example: 'Peanuts'\\npaths: {}\\n\"\n}"
"{\n  \"raw_json\": {\n    \"order_id\": \"ord_1023\",\n    \"items\": [\n      {\n        \"item_id\": \"itm_9876\",\n        \"name\": \"Wireless Mouse\",\n        \"quantity\": 2,\n        \"price\": 25.99,\n        \"currency\": \"USD\"\n      },\n      {\n        \"item_id\": \"itm_1234\",\n        \"name\": \"Mechanical Keyboard\",\n        \"quantity\": 1,\n        \"price\": 79.99,\n        \"currency\": \"USD\"\n      }\n    ],\n    \"shipping_address\": {\n      \"recipient_name\": \"John Doe\",\n      \"street\": \"123 Elm St\",\n      \"city\": \"Springfield\",\n      \"state\": \"IL\",\n      \"zip_code\": \"62704\",\n      \"country\": \"USA\"\n    },\n    \"payment\": {\n      \"transaction_id\": \"txn_556677\",\n      \"method\": \"credit_card\",\n      \"amount\": 131.97,\n      \"currency\": \"USD\",\n      \"status\": \"completed\"\n    },\n    \"_links\": {\n      \"self\": {\n        \"href\": \"https://api.example.com/orders/ord_1023\"\n      },\n      \"tracking\": {\n        \"href\": \"https://shipping.example.com/track/ord_1023\"\n      }\n    }\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"E-commerce Order API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Item\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a physical item in the order\\\",\\n        \\\"properties\\\": {\\n          \\\"item_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the item\\\",\\n            \\\"example\\\": \\\"itm_9876\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the item\\\",\\n            \\\"example\\\": \\\"Wireless Mouse\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantity of this item ordered\\\",\\n            \\\"example\\\": 2\\n          },\\n          \\\"price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Price per unit of the item\\\",\\n            \\\"example\\\": 25.99\\n          },\\n          \\\"currency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Currency code for the price\\\",\\n            \\\"example\\\": \\\"USD\\\"\\n          }\\n        }\\n      },\\n      \\\"ShippingAddress\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Customer's shipping address\\\",\\n        \\\"properties\\\": {\\n          \\\"recipient_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the recipient\\\",\\n            \\\"example\\\": \\\"John Doe\\\"\\n          },\\n          \\\"street\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Street address\\\",\\n            \\\"example\\\": \\\"123 Elm St\\\"\\n          },\\n          \\\"city\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"City of the shipping address\\\",\\n            \\\"example\\\": \\\"Springfield\\\"\\n          },\\n          \\\"state\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"State or province\\\",\\n            \\\"example\\\": \\\"IL\\\"\\n          },\\n          \\\"zip_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Postal or ZIP code\\\",\\n            \\\"example\\\": \\\"62704\\\"\\n          },\\n          \\\"country\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Country of the shipping address\\\",\\n            \\\"example\\\": \\\"USA\\\"\\n          }\\n        }\\n      },\\n      \\\"Payment\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payment transaction details\\\",\\n        \\\"properties\\\": {\\n          \\\"transaction_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the payment transaction\\\",\\n            \\\"example\\\": \\\"txn_556677\\\"\\n          },\\n          \\\"method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Payment method used\\\",\\n            \\\"example\\\": \\\"credit_card\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total amount paid\\\",\\n            \\\"example\\\": 131.97\\n          },\\n          \\\"currency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Currency of the payment\\\",\\n            \\\"example\\\": \\\"USD\\\"\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Current status of the payment\\\",\\n            \\\"example\\\": \\\"completed\\\"\\n          }\\n        }\\n      },\\n      \\\"Link\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Individual HAL link object\\\",\\n        \\\"properties\\\": {\\n          \\\"href\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"URL of the link\\\",\\n            \\\"example\\\": \\\"https://api.example.com/orders/ord_1023\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"href\\\"]\\n      },\\n      \\\"Links\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"HAL links related to the order\\\",\\n        \\\"properties\\\": {\\n          \\\"self\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Link\\\"\\n          },\\n          \\\"tracking\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Link\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"self\\\", \\\"tracking\\\"]\\n      },\\n      \\\"OrderResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Full response of an e-commerce order\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the order\\\",\\n            \\\"example\\\": \\\"ord_1023\\\"\\n          },\\n          \\\"items\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of physical items included in the order\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Item\\\"\\n            }\\n          },\\n          \\\"shipping_address\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/ShippingAddress\\\"\\n          },\\n          \\\"payment\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Payment\\\"\\n          },\\n          \\\"_links\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Links\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"order_id\\\", \\\"items\\\", \\\"shipping_address\\\", \\\"payment\\\", \\\"_links\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
