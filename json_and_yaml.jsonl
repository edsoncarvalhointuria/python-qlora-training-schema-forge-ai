\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Altitude above sea level in meters\\\",\\n            \\\"example\\\": 15.3\\n          }\\n        },\\n        \\\"required\\\": [\\\"latitude\\\", \\\"longitude\\\", \\\"altitude_meters\\\"]\\n      },\\n      \\\"BatteryHealth\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Diagnostic information regarding battery health\\\",\\n        \\\"properties\\\": {\\n          \\\"charge_percentage\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Current battery charge level as a percentage\\\",\\n            \\\"example\\\": 88\\n          },\\n          \\\"temperature_celsius\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Battery temperature in degrees Celsius\\\",\\n            \\\"example\\\": 39.2\\n          },\\n          \\\"voltage_volts\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Battery voltage in volts\\\",\\n            \\\"example\\\": 12.7\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Overall battery status\\\",\\n            \\\"example\\\": \\\"Good\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"charge_percentage\\\", \\\"temperature_celsius\\\", \\\"voltage_volts\\\", \\\"status\\\"]\\n      },\\n      \\\"DrivingAnomaly\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a detected driving anomaly\\\",\\n        \\\"properties\\\": {\\n          \\\"anomaly_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type or classification of the anomaly\\\",\\n            \\\"example\\\": \\\"Harsh Braking\\\"\\n          },\\n          \\\"severity\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Severity level of the anomaly\\\",\\n            \\\"example\\\": \\\"Moderate\\\"\\n          },\\n          \\\"detected_at\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Timestamp when the anomaly was detected\\\",\\n            \\\"example\\\": \\\"2024-06-23T15:20:10Z\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Additional information describing the anomaly\\\",\\n            \\\"example\\\": \\\"Deceleration exceeding threshold detected\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"anomaly_type\\\", \\\"severity\\\", \\\"detected_at\\\", \\\"description\\\"]\\n      },\\n      \\\"TelemetryPing\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Telemetry data transmitted by an autonomous fleet vehicle\\\",\\n        \\\"properties\\\": {\\n          \\\"vehicle_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the vehicle\\\",\\n            \\\"example\\\": \\\"veh_2047\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"UTC timestamp when the ping was recorded\\\",\\n            \\\"example\\\": \\\"2024-06-23T15:22:34Z\\\"\\n          },\\n          \\\"gps_coordinates\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/GpsCoordinates\\\"\\n          },\\n          \\\"current_speed_kph\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Current speed of the vehicle in kilometers per hour\\\",\\n            \\\"example\\\": 65.4\\n          },\\n          \\\"battery_health\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BatteryHealth\\\"\\n          },\\n          \\\"driving_anomalies\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of recent driving anomalies detected\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/DrivingAnomaly\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"vehicle_id\\\", \\\"timestamp\\\", \\\"gps_coordinates\\\", \\\"current_speed_kph\\\", \\\"battery_health\\\", \\\"driving_anomalies\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {}\\n}\"\n}"
