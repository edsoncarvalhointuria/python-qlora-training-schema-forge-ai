pe\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the subscriber company\\\",\\n        \\\"properties\\\": {\\n          \\\"company_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the company\\\",\\n            \\\"example\\\": \\\"comp_456\\\"\\n          },\\n          \\\"company_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Registered company name\\\",\\n            \\\"example\\\": \\\"Tech Solutions Ltd\\\"\\n          },\\n          \\\"address\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Physical address of the company\\\",\\n            \\\"example\\\": \\\"123 Innovation Drive, Tech City, TX 75001\\\"\\n          },\\n          \\\"contact_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"Billing contact email for the company\\\",\\n            \\\"example\\\": \\\"billing@techsolutions.com\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"company_id\\\", \\\"company_name\\\", \\\"address\\\", \\\"contact_email\\\"]\\n      },\\n      \\\"TaxDetail\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Individual tax charge detail\\\",\\n        \\\"properties\\\": {\\n          \\\"tax_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the tax\\\",\\n            \\\"example\\\": \\\"VAT\\\"\\n          },\\n          \\\"tax_rate\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Applied tax rate as a decimal\\\",\\n            \\\"example\\\": 0.15\\n          },\\n          \\\"tax_amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Computed tax amount in billing currency\\\",\\n            \\\"example\\\": 45.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"tax_name\\\", \\\"tax_rate\\\", \\\"tax_amount\\\"]\\n      },\\n      \\\"DiscountCoupon\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Applied discount coupon information\\\",\\n        \\\"properties\\\": {\\n          \\\"coupon_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Code used for discount\\\",\\n            \\\"example\\\": \\\"SPRING2024\\\"\\n          },\\n          \\\"discount_amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Discount amount applied from coupon\\\",\\n            \\\"example\\\": 20.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"coupon_code\\\", \\\"discount_amount\\\"]\\n      },\\n      \\\"InvoiceResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"SaaS subscription invoice with billing and discount details\\\",\\n        \\\"properties\\\": {\\n          \\\"invoice_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique invoice identifier\\\",\\n            \\\"example\\\": \\\"inv_789\\\"\\n          },\\n          \\\"billing_cycle\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BillingCycle\\\"\\n          },\\n          \\\"company\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Company\\\"\\n          },\\n          \\\"taxes\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of tax details applied to the invoice\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/TaxDetail\\\"\\n            }\\n          },\\n          \\\"discount_coupons\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n        