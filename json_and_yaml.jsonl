ernal Medicine\\\"\\n          },\\n          \\\"contact_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"Contact email address of the doctor\\\",\\n            \\\"example\\\": \\\"alice.smith@hospital.org\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"doctor_id\\\", \\\"name\\\", \\\"specialty\\\", \\\"contact_email\\\"]\\n      },\\n      \\\"PatientMedicalRecordSummary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Summary of a hospital patient's medical record with vital signs, current medications, and attending doctor information\\\",\\n        \\\"properties\\\": {\\n          \\\"patient_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the patient\\\",\\n            \\\"example\\\": \\\"patient_12345\\\"\\n          },\\n          \\\"vital_signs\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/VitalSigns\\\"\\n          },\\n          \\\"current_medications\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of medications the patient is currently taking\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Medication\\\"\\n            }\\n          },\\n          \\\"attending_doctor\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DoctorProfile\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"patient_id\\\", \\\"vital_signs\\\", \\\"current_medications\\\", \\\"attending_doctor\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PatientMedicalRecordSummary\\\": {\\n        \\\"$ref\\\": \\\"#/components/schemas/PatientMedicalRecordSummary\\\"\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"truck_id\": \"truck_1234\",\n    \"location\": {\n      \"latitude\": -23.55052,\n      \"longitude\": -46.633308,\n      \"speed_kmph\": 65.5\n    },\n    \"driver\": {\n      \"driver_id\": \"drv_5678\",\n      \"name\": \"Carlos Silva\",\n      \"license_number\": \"BR1234567\"\n    },\n    \"route_stops\": [\n      {\n        \"stop_id\": \"stop_1\",\n        \"name\": \"Warehouse A\",\n        \"scheduled_arrival\": \"2024-06-10T09:00:00Z\",\n        \"actual_arrival\": \"2024-06-10T09:05:00Z\"\n      },\n      {\n        \"stop_id\": \"stop_2\",\n        \"name\": \"Retail Store B\",\n        \"scheduled_arrival\": \"2024-06-10T11:30:00Z\",\n        \"actual_arrival\": null\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Logistics Fleet Tracking\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Location:\\n      type: object\\n      description: 'Informações de localização atual do caminhão'\\n      properties:\\n        latitude:\\n          type: number\\n          description: 'Latitude geográfica em coordenadas decimais'\\n          example: -23.55052\\n        longitude:\\n          type: number\\n          description: 'Longitude geográfica em coordenadas decimais'\\n          example: -46.633308\\n        speed_kmph:\\n          type: number\\n          description: 'Velocidade atual do caminhão em quilômetros por hora'\\n          example: 65.5\\n    Driver:\\n      type: object\\n      description: 'Detalhes do motorista responsável pelo caminhão'\\n      properties:\\n        driver_id:\\n          type: string\\n          description: 'Identificador único do motorista'\\n          example: 'drv_5678'\\n        name:\\n          type: string\\n          description: 'Nome completo do motorista'\\n          example: 'Carlos Silva'\\n        license_number:\\n          type: string\\n          description: 'Número da carteira de motorista'\\n          example: 'BR1234567'\\n    RouteStop:\\n