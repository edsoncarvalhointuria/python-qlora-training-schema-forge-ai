,\\n            \\\"description\\\": \\\"Timestamp when the post was created\\\",\\n            \\\"example\\\": \\\"2024-06-01T14:35:00Z\\\"\\n          },\\n          \\\"comments\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of comments on the post\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Comment\\\"\\n            }\\n          },\\n          \\\"liked_by\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of users who liked the post\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"post_id\\\", \\\"content\\\", \\\"timestamp\\\", \\\"comments\\\", \\\"liked_by\\\"]\\n      },\\n      \\\"UserFeedResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response containing user's feed with posts\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identifier of the user whose feed is returned\\\",\\n            \\\"example\\\": \\\"user_789\\\"\\n          },\\n          \\\"posts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of posts in the user's feed\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Post\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"user_id\\\", \\\"posts\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
