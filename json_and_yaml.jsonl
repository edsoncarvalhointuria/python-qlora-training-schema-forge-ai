"{\n  \"raw_json\": {\n    \"table_number\": 12,\n    \"stations\": [\n      {\n        \"station_name\": \"Grill\",\n        \"items\": [\n          {\n            \"item_name\": \"Cheeseburger\",\n            \"quantity\": 2,\n            \"modifiers\": [\"No pickles\", \"Extra cheese\"],\n            \"allergy_warnings\": [\"Dairy\", \"Gluten\"]\n          },\n          {\n            \"item_name\": \"Grilled Chicken\",\n            \"quantity\": 1,\n            \"modifiers\": [],\n            \"allergy_warnings\": []\n          }\n        ]\n      },\n      {\n        \"station_name\": \"Salad\",\n        \"items\": [\n          {\n            \"item_name\": \"Caesar Salad\",\n            \"quantity\": 1,\n            \"modifiers\": [\"Dressing on side\"],\n            \"allergy_warnings\": [\"Dairy\", \"Fish\"]\n          }\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Kitchen Display Ticket\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AllergyWarnings:\\n      type: string\\n      description: 'Common allergy warnings related to the item'\\n      example: 'Dairy'\\n    Modifier:\\n      type: string\\n      description: 'An item modifier or special instruction'\\n      example: 'No pickles'\\n    OrderedItem:\\n      type: object\\n      description: 'An individual ordered item with quantity, modifiers, and allergy warnings'\\n      properties:\\n        item_name:\\n          type: string\\n          description: 'Name of the ordered item'\\n          example: 'Cheeseburger'\\n        quantity:\\n          type: integer\\n          description: 'Number of this item ordered'\\n          example: 2\\n        modifiers:\\n          type: array\\n          description: 'Special instructions or modifications for the item'\\n          items:\\n            $ref: '#/components/schemas/Modifier'\\n          example: ['No pickles', 'Extra cheese']\\n        allergy_warnings:\\n          type: array\\n          descripti