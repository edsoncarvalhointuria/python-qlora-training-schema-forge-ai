"{\n  \"raw_json\": {\n    \"invoice_id\": \"inv_98765\",\n    \"billing_cycle\": {\n      \"start_date\": \"2024-05-01\",\n      \"end_date\": \"2024-05-31\"\n    },\n    \"company\": {\n      \"company_id\": \"comp_4321\",\n      \"name\": \"Acme Corporation\",\n      \"address\": {\n        \"street\": \"123 Business Rd\",\n        \"city\": \"Metropolis\",\n        \"state\": \"NY\",\n        \"postal_code\": \"10101\",\n        \"country\": \"USA\"\n      }\n    },\n    \"taxes\": [\n      {\n        \"tax_name\": \"VAT\",\n        \"tax_rate\": 0.12,\n        \"amount\": 72.50\n      },\n      {\n        \"tax_name\": \"Service Tax\",\n        \"tax_rate\": 0.05,\n        \"amount\": 30.21\n      }\n    ],\n    \"discount_coupons\": [\n      {\n        \"coupon_code\": \"SPRINGSALE10\",\n        \"discount_amount\": 10.00,\n        \"description\": \"10% off spring promotion\"\n      },\n      {\n        \"coupon_code\": \"LOYALTY5\",\n        \"discount_amount\": 5.00,\n        \"description\": \"5 USD loyalty discount\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"SaaS Subscription Invoice Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Address\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Postal address details of the company\\\",\\n        \\\"properties\\\": {\\n          \\\"street\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Street address\\\",\\n            \\\"example\\\": \\\"123 Business Rd\\\"\\n          },\\n          \\\"city\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"City name\\\",\\n            \\\"example\\\": \\\"Metropolis\\\"\\n          },\\n          \\\"state\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"State or province\\\",\\n            \\\"example\\\": \\\"NY\\\"\\n          },\\n          \\\"postal_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Postal or ZIP code\\\",\\n            \\\"example\\\": \\\"10101\\\"\\n          },\\n          \\\"country\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Country name\\\",\\n            \\\"example\\\": \\\"USA\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"street\\\", \\\"city\\\", \\\"state\\\", \\\"postal_code\\\", \\\"country\\\"]\\n      },\\n      \\\"Company\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the billed company\\\",\\n        \\\"properties\\\": {\\n          \\\"company_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique company identifier\\\",\\n            \\\"example\\\": \\\"comp_4321\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Company name\\\",\\n            \\\"example\\\": \\\"Acme Corporation\\\"\\n          },\\n          \\\"address\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Address\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"company_id\\\", \\\"name\\\", \\\"address\\\"]\\n      },\\n      \\\"BillingCycle\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Billing cycle start and end dates\\\",\\n        \\\"properties\\\": {\\n          \\\"start_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"Start date of the billing cycle\\\",\\n            \\\"example\\\": \\\"2024-05-01\\\"\\n          },\\n          \\\"end_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"End date of the billing cycle\\\",\\n            \\\"example\\\": \\\"2024-05-31\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"start_date\\\", \\\"end_date\\\"]\\n      },\\n      \\\"TaxDetail\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Breakdown of individual tax applied\\\",\\n        \\\"properties\\\": {\\n          \\\"tax_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the tax\\\",\\n            \\\"example\\\": \\\"VAT\\\"\\n          },\\n          \\\"tax_rate\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Tax rate as a decimal\\\",\\n            \\\"example\\\": 0.12\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Tax amount charged in the invoice currency\\\",\\n            \\\"example\\\": 72.50\\n          }\\n        },\\n        \\\"required\\\": [\\\"tax_name\\\", \\\"tax_rate\\\", \\\"amount\\\"]\\n      },\\n      \\\"DiscountCoupon\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about an applied discount coupon\\\",\\n        \\\"properties\\\": {\\n          \\\"coupon_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Coupon code used\\\",\\n            \\\"example\\\": \\\"SPRINGSALE10\\\"\\n          },\\n          \\\"discount_amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Amount discounted by this coupon\\\",\\n            \\\"example\\\": 10.00\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Short description of the discount\\\",\\n            \\\"example\\\": \\\"10% off spring promotion\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"coupon_code\\\", \\\"discount_amount\\\", \\\"description\\\"]\\n      },\\n      \\\"InvoiceResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response object for SaaS subscription invoice details\\\",\\n        \\\"properties\\\": {\\n          \\\"invoice_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique invoice identifier\\\",\\n            \\\"example\\\": \\\"inv_98765\\\"\\n          },\\n          \\\"billing_cycle\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BillingCycle\\\"\\n          },\\n          \\\"company\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Company\\\"\\n          },\\n          \\\"taxes\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of tax breakdowns applied\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/TaxDetail\\\" }\\n          },\\n          \\\"discount_coupons\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of applied discount coupons\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/DiscountCoupon\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"invoice_id\\\", \\\"billing_cycle\\\", \\\"company\\\", \\\"taxes\\\", \\\"discount_coupons\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {}\\n}\"\n}"
