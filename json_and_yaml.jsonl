"{\n  \"raw_json\": {\n    \"month\": \"2024-06\",\n    \"total_monthly_spend\": 15320.75,\n    \"services_costs\": [\n      {\n        \"service_name\": \"compute\",\n        \"cost\": 9200.50,\n        \"details\": [\n          {\n            \"resource\": \"vm_instances\",\n            \"usage_hours\": 450,\n            \"unit_cost\": 0.12,\n            \"total_cost\": 54.0\n          },\n          {\n            \"resource\": \"containers\",\n            \"usage_hours\": 800,\n            \"unit_cost\": 0.10,\n            \"total_cost\": 80.0\n          }\n        ]\n      },\n      {\n        \"service_name\": \"storage\",\n        \"cost\": 6120.25,\n        \"details\": [\n          {\n            \"resource\": \"block_storage\",\n            \"usage_gb\": 3000,\n            \"unit_cost\": 0.02,\n            \"total_cost\": 60.0\n          },\n          {\n            \"resource\": \"object_storage\",\n            \"usage_gb\": 5000,\n            \"unit_cost\": 0.11,\n            \"total_cost\": 550.0\n          }\n        ]\n      }\n    ],\n    \"forecast\": {\n      \"next_month_estimated_spend\": 16000.00,\n      \"notes\": \"Increasing demand expected due to new deployments.\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Cloud Billing Dashboard\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ResourceDetail:\\n      type: object\\n      description: 'Detalhes do recurso usado no serviço de nuvem'\\n      properties:\\n        resource:\\n          type: string\\n          description: 'Nome do tipo de recurso utilizado'\\n          example: 'vm_instances'\\n        usage_hours:\\n          type: number\\n          description: 'Horas de uso do recurso, quando aplicável'\\n          example: 450\\n        usage_gb:\\n          type: integer\\n          description: 'Quantidade de uso em gigabytes, quando aplicável'\\n          example: 3000\\n        unit_cost:\\n          type: number\\n          description: 'Custo unitário por hora ou por gigabyte'\\n          example: 0.12\\n        total_cost:\\n          type: number\\n          description: 'Custo total calculado para o recurso específico'\\n          example: 54.0\\n      oneOf:\\n        - required: [resource, usage_hours, unit_cost, total_cost]\\n        - required: [resource, usage_gb, unit_cost, total_cost]\\n    ServiceCost:\\n      type: object\\n      description: 'Custos detalhados por serviço em nuvem'\\n      properties:\\n        service_name:\\n          type: string\\n          description: 'Nome do serviço de nuvem para custo discriminado'\\n          example: 'compute'\\n        cost:\\n          type: number\\n          description: 'Custo total do serviço para o mês'\\n          example: 9200.50\\n        details:\\n          type: array\\n          description: 'Lista de detalhes dos recursos e seus custos no serviço'\\n          items:\\n            $ref: '#/components/schemas/ResourceDetail'\\n    Forecast:\\n      type: object\\n      description: 'Projeção de gastos para o próximo mês'\\n      properties:\\n        next_month_estimated_spend:\\n          type: number\\n          description: 'Estimativa de gastos para o próximo mês'\\n          example: 16000.00\\n        notes:\\n          type: string\\n          description: 'Notas adicionais sobre a previsão de gastos'\\n          example: 'Increasing demand expected due to new deployments.'\\n    BillingDashboard:\\n      type: object\\n      description: 'Painel de cobrança mensal detalhado da infraestrutura em nuvem'\\n      properties:\\n        month:\\n          type: string\\n          description: 'Mês referente aos dados de cobrança no formato AAAA-MM'\\n          example: '2024-06'\\n        total_monthly_spend:\\n          type: number\\n          description: 'Gasto total em nuvem para o mês'\\n          example: 15320.75\\n        services_costs:\\n          type: array\\n          description: 'Array de custos discriminados por serviço na infraestrutura de nuvem'\\n          items:\\n            $ref: '#/components/schemas/ServiceCost'\\n        forecast:\\n          $ref: '#/components/schemas/Forecast'\\n\"\n}"
