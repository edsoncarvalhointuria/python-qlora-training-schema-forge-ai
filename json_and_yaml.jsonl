"{\n  \"raw_json\": {\n    \"user_profile\": {\n      \"user_id\": \"user_12345\",\n      \"name\": \"Jane Doe\",\n      \"email\": \"jane.doe@example.com\",\n      \"phone\": \"+1234567890\"\n    },\n    \"current_balance\": 2540.75,\n    \"recent_transactions\": [\n      {\n        \"transaction_id\": \"txn_1001\",\n        \"date\": \"2024-04-25T14:30:00Z\",\n        \"type\": \"debit\",\n        \"amount\": 120.50,\n        \"currency\": \"USD\",\n        \"description\": \"Grocery shopping\"\n      },\n      {\n        \"transaction_id\": \"txn_1002\",\n        \"date\": \"2024-04-24T09:15:00Z\",\n        \"type\": \"credit\",\n        \"amount\": 500,\n        \"currency\": \"USD\",\n        \"description\": \"Salary deposit\"\n      },\n      {\n        \"transaction_id\": \"txn_1003\",\n        \"date\": \"2024-04-23T19:45:00Z\",\n        \"type\": \"debit\",\n        \"amount\": 45.00,\n        \"currency\": \"USD\",\n        \"description\": \"Online subscription\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Digital Wallet Statement\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UserProfile:\\n      type: object\\n      description: 'Details about the wallet user profile'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier of the user'\\n          example: 'user_12345'\\n        name:\\n          type: string\\n          description: 'Full name of the user'\\n          example: 'Jane Doe'\\n        email:\\n          type: string\\n          description: 'Email address of the user'\\n          example: 'jane.doe@example.com'\\n        phone:\\n          type: string\\n          description: 'Contact phone number of the user'\\n          example: '+1234567890'\\n    Transaction:\\n      type: object\\n      description: 'Details of a single transaction in the wallet'\\n      properties:\\n        transaction_id:\\n          type: string\\n          description: 'Unique identifier for the transaction'\\n          example: 'txn_1001'\\n        date:\\n          type: string\\n          format: date-time\\n          description: 'Date and time when the transaction occurred, in ISO 8601 format'\\n          example: '2024-04-25T14:30:00Z'\\n        type:\\n          type: string\\n          description: 'Indicates if the transaction is a debit or credit'\\n          example: 'debit'\\n        amount:\\n          type: number\\n          format: float\\n          description: 'Amount of money debited or credited in the transaction'\\n          example: 120.50\\n        currency:\\n          type: string\\n          description: 'Currency code following ISO 4217'\\n          example: 'USD'\\n        description:\\n          type: string\\n          description: 'Brief description or memo for the transaction'\\n          example: 'Grocery shopping'\\n    DigitalWalletStatement:\\n      type: object\\n      description: 'Complete digital wallet statement including user profile, balance, and recent transactions'\\n      properties:\\n        user_profile:\\n          $ref: '#/components/schemas/UserProfile'\\n        current_balance:\\n          type: number\\n          format: float\\n          description: 'Current balance available in the digital wallet'\\n          example: 2540.75\\n        recent_transactions:\\n          type: array\\n          description: 'List of the last three transactions executed in the wallet'\\n          items:\\n            $ref: '#/components/schemas/Transaction'\\n\"\n}"
