bject\\\",\\n        \\\"description\\\": \\\"Details of the passenger\\\",\\n        \\\"properties\\\": {\\n          \\\"first_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's first name\\\",\\n            \\\"example\\\": \\\"John\\\"\\n          },\\n          \\\"last_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's last name\\\",\\n            \\\"example\\\": \\\"Doe\\\"\\n          },\\n          \\\"passport_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's passport number\\\",\\n            \\\"example\\\": \\\"X1234567\\\"\\n          },\\n          \\\"contact_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"Contact email for the passenger\\\",\\n            \\\"example\\\": \\\"john.doe@example.com\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"first_name\\\", \\\"last_name\\\", \\\"passport_number\\\", \\\"contact_email\\\"]\\n      },\\n      \\\"Layover\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details about a layover between flights\\\",\\n        \\\"properties\\\": {\\n          \\\"location\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Layover airport code\\\",\\n            \\\"example\\\": \\\"ORD\\\"\\n          },\\n          \\\"duration_minutes\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Duration of the layover in minutes\\\",\\n            \\\"example\\\": 60\\n          }\\n        },\\n        \\\"required\\\": [\\\"location\\\", \\\"duration_minutes\\\"]\\n      },\\n      \\\"Segment\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"One flight segment in the itinerary\\\",\\n        \\\"properties\\\": {\\n          \\\"flight_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Flight number for this segment\\\",\\n            \\\"example\\\": \\\"AA100\\\"\\n          },\\n          \\\"departure_airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Departure airport code\\\",\\n            \\\"example\\\": \\\"JFK\\\"\\n          },\\n          \\\"arrival_airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Arrival airport code\\\",\\n            \\\"example\\\": \\\"ORD\\\"\\n          },\\n          \\\"departure_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled departure time in ISO 8601 format\\\",\\n            \\\"example\\\": \\\"2024-07-01T08:00:00Z\\\"\\n          },\\n          \\\"arrival_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled arrival time in ISO 8601 format\\\",\\n            \\\"example\\\": \\\"2024-07-01T09:45:00Z\\\"\\n          },\\n          \\\"layover\\\": {\\n            \\\"oneOf\\\": [\\n              { \\\"$ref\\\": \\\"#/components/schemas/Layover\\\" },\\n              { \\\"type\\\": \\\"null\\\" }\\n            ],\\n            \\\"description\\\": \\\"Layover details if this segment ends in a connecting airport, null otherwise\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"flight_number\\\", \\\"departure_airport\\\", \\\"arrival_airport\\\", \\\"departure_time\\\", \\\"arrival_time\\\", \\\"layover\\\"]\\n      },\\n      \\\"Itinerary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Complete flight itinerary for the booking\\\",\\n        \\\"properties\\\": {\\n          \\\"origin\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Origin airport code\\\",\\n            \\\"example\\\": \\\"JFK\\\"\\n          },\\n          \\\"destination\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Destination airport code\\\",\\n            \\\"example\\\": \\\"LAX\\\"\\n          },\\n          \\\"departure_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Start of the itinerary departure time\\\",\\n            \\\"example\\\": \\\"2024-07-01T08:00:00Z\\\"\\n          },\\n          \\\"arrival_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"End of the itinerary arrival time\\\",\\n            \\\"example\\\": \\\"2024-07-01T11:00:00Z\\\"\\n          },\\n          \\\"segments\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of all flight segments with possible layovers\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/Segment\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"origin\\\", \\\"destination\\\", \\\"departure_time\\\", \\\"arrival_time\\\", \\\"segments\\\"]\\n      },\\n      \\\"SeatUpgrade\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Selected seat upgrade options for a flight segment\\\",\\n        \\\"properties\\\": {\\n          \\\"segment_flight_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Flight number of the segment this upgrade applies to\\\",\\n            \\\"example\\\": \\\"AA100\\\"\\n          },\\n          \\\"seat_class\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Class of the upgraded seat\\\",\\n            \\\"example\\\": \\\"Business\\\"\\n          },\\n          \\\"extra_cost_usd\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Extra cost in USD for the seat upgrade\\\",\\n            \\\"example\\\": 150.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"segment_flight_number\\\", \\\"seat_class\\\", \\\"extra_cost_usd\\\"]\\n      },\\n      \\\"MealPreference\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Passenger's meal preference for a flight segment\\\",\\n        \\\"properties\\\": {\\n          \\\"segment_flight_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Flight number of the segment this meal preference applies to\\\",\\n            \\\"example\\\": \\\"AA100\\\"\\n          },\\n          \\\"meal_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of meal requested\\\",\\n            \\\"example\\\": \\\"Vegetarian\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"segment_flight_number\\\", \\\"meal_type\\\"]\\n      },\\n      \\\"FlightBookingConfirmation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Complete flight booking confirmation with passenger details, itinerary, seat upgrades, and meal preferences\\\",\\n        \\\"properties\\\": {\\n          \\\"confirmation_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique booking confirmation number\\\",\\n            \\\"example\\\": \\\"ABC123456\\\"\\n          },\\n          \\\"passenger\\\": { \\\"$ref\\\": \\\"#/components/schemas/Passenger\\\" },\\n          \\\"itinerary\\\": { \\\"$ref\\\": \\\"#/components/schemas/Itinerary\\\" },\\n          \\\"seat_upgrades\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of seat upgrade selections\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/SeatUpgrade\\\" }\\n          },\\n          \\\"meal_preferences\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of meal preferences\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/MealPreference\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"confirmation_number\\\", \\\"passenger\\\", \\\"itinerary\\\", \\\"seat_upgrades\\\", \\\"meal_preferences\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"paths\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"paths\\\": {},\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FlightBookingConfirmation\\\": { \\\"$ref\\\": \\\"#/components/schemas/FlightBookingConfirmation\\\" }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"property\": {\n      \"id\": \"prop_9876\",\n      \"title\": \"Modern Family Villa\",\n      \"description\": \"Spacious 4-bedroom villa with modern amenities and lush garden\",\n      \"price\": 1250000,\n      \"architectural_specs\": {\n        \"year_built\": 2018,\n        \"square_feet\": 3500,\n        \"num_bedrooms\": 4,\n        \"num_bathrooms\": 3.5,\n        \"property_type\": \"Villa\",\n        \"features\": [\"Swimming Pool\", \"Home Theater\", \"Solar Panels\"]\n      },\n      \"images\": [\n        {\n          \"url\": \"https://realestate.example.com/images/villa_front_hd.jpg\",\n          \"description\": \"Front view of the villa\"\n        },\n        {\n          \"url\": \"https://realestate.example.com/images/villa_livingroom_hd.jpg\",\n          \"description\": \"Spacious living room with natural light\"\n        }\n      ],\n      \"realtor\": {\n        \"id\": \"agent_204\",\n        \"name\": \"Jane Doe\",\n        \"phone\": \"+1-555-123-4567\",\n        \"email\": \"jane.doe@realestateco.com\",\n        \"agency\": \"RealEstateCo\",\n        \"profile_url\": \"https://realestate.example.com/agents/janedoe\"\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Real Estate Property Listing\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Detailed architectural specifications of the property'\\n      properties:\\n        year_built:\\n          type: integer\\n          description: 'Year the property was constructed'\\n          example: 2018\\n        square_feet:\\n          type: integer\\n          description: 'Total square footage of the property'\\n          example: 3500\\n        num_bedrooms:\\n          type: integer\\n          description: 'Number of bedrooms in the property'\\n          example: 4\\n        num_bathrooms:\\n          type: number\\n          format: float\\n          description: 'Number of bathrooms in the property'\\n          example: 3.5\\n        property_type:\\n          type: string\\n          description: 'Type or category of the property'\\n          example: 'Villa'\\n        features:\\n          type: array\\n          description: 'Key features and amenities included with the property'\\n          items:\\n            type: string\\n            example: 'Swimming Pool'\\n    Image:\\n      type: object\\n      description: 'High-resolution image URL with description'\\n      properties:\\n        url:\\n          type: string\\n          format: uri\\n          description: 'Direct URL to the high-resolution image'\\n          example: 'https://realestate.example.com/images/villa_front_hd.jpg'\\n        description:\\n          type: string\\n          description: 'Short text describing the image'\\n          example: 'Front view of the villa'\\n    Realtor:\\n      type: object\\n      description: 'Information about the assigned realtor'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier for the realtor'\\n          example: 'agent_204'\\n        name:\\n          type: string\\n          description: 'Full name of the realtor'\\n          example: 'Jane Doe'\\n        phone:\\n          type: string\\n          description: 'Contact phone number for the realtor'\\n          example: '+1-555-123-4567'\\n        email:\\n          type: string\\n          format: email\\n          description: 'Email address of the realtor'\\n          example: 'jane.doe@realestateco.com'\\n        agency:\\n          type: string\\n          description: 'Name of the real estate agency'\\n          example: 'RealEstateCo'\\n        profile_url:\\n          type: string\\n          format: uri\\n          description: 'URL to the realtor profile page'\\n          example: 'https://realestate.example.com/agents/janedoe'\\n    Property:\\n      type: object\\n      description: 'Complete property listing with details, images, and realtor contact'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier of the property'\\n          example: 'prop_9876'\\n        title:\\n          type: string\\n          description: 'Title or headline of the property listing'\\n          example: 'Modern Family Villa'\\n        description:\\n          type: string\\n          description: 'Detailed description about the property'\\n          example: 'Spacious 4-bedroom villa with modern amenities and lush garden'\\n        price:\\n          type: integer\\n          description: 'Listing price in US dollars'\\n          example: 1250000\\n        architectural_specs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n          description: 'Array of high-resolution property images with descriptions'\\n          items:\\n            $ref: '#/components/schemas/Image'\\n        realtor:\\n          $ref: '#/components/schemas/Realtor'\\n    PropertyListingResponse:\\n      type: object\\n      description: 'API response object containing a real estate property listing'\\n      properties:\\n        property:\\n          $ref: '#/components/schemas/Property'\"\n}"
"{\n  \"raw_json\": {\n    \"reservation_id\": \"res_20240601\",\n    \"room_type\": \"Deluxe Suite\",\n    \"pricing\": {\n      \"nights\": 3,\n      \"breakdown_per_night\": [\n        {\n          \"date\": \"2024-06-10\",\n          \"base_rate\": 200.0,\n          \"taxes\": 30.0,\n          \"total\": 230.0\n        },\n        {\n          \"date\": \"2024-06-11\",\n          \"base_rate\": 200.0,\n          \"taxes\": 30.0,\n          \"total\": 230.0\n        },\n        {\n          \"date\": \"2024-06-12\",\n          \"base_rate\": 200.0,\n          \"taxes\": 30.0,\n          \"total\": 230.0\n        }\n      ],\n      \"overall_total\": 690.0\n    },\n    \"requested_amenities\": [\n      {\n        \"amenity_type\": \"crib\",\n        \"quantity\": 1,\n        \"description\": \"Portable baby crib\"\n      },\n      {\n        \"amenity_type\": \"extra_bed\",\n        \"quantity\": 2,\n        \"description\": \"Foldable extra beds for guests\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Hotel Reservation Detail\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PricingBreakdownNight\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detailed pricing for a single night\\\",\\n        \\\"properties\\\": {\\n          \\\"date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"The date of the pricing night\\\",\\n            \\\"example\\\": \\\"2024-06-10\\\"\\n          },\\n          \\\"base_rate\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Base room rate for the night in USD\\\",\\n            \\\"example\\\": 200.0\\n          },\\n          \\\"taxes\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Taxes applied on the base rate for the night in USD\\\",\\n            \\\"example\\\": 30.0\\n          },\\n          \\\"total\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total charge for the night including taxes in USD\\\",\\n            \\\"example\\\": 230.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"date\\\", \\\"base_rate\\\", \\\"taxes\\\", \\\"total\\\"]\\n      },\\n      \\\"Pricing\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Pricing details covering all nights reserved\\\",\\n        \\\"properties\\\": {\\n          \\\"nights\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Total number of nights for the reservation\\\",\\n            \\\"example\\\": 3\\n          },\\n          \\\"breakdown_per_night\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of pricing details for each night\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/PricingBreakdownNight\\\"\\n            }\\n          },\\n          \\\"overall_total\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Aggregate total cost for the entire stay in USD\\\",\\n            \\\"example\\\": 690.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"nights\\\", \\\"breakdown_per_night\\\", \\\"overall_total\\\"]\\n      },\\n      \\\"Amenity\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"An amenity requested by the guest\\\",\\n        \\\"properties\\\": {\\n          \\\"amenity_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of amenity requested\\\",\\n            \\\"example\\\": \\\"crib\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of this amenity requested\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Description of the amenity\\\",\\n            \\\"example\\\": \\\"Portable baby crib\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"amenity_type\\\", \\\"quantity\\\", \\\"description\\\"]\\n      },\\n      \\\"HotelReservationResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response object containing hotel reservation details\\\",\\n        \\\"properties\\\": {\\n          \\\"reservation_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the reservation\\\",\\n            \\\"example\\\": \\\"res_20240601\\\"\\n          },\\n          \\\"room_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type or category of the room reserved\\\",\\n            \\\"example\\\": \\\"Deluxe Suite\\\"\\n          },\\n          \\\"pricing\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Pricing\\\"\\n          },\\n          \\\"requested_amenities\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of amenities requested by guest\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Amenity\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"reservation_id\\\", \\\"room_type\\\", \\\"pricing\\\", \\\"requested_amenities\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"root_schema\\\": {\\n    \\\"$ref\\\": \\\"#/components/schemas/HotelReservationResponse\\\"\\n  }\\n}\"\n}"
