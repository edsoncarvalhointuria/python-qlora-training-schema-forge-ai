erties:\\n        station_name:\\n          type: string\\n          description: 'Nome da estação de preparação'\\n          example: 'Grill'\\n        items:\\n          type: array\\n          description: 'Lista de itens a serem preparados nesta estação'\\n          items:\\n            $ref: '#/components/schemas/OrderedItem'\\n    KitchenDisplayTicket:\\n      type: object\\n      description: 'Ticket exibido na cozinha com número da mesa e itens agrupados por estação'\\n      properties:\\n        table_number:\\n          type: integer\\n          description: 'Número da mesa para o pedido'\\n          example: 12\\n        stations:\\n          type: array\\n          description: 'Lista de estações de preparação com seus itens'\\n          items:\\n            $ref: '#/components/schemas/PreparationStation'\\n\"\n}"
