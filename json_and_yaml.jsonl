 Widget\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantity of units ordered\\\",\\n            \\\"example\\\": 500\\n          },\\n          \\\"unit_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Price per individual unit\\\",\\n            \\\"example\\\": 10.50\\n          },\\n          \\\"discount_tiers\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of tiered discounts applied based on quantities\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/DiscountTier\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"sku\\\", \\\"description\\\", \\\"quantity\\\", \\\"unit_price\\\", \\\"discount_tiers\\\"]\\n      },\\n      \\\"FreightTerms\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Shipping and freight related terms\\\",\\n        \\\"properties\\\": {\\n          \\\"shipping_method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Incoterm or shipping method agreed\\\",\\n            \\\"example\\\": \\\"FOB\\\"\\n          },\\n          \\\"carrier\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the shipping carrier\\\",\\n            \\\"example\\\": \\\"FastShip Logistics\\\"\\n          },\\n          \\\"estimated_delivery_days\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Expected number of days for delivery\\\",\\n            \\\"example\\\": 7\\n          },\\n          \\\"shipping_cost\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Cost of freight/shipping\\\",\\n            \\\"example\\\": 150.