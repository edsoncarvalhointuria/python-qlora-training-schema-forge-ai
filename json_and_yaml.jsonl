"{\n  \"raw_json\": {\n    \"soilMoisture\": 23.5,\n    \"weatherForecast\": {\n      \"temperature\": 18.7,\n      \"humidity\": 76,\n      \"precipitationProbability\": 40,\n      \"forecastTime\": \"2024-06-10T15:00:00Z\"\n    },\n    \"recentIrrigationEvents\": [\n      {\n        \"eventId\": \"ev1234\",\n        \"startTime\": \"2024-06-09T06:30:00Z\",\n        \"durationMinutes\": 15,\n        \"waterUsedLiters\": 120\n      },\n      {\n        \"eventId\": \"ev1235\",\n        \"startTime\": \"2024-06-08T18:00:00Z\",\n        \"durationMinutes\": 20,\n        \"waterUsedLiters\": 150\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Smart Agriculture Sensor Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherForecast:\\n      type: object\\n      description: 'Weather forecast predictions including temperature, humidity, and precipitation probability'\\n      properties:\\n        temperature:\\n          type: number\\n          format: float\\n          description: 'Predicted temperature in degrees Celsius'\\n          example: 18.7\\n        humidity:\\n          type: integer\\n          description: 'Predicted relative humidity percentage'\\n          example: 76\\n        precipitationProbability:\\n          type: integer\\n          description: 'Probability of precipitation as a percentage'\\n          example: 40\\n        forecastTime:\\n          type: string\\n          format: date-time\\n          description: 'Timestamp for the forecast prediction in ISO 8601 format'\\n          example: '2024-06-10T15:00:00Z'\\n    IrrigationEvent:\\n      type: object\\n      description: 'Information about a single automated irrigation event'\\n      properties:\\n        eventId:\\n          type: string\\n          description: 'Unique identifier for the irrigation event'\\n          example: 'ev1234'\\n        startTime:\\n          type: string\\n          format: date-time\\n          description: 'Start time of the irrigation event in ISO 8601 format'\\n          example: '2024-06-09T06:30:00Z'\\n        durationMinutes:\\n          type: integer\\n          description: 'Duration of the irrigation event in minutes'\\n          example: 15\\n        waterUsedLiters:\\n          type: integer\\n          description: 'Amount of water used during the irrigation event in liters'\\n          example: 120\\n    SensorResponse:\\n      type: object\\n      description: 'Response containing soil moisture, weather forecast, and recent irrigation events from the sensor'\\n      properties:\\n        soilMoisture:\\n          type: number\\n          format: float\\n          description: 'Current soil moisture level as a percentage'\\n          example: 23.5\\n        weatherForecast:\\n          $ref: '#/components/schemas/WeatherForecast'\\n        recentIrrigationEvents:\\n          type: array\\n          description: 'List of recent automated irrigation events'\\n          items:\\n            $ref: '#/components/schemas/IrrigationEvent'\\n\"\n}"
