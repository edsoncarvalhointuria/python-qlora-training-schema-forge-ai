"{\n  \"raw_json\": {\n    \"appointment_id\": \"appt_4567\",\n    \"pet\": {\n      \"name\": \"Buddy\",\n      \"species\": \"Dog\",\n      \"breed\": \"Golden Retriever\",\n      \"weight_kg\": 30.5\n    },\n    \"owner\": {\n      \"owner_id\": \"owner_890\",\n      \"full_name\": \"Alice Johnson\",\n      \"phone\": \"+1234567890\",\n      \"email\": \"alice.johnson@example.com\"\n    },\n    \"procedure\": {\n      \"procedure_id\": \"proc_301\",\n      \"name\": \"Vaccination\",\n      \"description\": \"Rabies vaccine administration\",\n      \"scheduled_date\": \"2024-07-20T10:30:00Z\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Veterinary Clinic Appointment Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Pet:\\n      type: object\\n      description: 'Details about the pet'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Name of the pet'\\n          example: 'Buddy'\\n        species:\\n          type: string\\n          description: 'Species of the pet'\\n          example: 'Dog'\\n        breed:\\n          type: string\\n          description: 'Breed of the pet'\\n          example: 'Golden Retriever'\\n        weight_kg:\\n          type: number\\n          format: float\\n          description: 'Weight of the pet in kilograms'\\n          example: 30.5\\n    Owner:\\n      type: object\\n      description: 'Owner contact information'\\n      properties:\\n        owner_id:\\n          type: string\\n          description: 'Unique identifier for the owner'\\n          example: 'owner_890'\\n        full_name:\\n          type: string\\n          description: 'Full name of the owner'\\n          example: 'Alice Johnson'\\n        phone:\\n          type: string\\n          description: 'Contact phone number of the owner'\\n          example: '+1234567890'\\n        email:\\n          type: string\\n          description: 'Email address of the owner'\\n          example: 'alice.johnson@example.com'\\n    Procedure:\\n      type: object\\n      description: 'Details about the scheduled procedure'\\n      properties:\\n        procedure_id:\\n          type: string\\n          description: 'Unique identifier for the procedure'\\n          example: 'proc_301'\\n        name:\\n          type: string\\n          description: 'Name of the procedure'\\n          example: 'Vaccination'\\n        description:\\n          type: string\\n          description: 'Detailed description of the procedure'\\n          example: 'Rabies vaccine administration'\\n        scheduled_date:\\n          type: string\\n          format: date-time\\n          description: 'Scheduled date and time of the procedure in ISO 8601 format'\\n          example: '2024-07-20T10:30:00Z'\\n    AppointmentResponse:\\n      type: object\\n      description: 'Response containing appointment details including pet, owner, and procedure'\\n      properties:\\n        appointment_id:\\n          type: string\\n          description: 'Unique identifier for the appointment'\\n          example: 'appt_4567'\\n        pet:\\n          $ref: '#/components/schemas/Pet'\\n        owner:\\n          $ref: '#/components/schemas/Owner'\\n        procedure:\\n          $ref: '#/components/schemas/Procedure'\"\n}"
