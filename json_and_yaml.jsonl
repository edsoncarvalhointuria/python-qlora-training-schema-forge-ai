"{\n  \"raw_json\": {\n    \"appointment_id\": \"apt-123456\",\n    \"scheduled_date\": \"2024-07-15T10:30:00Z\",\n    \"procedure\": {\n      \"procedure_code\": \"PROC789\",\n      \"procedure_name\": \"Vaccination\",\n      \"description\": \"Routine annual vaccination for dogs\"\n    },\n    \"pet\": {\n      \"pet_id\": \"pet-987654\",\n      \"name\": \"Buddy\",\n      \"species\": \"Dog\",\n      \"breed\": \"Golden Retriever\",\n      \"weight_kg\": 30.5\n    },\n    \"owner\": {\n      \"owner_id\": \"owner-112233\",\n      \"full_name\": \"Jane Doe\",\n      \"contact\": {\n        \"email\": \"jane.doe@example.com\",\n        \"phone\": \"+1234567890\"\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Veterinary Clinic Appointment Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ContactInfo:\\n      type: object\\n      description: Contact information for a person\\n      properties:\\n        email:\\n          type: string\\n          description: Email address for contact\\n          example: jane.doe@example.com\\n        phone:\\n          type: string\\n          description: Phone number for contact\\n          example: '+1234567890'\\n    Owner:\\n      type: object\\n      description: Owner of the pet\\n      properties:\\n        owner_id:\\n          type: string\\n          description: Unique identifier for the pet owner\\n          example: owner-112233\\n        full_name:\\n          type: string\\n          description: Full name of the pet owner\\n          example: Jane Doe\\n        contact:\\n          $ref: '#/components/schemas/ContactInfo'\\n    Pet:\\n      type: object\\n      description: Details about the pet\\n      properties:\\n        pet_id:\\n          type: string\\n          description: Unique identifier for the pet\\n          example: pet-987654\\n        name:\\n          type: string\\n          description: Name of the pet\\n          example: Buddy\\n        species:\\n 