ider\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Provider\\\"\\n          },\\n          \\\"procedures_billed\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of medical procedures billed in the claim\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/ProcedureBilled\\\"\\n            }\\n          },\\n          \\\"costs\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Costs\\\"\\n          }\\n        }\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"security\\\": []\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"tooth_chart\": {\n      \"tooth_number\": \"12\",\n      \"tooth_name\": \"Upper Left First Premolar\",\n      \"condition\": \"Filling\",\n      \"notes\": \"Composite resin filling on occlusal surface\"\n    },\n    \"past_procedures\": [\n      {\n        \"procedure_id\": \"proc_1001\",\n        \"procedure_name\": \"Root Canal Treatment\",\n        \"date_performed\": \"2023-11-05\",\n        \"dentist\": {\n          \"id\": \"dent_45\",\n          \"name\": \"Dra. Ana Silva\"\n        },\n        \"notes\": \"Successful treatment, no complications\"\n      },\n      {\n        \"procedure_id\": \"proc_1002\",\n        \"procedure_name\": \"Teeth Whitening\",\n        \"date_performed\": \"2024-01-20\",\n        \"dentist\": {\n          \"id\": \"dent_33\",\n          \"name\": \"Dr. João Pereira\"\n        },\n        \"notes\": \"Patient satisfied with results\"\n      }\n    ],\n    \"upcoming_cleanings\": {\n      \"next_cleaning_date\": \"2024-07-15\",\n      \"location\": \"Clinic A - Room 3\",\n      \"reminder_sent\": true,\n      \"reminder_metadata\": {\n        \"method\": \"email\",\n        \"sent_at\": \"2024-06-15T09:00:00Z\",\n        \"confirmed\": false\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Dental Clinic Patient History API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ToothChart:\\n      type: object\\n      description: 'Informações anatômicas do dente do paciente'\\n      properties:\\n        tooth_number:\\n          type: string\\n          description: 'Número anatômico do dente'\\n          example: '12'\\n        tooth_name:\\n          type: string\\n          description: 'Nome do dente'\\n          example: 'Upper Left First Premolar'\\n        condition:\\n          type: string\\n          description: 'Condição atual do dente'\\n          example: 'Filling'\\n        notes:\\n          type: string\\n          description: 'Observações adicionais sobre o dente'\\n          example: 'Composite resin filling on occlusal surface'\\n    Dentist:\\n      type: object\\n      description: 'Detalhes do dentista responsável pelo procedimento'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Identificador único do dentista'\\n          example: 'dent_45'\\n        name:\\n          type: string\\n          description: 'Nome completo do dentista'\\n          example: 'Dra. Ana Silva'\\n    PastProcedure:\\n      type: object\\n      description: 'Registro de procedimento odontológico realizado anteriormente'\\n      properties:\\n        procedure_id:\\n          type: string\\n          description: 'Identificador único do procedimento'\\n          example: 'proc_1001'\\n        procedure_name:\\n          type: string\\n          description: 'Nome do procedimento realizado'\\n          example: 'Root Canal Treatment'\\n        date_performed:\\n          type: string\\n          format: date\\n          description: 'Data em que o procedimento foi realizado'\\n          example: '2023-11-05'\\n        dentist:\\n          $ref: '#/components/schemas/Dentist'\\n        notes:\\n          type: string\\n          description: 'Observações relevantes do procedimento'\\n          example: 'Successful treatment, no complications'\\n    ReminderMetadata:\\n      type: object\\n      description: 'Metadados sobre o lembrete enviado para a limpeza agendada'\\n      properties:\\n        method:\\n          type: string\\n          description: 'Método utilizado para envio do lembrete'\\n          example: 'email'\\n        sent_at:\\n          type: string\\n          format: date-time\\n          description: 'Data e hora em que o lembrete foi enviado'\\n          example: '2024-06-15T09:00:00Z'\\n        confirmed:\\n          type: boolean\\n          description: 'Confirmação do paciente sobre o agendamento'\\n          example: false\\n    UpcomingCleanings:\\n      type: object\\n      description: 'Informações sobre limpezas agendadas futuras'\\n      properties:\\n        next_cleaning_date:\\n          type: string\\n          format: date\\n          description: 'Data da próxima limpeza agendada'\\n          example: '2024-07-15'\\n        location:\\n          type: string\\n          description: 'Local onde ocorrerá a limpeza'\\n          example: 'Clinic A - Room 3'\\n        reminder_sent:\\n          type: boolean\\n          description: 'Indica se o lembrete foi enviado'\\n          example: true\\n        reminder_metadata:\\n          $ref: '#/components/schemas/ReminderMetadata'\\n    PatientHistory:\\n      type: object\\n      description: 'Histórico completo do paciente na clínica odontológica'\\n      properties:\\n        tooth_chart:\\n          $ref: '#/components/schemas/ToothChart'\\n        past_procedures:\\n          type: array\\n          description: 'Lista de procedimentos anteriores realizados pelo paciente'\\n          items:\\n            $ref: '#/components/schemas/PastProcedure'\\n        upcoming_cleanings:\\n          $ref: '#/components/schemas/UpcomingCleanings'\\n\"\n}"
