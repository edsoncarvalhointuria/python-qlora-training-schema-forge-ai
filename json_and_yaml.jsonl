"{\n  \"raw_json\": {\n    \"property_id\": \"prop_12345\",\n    \"address\": \"123 Maple Street, Springfield, IL 62704\",\n    \"architectural_specs\": {\n      \"area_sq_ft\": 3500,\n      \"bedrooms\": 4,\n      \"bathrooms\": 3.5,\n      \"year_built\": 2015,\n      \"style\": \"Modern\"\n    },\n    \"images\": [\n      {\n        \"url\": \"https://example.com/images/property_12345_front.jpg\",\n        \"description\": \"Front view of the house\"\n      },\n      {\n        \"url\": \"https://example.com/images/property_12345_kitchen.jpg\",\n        \"description\": \"Modern kitchen with island\"\n      },\n      {\n        \"url\": \"https://example.com/images/property_12345_backyard.jpg\",\n        \"description\": \"Spacious backyard with pool\"\n      }\n    ],\n    \"realtor\": {\n      \"name\": \"Jane Doe\",\n      \"phone\": \"+1-555-123-4567\",\n      \"email\": \"jane.doe@realestateco.com\",\n      \"agency\": \"Real Estate Co\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Real Estate Property Listing\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Architectural specifications of the property'\\n      properties:\\n        area_sq_ft:\\n          type: integer\\n          description: 'Total living area in square feet'\\n          example: 3500\\n        bedrooms:\\n          type: integer\\n          description: 'Number of bedrooms'\\n          example: 4\\n        bathrooms:\\n          type: number\\n          format: float\\n          description: 'Number of bathrooms, including partials'\\n          example: 3.5\\n        year_built:\\n          type: integer\\n          description: 'Year the property was built'\\n          example: 2015\\n        style:\\n          type: string\\n          description: 'Architectural style of the property'\\n          example: 'Modern'\\n    Image:\\n      type: object\\n      description: 'High-resolution image details of the property'\\n      properties:\\n        url:\\n          type: string\\n          format: uri\\n          description: 'URL to the high-resolution image'\\n          example: 'https://example.com/images/property_12345_front.jpg'\\n        description:\\n          type: string\\n          description: 'Short description of the image content'\\n          example: 'Front view of the house'\\n    RealtorContact:\\n      type: object\\n      description: 'Contact details for the assigned realtor'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Full name of the realtor'\\n          example: 'Jane Doe'\\n        phone:\\n          type: string\\n          description: 'Contact phone number of the realtor'\\n          example: '+1-555-123-4567'\\n        email:\\n          type: string\\n          format: email\\n          description: 'Email address of the realtor'\\n          example: 'jane.doe@realestateco.com'\\n        agency:\\n          type: string\\n          description: 'Real estate agency the realtor belongs to'\\n          example: 'Real Estate Co'\\n    PropertyListing:\\n      type: object\\n      description: 'Complete real estate property listing with specs, images, and realtor info'\\n      properties:\\n        property_id:\\n          type: string\\n          description: 'Unique identifier of the property listing'\\n          example: 'prop_12345'\\n        address:\\n          type: string\\n          description: 'Full physical address of the property'\\n          example: '123 Maple Street, Springfield, IL 62704'\\n        architectural_specs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n          description: 'List of high-resolution property images'\\n          items:\\n            $ref: '#/components/schemas/Image'\\n        realtor:\\n          $ref: '#/components/schemas/RealtorContact'\\n\"\n}"
