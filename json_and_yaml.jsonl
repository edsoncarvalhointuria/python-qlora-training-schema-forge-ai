ile including biography, top streamed tracks, and upcoming tour'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier of the artist'\\n          example: 'artist_12345'\\n        name:\\n          type: string\\n          description: 'Name of the artist or band'\\n          example: 'The Melodics'\\n        biography:\\n          type: string\\n          description: 'Biography or description of the artist'\\n          example: 'An indie rock band from Seattle known for their melodic tunes and heartfelt lyrics.'\\n        origin:\\n          type: string\\n          description: 'Origin city and country of the artist'\\n          example: 'Seattle, Washington, USA'\\n        genre:\\n          type: string\\n          description: 'Primary genre of the artist'\\n          example: 'Indie Rock'\\n        years_active:\\n          type: string\\n          description: 'Active years of the artist'\\n          example: '2010–present'\\n        top_streamed_tracks:\\n          type: array\\n          description: 'List of top streamed tracks by the artist'\\n          items:\\n            $ref: '#/components/schemas/Track'\\n        upcoming_tour:\\n          $ref: '#/components/schemas/UpcomingTour'\\n  schemas:\\n    ArtistProfileResponse:\\n      type: object\\n      description: 'Response containing artist profile data'\\n      properties:\\n        artist:\\n          $ref: '#/components/schemas/ArtistProfile'\"\n}"
