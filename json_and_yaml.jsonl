"{\n  \"raw_json\": {\n    \"table_number\": 12,\n    \"stations\": [\n      {\n        \"station_name\": \"Grill\",\n        \"items\": [\n          {\n            \"item_name\": \"Cheeseburger\",\n            \"quantity\": 2,\n            \"allergy_warnings\": [\"Gluten\", \"Dairy\"]\n          },\n          {\n            \"item_name\": \"Grilled Chicken\",\n            \"quantity\": 1,\n            \"allergy_warnings\": []\n          }\n        ]\n      },\n      {\n        \"station_name\": \"Salad\",\n        \"items\": [\n          {\n            \"item_name\": \"Caesar Salad\",\n            \"quantity\": 1,\n            \"allergy_warnings\": [\"Egg\"]\n          }\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Kitchen Display Ticket\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Item:\\n      type: object\\n      description: 'Individual ordered item details'\\n      properties:\\n        item_name:\\n          type: string\\n          description: 'Name of the menu item ordered'\\n          example: 'Cheeseburger'\\n        quantity:\\n          type: integer\\n          description: 'Number of this item ordered'\\n          example: 2\\n        allergy_warnings:\\n          type: array\\n          description: 'List of allergy warnings associated with this item'\\n          items:\\n            type: string\\n            description: 'An allergen warning'\\n            example: 'Gluten'\\n    Station:\\n      type: object\\n      description: 'Preparation station grouping with its ordered items'\\n      properties:\\n        station_name:\\n          type: string\\n          description: 'Name of the kitchen preparation station'\\n          example: 'Grill'\\n        items:\\n          type: array\\n          description: 'Ordered items assigned to this station'\\n          items:\\n            $ref: '#/components/schemas/Item'\\n    KitchenTicket:\\n      type: object\\n      description: 'Complete kitchen t