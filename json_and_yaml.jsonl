        \\\"description\\\": \\\"Lista de subtópicos que serão estudados\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Subtópico detalhado\\\",\\n              \\\"example\\\": \\\"Histórico e evolução\\\"\\n            },\\n            \\\"example\\\": [\\\"Histórico e evolução\\\", \\\"Modelos de processo\\\", \\\"Princípios básicos\\\"]\\n          },\\n          \\\"reading_list\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de livros texto recomendados para a semana\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Textbook\\\"\\n            },\\n            \\\"example\\\": [\\n              {\\n                \\\"title\\\": \\\"Software Engineering (10th Edition)\\\",\\n                \\\"author\\\": \\\"Ian Sommerville\\\",\\n                \\\"isbn\\\": \\\"978-1292156138\\\"\\n              }\\n            ]\\n          }\\n        },\\n        \\\"required\\\": [\\\"week\\\", \\\"topic\\\", \\\"subtopics\\\", \\\"reading_list\\\"]\\n      },\\n      \\\"CourseSyllabus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Estrutura completa da ementa do curso universitário\\\",\\n        \\\"properties\\\": {\\n          \\\"course_title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome oficial do curso\\\",\\n            \\\"example\\\": \\\"Advanced Software Engineering\\\"\\n          },\\n          \\\"professor\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Professor\\\"\\n          },\\n          \\\"weekly_modules\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de módulos semanais com tópicos e leituras\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/WeeklyModule\\\"\\n            }\\n          }\\n        },\\