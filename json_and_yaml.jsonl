he product\\\",\\n            \\\"example\\\": \\\"Industrial Widget\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantity ordered in bulk\\\",\\n            \\\"example\\\": 500\\n          },\\n          \\\"unit_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Price per individual unit before discounts\\\",\\n            \\\"example\\\": 15.75\\n          },\\n          \\\"discounts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of tiered discounts applicable to this order item\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Discount\\\"\\n            }\\n          },\\n          \\\"final_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total price after applying tiered discounts\\\",\\n            \\\"example\\\": 7087.5\\n          }\\n        },\\n        \\\"required\\\": [\\\"product_code\\\", \\\"product_name\\\", \\\"quantity\\\", \\\"unit_price\\\", \\\"discounts\\\", \\\"final_price\\\"]\\n      },\\n      \\\"FreightShippingTerms\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Terms and costs related to freight and shipping\\\",\\n        \\\"properties\\\": {\\n          \\\"carrier\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the shipping carrier\\\",\\n            \\\"example\\\": \\\"TransGlobal Shipping\\\"\\n          },\\n          \\\"incoterm\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"International commercial term defining shipping responsibilities\\\",\\n            \\\"example\\\": \\\"FOB\\\"\\n          },\\n          \\\"estimated_delivery_days\\\":