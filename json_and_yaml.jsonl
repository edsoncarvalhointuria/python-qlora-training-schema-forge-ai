"{\n  \"raw_json\": {\n    \"user_profile\": {\n      \"user_id\": \"user_987\",\n      \"full_name\": \"Jane Doe\",\n      \"email\": \"jane.doe@example.com\"\n    },\n    \"current_balance\": {\n      \"currency\": \"USD\",\n      \"amount\": 2540.75\n    },\n    \"recent_transactions\": [\n      {\n        \"transaction_id\": \"txn_1001\",\n        \"date\": \"2024-06-10T14:12:00Z\",\n        \"type\": \"debit\",\n        \"amount\": 150.00,\n        \"currency\": \"USD\",\n        \"description\": \"Grocery Store Purchase\"\n      },\n      {\n        \"transaction_id\": \"txn_1002\",\n        \"date\": \"2024-06-09T09:30:00Z\",\n        \"type\": \"credit\",\n        \"amount\": 500.00,\n        \"currency\": \"USD\",\n        \"description\": \"Salary Payment\"\n      },\n      {\n        \"transaction_id\": \"txn_1003\",\n        \"date\": \"2024-06-08T18:45:00Z\",\n        \"type\": \"debit\",\n        \"amount\": 75.25,\n        \"currency\": \"USD\",\n        \"description\": \"Electricity Bill\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Digital Wallet Statement API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UserProfile:\\n      type: object\\n      description: 'Detailed information about the user'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'user_987'\\n        full_name:\\n          type: string\\n          description: 'Complete name of the user'\\n          example: 'Jane Doe'\\n        email:\\n          type: string\\n          description: 'User email address'\\n          example: 'jane.doe@example.com'\\n    Balance:\\n      type: object\\n      description: 'Current balance details of the digital wallet'\\n      properties:\\n        currency:\\n          type: string\\n          description: 'Currency code in ISO 4217 format'\\n          example: 'USD'\\n        amount:\\n          type: number\\n      