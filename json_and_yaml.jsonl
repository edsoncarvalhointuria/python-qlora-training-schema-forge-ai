ons for the item'\\n          example: 'No dressing'\\n    ReservationResponse:\\n      type: object\\n      description: 'Response schema for a restaurant reservation with pre-ordered items and dietary restrictions'\\n      properties:\\n        table_number:\\n          type: integer\\n          description: 'Assigned table number for the reservation'\\n          example: 12\\n        customer:\\n          $ref: '#/components/schemas/Customer'\\n        pre_ordered_items:\\n          type: array\\n          description: 'List of items pre-ordered by the customer'\\n          items:\\n            $ref: '#/components/schemas/PreOrderedItem'\\n\"\n}"
