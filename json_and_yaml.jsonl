ser:\\n      type: object\\n      description: 'Informações básicas do usuário que ocupa uma mesa'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário'\\n          example: 'usr_22'\\n        full_name:\\n          type: string\\n          description: 'Nome completo do usuário'\\n          example: 'Joana Silva'\\n    OccupiedHotDesk:\\n      type: object\\n      description: 'Detalhes de uma mesa hot-desk atualmente ocupada'\\n      properties:\\n        desk_id:\\n          type: string\\n          description: 'Identificador da mesa'\\n          example: 'hd_101'\\n        user:\\n          $ref: '#/components/schemas/User'\\n        occupied_since:\\n          type: string\\n          format: date-time\\n          description: 'Data e hora em que a mesa começou a ser ocupada'\\n          example: '2024-06-25T09:30:00Z'\\n    MeetingRoomReservation:\\n      type: object\\n      description: 'Reserva futura de uma sala de reuniões'\\n      properties:\\n        reservation_id:\\n          type: string\\n          description: 'Identificador único da reserva'\\n          example: 'res_870'\\n        room_name:\\n          type: string\\n          description: 'Nome da sala reservada'\\n          example: 'Sala A'\\n        reserved_by:\\n          type: string\\n          description: 'Nome da pessoa que realizou a reserva'\\n          example: 'Fernanda Costa'\\n        start_time:\\n          type: string\\n          format: date-time\\n          description: 'Horário de início da reserva'\\n          example: '2024-06-26T14:00:00Z'\\n        end_time:\\n          type: string\\n          format: date-time\\n          description: 'Horário de término da reserva'\\n          example: '2024-06-26T15:00:00Z'\\n    DeskAvailabilityReport:\\n      type: object\\n      description: 'Relatório geral da disponibilidade de mesas no espaço de coworking'\\n      properties:\\n        floor_plan:\\n          $ref: '#/components/schemas/FloorPlan'\\n        occupied_hot_desks:\\n          type: array\\n          description: 'Lista de mesas hot-desk atualmente ocupadas'\\n          items:\\n            $ref: '#/components/schemas/OccupiedHotDesk'\\n        meeting_room_reservations:\\n          type: array\\n          description: 'Lista de reservas futuras para salas de reuniões'\\n          items:\\n            $ref: '#/components/schemas/MeetingRoomReservation'\\n\"\n}"
"{\n  \"raw_json\": {\n    \"course_id\": \"CS101\",\n    \"course_name\": \"Introduction to Computer Science\",\n    \"professor\": {\n      \"name\": \"Dr. Ana Silva\",\n      \"academic_background\": \"PhD em Ciência da Computação pela USP\",\n      \"contact_email\": \"ana.silva@university.edu.br\"\n    },\n    \"weekly_modules\": [\n      {\n        \"week\": 1,\n        \"title\": \"Fundamentos de Computação\",\n        \"topics\": [\"História da Computação\", \"Arquitetura de Computadores\"],\n        \"reading_list\": [\n          {\n            \"title\": \"Computer Science: An Overview\",\n            \"author\": \"J. Glenn Brookshear\",\n            \"edition\": \"13th\",\n            \"publisher\": \"Pearson\"\n          }\n        ]\n      },\n      {\n        \"week\": 2,\n        \"title\": \"Lógica e Algoritmos\",\n        \"topics\": [\"Algoritmos Simples\", \"Lógica Matemática\"],\n        \"reading_list\": [\n          {\n            \"title\": \"Introduction to Algorithms\",\n            \"author\": \"Cormen, Leiserson, Rivest, Stein\",\n            \"edition\": \"3rd\",\n            \"publisher\": \"MIT Press\"\n          },\n          {\n            \"title\": \"Discrete Mathematics and Its Applications\",\n            \"author\": \"Kenneth H. Rosen\",\n            \"edition\": \"7th\",\n            \"publisher\": \"McGraw-Hill\"\n          }\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Síntese do Curso Universitário\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Textbook\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes do livro didático requerido para o curso\\\",\\n        \\\"properties\\\": {\\n          \\\"title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Título do livro\\\",\\n            \\\"example\\\": \\\"Computer Science: An Overview\\\"\\n          },\\n          \\\"author\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Autor(es) do livro\\\",\\n            \\\"example\\\": \\\"J. Glenn Brookshear\\\"\\n          },\\n          \\\"edition\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Edição do livro\\\",\\n            \\\"example\\\": \\\"13th\\\"\\n          },\\n          \\\"publisher\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Editora do livro\\\",\\n            \\\"example\\\": \\\"Pearson\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"title\\\", \\\"author\\\", \\\"edition\\\", \\\"publisher\\\"]\\n      },\\n      \\\"WeeklyModule\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações do módulo semanal do curso\\\",\\n        \\\"properties\\\": {\\n          \\\"week\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Número da semana no curso\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Título do módulo semanal\\\",\\n            \\\"example\\\": \\\"Fundamentos de Computação\\\"\\n          },\\n          \\\"topics\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista dos tópicos principais abordados na semana\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Um tópico específico da semana\\\",\\n              \\\"example\\\": \\\"História da Computação\\\"\\n            }\\n          },\\n          \\\"reading_list\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de livros recomendados ou requeridos para a semana\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/Textbook\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"week\\\", \\\"title\\\", \\\"topics\\\", \\\"reading_list\\\"]\\n      },\\n      \\\"Professor\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações acadêmicas do professor responsável pelo curso\\\",\\n        \\\"properties\\\": {\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome completo do professor\\\",\\n            \\\"example\\\": \\\"Dr. Ana Silva\\\"\\n          },\\n          \\\"academic_background\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Formação acadêmica e títulos do professor\\\",\\n            \\\"example\\\": \\\"PhD em Ciência da Computação pela USP\\\"\\n          },\\n          \\\"contact_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Email para contato acadêmico\\\",\\n            \\\"example\\\": \\\"ana.silva@university.edu.br\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"name\\\", \\\"academic_background\\\", \\\"contact_email\\\"]\\n      },\\n      \\\"CourseSyllabus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Ementa detalhada do curso universitário incluindo professor, módulos e leitura\\\",\\n        \\\"properties\\\": {\\n          \\\"course_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do curso\\\",\\n            \\\"example\\\": \\\"CS101\\\"\\n          },\\n          \\\"course_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome oficial do curso\\\",\\n            \\\"example\\\": \\\"Introduction to Computer Science\\\"\\n          },\\n          \\\"professor\\\": { \\\"$ref\\\": \\\"#/components/schemas/Professor\\\" },\\n          \\\"