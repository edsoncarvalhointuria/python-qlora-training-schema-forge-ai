Response detailing tax return assessment with income, deductions, and tax summary\\\",\\n        \\\"properties\\\": {\\n          \\\"citizen_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the citizen\\\",\\n            \\\"example\\\": \\\"123-45-6789\\\"\\n          },\\n          \\\"declared_income\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total income declared by the citizen\\\",\\n            \\\"example\\\": 85000.00\\n          },\\n          \\\"deductions\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of tax deductions with detailed entries\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/Deduction\\\" }\\n          },\\n          \\\"tax_summary\\\": { \\\"$ref\\\": \\\"#/components/schemas/TaxSummary\\\" }\\n        },\\n        \\\"required\\\": [\\\"citizen_id\\\", \\\"declared_income\\\", \\\"deductions\\\", \\\"tax_summary\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
