yment_transaction\\\", \\\"_links\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"examples\\\": {},\\n  \\\"root_schema\\\": {\\n    \\\"$ref\\\": \\\"#/components/schemas/OrderResponse\\\"\\n  }\\n}\"\n}"
