\\"description\\\": \\\"Name of the port where the container is currently located\\\",\\n            \\\"example\\\": \\\"Port of Rotterdam\\\"\\n          },\\n          \\\"customs_clearance\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/CustomsClearanceStatus\\\"\\n          },\\n          \\\"environmental_readings\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of environmental measurements inside the container over time\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/EnvironmentalReading\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"container_id\\\", \\\"current_port\\\", \\\"customs_clearance\\\", \\\"environmental_readings\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  }\\n}\"\n}"
