ionResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response containing detailed hotel reservation information\\\",\\n        \\\"properties\\\": {\\n          \\\"reservation_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the reservation\\\",\\n            \\\"example\\\": \\\"res_1023\\\"\\n          },\\n          \\\"room_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of room reserved\\\",\\n            \\\"example\\\": \\\"Deluxe Suite\\\"\\n          },\\n          \\\"pricing\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Pricing\\\"\\n          },\\n          \\\"requested_amenities\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of amenities requested for the stay\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Amenity name\\\",\\n              \\\"example\\\": \\\"crib\\\"\\n            },\\n            \\\"example\\\": [\\\"crib\\\", \\\"extra_bed\\\"]\\n          }\\n        },\\n        \\\"required\\\": [\\\"reservation_id\\\", \\\"room_type\\\", \\\"pricing\\\", \\\"requested_amenities\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
