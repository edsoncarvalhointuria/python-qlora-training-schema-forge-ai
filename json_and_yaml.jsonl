"{\n  \"raw_json\": {\n    \"vehicle_id\": \"veh_1024\",\n    \"timestamp\": \"2024-06-15T09:30:00Z\",\n    \"location\": {\n      \"latitude\": 37.7749,\n      \"longitude\": -122.4194\n    },\n    \"speed_kmph\": 65.5,\n    \"battery_health\": {\n      \"charge_level_percent\": 78,\n      \"temperature_celsius\": 35.2,\n      \"voltage_volts\": 400,\n      \"status\": \"Healthy\"\n    },\n    \"driving_anomalies\": [\n      {\n        \"type\": \"Hard Braking\",\n        \"timestamp\": \"2024-06-15T09:28:45Z\",\n        \"severity_level\": 3,\n        \"description\": \"Severe deceleration detected over 3 seconds\"\n      },\n      {\n        \"type\": \"Rapid Acceleration\",\n        \"timestamp\": \"2024-06-15T09:29:20Z\",\n        \"severity_level\": 2,\n        \"description\": \"Sudden increase in speed within 2 seconds\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Autonomous Fleet Vehicle Telemetry Ping\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Location\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"GPS coordinates of the vehicle's current position\\\",\\n        \\\"properties\\\": {\\n          \\\"latitude\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Latitude coordinate in decimal degrees\\\",\\n            \\\"example\\\": 37.7749\\n          },\\n          \\\"longitude\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Longitude coordinate in decimal degrees\\\",\\n            \\\"example\\\": -122.4194\\n          }\\n        },\\n        \\\"required\\\": [\\\"latitude\\\", \\\"longitude\\\"]\\n      },\\n      \\\"BatteryHealth\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Diagnostics information about the vehicle battery health\\\",\\n        \\\"properties\\\": {\\n          \\\"charge_level_percent\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Current battery charge level as a percentage\\\",\\n            \\\"example\\\": 78\\n          },\\n          \\\"temperature_celsius\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Battery temperature in degrees Celsius\\\",\\n            \\\"example\\\": 35.2\\n          },\\n          \\\"voltage_volts\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Battery voltage in volts\\\",\\n            \\\"example\\\": 400\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Overall health status of the battery\\\",\\n            \\\"example\\\": \\\"Healthy\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"charge_level_percent\\\", \\\"temperature_celsius\\\", \\\"voltage_volts\\\", \\\"status\\\"]\\n      },\\n      \\\"DrivingAnomaly\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Record representing a recent driving anomaly detected by the vehicle\\\",\\n        \\\"properties\\\": {\\n          \\\"type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Category or type of anomaly\\\",\\n            \\\"example\\\": \\\"Hard Braking\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"ISO8601 timestamp when the anomaly occurred\\\",\\n            \\\"example\\\": \\\"2024-06-15T09:28:45Z\\\"\\n          },\\n          \\\"severity_level\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Severity level of the anomaly (e.g., 1=low, 5=high)\\\",\\n            \\\"example\\\": 3\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Detailed description of the anomaly\\\",\\n            \\\"example\\\": \\\"Severe deceleration detected over 3 seconds\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"type\\\", \\\"timestamp\\\", \\\"severity_level\\\", \\\"description\\\"]\\n      },\\n      \\\"TelemetryPing\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Telemetry data ping from an autonomous fleet vehicle\\\",\\n        \\\"properties\\\": {\\n          \\\"vehicle_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the vehicle\\\",\\n            \\\"example\\\": \\\"veh_1024\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"ISO8601 timestamp when telemetry was recorded\\\",\\n            \\\"example\\\": \\\"2024-06-15T09:30:00Z\\\"\\n          },\\n          \\\"location\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Location\\\"\\n          },\\n          \\\"speed_kmph\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Current speed of the vehicle in kilometers per hour\\\",\\n            \\\"example\\\": 65.5\\n          },\\n          \\\"battery_health\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BatteryHealth\\\"\\n          },\\n          \\\"driving_anomalies\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of recent detected driving anomalies\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/DrivingAnomaly\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"vehicle_id\\\", \\\"timestamp\\\", \\\"location\\\", \\\"speed_kmph\\\", \\\"battery_health\\\", \\\"driving_anomalies\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  },\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"root\\\": {\\n    \\\"$ref\\\": \\\"#/components/schemas/TelemetryPing\\\"\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"intersection_id\": \"INT12345\",\n    \"congestion_level\": \"high\",\n    \"detected_vehicles\": [\n      {\n        \"vehicle_type\": \"car\",\n        \"count\": 15\n      },\n      {\n        \"vehicle_type\": \"bus\",\n        \"count\": 3\n      },\n      {\n        \"vehicle_type\": \"motorcycle\",\n        \"count\": 7\n      }\n    ],\n    \"pedestrian_crossings\": [\n      {\n        \"crossing_id\": \"CR001\",\n        \"is_alert_active\": true,\n        \"alert_message\": \"Pedestres atravessando ativamente\"\n      },\n      {\n        \"crossing_id\": \"CR002\",\n        \"is_alert_active\": false,\n        \"alert_message\": \"Nenhuma atividade detectada\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Relatório da Câmera de Trânsito da Cidade Inteligente\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    VehicleInfo:\\n      type: object\\n      description: 'Informação sobre um tipo específico de veículo detectado no cruzamento'\\n      properties:\\n        vehicle_type:\\n          type: string\\n          description: 'Tipo do veículo detectado'\\n          example: 'car'\\n        count:\\n          type: integer\\n          description: 'Quantidade de veículos deste tipo detectados'\\n          example: 15\\n    PedestrianCrossingAlert:\\n      type: object\\n      description: 'Informações sobre alertas ativos nos cruzamentos de pedestres'\\n      properties:\\n        crossing_id:\\n          type: string\\n          description: 'Identificador único do cruzamento de pedestres'\\n          example: 'CR001'\\n        is_alert_active:\\n          type: boolean\\n          description: 'Indica se o alerta de travessia está ativo'\\n          example: true\\n        alert_message:\\n          type: string\\n          description: 'Mensagem descrevendo o estado atual do alerta'\\n          example: 'Pedestres atravessando ativamente'\\n    TrafficCameraReport:\\n      type: object\\n      description: 'Relatório gerado pela câmera de trânsito detalhando o congestionamento, veículos detectados e alertas de travessia'\\n      properties:\\n        intersection_id:\\n          type: string\\n          description: 'Identificador único do cruzamento monitorado'\\n          example: 'INT12345'\\n        congestion_level:\\n          type: string\\n          description: 'Nível de congestionamento no cruzamento'\\n          example: 'high'\\n        detected_vehicles:\\n          type: array\\n          description: 'Lista dos tipos de veículos detectados e suas quantidades'\\n          items:\\n            $ref: '#/components/schemas/VehicleInfo'\\n        pedestrian_crossings:\\n          type: array\\n          description: 'Lista de alertas ativos e inativos nas travessias de pedestres'\\n          items:\\n            $ref: '#/components/schemas/PedestrianCrossingAlert'\\n\"\n}"
"{\n  \"raw_json\": {\n    \"container_id\": \"CONT1234567\",\n    \"current_port_location\": {\n      \"port_name\": \"Port of Rotterdam\",\n      \"country\": \"Netherlands\",\n      \"arrival_date\": \"2024-06-15T08:30:00Z\"\n    },\n    \"customs_clearance_status\": {\n      \"status\": \"Cleared\",\n      \"inspection_date\": \"2024-06-16T14:00:00Z\",\n      \"notes\": \"No issues found during inspection\"\n    },\n    \"environmental_readings\": [\n      {\n        \"timestamp\": \"2024-06-16T12:00:00Z\",\n        \"temperature_celsius\": 5.3,\n        \"humidity_percent\": 68\n      },\n      {\n        \"timestamp\": \"2024-06-16T13:00:00Z\",\n        \"temperature_celsius\": 5.1,\n        \"humidity_percent\": 69\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Global Shipping Container Tracking Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PortLocation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the current port location of the container\\\",\\n        \\\"properties\\\": {\\n          \\\"port_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the port\\\",\\n            \\\"example\\\": \\\"Port of Rotterdam\\\"\\n          },\\n          \\\"country\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Country where the port is located\\\",\\n            \\\"example\\\": \\\"Netherlands\\\"\\n          },\\n          \\\"arrival_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Date and time when the container arrived at the port in ISO 8601 format\\\",\\n            \\\"example\\\": \\\"2024-06-15T08:30:00Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"port_name\\\", \\\"country\\\", \\\"arrival_date\\\"]\\n      },\\n      \\\"CustomsClearanceStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Status details of the customs clearance process\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Current customs clearance status\\\",\\n            \\\"example\\\": \\\"Cleared\\\"\\n          },\\n          \\\"inspection_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Date and time when customs inspection was done in ISO 8601 format\\\",\\n            \\\"example\\\": \\\"2024-06-16T14:00:00Z\\\"\\n          },\\n          \\\"notes\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Additional notes regarding customs clearance\\\",\\n            \\\"example\\\": \\\"No issues found during inspection\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"status\\\", \\\"inspection_date\\\"]\\n      },\\n      \\\"EnvironmentalReading\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Environmental sensor reading inside the container\\\",\\n        \\\"properties\\\": {\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Date and time when the environmental reading was recorded in ISO 8601 format\\\",\\n            \\\"example\\\": \\\"2024-06-16T12:00:00Z\\\"\\n          },\\n          \\\"temperature_celsius\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Temperature in degrees Celsius\\\",\\n            \\\"example\\\": 5.3\\n          },\\n          \\\"humidity_percent\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Relative humidity percentage\\\",\\n            \\\"example\\\": 68\\n          }\\n        },\\n        \\\"required\\\": [\\\"timestamp\\\", \\\"temperature_celsius\\\", \\\"humidity_percent\\\"]\\n      },\\n      \\\"ContainerTrackingResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response showing the current status and environmental data of a global shipping container\\\",\\n        \\\"properties\\\": {\\n          \\\"container_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the shipping container\\\",\\n            \\\"example\\\": \\\"CONT1234567\\\"\\n          },\\n          \\\"current_port_location\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/PortLocation\\\"\\n          },\\n          \\\"customs_clearance_status\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/CustomsClearanceStatus\\\"\\n          },\\n          \\\"environmental_readings\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of environmental sensor readings recorded in the container\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/EnvironmentalReading\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"container_id\\\", \\\"current_port_location\\\", \\\"customs_clearance_status\\\", \\\"environmental_readings\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  },\\n  \\\"definitions\\\": {},\\n  \\\"paths\\\": {},\\n  \\\"servers\\\": []\\n}\"\n}"
