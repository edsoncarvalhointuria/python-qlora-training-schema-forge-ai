e\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Street address\\\",\\n            \\\"example\\\": \\\"123 Commerce St\\\"\\n          },\\n          \\\"city\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"City name\\\",\\n            \\\"example\\\": \\\"Tradeville\\\"\\n          },\\n          \\\"state\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"State or province\\\",\\n            \\\"example\\\": \\\"TX\\\"\\n          },\\n          \\\"postal_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Postal or ZIP code\\\",\\n            \\\"example\\\": \\\"75001\\\"\\n          },\\n          \\\"country\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Country name\\\",\\n            \\\"example\\\": \\\"USA\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"street\\\",\\\"city\\\",\\\"state\\\",\\\"postal_code\\\",\\\"country\\\"]\\n      },\\n      \\\"BuyerCompany\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Buyer company profile information\\\",\\n        \\\"properties\\\": {\\n          \\\"company_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the buyer company\\\",\\n            \\\"example\\\": \\\"comp_456\\\"\\n          },\\n          \\\"company_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Official name of the buyer company\\\",\\n            \\\"example\\\": \\\"Global Wholesale Ltd\\\"\\n          },\\n          \\\"contact_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"Contact email address for the buyer company\\\",\\n            \\\"example\\\": \\\"contact@globalwholesale.com\\\"\\n          },\\n          \\\"address\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Address\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"company_id\\\",\\\"company_name\\\",\\\"contact_email\\\",\\\"address\\\"]\\n      },\\n      \\\"TieredDiscount\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Discount tier based on quantity ranges\\\",\\n        \\\"properties\\\": {\\n          \\\"min_quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Minimum quantity for this discount tier\\\",\\n            \\\"example\\\": 100\\n          },\\n          \\\"max_quantity\\\": {\\n            \\\"type\\\": [\\\"integer\\\", \\\"null\\\"],\\n            \\\"description\\\": \\\"Maximum quantity for this discount tier, null means no upper limit\\\",\\n            \\\"example\\\": 199\\n          },\\n          \\\"discount_percent\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Discount percentage applied for the tier\\\",\\n            \\\"example\\\": 5.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"min_quantity\\\",\\\"max_quantity\\\",\\\"discount_percent\\\"]\\n      },\\n      \\\"BulkItem\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details about a bulk item in the invoice\\\",\\n        \\\"properties\\\": {\\n          \\\"item_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the item\\\",\\n            \\\"example\\\": \\\"item_1001\\\"\\n          },\\n          \\\"product_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the product\\\",\\n            \\\"example\\\": \\\"Industrial Widget\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantity ordered\\\",\\n            \\\"example\\\": 500\\n          },\\n          \\\"unit_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Price per unit before discount\\\",\\n            \\\"example\\\": 15.0\\n          },\\n          \\\"tiered_discounts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of tiered discounts available for this item\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/TieredDiscount\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"item_id\\\",\\\"product_name\\\",\\\"quantity\\\",\\\"unit_price\\\",\\\"tiered_discounts\\\"]\\n      },\\n      \\\"FreightTerms\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Shipping and freight cost details\\\",\\n        \\\"properties\\\": {\\n          \\\"shipping_method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Freight shipping terms\\\",\\n            \\\"example\\\": \\\"FOB Shipping Point\\\"\\n          },\\n          \\\"freight_cost\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Cost of the freight shipping\\\",\\n            \\\"example\\\": 250.0\\n          },\\n          \\\"estimated_delivery_days\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Estimated number of days for delivery\\\",\\n            \\\"example\\\": 7\\n          },\\n          \\\"carrier\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the freight carrier\\\",\\n            \\\"example\\\": \\\"FastFreight Logistics\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"shipping_method\\\",\\\"freight_cost\\\",\\\"estimated_delivery_days\\\",\\\"carrier\\\"]\\n      },\\n      \\\"InvoiceResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Comprehensive B2B wholesale order invoice response\\\",\\n        \\\"properties\\\": {\\n          \\\"invoice_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique invoice identifier\\\",\\n            \\\"example\\\": \\\"inv_20240601_789\\\"\\n          },\\n          \\\"buyer_company\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BuyerCompany\\\"\\n          },\\n          \\\"bulk_items\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Collection of bulk items with tiered discounts\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/BulkItem\\\"\\n            }\\n          },\\n          \\\"freight_terms\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/FreightTerms\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"invoice_id\\\",\\\"buyer_company\\\",\\\"bulk_items\\\",\\\"freight_terms\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"daily_active_users\": 1200,\n    \"feature_usages\": [\n      {\n        \"feature_name\": \"Dashboard\",\n        \"usage_count\": 850,\n        \"usage_details\": [\n          {\n            \"time_period\": \"2024-05-01T09:00:00Z\",\n            \"actions_performed\": 300\n          },\n          {\n            \"time_period\": \"2024-05-01T15:00:00Z\",\n            \"actions_performed\": 550\n          }\n        ]\n      },\n      {\n        \"feature_name\": \"Reports\",\n        \"usage_count\": 430,\n        \"usage_details\": [\n          {\n            \"time_period\": \"2024-05-01T11:00:00Z\",\n            \"actions_performed\": 200\n          },\n          {\n            \"time_period\": \"2024-05-01T16:00:00Z\",\n            \"actions_performed\": 230\n          }\n        ]\n      }\n    ],\n    \"subscription_tier_limits\": {\n      \"tier_name\": \"Pro\",\n      \"max_users\": 5000,\n      \"max_features\": 25,\n      \"max_data_storage_gb\": 100\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: SaaS Platform User Analytics\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UsageDetail:\\n      type: object\\n      description: 'Detailed usage statistics within a specific time period'\\n      properties:\\n        time_period:\\n          type: string\\n          format: date-time\\n          description: 'ISO 8601 timestamp for the usage statistics period'\\n          example: '2024-05-01T09:00:00Z'\\n        actions_performed:\\n          type: integer\\n          description: 'Number of actions performed during the time period'\\n          example: 300\\n    FeatureUsage:\\n      type: object\\n      description: 'Usage metrics for a specific feature'\\n      properties:\\n        feature_name:\\n          type: string\\n          description: 'Name of the feature being used'\\n          example: 'Dashboard'\\n        usage_count:\\n          type: integer\\n          description: 'Total usage count for the feature during the day'\\n          example: 850\\n        usage_details:\\n          type: array\\n          description: 'Breakdown of usage details per time period'\\n          items:\\n            $ref: '#/components/schemas/UsageDetail'\\n    SubscriptionTierLimits:\\n      type: object\\n      description: 'Limits imposed by the user account subscription tier'\\n      properties:\\n        tier_name:\\n          type: string\\n          description: 'Name of the subscription tier'\\n          example: 'Pro'\\n        max_users:\\n          type: integer\\n          description: 'Maximum number of users allowed under this tier'\\n          example: 5000\\n        max_features:\\n          type: integer\\n          description: 'Maximum number of features accessible under this tier'\\n          example: 25\\n        max_data_storage_gb:\\n          type: integer\\n          description: 'Maximum data storage capacity in gigabytes for this tier'\\n          example: 100\\n    UserAnalyticsReport:\\n      type: object\\n      description: 'Daily user analytics report for the SaaS platform'\\n      properties:\\n        daily_active_users:\\n          type: integer\\n          description: 'Number of users active on the platform within the day'\\n          example: 1200\\n        feature_usages:\\n          type: array\\n          description: 'Usage metrics for multiple features within the day'\\n          items:\\n            $ref: '#/components/schemas/FeatureUsage'\\n        subscription_tier_limits:\\n          $ref: '#/components/schemas/SubscriptionTierLimits'\\n\"\n}"
"{\n  \"raw_json\": {\n    \"alert_id\": \"alert_12345\",\n    \"severity\": \"high\",\n    \"affected_ips\": [\n      {\n        \"ip\": \"192.168.1.10\",\n        \"location\": \"New York, USA\",\n        \"threat_type\": \"malware\"\n      },\n      {\n        \"ip\": \"10.0.0.5\",\n        \"location\": \"San Francisco, USA\",\n        \"threat_type\": \"phishing\"\n      }\n    ],\n    \"mitigation_protocols\": [\n      \"Isolate affected machines\",\n      \"Update firewall rules\",\n      \"Run antivirus scans\",\n      \"Notify security team\"\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Cybersecurity Threat Intelligence Alert\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"AffectedIP\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of an IP address affected by the cybersecurity threat\\\",\\n        \\\"properties\\\": {\\n          \\\"ip\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Affected IP address\\\",\\n            \\\"example\\\": \\\"192.168.1.10\\\"\\n          },\\n          \\\"location\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Geographical location of the IP address\\\",\\n            \\\"example\\\": \\\"New York, USA\\\"\\n          },\\n          \\\"threat_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of cybersecurity threat detected on this IP\\\",\\n            \\\"example\\\": \\\"malware\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"ip\\\", \\\"location\\\", \\\"threat_type\\\"]\\n      },\\n      \\\"ThreatAlert\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Cybersecurity threat intelligence alert containing severity, affected IPs, and mitigation protocols\\\",\\n        \\\"properties\\\": {\\n          \\\"alert_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the alert\\\",\\n            \\\"example\\\": \\\"alert_12345\\\"\\n          },\\n          \\\"severity\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Level of severity of the alert\\\",\\n            \\\"example\\\": \\\"high\\\"\\n          },\\n          \\\"affected_ips\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of affected IP addresses with detailed threat information\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/AffectedIP\\\"\\n            }\\n          },\\n          \\\"mitigation_protocols\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Recommended mitigation steps to address the threat\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"example\\\": \\\"Isolate affected machines\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"alert_id\\\", \\\"severity\\\", \\\"affected_ips\\\", \\\"mitigation_protocols\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"total_monthly_spend\": 12450.75,\n    \"cost_breakdown\": [\n      {\n        \"service_name\": \"compute\",\n        \"monthly_cost\": 8200.50,\n        \"details\": [\n          {\n            \"resource_type\": \"virtual_machine\",\n            \"cost\": 5000.25\n          },\n          {\n            \"resource_type\": \"containers\",\n            \"cost\": 3200.25\n          }\n        ]\n      },\n      {\n        \"service_name\": \"storage\",\n        \"monthly_cost\": 4250.25,\n        \"details\": [\n          {\n            \"resource_type\": \"block_storage\",\n            \"cost\": 2300.00\n          },\n          {\n            \"resource_type\": \"object_storage\",\n            \"cost\": 1950.25\n          }\n        ]\n      }\n    ],\n    \"projected_forecast\": {\n      \"next_month_estimate\": 13000.00,\n      \"trend_percentage\": 4.46\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Cloud Infrastructure Billing Dashboard\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CostDetail:\\n      type: object\\n      description: 'Detailed cost information for a specific resource type within a service'\\n      properties:\\n        resource_type:\\n          type: string\\n          description: 'The type of cloud resource incurring cost'\\n          example: 'virtual_machine'\\n        cost:\\n          type: number\\n          format: double\\n          description: 'Cost associated with the resource type in USD'\\n          example: 5000.25\\n    ServiceCostBreakdown:\\n      type: object\\n      description: 'Cost breakdown of a service including detailed costs per resource type'\\n      properties:\\n        service_name:\\n          type: string\\n          description: 'Name of the cloud service'\\n          example: 'compute'\\n        monthly_cost:\\n          type: number\\n          format: double\\n          description: 'Total monthly cost for the service in USD'\\n          example: 8200.50\\n        details:\\n          type: array\\n          description: 'Detailed costs broken down by resource type within the service'\\n          items:\\n            $ref: '#/components/schemas/CostDetail'\\n    ProjectedForecast:\\n      type: object\\n      description: 'Forecasted billing information for upcoming month'\\n      properties:\\n        next_month_estimate:\\n          type: number\\n          format: double\\n          description: 'Estimated total spend for the next month in USD'\\n          example: 13000.00\\n        trend_percentage:\\n          type: number\\n          format: float\\n          description: 'Percentage change in spend compared to the current month'\\n          example: 4.46\\n    BillingDashboard:\\n      type: object\\n      description: 'Summary of cloud infrastructure billing dashboard showing current spend, breakdown, and forecast'\\n      properties:\\n        total_monthly_spend:\\n          type: number\\n          format: double\\n          description: 'Total cloud spend in the current month in USD'\\n          example: 12450.75\\n        cost_breakdown:\\n          type: array\\n          description: 'Breakdown of monthly costs by cloud service'\\n          items:\\n            $ref: '#/components/schemas/ServiceCostBreakdown'\\n        projected_forecast:\\n          $ref: '#/components/schemas/ProjectedForecast'\\n\"\n}"
"{\n  \"raw_json\": {\n    \"citizen_id\": \"CITIZEN12345\",\n    \"declared_income\": 85000,\n    \"deductions\": [\n      {\n        \"category\": \"Education\",\n        \"entries\": [\n          {\n            \"description\": \"Tuition fees\",\n            \"amount\": 2000\n          },\n          {\n            \"description\": \"Books and supplies\",\n            \"amount\": 500\n          }\n        ]\n      },\n      {\n        \"category\": \"Healthcare\",\n        \"entries\": [\n          {\n            \"description\": \"Medical expenses\",\n            \"amount\": 3000\n          }\n        ]\n      }\n    ],\n    \"final_assessment\": {\n      \"taxable_income\": 79000,\n      \"tax_paid\": 15000,\n      \"tax_liability\": 14250,\n      \"refund_or_debt\": -750,\n      \"status\": \"refund\"\n    }\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Tax Return Assessment Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"DeductionEntry\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Single entry detailing a specific deduction\\\",\\n        \\\"properties\\\": {\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Description of the deduction\\\",\\n            \\\"example\\\": \\\"Tuition fees\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"description\\\": \\\"Amount claimed for this deduction\\\",\\n            \\\"example\\\": 2000\\n          }\\n        },\\n        \\\"required\\\": [\\\"description\\\", \\\"amount\\\"]\\n      },\\n      \\\"DeductionCategory\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Category grouping multiple deduction entries\\\",\\n        \\\"properties\\\": {\\n          \\\"category\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the deduction category\\\",\\n            \\\"example\\\": \\\"Education\\\"\\n          },\\n          \\\"entries\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Detailed entries within the deduction category\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/DeductionEntry\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"category\\\", \\\"entries\\\"]\\n      },\\n      \\\"FinalAssessment\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Summary of the final tax assessment calculations\\\",\\n        \\\"properties\\\": {\\n          \\\"taxable_income\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"description\\\": \\\"Income amount after deductions applied\\\",\\n            \\\"example\\\": 79000\\n          },\\n          \\\"tax_paid\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"description\\\": \\\"Total tax amount already paid\\\",\\n            \\\"example\\\": 15000\\n          },\\n          \\\"tax_liability\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"description\\\": \\\"Calculated tax obligation based on taxable income\\\",\\n            \\\"example\\\": 14250\\n          },\\n          \\\"refund_or_debt\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"description\\\": \\\"Final refund amount (negative value) or debt owed (positive value)\\\",\\n            \\\"example\\\": -750\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Indicates if the citizen is due a refund or has debt\\\",\\n            \\\"example\\\": \\\"refund\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"taxable_income\\\", \\\"tax_paid\\\", \\\"tax_liability\\\", \\\"refund_or_debt\\\", \\\"status\\\"]\\n      },\\n      \\\"TaxReturnAssessmentResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Government tax return assessment response for a citizen\\\",\\n        \\\"properties\\\": {\\n          \\\"citizen_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the citizen\\\",\\n            \\\"example\\\": \\\"CITIZEN12345\\\"\\n          },\\n          \\\"declared_income\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"description\\\": \\\"Total income declared by the citizen\\\",\\n            \\\"example\\\": 85000\\n          },\\n          \\\"deductions\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of deduction categories with their respective entries\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/DeductionCategory\\\"\\n            }\\n          },\\n          \\\"final_assessment\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/FinalAssessment\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"citizen_id\\\", \\\"declared_income\\\", \\\"deductions\\\", \\\"final_assessment\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"paths\\\": {},\\n  \\\"tags\\\": [],\\n  \\\"info\\\": {\\n      \\\"title\\\": \\\"Tax Return Assessment Response\\\",\\n      \\\"version\\\": \\\"1.0.0\\\"\\n  }\\n}\"\n}"
