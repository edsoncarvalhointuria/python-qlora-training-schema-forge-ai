 about a multiplayer RPG player\\\",\\n        \\\"properties\\\": {\\n          \\\"player_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the player\\\",\\n            \\\"example\\\": \\\"player_12345\\\"\\n          },\\n          \\\"current_level\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Current level of the player character\\\",\\n            \\\"example\\\": 27\\n          },\\n          \\\"equipped_gear\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/EquippedGear\\\"\\n          },\\n          \\\"unlocked_achievements\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of achievements unlocked by the player\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Achievement\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"player_id\\\", \\\"current_level\\\", \\\"equipped_gear\\\", \\\"unlocked_achievements\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"match_summary\": {\n      \"team_scores\": {\n        \"team_alpha\": 16,\n        \"team_bravo\": 14\n      },\n      \"player_statistics\": [\n        {\n          \"player_name\": \"Ace\",\n          \"kills\": 20,\n          \"deaths\": 5,\n          \"assists\": 7\n        },\n        {\n          \"player_name\": \"Blaze\",\n          \"kills\": 15,\n          \"deaths\": 8,\n          \"assists\": 10\n        },\n        {\n          \"player_name\": \"Cypher\",\n          \"kills\": 13,\n          \"deaths\": 6,\n          \"assists\": 12\n        },\n        {\n          \"player_name\": \"Dusk\",\n          \"kills\": 9,\n          \"deaths\": 9,\n          \"assists\": 5\n        },\n        {\n          \"player_name\": \"Echo\",\n          \"kills\": 11,\n          \"deaths\": 7,\n          \"assists\": 8\n        }\n      ],\n      \"match_timeline\": [\n        {\n          \"timestamp\": \"00:03:15\",\n          \"event_type\": \"kill\",\n          \"description\": \"Ace eliminated player Omega\",\n          \"involved_players\": [\"Ace\", \"Omega\"]\n        },\n        {\n          \"timestamp\": \"00:05:47\",\n          \"event_type\": \"objective_taken\",\n          \"description\": \"Team Alpha secured the first tower\",\n          \"involved_players\": []\n        },\n        {\n          \"timestamp\": \"00:12:05\",\n          \"event_type\": \"multi_kill\",\n          \"description\": \"Blaze achieved a triple kill\",\n          \"involved_players\": [\"Blaze\", \"Sigma\", \"Theta\", \"Zeta\"]\n        },\n        {\n          \"timestamp\": \"00:18:30\",\n          \"event_type\": \"team_fight\",\n          \"description\": \"Team Bravo won a crucial team fight near the midlane\",\n          \"involved_players\": [\"Blaze\", \"Cypher\", \"Dusk\", \"Echo\", \"Omega\", \"Sigma\"]\n        },\n        {\n          \"timestamp\": \"00:24:10\",\n          \"event_type\": \"match_point\",\n          \"description\": \"Team Alpha captured the final objective and secured the match point\",\n          \"involved_players\": []\n        }\n      ]\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: E-sports Match Summary API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    TeamScores:\\n      type: object\\n      description: 'Scores of the competing teams in the match'\\n      properties:\\n        team_alpha:\\n          type: integer\\n          description: 'Score of Team Alpha'\\n          example: 16\\n        team_bravo:\\n          type: integer\\n          description: 'Score of Team Bravo'\\n          example: 14\\n    PlayerStatistic:\\n      type: object\\n      description: 'Statistics for an individual player'\\n      properties:\\n        player_name:\\n          type: string\\n          description: 'Name of the player'\\n          example: 'Ace'\\n        kills:\\n          type: integer\\n          description: 'Number of kills achieved by the player'\\n          example: 20\\n        deaths:\\n          type: integer\\n          description: 'Number of times the player died'\\n          example: 5\\n        assists:\\n          type: integer\\n          description: 'Number of assists by the player'\\n          example: 7\\n    MatchEvent:\\n      type: object\\n      description: 'A significant event occurring during the match timeline'\\n      properties:\\n        timestamp:\\n          type: string\\n          description: 'Time in the match when the event occurred (MM:SS)'\\n          example: '00:03:15'\\n        event_type:\\n          type: string\\n          description: 'Type of event occurring in the match'\\n          example: 'kill'\\n        description:\\n          type: string\\n          description: 'Text description of the event'\\n          example: 'Ace eliminated player Omega'\\n        involved_players:\\n          type: array\\n          description: 'List of player names involved in the event'\\n          items:\\n            type: string\\n          example: ['Ace', 'Omega']\\n    MatchSummary:\\n      type: object\\n      description: 'Summary of a competitive e-sports match'\\n      properties:\\n        team_scores:\\n          $ref: '#/components/schemas/TeamScores'\\n        player_statistics:\\n          type: array\\n          description: 'Array of player statistics for the match'\\n          items:\\n            $ref: '#/components/schemas/PlayerStatistic'\\n        match_timeline:\\n          type: array\\n          description: 'Chronological list of key match events'\\n          items:\\n            $ref: '#/components/schemas/MatchEvent'\\n    RootResponse:\\n      type: object\\n      description: 'Root object containing the match summary'\\n      properties:\\n        match_summary:\\n          $ref: '#/components/schemas/MatchSummary'\\n\"\n}"
