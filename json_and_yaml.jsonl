on: 'Status financeiro do estudante em relação às mensalidades da universidade'\\n      properties:\\n        tuition_due:\\n          type: number\\n          format: float\\n          description: 'Valor devido da mensalidade'\\n          example: 3500.00\\n        due_date:\\n          type: string\\n          format: date\\n          description: 'Data limite para pagamento da mensalidade'\\n          example: '2024-07-15'\\n        status:\\n          type: string\\n          description: 'Status atual do pagamento da mensalidade'\\n          example: 'pending'\\n        last_payment_date:\\n          type: string\\n          format: date\\n          description: 'Data do último pagamento realizado'\\n          example: '2024-01-10'\\n        payment_method:\\n          type: string\\n          description: 'Método utilizado no último pagamento'\\n          example: 'cartão de crédito'\\n    StudentDashboard:\\n      type: object\\n      description: 'Resposta da dashboard do estudante com histórico acadêmico, cursos atuais e situação financeira'\\n      properties:\\n        student_id:\\n          type: string\\n          description: 'Identificação única do estudante'\\n          example: '2023123456'\\n        name:\\n          type: string\\n          description: 'Nome completo do estudante'\\n          example: 'Carlos Silva'\\n        academic_history:\\n          $ref: '#/components/schemas/AcademicHistory'\\n        current_courses:\\n          type: array\\n          description: 'Cursos nos quais o estudante está matriculado atualmente'\\n          items:\\n            $ref: '#/components/schemas/CurrentCourse'\\n        financial_status:\\n          $ref: '#/components/schemas/FinancialStatus'\\npaths: {}\"\n}"
