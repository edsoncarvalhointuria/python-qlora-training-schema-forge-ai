 \\\"integer\\\",\\n            \\\"description\\\": \\\"Valor de ataque fornecido pelo item (se aplicável)\\\",\\n            \\\"example\\\": 48\\n          }\\n        },\\n        \\\"oneOf\\\": [\\n          { \\\"required\\\": [\\\"item_id\\\", \\\"name\\\", \\\"defense\\\"] },\\n          { \\\"required\\\": [\\\"item_id\\\", \\\"name\\\", \\\"attack\\\"] }\\n        ]\\n      },\\n      \\\"EquippedGear\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Conjunto de equipamentos atualmente usados pelo jogador\\\",\\n        \\\"properties\\\": {\\n          \\\"head\\\": { \\\"$ref\\\": \\\"#/components/schemas/GearItem\\\" },\\n          \\\"chest\\\": { \\\"$ref\\\": \\\"#/components/schemas/GearItem\\\" },\\n          \\\"weapon\\\": { \\\"$ref\\\": \\\"#/components/schemas/GearItem\\\" }\\n        },\\n        \\\"required\\\": [\\\"head\\\", \\\"chest\\\", \\\"weapon\\\"]\\n      },\\n      \\\"Achievement\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes de uma conquista desbloqueada\\\",\\n        \\\"properties\\\": {\\n          \\\"achievement_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único da conquista\\\",\\n            \\\"example\\\": \\\"achv_001\\\"\\n          },\\n          \\\"title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Título ou nome da conquista\\\",\\n            \\\"example\\\": \\\"Primeira Missão Completa\\\"\\n          },\\n          \\\"unlocked_at\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Timestamp UTC quando a conquista foi desbloqueada\\\",\\n            \\\"example\\\": \\\"2024-03-15T14:12:00Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"achievement_id\\\", \\\"title\\\", \\\"unlocked_at\\\"]\\n      },\\n      \\\"PlayerProfile\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Perfil de um jogador em um RPG multiplayer incluindo nível, equipamentos e conquistas\\\",\\n        \\\"properties\\\": {\\n          \\\"player_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do jogador\\\",\\n            \\\"example\\\": \\\"player_1234\\\"\\n          },\\n          \\\"current_level\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Nível atual do jogador\\\",\\n            \\\"example\\\": 45\\n          },\\n          \\\"equipped_gear\\\": { \\\"$ref\\\": \\\"#/components/schemas/EquippedGear\\\" },\\n          \\\"unlocked_achievements\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de conquistas desbloqueadas pelo jogador\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/Achievement\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"player_id\\\", \\\"current_level\\\", \\\"equipped_gear\\\", \\\"unlocked_achievements\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"match_summary\": {\n      \"team_scores\": {\n        \"team_alpha\": 16,\n        \"team_bravo\": 12\n      },\n      \"player_statistics\": [\n        {\n          \"player_id\": \"player_001\",\n          \"name\": \"ShadowFox\",\n          \"kills\": 20,\n          \"deaths\": 5,\n          \"assists\": 7\n        },\n        {\n          \"player_id\": \"player_002\",\n          \"name\": \"Blaze\",\n          \"kills\": 15,\n          \"deaths\": 8,\n          \"assists\": 10\n        },\n        {\n          \"player_id\": \"player_003\",\n          \"name\": \"Viper\",\n          \"kills\": 13,\n          \"deaths\": 6,\n          \"assists\": 14\n        }\n      ],\n      \"match_timeline\": [\n        {\n          \"timestamp\": \"00:05:23\",\n          \"event_type\": \"Kill\",\n          \"description\": \"ShadowFox eliminated Blaze\",\n          \"involved_players\": [\"player_001\", \"player_002\"]\n        },\n        {\n          \"timestamp\": \"00:12:47\",\n          \"event_type\": \"ObjectiveCaptured\",\n          \"description\": \"Team Alpha captured the control point\",\n          \"involved_players\": []\n        },\n        {\n          \"timestamp\": \"00:20:10\",\n          \"event_type\": \"TeamFight\",\n          \"description\": \"Intense team fight near the mid area\",\n          \"involved_players\": [\"player_001\", \"player_002\", \"player_003\"]\n        }\n      ]\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: E-Sports Match Summary API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    TeamScores:\\n      type: object\\n      description: 'Scores of competing teams in the match'\\n      properties:\\n        team_alpha:\\n          type: integer\\n          description: 'Score of Team Alpha'\\n          example: 16\\n        team_bravo:\\n          type: integer\\n          description: 'Score of Team Bravo'\\n          example: 12\\n    PlayerStatistics:\\n      type: object\\n      description: 'Individual player statistics for the match'\\n      properties:\\n        player_id:\\n          type: string\\n          description: 'Unique identifier for the player'\\n          example: 'player_001'\\n        name:\\n          type: string\\n          description: 'Player in-game name or alias'\\n          example: 'ShadowFox'\\n        kills:\\n          type: integer\\n          description: 'Number of kills by the player'\\n          example: 20\\n        deaths:\\n          type: integer\\n          description: 'Number of times the player died'\\n          example: 5\\n        assists:\\n          type: integer\\n          description: 'Number of assists the player made'\\n          example: 7\\n    MatchEvent:\\n      type: object\\n      description: 'Key event occurring during the match timeline'\\n      properties:\\n        timestamp:\\n          type: string\\n          description: 'Time when the event occurred'\\n          example: '00:05:23'\\n        event_type:\\n          type: string\\n          description: 'Type/category of the match event'\\n          example: 'Kill'\\n        description:\\n          type: string\\n          description: 'Short description of the event'\\n          example: 'ShadowFox eliminated Blaze'\\n        involved_players:\\n          type: array\\n          description: 'List of player IDs involved in the event'\\n          items:\\n            type: string\\n            example: 'player_001'\\n    MatchSummary:\\n      type: object\\n      description: 'Summary of a competitive e-sports match'\\n      properties:\\n        team_scores:\\n          $ref: '#/components/schemas/TeamScores'\\n        player_statistics:\\n          type: array\\n          description: 'Statistics of all players involved in the match'\\n          items:\\n            $ref: '#/components/schemas/PlayerStatistics'\\n        match_timeline:\\n          type: array\\n          description: 'Chronological list of key ma