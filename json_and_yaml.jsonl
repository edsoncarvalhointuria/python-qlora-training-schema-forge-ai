nico do recibo de compra\\\",\\n            \\\"example\\\": \\\"rcpt_20240601_001\\\"\\n          },\\n          \\\"purchase\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Purchase\\\"\\n          },\\n          \\\"unlocked_cosmetics\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de itens cosméticos desbloqueados nesta transação\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/CosmeticItem\\\" },\\n            \\\"example\\\": [\\n              {\\n                \\\"item_id\\\": \\\"cos_001\\\",\\n                \\\"name\\\": \\\"Golden Sword\\\",\\n                \\\"rarity\\\": \\\"legendary\\\",\\n                \\\"acquired_date\\\": \\\"2024-06-01T14:30:00Z\\\"\\n              },\\n              {\\n                \\\"item_id\\\": \\\"cos_042\\\",\\n                \\\"name\\\": \\\"Dragon Wings\\\",\\n                \\\"rarity\\\": \\\"epic\\\",\\n                \\\"acquired_date\\\": \\\"2024-06-01T14:30:00Z\\\"\\n              }\\n            ]\\n          }\\n        },\\n        \\\"required\\\": [\\\"receipt_id\\\", \\\"purchase\\\", \\\"unlocked_cosmetics\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"$ref\\\": \\\"#/components/schemas/MicrotransactionReceipt\\\"\\n}\"\n}"
