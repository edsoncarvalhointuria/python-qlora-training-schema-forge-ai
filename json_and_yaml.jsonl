\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Severity level of the anomaly\\\",\\n            \\\"example\\\": \\\"moderate\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Human-readable description of the anomaly\\\",\\n            \\\"example\\\": \\\"Unexpected sudden braking detected\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"anomaly_type\\\", \\\"timestamp\\\", \\\"severity\\\", \\\"description\\\"]\\n      },\\n      \\\"FleetVehicleTelemetry\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Telemetry ping data from an autonomous fleet vehicle\\\",\\n        \\\"properties\\\": {\\n          \\\"vehicle_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the vehicle\\\",\\n            \\\"example\\\": \\\"veh_789\\\"\\n          },\\n          \\\"telemetry_timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"UTC timestamp when telemetry was recorded\\\",\\n            \\\"example\\\": \\\"2024-06-01T14:30:00Z\\\"\\n          },\\n          \\\"location\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Location\\\"\\n          },\\n          \\\"current_speed_kph\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Current speed of the vehicle in kilometers per hour\\\",\\n            \\\"example\\\": 85.6\\n          },\\n          \\\"battery_health\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BatteryHealth\\\"\\n          },\\n          \\\"recent_anomalies\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of recent driving anomalies detected\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/DrivingAnomaly\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"vehicle_id\\\", \\\"telemetry_timestamp\\\", \\\"location\\\", \\\"current_speed_kph\\\", \\\"battery_health\\\", \\\"recent_anomalies\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"intersection_id\": \"int_205\",\n    \"congestion_level\": \"high\",\n    \"vehicles_detected\": [\n      {\n        \"type\": \"car\",\n        \"count\": 37\n      },\n      {\n        \"type\": \"bus\",\n        \"count\": 4\n      },\n      {\n        \"type\": \"motorcycle\",\n        \"count\": 15\n      }\n    ],\n    \"pedestrian_alerts\": [\n      {\n        \"crosswalk_id\": \"cw_12\",\n        \"active\": true,\n        \"alert_level\": \"medium\"\n      },\n      {\n        \"crosswalk_id\": \"cw_15\",\n        \"active\": false,\n        \"alert_level\": \"none\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Smart City Traffic Camera Report API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    VehicleType:\\n      type: object\\n      description: 'Detalhes do tipo de veículo detectado e sua contagem'\\n      properties:\\n        type:\\n          type: string\\n          description: 'Tipo de veículo detectado na interseção'\\n          example: 'car'\\n        count:\\n          type: integer\\n          description: 'Número de veículos desse tipo detectados'\\n          example: 37\\n    PedestrianAlert:\\n      type: object\\n      description: 'Alerta ativo relacionado à faixa de pedestres na interseção'\\n      properties:\\n        crosswalk_id:\\n          type: string\\n          description: 'Identificador único da faixa de pedestres'\\n          example: 'cw_12'\\n        active:\\n          type: boolean\\n          description: 'Indica se o alerta da faixa está ativo'\\n          example: true\\n        alert_level:\\n          type: string\\n          description: 'Nível de alerta para a faixa de pedestres'\\n          example: 'medium'\\n    TrafficCameraReport:\\n      type: object\\n      description: 'Relatório da câmera de tráfego detalhando congestionamento, veículos detectados e alertas de pedestres ativos'\\n      properties:\\n        intersection_id:\\n          type: string\\n          description: 'Identificador único da interseção monitorada'\\n          example: 'int_205'\\n        congestion_level:\\n          type: string\\n          description: 'Nível atual de congestionamento na interseção'\\n          example: 'high'\\n        vehicles_detected:\\n          type: array\\n          description: 'Lista dos tipos de veículos detectados e suas quantidades'\\n          items:\\n            $ref: '#/components/schemas/VehicleType'\\n        pedestrian_alerts:\\n          type: array\\n          description: 'Alertas ativos nas faixas de pedestres na interseção'\\n          items:\\n            $ref: '#/components/schemas/PedestrianAlert'\\n\"\n}"
