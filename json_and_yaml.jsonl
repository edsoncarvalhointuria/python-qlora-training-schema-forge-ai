    description: 'Data e hora da transação no formato ISO 8601'\\n          example: '2024-06-15T14:23:00Z'\\n        description:\\n          type: string\\n          description: 'Descrição da transação'\\n          example: 'Pagamento cartão crédito'\\n        amount:\\n          type: number\\n          format: float\\n          description: 'Valor da transação, positivo para crédito e negativo para débito'\\n          example: -320.50\\n        currency:\\n          type: string\\n          description: 'Código da moeda em formato ISO 4217'\\n          example: 'BRL'\\n        status:\\n          type: string\\n          description: 'Estado atual da transação'\\n          example: 'completed'\\n    WalletStatement:\\n      type: object\\n      description: 'Extrato da carteira digital incluindo saldo, dados do usuário e últimas transações'\\n      properties:\\n        balance:\\n          type: number\\n          format: float\\n          description: 'Saldo atual disponível na carteira'\\n          example: 2543.75\\n        user_profile:\\n          $ref: '#/components/schemas/UserProfile'\\n        recent_transactions:\\n          type: array\\n          description: 'Lista das últimas três transações'\\n          items:\\n            $ref: '#/components/schemas/Transaction'\\n\"\n}"
