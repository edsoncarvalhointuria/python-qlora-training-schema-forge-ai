r_id\\\", \\\"items\\\", \\\"shipping_address\\\", \\\"payment_transaction\\\", \\\"_links\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"paths\\\": {},\\n  \\\"responses\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"security\\\": [],\\n  \\\"tags\\\": [],\\n  \\\"externalDocs\\\": {},\\n  \\\"info\\\": {},\\n  \\\"servers\\\": []\\n}\"\n}"
