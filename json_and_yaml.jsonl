        example: 'https://realestate.example.com/images/prop9876_front.jpg'\\n        description:\\n          type: string\\n          description: 'Brief description of the image content'\\n          example: 'Front view of the property'\\n    Realtor:\\n      type: object\\n      description: 'Contact details of the assigned realtor'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier for the realtor'\\n          example: 'agent_101'\\n        name:\\n          type: string\\n          description: 'Full name of the realtor'\\n          example: 'Jane Doe'\\n        phone:\\n          type: string\\n          description: 'Primary phone number of the realtor'\\n          example: '+1-555-123-4567'\\n        email:\\n          type: string\\n          format: email\\n          description: 'Email address of the realtor'\\n          example: 'jane.doe@realestateagency.com'\\n        agency:\\n          type: string\\n          description: 'Real estate agency the realtor belongs to'\\n          example: 'Springfield Realty'\\n    Property:\\n      type: object\\n      description: 'Detailed real estate property listing'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier for the property'\\n          example: 'prop_9876'\\n        title:\\n          type: string\\n          description: 'Title or headline of the property listing'\\n          example: 'Modern Family Home'\\n        description:\\n          type: string\\n          description: 'Detailed description of the property'\\n          example: 'Spacious 4-bedroom family home with modern amenities and open floor plan.'\\n        price:\\n          type: number\\n          format: float\\n          description: 'Listing price of the property in USD'\\n          example: 585000\\n        address:\\n          $ref: '#/components/schemas/Address'\\n        architectural_specs:\\n          $ref: '#/components/sch