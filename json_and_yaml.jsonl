identifier of the user'\\n          example: 'U1001'\\n        name:\\n          type: string\\n          description: 'Full name of the user'\\n          example: 'Alice Johnson'\\n    OccupiedHotDesk:\\n      type: object\\n      description: 'Information about a currently occupied hot-desk'\\n      properties:\\n        desk_id:\\n          type: string\\n          description: 'Identifier of the hot-desk'\\n          example: 'HD101'\\n        user:\\n          $ref: '#/components/schemas/User'\\n        occupied_since:\\n          type: string\\n          format: date-time\\n          description: 'ISO 8601 timestamp when the desk became occupied'\\n          example: '2024-06-15T09:00:00Z'\\n    FloorPlan:\\n      type: object\\n      description: 'Details of a floor plan and its occupied hot-desks'\\n      properties:\\n        floor_number:\\n          type: integer\\n          description: 'Number identifying the floor'\\n          example: 1\\n        description:\\n          type: string\\n          description: 'Description of the floor environment'\\n          example: 'Main floor with open space and conference rooms'\\n        occupied_hot_desks:\\n          type: array\\n          description: 'List of currently occupied hot-desks on this floor'\\n          items:\\n            $ref: '#/components/schemas/OccupiedHotDesk'\\n    MeetingRoomReservation:\\n      type: object\\n      description: 'Details of an upcoming meeting room reservation'\\n      properties:\\n        reservation_id:\\n          type: string\\n          description: 'Unique identifier of the reservation'\\n          example: 'R3001'\\n        room_name:\\n          type: string\\n          description: 'Name of the meeting room'\\n          example: 'Conference Room A'\\n        reserved_by:\\n          type: string\\n          description: 'Name of the person who reserved the room'\\n          example: 'Tom Harris'\\n        start_time:\\n          type: string\\n          format: