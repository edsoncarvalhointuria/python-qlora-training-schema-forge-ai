ntifier for the order'\\n          example: 'ORD123456'\\n        status:\\n          type: string\\n          description: 'Current status of the order'\\n          example: 'Out for delivery'\\n        courier:\\n          $ref: '#/components/schemas/Courier'\\n        restaurant:\\n          $ref: '#/components/schemas/RestaurantProfile'\\n        ordered_dishes:\\n          type: array\\n          description: 'List of dishes ordered with details'\\n          items:\\n            $ref: '#/components/schemas/OrderedDish'\\n\"\n}"
