e\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total amount claimed under this deduction\\\",\\n            \\\"example\\\": 2000.00\\n          },\\n          \\\"entries\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Detailed entries for the deduction\\\",\\n            \\\"oneOf\\\": [\\n              {\\n                \\\"type\\\": \\\"array\\\",\\n                \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/DeductionEntryCharity\\\" }\\n              },\\n              {\\n                \\\"type\\\": \\\"array\\\",\\n                \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/DeductionEntryMedical\\\" }\\n              }\\n            ]\\n          }\\n        },\\n        \\\"required\\\": [\\\"deduction_type\\\", \\\"total_amount\\\", \\\"entries\\\"]\\n      },\\n      \\\"TaxResult\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Tax calculation result including final amounts\\\",\\n        \\\"properties\\\": {\\n          \\\"calculated_tax\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Calculated tax on declared income before deductions\\\",\\n            \\\"example\\\": 15000.00\\n          },\\n          \\\"total_deductions\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Sum of all deductible amounts\\\",\\n            \\\"example\\\": 3200.50\\n          },\\n          \\\"final_tax_due\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Final tax amount due or refundable after deductions\\\",\\n            \\\"example\\\": 11799.50\\n          },\\n          \\\"refund_or_debt\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Indicates if the citizen owes tax or gets a refund\\\",\\n            \\\"example\\\": \\\"debt\\\",\\n            \\\"enum\\\": [\\\"refund\\\", \\\"debt\\\"]\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Amount of tax refund or debt\\\",\\n            \\\"example\\\": 11799.50\\n          }\\n        },\\n        \\\"required\\\": [\\\"calculated_tax\\\", \\\"total_deductions\\\", \\\"final_tax_due\\\", \\\"refund_or_debt\\\", \\\"amount\\\"]\\n      },\\n      \\\"TaxAssessmentResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Full government tax return assessment including income, deductions, and tax result\\\",\\n        \\\"properties\\\": {\\n          \\\"citizen_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the taxpayer\\\",\\n            \\\"example\\\": \\\"CIT123456789\\\"\\n          },\\n          \\\"declared_income\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total declared income for the tax period\\\",\\n            \\\"example\\\": 75000.00\\n          },\\n          \\\"deductions\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of valid deduction categories\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/Deduction\\\" }\\n          },\\n          \\\"tax_result\\\": { \\\"$ref\\\": \\\"#/components/schemas/TaxResult\\\" }\\n        },\\n        \\\"required\\\": [\\\"citizen_id\\\", \\\"declared_income\\\", \\\"deductions\\\", \\\"tax_result\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
