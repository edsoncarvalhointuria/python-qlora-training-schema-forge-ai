,\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of units ordered.\\\",\\n            \\\"example\\\": 500\\n          },\\n          \\\"unit_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Price per single unit.\\\",\\n            \\\"example\\\": 25.00\\n          },\\n          \\\"tiered_discounts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of tiered discount rules applicable for this item.\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/TieredDiscount\\\"\\n            }\\n          },\\n          \\\"total_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"final price after applying relevant tier discount.\\\",\\n            \\\"example\\\": 11250.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"product_id\\\", \\\"product_name\\\", \\\"quantity\\\", \\\"unit_price\\\", \\\"tiered_discounts\\\", \\\"total_price\\\"]\\n      },\\n      \\\"FreightShipping\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Shipping terms and cost details for freight.\\\",\\n        \\\"properties\\\": {\\n          \\\"terms\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Shipping terms such as FOB or CIF.\\\",\\n            \\\"example\\\": \\\"FOB\\\"\\n          },\\n          \\\"carrier\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Freight carrier company name.\\\",\\n            \\\"example\\\": \\\"Swift Freight Logistics\\\"\\n          },\\n          \\\"estimated_delivery_days\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Estimated number of days fo