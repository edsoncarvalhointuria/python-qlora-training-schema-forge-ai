"{\n  \"raw_json\": {\n    \"gross_salary\": 8500.75,\n    \"tax_deductions\": {\n      \"income_tax\": 1275.11,\n      \"social_security\": 658.05,\n      \"other_taxes\": 120.00\n    },\n    \"health_benefits\": {\n      \"insurance_provider\": \"SaúdeSegura\",\n      \"plan_type\": \"Premium Plus\",\n      \"monthly_cost\": 350.00\n    },\n    \"direct_deposits\": [\n      {\n        \"bank_name\": \"Banco Central\",\n        \"account_number\": \"1234567890\",\n        \"branch_code\": \"001\",\n        \"deposit_percentage\": 70\n      },\n      {\n        \"bank_name\": \"Banco Estadual\",\n        \"account_number\": \"0987654321\",\n        \"branch_code\": \"054\",\n        \"deposit_percentage\": 30\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Corporate Payroll Slip\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TaxDeductions\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhamento dos descontos de impostos aplicados\\\",\\n        \\\"properties\\\": {\\n          \\\"income_tax\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Imposto de renda descontado\\\",\\n            \\\"example\\\": 1275.11\\n          },\\n          \\\"social_security\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Contribuição para a seguridade social\\\",\\n            \\\"example\\\": 658.05\\n          },\\n          \\\"other_taxes\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Outros impostos deduzidos\\\",\\n            \\\"example\\\": 120.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"income_tax\\\", \\\"social_security\\\", \\\"other_taxes\\\"]\\n      },\\n      \\\"HealthBenefits\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações sobre os benefícios de saúde incluídos no salário\\\",\\n        \\\"properties\\\": {\\n          \\\"insurance_provider\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome da seguradora de saúde\\\",\\n            \\\"example\\\": \\\"SaúdeSegura\\\"\\n          },\\n          \\\"plan_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo do plano de saúde contratado\\\",\\n            \\\"example\\\": \\\"Premium Plus\\\"\\n          },\\n          \\\"monthly_cost\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Custo mensal do plano de saúde\\\",\\n            \\\"example\\\": 350.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"insurance_provider\\\", \\\"plan_type\\\", \\\"monthly_cost\\\"]\\n      },\\n      \\\"DirectDepositAccount\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes da conta bancária para depósito direto\\\",\\n        \\\"properties\\\": {\\n          \\\"bank_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome do banco\\\",\\n            \\\"example\\\": \\\"Banco Central\\\"\\n          },\\n          \\\"account_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Número da conta bancária\\\",\\n            \\\"example\\\": \\\"1234567890\\\"\\n          },\\n          \\\"branch_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código da agência bancária\\\",\\n            \\\"example\\\": \\\"001\\\"\\n          },\\n          \\\"deposit_percentage\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\