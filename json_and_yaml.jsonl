"{\n  \"raw_json\": {\n    \"provider\": {\n      \"provider_id\": \"prov_12345\",\n      \"name\": \"HealthCare Provider Inc.\",\n      \"contact_number\": \"+1-800-555-1234\"\n    },\n    \"procedures_billed\": [\n      {\n        \"procedure_code\": \"99213\",\n        \"description\": \"Office visit, established patient\",\n        \"date_of_service\": \"2024-05-15\"\n      },\n      {\n        \"procedure_code\": \"73030\",\n        \"description\": \"X-ray exam of elbow\",\n        \"date_of_service\": \"2024-05-16\"\n      }\n    ],\n    \"costs\": {\n      \"covered\": 250.00,\n      \"out_of_pocket\": 50.00,\n      \"currency\": \"USD\"\n    }\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Health Insurance Claim Status Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Provider\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the health service provider processing the claim\\\",\\n        \\\"properties\\\": {\\n          \\\"provider_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the provider\\\",\\n            \\\"example\\\": \\\"prov_12345\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the healthcare provider\\\",\\n            \\\"example\\\": \\\"HealthCare Provider Inc.\\\"\\n          },\\n          \\\"contact_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Contact phone number of the provider\\\",\\n            \\\"example\\\": \\\"+1-800-555-1234\\\"\\n          }\\n        }\\n      },\\n      \\\"ProcedureBilled\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"A medical procedure billed in the claim\\\",\\n        \\\"properties\\\"