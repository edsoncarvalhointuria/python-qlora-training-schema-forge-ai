"{\n  \"raw_json\": {\n    \"currentTemperature\": 22.5,\n    \"targetTemperature\": 24.0,\n    \"deviceHealth\": {\n      \"batteryLevel\": 85,\n      \"wifiSignalStrength\": -70\n    },\n    \"usageHistory\": [\n      {\n        \"timestamp\": \"2024-04-25T08:00:00Z\",\n        \"temperature\": 21.0\n      },\n      {\n        \"timestamp\": \"2024-04-25T12:00:00Z\",\n        \"temperature\": 22.3\n      },\n      {\n        \"timestamp\": \"2024-04-25T16:00:00Z\",\n        \"temperature\": 23.1\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Smart Thermostat Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"DeviceHealth\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about the device's battery and WiFi status\\\",\\n        \\\"properties\\\": {\\n          \\\"batteryLevel\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Current battery level percentage of the device\\\",\\n            \\\"example\\\": 85\\n          },\\n          \\\"wifiSignalStrength\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"WiFi signal strength in dBm\\\",\\n            \\\"example\\\": -70\\n          }\\n        },\\n        \\\"required\\\": [\\\"batteryLevel\\\", \\\"wifiSignalStrength\\\"]\\n      },\\n      \\\"UsageRecord\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Historical temperature record at a specific time\\\",\\n        \\\"properties\\\": {\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"ISO 8601 timestamp of the recorded temperature\\\",\\n            \\\"example\\\": \\\"2024-04-25T08:00:00Z\\\"\\n          },\\n          \\\"temperatur