         \\\"description\\\": \\\"Nível de severidade da anomalia\\\",\\n            \\\"example\\\": \\\"medium\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora em que a anomalia foi detectada\\\",\\n            \\\"example\\\": \\\"2024-06-01T12:33:20Z\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Descrição detalhada da anomalia\\\",\\n            \\\"example\\\": \\\"Frenagem brusca detectada em velocidade alta\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"anomaly_type\\\", \\\"severity_level\\\", \\\"timestamp\\\", \\\"description\\\"]\\n      },\\n      \\\"TelemetryPing\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Ping de telemetria contendo dados do veículo autônomo\\\",\\n        \\\"properties\\\": {\\n          \\\"vehicle_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do veículo\\\",\\n            \\\"example\\\": \\\"fleet_veh_789\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora do ping de telemetria\\\",\\n            \\\"example\\\": \\\"2024-06-01T12:34:56Z\\\"\\n          },\\n          \\\"location\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Location\\\"\\n          },\\n          \\\"speed_kmh\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Velocidade atual do veículo em km/h\\\",\\n            \\\"example\\\": 65.4\\n          },\\n          \\\"battery_health\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BatteryHealth\\\"\\n          }