\"string\\\",\\n            \\\"description\\\": \\\"Nome de usuário do criador\\\",\\n            \\\"example\\\": \\\"JazzLover\\\"\\n          },\\n          \\\"profile_url\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"URL para o perfil público do usuário\\\",\\n            \\\"example\\\": \\\"https://music.example.com/users/JazzLover\\\"\\n          }\\n        }\\n      },\\n      \\\"AudioSpec\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Especificações técnicas do áudio da faixa\\\",\\n        \\\"properties\\\": {\\n          \\\"bitrate_kbps\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Taxa de bits do áudio em kilobits por segundo\\\",\\n            \\\"example\\\": 320\\n          },\\n          \\\"sample_rate_hz\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Taxa de amostragem do áudio em hertz\\\",\\n            \\\"example\\\": 44100\\n          },\\n          \\\"channels\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Número de canais de áudio\\\",\\n            \\\"example\\\": 2\\n          }\\n        }\\n      },\\n      \\\"Track\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Dados detalhados de uma faixa de música\\\",\\n        \\\"properties\\\": {\\n          \\\"track_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único da faixa\\\",\\n            \\\"example\\\": \\\"track_001\\\"\\n          },\\n          \\\"title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Título da faixa\\\",\\n            \\\"example\\\": \\\"Midnight Blues\\\"\\n          },\\n          \\\"duration_ms\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Duração da faixa em milis