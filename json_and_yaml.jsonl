          \\\"description\\\": \\\"Identificador único do comentário\\\",\\n            \\\"example\\\": \\\"comm_101\\\"\\n          },\\n          \\\"user\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n          },\\n          \\\"comment_text\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Texto do comentário\\\",\\n            \\\"example\\\": \\\"Great job, congrats!\\\"\\n          },\\n          \\\"commented_at\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora em que o comentário foi feito\\\",\\n            \\\"example\\\": \\\"2024-06-20T15:00:00Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"comment_id\\\", \\\"user\\\", \\\"comment_text\\\", \\\"commented_at\\\"]\\n      },\\n      \\\"Post\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Publicação feita pelo usuário na plataforma\\\",\\n        \\\"properties\\\": {\\n          \\\"post_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único da publicação\\\",\\n            \\\"example\\\": \\\"post_456\\\"\\n          },\\n          \\\"content\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Conteúdo textual da publicação\\\",\\n            \\\"example\\\": \\\"Excited to share my new project!\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora da publicação\\\",\\n            \\\"example\\\": \\\"2024-06-20T14:30:00Z\\\"\\n          },\\n          \\\"comments\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de comentários na publicação\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Comment\\\"\\n            }\\n          },\\n          \\\"liked_by\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Usuários que curtiram a publicação\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"post_id\\\", \\\"content\\\", \\\"timestamp\\\", \\\"comments\\\", \\\"liked_by\\\"]\\n      },\\n      \\\"UserFeedResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta contendo o feed de posts do usuário\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do usuário\\\",\\n            \\\"example\\\": \\\"user_789\\\"\\n          },\\n          \\\"posts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de publicações do usuário\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Post\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"user_id\\\", \\\"posts\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
