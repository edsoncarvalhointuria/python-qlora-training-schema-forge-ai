ng\\n          description: 'Identificador único do proprietário'\\n          example: 'own_2021'\\n        full_name:\\n          type: string\\n          description: 'Nome completo do proprietário'\\n          example: 'João Silva'\\n        contact:\\n          $ref: '#/components/schemas/ContactInfo'\\n    Procedure:\\n      type: object\\n      description: 'Detalhes do procedimento agendado'\\n      properties:\\n        procedure_code:\\n          type: string\\n          description: 'Código identificador do procedimento'\\n          example: 'VAC01'\\n        description:\\n          type: string\\n          description: 'Descrição do procedimento'\\n          example: 'Vacinação antirrábica'\\n        duration_minutes:\\n          type: integer\\n          description: 'Duração estimada do procedimento em minutos'\\n          example: 20\\n    AppointmentResponse:\\n      type: object\\n      description: 'Resposta contendo detalhes do agendamento da clínica veterinária'\\n      properties:\\n        appointment_id:\\n          type: string\\n          description: 'Identificador único do agendamento'\\n          example: 'apt_98342'\\n        scheduled_date:\\n          type: string\\n          format: date-time\\n          description: 'Data e hora agendada para o procedimento'\\n          example: '2024-07-15T14:30:00Z'\\n        pet:\\n          $ref: '#/components/schemas/Pet'\\n        owner:\\n          $ref: '#/components/schemas/Owner'\\n        procedure:\\n          $ref: '#/components/schemas/Procedure'\\n\"\n}"
