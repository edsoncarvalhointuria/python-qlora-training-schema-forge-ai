"{\n  \"raw_json\": {\n    \"property\": {\n      \"id\": \"prop_9876\",\n      \"title\": \"Modern Family Home\",\n      \"description\": \"Spacious 4-bedroom family home with modern amenities and open floor plan.\",\n      \"price\": 585000,\n      \"address\": {\n        \"street\": \"1234 Oak Drive\",\n        \"city\": \"Springfield\",\n        \"state\": \"IL\",\n        \"zip_code\": \"62704\"\n      },\n      \"architectural_specs\": {\n        \"year_built\": 2015,\n        \"square_feet\": 3200,\n        \"num_bedrooms\": 4,\n        \"num_bathrooms\": 3,\n        \"flooring\": \"Hardwood\",\n        \"has_garage\": true,\n        \"garage_spaces\": 2,\n        \"heating_type\": \"Forced Air\",\n        \"cooling_type\": \"Central Air\"\n      },\n      \"images\": [\n        {\n          \"url\": \"https://realestate.example.com/images/prop9876_front.jpg\",\n          \"description\": \"Front view of the property\"\n        },\n        {\n          \"url\": \"https://realestate.example.com/images/prop9876_livingroom.jpg\",\n          \"description\": \"Spacious living room with natural light\"\n        },\n        {\n          \"url\": \"https://realestate.example.com/images/prop9876_kitchen.jpg\",\n          \"description\": \"Modern kitchen with stainless steel appliances\"\n        }\n      ],\n      \"realtor\": {\n        \"id\": \"agent_101\",\n        \"name\": \"Jane Doe\",\n        \"phone\": \"+1-555-123-4567\",\n        \"email\": \"jane.doe@realestateagency.com\",\n        \"agency\": \"Springfield Realty\"\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Real Estate Property Listing\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Address:\\n      type: object\\n      description: 'Physical location details of the property'\\n      properties:\\n        street:\\n          type: string\\n          description: 'Street address of the property'\\n          example: '1234 Oak Drive'\\n        city:\\n          ty