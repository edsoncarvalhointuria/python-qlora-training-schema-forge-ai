"description\\\": \\\"Number of breaths per minute\\\",\\n            \\\"example\\\": 16\\n          }\\n        }\\n      },\\n      \\\"Medication\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about a current medication\\\",\\n        \\\"properties\\\": {\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Medication name\\\",\\n            \\\"example\\\": \\\"Lisinopril\\\"\\n          },\\n          \\\"dosage\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Amount of medication per dose\\\",\\n            \\\"example\\\": \\\"10 mg\\\"\\n          },\\n          \\\"frequency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"How often the medication is taken\\\",\\n            \\\"example\\\": \\\"Once daily\\\"\\n          }\\n        }\\n      },\\n      \\\"Contact\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Contact information for a person\\\",\\n        \\\"properties\\\": {\\n          \\\"email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"Email address\\\",\\n            \\\"example\\\": \\\"jane.smith@hospital.org\\\"\\n          },\\n          \\\"phone\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Phone number including country code\\\",\\n            \\\"example\\\": \\\"+1234567890\\\"\\n          }\\n        }\\n      },\\n      \\\"DoctorProfile\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Profile information for the attending doctor\\\",\\n        \\\"properties\\\": {\\n          \\\"doctor_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique doctor identifier\\\",\\n            \\\"example\\\": \\\"doc_4321\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Full name of the doctor\\\",\\n            \\\"example\\\": \\\"Dr. Jane Smith\\\"\\n          },\\n          \\\"specialty\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Medical specialty of the doctor\\\",\\n            \\\"example\\\": \\\"Cardiology\\\"\\n          },\\n          \\\"contact\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Contact\\\"\\n          }\\n        }\\n      },\\n      \\\"PatientMedicalRecordSummary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Summary of the patient's medical record including vital signs, medications, and attending doctor\\\",\\n        \\\"properties\\\": {\\n          \\\"patient_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique patient identifier\\\",\\n            \\\"example\\\": \\\"pat_9876\\\"\\n          },\\n          \\\"vital_signs\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/VitalSigns\\\"\\n          },\\n          \\\"current_medications\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of current medications the patient is taking\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Medication\\\"\\n            }\\n          },\\n          \\\"attending_doctor\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DoctorProfile\\\"\\n          }\\n        }\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {}\\n}\"\n}"
