\",\\n            \\\"example\\\": \\\"Detected malware communication attempts\\\"\\n          },\\n          \\\"last_seen\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"The last time this threat was observed\\\",\\n            \\\"example\\\": \\\"2024-06-15T14:22:00Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"threat_type\\\", \\\"description\\\", \\\"last_seen\\\"]\\n      },\\n      \\\"AffectedIP\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about an IP address affected by threats\\\",\\n        \\\"properties\\\": {\\n          \\\"ip_address\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"IP address affected by cybersecurity threats\\\",\\n            \\\"example\\\": \\\"192.168.1.100\\\"\\n          },\\n          \\\"threat_details\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of detected threats for the affected IP\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/ThreatDetail\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"ip_address\\\", \\\"threat_details\\\"]\\n      },\\n      \\\"ThreatAlert\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Cybersecurity threat intelligence alert containing severity, affected IPs, and mitigations\\\",\\n        \\\"properties\\\": {\\n          \\\"alert_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the alert\\\",\\n            \\\"example\\\": \\\"alert_98765\\\"\\n          },\\n          \\\"severity_level\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Severity level of the threat\\\",\\n            \\\"example\\\": \\\"High\\\"\\n          },\\n          \\\"affected_ips\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of IP addresses affected by threats\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/AffectedIP\\\" }\\n          },\\n          \\\"mitigation_protocols\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Recommended protocols to mitigate the threats\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"example\\\": \\\"Isolate affected machines from network\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"alert_id\\\", \\\"severity_level\\\", \\\"affected_ips\\\", \\\"mitigation_protocols\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"total_monthly_spend\": 12500.75,\n    \"costs_by_service\": [\n      {\n        \"service_name\": \"compute\",\n        \"costs\": [\n          { \"resource\": \"vm_instance_1\", \"amount\": 3000.50 },\n          { \"resource\": \"vm_instance_2\", \"amount\": 2500.00 }\n        ]\n      },\n      {\n        \"service_name\": \"storage\",\n        \"costs\": [\n          { \"resource\": \"s3_bucket_1\", \"amount\": 1500.75 },\n          { \"resource\": \"blob_storage_1\", \"amount\": 3500.00 }\n        ]\n      }\n    ],\n    \"projected_forecast\": 13500.00\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Cloud Billing Dashboard\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CostDetail:\\n      type: object\\n      description: 'Details of cost for an individual resource'\\n      properties:\\n        resource:\\n          type: string\\n          description: 'Name of the resource incurring cost'\\n          example: 'vm_instance_1'\\n        amount:\\n          type: number\\n          format: float\\n          description: 'Cost amount for the resource in USD'\\n          example: 3000.50\\n    ServiceCost:\\n      type: object\\n      description: 'Cost breakdown for a specific cloud service'\\n      properties:\\n        service_name:\\n          type: string\\n          description: 'Name of the cloud service'\\n          example: 'compute'\\n        costs:\\n          type: array\\n          description: 'List of cost details for resources within the service'\\n          items:\\n            $ref: '#/components/schemas/CostDetail'\\n    BillingDashboard:\\n      type: object\\n      description: 'Overall billing dashboard summary for cloud infrastructure'\\n      properties:\\n        total_monthly_spend:\\n          type: number\\n          format: float\\n          description: 'Total cloud spend for the current month in USD'\\n          example: 12500.75\\n        costs_by_service:\\n          type: array\\n          description: 'Array of cost breakdowns grouped by cloud service'\\n          items:\\n            $ref: '#/components/schemas/ServiceCost'\\n        projected_forecast:\\n          type: number\\n          format: float\\n          description: 'Projected cloud spend forecast in USD for the upcoming period'\\n          example: 13500.00\\n\"\n}"
"{\n  \"raw_json\": {\n    \"citizen_id\": \"12345678900\",\n    \"declared_income\": 85000.50,\n    \"deductions\": [\n      {\n        \"type\": \"medical_expenses\",\n        \"amount\": 1500.75,\n        \"details\": [\n          {\n            \"provider\": \"Hospital XYZ\",\n            \"service\": \"Surgery\",\n            \"date\": \"2023-08-15\"\n          },\n          {\n            \"provider\": \"Clinica ABC\",\n            \"service\": \"Consultation\",\n            \"date\": \"2023-05-20\"\n          }\n        ]\n      },\n      {\n        \"type\": \"education\",\n        \"amount\": 2500.00,\n        \"details\": [\n          {\n            \"institution\": \"University DEF\",\n            \"course\": \"Postgraduate Course\",\n            \"year\": 2023\n          }\n        ]\n      }\n    ],\n    \"tax_summary\": {\n      \"taxable_income\": 81000.75,\n      \"tax_due\": 12000.00,\n      \"tax_paid\": 13000.00,\n      \"refund_or_debt\": 1000.00,\n      \"status\": \"refund\"\n    }\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Resposta da Avaliação de Declaração de Imposto\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"DeductionDetailMedical\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes de uma despesa médica dedutível\\\",\\n        \\\"properties\\\": {\\n          \\\"provider\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome do fornecedor do serviço médico\\\",\\n            \\\"example\\\": \\\"Hospital XYZ\\\"\\n          },\\n          \\\"service\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Descrição do serviço médico prestado\\\",\\n            \\\"example\\\": \\\"Surgery\\\"\\n          },\\n          \\\"date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"Data em que o serviço foi realizado\\\",\\n            \\\"example\\\": \\\"2023-08-15\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"provider\\\", \\\"service\\\", \\\"date\\\"]\\n      },\\n      \\\"DeductionDetailEducation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes de uma despesa educacional dedutível\\\",\\n        \\\"properties\\\": {\\n          \\\"institution\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome da instituição educacional\\\",\\n            \\\"example\\\": \\\"University DEF\\\"\\n          },\\n          \\\"course\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome do curso realizado\\\",\\n            \\\"example\\\": \\\"Postgraduate Course\\\"\\n          },\\n          \\\"year\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Ano em que a despesa foi realizada\\\",\\n            \\\"example\\\": 2023\\n          }\\n        },\\n        \\\"required\\\": [\\\"institution\\\", \\\"course\\\", \\\"year\\\"]\\n      },\\n      \\\"Deduction\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações sobre uma dedução fiscal aplicada\\\",\\n        \\\"properties\\\": {\\n          \\\"type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo da dedução\\\",\\n            \\\"example\\\": \\\"medical_expenses\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Valor total dedutível da categoria\\\",\\n            \\\"example\\\": 1500.75\\n          },\\n          \\\"details\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Detalhes específicos da dedução\\\",\\n            \\\"items\\\": {\\n              \\\"oneOf\\\": [\\n                { \\\"$ref\\\": \\\"#/components/schemas/DeductionDetailMedical\\\" },\\n                { \\\"$ref\\\": \\\"#/components/schemas/DeductionDetailEducation\\\" }\\n              ]\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"type\\\", \\\"amount\\\", \\\"details\\\"]\\n      },\\n      \\\"TaxSummary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resumo do cálculo de imposto após aplicação das deduções\\\",\\n        \\\"properties\\\": {\\n          \\\"taxable_income\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Renda tributável após deduções\\\",\\n            \\\"example\\\": 81000.75\\n          },\\n          \\\"tax_due\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Valor total do imposto devido\\\",\\n            \\\"example\\\": 12000.00\\n          },\\n          \\\"tax_paid\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Valor total do imposto já pago\\\",\\n            \\\"example\\\": 13000.00\\n          },\\n          \\\"refund_or_debt\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Valor a ser restituído (positivo) ou devido (negativo)\\\",\\n            \\\"example\\\": 1000.00\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Status da restituição ou dívida fiscal\\\",\\n            \\\"example\\\": \\\"refund\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"taxable_income\\\", \\\"tax_due\\\", \\\"tax_paid\\\", \\\"refund_or_debt\\\", \\\"status\\\"]\\n      },\\n      \\\"TaxReturnAssessment\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta completa da avaliação da declaração de imposto do cidadão\\\",\\n        \\\"properties\\\": {\\n          \\\"citizen_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do cidadão\\\",\\n            \\\"example\\\": \\\"12345678900\\\"\\n          },\\n          \\\"declared_income\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Renda anual declarada pelo cidadão\\\",\\n            \\\"example\\\": 85000.50\\n          },\\n          \\\"deductions\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de deduções válidas aplicadas à declaração\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/Deduction\\\" }\\n          },\\n          \\\"tax_summary\\\": { \\\"$ref\\\": \\\"#/components/schemas/TaxSummary\\\" }\\n        },\\n        \\\"required\\\": [\\\"citizen_id\\\", \\\"declared_income\\\", \\\"deductions\\\", \\\"tax_summary\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"rootSchema\\\": { \\\"$ref\\\": \\\"#/components/schemas/TaxReturnAssessment\\\" }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"table_number\": 12,\n    \"stations\": [\n      {\n        \"station_name\": \"Grill\",\n        \"orders\": [\n          {\n            \"item_name\": \"Cheeseburger\",\n            \"quantity\": 2,\n            \"allergy_warnings\": [\"Dairy\", \"Gluten\"]\n          },\n          {\n            \"item_name\": \"Steak\",\n            \"quantity\": 1,\n            \"allergy_warnings\": []\n          }\n        ]\n      },\n      {\n        \"station_name\": \"Salad\",\n        \"orders\": [\n          {\n            \"item_name\": \"Caesar Salad\",\n            \"quantity\": 1,\n            \"allergy_warnings\": [\"Eggs\", \"Fish\"]\n          }\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Sistema de Exibição de Cozinha - Ticket\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AllergyWarnings:\\n      type: string\\n      description: 'Avisos de alergias relacionados ao item'\\n      example: 'Dairy'\\n    OrderItem:\\n      type: object\\n      description: 'Detalhes de um item pedido'\\n      properties:\\n        item_name:\\n          type: string\\n          description: 'Nome do item pedido'\\n          example: 'Cheeseburger'\\n        quantity:\\n          type: integer\\n          description: 'Quantidade do item pedido'\\n          example: 2\\n        allergy_warnings:\\n          type: array\\n          description: 'Lista de avisos de alergia para o item'\\n          items:\\n            $ref: '#/components/schemas/AllergyWarnings'\\n    StationOrders:\\n      type: object\\n      description: 'Pedidos agrupados por estação de preparação'\\n      properties:\\n        station_name:\\n          type: string\\n          description: 'Nome da estação de preparação'\\n          example: 'Grill'\\n        orders:\\n          type: array\\n          description: 'Lista de itens pedidos para a estação'\\n          items:\\n            $ref: '#/components/schemas/OrderItem'\\n    KitchenTicket:\\n      type: object\\n      description: 'Ticket de pedido exibido na cozinha'\\n      properties:\\n        table_number:\\n          type: integer\\n          description: 'Número da mesa'\\n          example: 12\\n        stations:\\n          type: array\\n          description: 'Lista de estações com seus pedidos'\\n          items:\\n            $ref: '#/components/schemas/StationOrders'\\n\"\n}"
"{\n  \"raw_json\": {\n    \"order_id\": \"order_12345\",\n    \"items\": [\n      {\n        \"item_id\": \"item_987\",\n        \"name\": \"Wireless Mouse\",\n        \"quantity\": 2,\n        \"price\": 25.99\n      },\n      {\n        \"item_id\": \"item_654\",\n        \"name\": \"Mechanical Keyboard\",\n        \"quantity\": 1,\n        \"price\": 89.99\n      }\n    ],\n    \"shipping_address\": {\n      \"recipient_name\": \"John Doe\",\n      \"street\": \"123 Elm St\",\n      \"city\": \"Springfield\",\n      \"state\": \"IL\",\n      \"zip\": \"62704\",\n      \"country\": \"USA\"\n    },\n    \"payment\": {\n      \"transaction_id\": \"txn_78910\",\n      \"method\": \"credit_card\",\n      \"status\": \"completed\",\n      \"amount\": 141.97,\n      \"currency\": \"USD\"\n    },\n    \"_links\": {\n      \"self\": {\n        \"href\": \"https://api.shop.com/orders/order_12345\"\n      },\n      \"tracking\": {\n        \"href\": \"https://shipping.shipper.com/track/track_56789\"\n      }\n    }\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"E-commerce Order Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Item\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Physical item included in the order\\\",\\n        \\\"properties\\\": {\\n          \\\"item_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the item\\\",\\n            \\\"example\\\": \\\"item_987\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the product\\\",\\n            \\\"example\\\": \\\"Wireless Mouse\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantity of the item ordered\\\",\\n            \\\"example\\\": 2\\n          },\\n          \\\"price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Price per unit of the item\\\",\\n            \\\"example\\\": 25.99\\n          }\\n        },\\n        \\\"required\\\": [\\\"item_id\\\", \\\"name\\\", \\\"quantity\\\", \\\"price\\\"]\\n      },\\n      \\\"ShippingAddress\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Shipping address details for the order\\\",\\n        \\\"properties\\\": {\\n          \\\"recipient_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the recipient\\\",\\n            \\\"example\\\": \\\"John Doe\\\"\\n          },\\n          \\\"street\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Street address\\\",\\n            \\\"example\\\": \\\"123 Elm St\\\"\\n          },\\n          \\\"city\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"City name\\\",\\n            \\\"example\\\": \\\"Springfield\\\"\\n          },\\n          \\\"state\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"State or region\\\",\\n            \\\"example\\\": \\\"IL\\\"\\n          },\\n          \\\"zip\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Postal code\\\",\\n            \\\"example\\\": \\\"62704\\\"\\n          },\\n          \\\"country\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Country name\\\",\\n            \\\"example\\\": \\\"USA\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"recipient_name\\\", \\\"street\\\", \\\"city\\\", \\\"state\\\", \\\"zip\\\", \\\"country\\\"]\\n      },\\n      \\\"Payment\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payment transaction details for the order\\\",\\n        \\\"properties\\\": {\\n          \\\"transaction_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the payment transaction\\\",\\n            \\\"example\\\": \\\"txn_78910\\\"\\n          },\\n          \\\"method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Payment method used\\\",\\n            \\\"example\\\": \\\"credit_card\\\"\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Current status of the payment\\\",\\n            \\\"example\\\": \\\"completed\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total payment amount\\\",\\n            \\\"example\\\": 141.97\\n          },\\n          \\\"currency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Currency code for the payment\\\",\\n            \\\"example\\\": \\\"USD\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"transaction_id\\\", \\\"method\\\", \\\"status\\\", \\\"amount\\\", \\\"currency\\\"]\\n      },\\n      \\\"Link\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"HAL link object containing an href\\\",\\n        \\\"properties\\\": {\\n          \\\"href\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"uri\\\",\\n            \\\"description\\\": \\\"URL of the linked resource\\\",\\n            \\\"example\\\": \\\"https://api.shop.com/orders/order_12345\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"href\\\"]\\n      },\\n      \\\"Links\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"HAL links related to the order\\\",\\n        \\\"properties\\\": {\\n          \\\"self\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Link\\\"\\n          },\\n          \\\"tracking\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Link\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"self\\\", \\\"tracking\\\"]\\n      },\\n      \\\"OrderResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Complete e-commerce order response including items, address, payment, and links\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the order\\\",\\n            \\\"example\\\": \\\"order_12345\\\"\\n          },\\n          \\\"items\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of physical items in the order\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Item\\\"\\n            }\\n          },\\n          \\\"shipping_address\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/ShippingAddress\\\"\\n          },\\n          \\\"payment\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Payment\\\"\\n          },\\n          \\\"_links\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Links\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"order_id\\\", \\\"items\\\", \\\"shipping_address\\\", \\\"payment\\\", \\\"_links\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"current_balance\": 2570.45,\n    \"currency\": \"USD\",\n    \"user_profile\": {\n      \"user_id\": \"u123456789\",\n      \"full_name\": \"Alice Johnson\",\n      \"email\": \"alice.johnson@example.com\",\n      \"phone\": \"+1234567890\",\n      \"account_status\": \"Active\"\n    },\n    \"recent_transactions\": [\n      {\n        \"transaction_id\": \"tx1001\",\n        \"date\": \"2024-06-25T14:22:05Z\",\n        \"type\": \"Credit\",\n        \"amount\": 500.00,\n        \"currency\": \"USD\",\n        \"description\": \"Salary Deposit\",\n        \"merchant\": null,\n        \"status\": \"Completed\"\n      },\n      {\n        \"transaction_id\": \"tx1002\",\n        \"date\": \"2024-06-24T10:12:30Z\",\n        \"type\": \"Debit\",\n        \"amount\": 75.5,\n        \"currency\": \"USD\",\n        \"description\": \"Grocery Shopping\",\n        \"merchant\": \"Supermarket XYZ\",\n        \"status\": \"Completed\"\n      },\n      {\n        \"transaction_id\": \"tx1003\",\n        \"date\": \"2024-06-23T18:45:00Z\",\n        \"type\": \"Debit\",\n        \"amount\": 20.0,\n        \"currency\": \"USD\",\n        \"description\": \"Coffee Shop\",\n        \"merchant\": \"Cafe ABC\",\n        \"status\": \"Completed\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Digital Wallet Statement\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UserProfile:\\n      type: object\\n      description: 'Details of the wallet user profile'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier of the user'\\n          example: 'u123456789'\\n        full_name:\\n          type: string\\n          description: 'Full name of the user'\\n          example: 'Alice Johnson'\\n        email:\\n          type: string\\n          description: 'Email address of the user'\\n          example: 'alice.johnson@example.com'\\n        phone:\\n          type: string\\n          description: 'Contact phone number of the user'\\n          example: '+1234567890'\\n        account_status:\\n          type: string\\n          description: 'Current status of the user account'\\n          example: 'Active'\\n    Transaction:\\n      type: object\\n      description: 'Representation of a wallet transaction'\\n      properties:\\n        transaction_id:\\n          type: string\\n          description: 'Unique identifier of the transaction'\\n          example: 'tx1001'\\n        date:\\n          type: string\\n          format: date-time\\n          description: 'Transaction date and time in ISO 8601 format'\\n          example: '2024-06-25T14:22:05Z'\\n        type:\\n          type: string\\n          description: 'Type of transaction, either Credit or Debit'\\n          example: 'Credit'\\n        amount:\\n          type: number\\n          format: float\\n          description: 'Amount involved in the transaction'\\n          example: 500.00\\n        currency:\\n          type: string\\n          description: 'Currency code used for the transaction'\\n          example: 'USD'\\n        description:\\n          type: string\\n          description: 'Brief description of the transaction'\\n          example: 'Salary Deposit'\\n        merchant:\\n          type: string\\n          nullable: true\\n          description: 'Name of the merchant involved, if any'\\n          example: null\\n        status:\\n          type: string\\n          description: 'Current status of the transaction'\\n          example: 'Completed'\\n    WalletStatement:\\n      type: object\\n      description: 'Digital wallet statement including balance, user profile and recent transactions'\\n      properties:\\n        current_balance:\\n          type: number\\n          format: float\\n          description: 'Current balance available in the wallet'\\n          example: 2570.45\\n        currency:\\n          type: string\\n          description: 'Currency code of the wallet balance'\\n          example: 'USD'\\n        user_profile:\\n          $ref: '#/components/schemas/UserProfile'\\n        recent_transactions:\\n          type: array\\n          description: 'List of the last 3 recent wallet transactions'\\n          items:\\n            $ref: '#/components/schemas/Transaction'\"\n}"
