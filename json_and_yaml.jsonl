do todas as noites\\\",\\n            \\\"example\\\": 1035.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"currency\\\", \\\"nights\\\", \\\"total_price\\\"]\\n      },\\n      \\\"Amenity\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Amenidade solicitada para a reserva\\\",\\n        \\\"properties\\\": {\\n          \\\"code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código identificador da amenidade\\\",\\n            \\\"example\\\": \\\"CRIB\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Descrição da amenidade\\\",\\n            \\\"example\\\": \\\"Berço para bebê\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"code\\\", \\\"description\\\"]\\n      },\\n      \\\"ReservationResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta detalhada do sistema para uma reserva de hotel\\\",\\n        \\\"properties\\\": {\\n          \\\"reservation_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único da reserva\\\",\\n            \\\"example\\\": \\\"res_98765\\\"\\n          },\\n          \\\"room_type\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/RoomType\\\"\\n          },\\n          \\\"pricing\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/PricingBreakdown\\\"\\n          },\\n          \\\"amenities_requested\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de amenidades solicitadas na reserva\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Amenity\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"reservation_id\\\", \\\"room_type\\\", \\\"pricing\\\", \\\"amenities_requested\\\"]\\n      }\\n    }\\n  },\\n  \\\"pa