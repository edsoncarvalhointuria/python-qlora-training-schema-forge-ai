: {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Meal preference selected by the passenger\\\",\\n        \\\"properties\\\": {\\n          \\\"meal_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of meal\\\",\\n            \\\"example\\\": \\\"Vegetarian\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Description of the meal preference\\\",\\n            \\\"example\\\": \\\"A vegetarian meal with no meat or fish\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"meal_type\\\", \\\"description\\\"]\\n      },\\n      \\\"BookingConfirmation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Airline flight booking confirmation details\\\",\\n        \\\"properties\\\": {\\n          \\\"booking_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the booking\\\",\\n            \\\"example\\\": \\\"BK123456789\\\"\\n          },\\n          \\\"passenger\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Passenger\\\"\\n          },\\n          \\\"itinerary\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Itinerary\\\"\\n          },\\n          \\\"upgrades\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of selected seat upgrades\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Upgrade\\\"\\n            }\\n          },\\n          \\\"meal_preferences\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of meal preferences\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/MealPreference\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"booking_id\\\", \\\"passenger\\\", \\\"itinerary\\\", \\\"upgrades\\\", \\\"meal_preferences\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"security\\\": [],\\n  \\\"externalDocs\\\": {},\\n  \\\"tags\\\": [],\\n  \\\"servers\\\": []\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"property_id\": \"prop_12345\",\n    \"address\": \"1234 Elm Street, Springfield, IL\",\n    \"architectural_specs\": {\n      \"year_built\": 1998,\n      \"square_feet\": 3200,\n      \"bedrooms\": 4,\n      \"bathrooms\": 3.5,\n      \"building_type\": \"Single Family Home\",\n      \"has_garage\": true\n    },\n    \"images\": [\n      {\n        \"url\": \"https://realestate.example.com/images/property12345/front_view_highres.jpg\",\n        \"description\": \"Front view\"\n      },\n      {\n        \"url\": \"https://realestate.example.com/images/property12345/living_room_highres.jpg\",\n        \"description\": \"Living room\"\n      },\n      {\n        \"url\": \"https://realestate.example.com/images/property12345/kitchen_highres.jpg\",\n        \"description\": \"Kitchen\"\n      }\n    ],\n    \"realtor_contact\": {\n      \"name\": \"Jane Doe\",\n      \"phone\": \"+1-555-234-5678\",\n      \"email\": \"jdoe@realestateco.com\",\n      \"agency\": \"RealEstateCo\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Real Estate Property Listing\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Architectural specifications of the property'\\n      properties:\\n        year_built:\\n          type: integer\\n          description: 'Year the property was constructed'\\n          example: 1998\\n        square_feet:\\n          type: integer\\n          description: 'Total area of the property in square feet'\\n          example: 3200\\n        bedrooms:\\n          type: integer\\n          description: 'Number of bedrooms in the property'\\n          example: 4\\n        bathrooms:\\n          type: number\\n          description: 'Number of bathrooms, including partial baths'\\n          example: 3.5\\n        building_type:\\n          type: string\\n          description: 'Type of the building'\\n          example: 'Single Family Home'\\n        has_garage:\\n          type: boolean\\n          description: 'Indicates if the property has a garage'\\n          example: true\\n    PropertyImage:\\n      type: object\\n      description: 'High-resolution image detail for the property'\\n      properties:\\n        url:\\n          type: string\\n          format: uri\\n          description: 'URL to the high-resolution image'\\n          example: 'https://realestate.example.com/images/property12345/front_view_highres.jpg'\\n        description:\\n          type: string\\n          description: 'Description of the image content'\\n          example: 'Front view'\\n    RealtorContact:\\n      type: object\\n      description: 'Contact information for the assigned realtor'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Full name of the realtor'\\n          example: 'Jane Doe'\\n        phone:\\n          type: string\\n          description: 'Contact phone number with country code'\\n          example: '+1-555-234-5678'\\n        email:\\n          type: string\\n          format: email\\n          description: 'Email address of the realtor'\\n          example: 'jdoe@realestateco.com'\\n        agency:\\n          type: string\\n          description: 'Real estate agency name'\\n          example: 'RealEstateCo'\\n    PropertyListing:\\n      type: object\\n      description: 'Complete real estate property listing with specs, images, and realtor info'\\n      properties:\\n        property_id:\\n          type: string\\n          description: 'Unique identifier for the property'\\n          example: 'prop_12345'\\n        address:\\n          type: string\\n          description: 'Full street address of the property'\\n          example: '1234 Elm Street, Springfield, IL'\\n        architectural_specs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n          description: 'Array of high-resolution images for the property'\\n          items:\\n            $ref: '#/components/schemas/PropertyImage'\\n        realtor_contact:\\n          $ref: '#/components/schemas/RealtorContact'\"\n}"
"{\n  \"raw_json\": {\n    \"room_type\": \"Deluxe Suite\",\n    \"pricing\": {\n      \"nights\": 3,\n      \"price_per_night\": 450.5,\n      \"taxes\": 67.58,\n      \"total_price\": 1418.08\n    },\n    \"requested_amenities\": [\n      {\n        \"amenity_name\": \"Crib\",\n        \"quantity\": 1,\n        \"additional_cost\": 15.0\n      },\n      {\n        \"amenity_name\": \"Extra Bed\",\n        \"quantity\": 2,\n        \"additional_cost\": 40.0\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Resposta do Sistema de Reserva de Hotel\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Pricing\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhamento do preço por noite e custos totais\\\",\\n        \\\"properties\\\": {\\n          \\\"nights\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Número de noites reservadas\\\",\\n            \\\"example\\\": 3\\n          },\\n          \\\"price_per_night\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Preço cobrado por cada noite\\\",\\n            \\\"example\\\": 450.5\\n          },\\n          \\\"taxes\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Valor total dos impostos aplicados\\\",\\n            \\\"example\\\": 67.58\\n          },\\n          \\\"total_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Preço total incluindo todas as noites e impostos\\\",\\n            \\\"example\\\": 1418.08\\n          }\\n        },\\n        \\\"required\\\": [\\\"nights\\\", \\\"price_per_night\\\", \\\"taxes\\\", \\\"total_price\\\"]\\n      },\\n      \\\"Amenity\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Descrição de um item de comodidade solicitado\\\",\\n        \\\"properties\\\": {\\n          \\\"amenity_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome do item de comodidade\\\",\\n            \\\"example\\\": \\\"Crib\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantidade solicitada deste item\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"additional_cost\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Custo adicional para esta comodidade\\\",\\n            \\\"example\\\": 15.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"amenity_name\\\", \\\"quantity\\\", \\\"additional_cost\\\"]\\n      },\\n      \\\"HotelReservationResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta contendo tipo de quarto, detalhamento do preço e comodidades solicitadas\\\",\\n        \\\"properties\\\": {\\n          \\\"room_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo do quarto reservado\\\",\\n            \\\"example\\\": \\\"Deluxe Suite\\\"\\n          },\\n          \\\"pricing\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Pricing\\\"\\n          },\\n          \\\"requested_amenities\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de comodidades solicitadas pelo hóspede\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Amenity\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"room_type\\\", \\\"pricing\\\", \\\"requested_amenities\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"componentsNullable\\\": false\\n}\"\n}"
