\n      properties:\\n        min:\\n          type: number\\n          description: 'Minimum normal value for the biomarker'\\n          example: 13.5\\n        max:\\n          type: number\\n          description: 'Maximum normal value for the biomarker'\\n          example: 17.5\\n    BiomarkerResult:\\n      type: object\\n      description: 'Result data for a single blood biomarker'\\n      properties:\\n        biomarker:\\n          type: string\\n          description: 'Name of the biomarker tested'\\n          example: 'Hemoglobin'\\n        value:\\n          type: number\\n          description: 'Measured value of the biomarker'\\n          example: 14.2\\n        unit:\\n          type: string\\n          description: 'Measurement unit of the biomarker value'\\n          example: 'g/dL'\\n        normal_range:\\n          $ref: '#/components/schemas/NormalRange'\\n    PathologistSignature:\\n      type: object\\n      description: 'Digital signature details of the reviewing pathologist'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Full name of the pathologist'\\n          example: 'Dr. Alice Smith'\\n        signature_date:\\n          type: string\\n          format: date-time\\n          description: 'ISO 8601 date and time when signature was applied'\\n          example: '2024-05-30T14:35:00Z'\\n        digital_signature:\\n          type: string\\n          description: 'Encoded digital signature identifier of the pathologist'\\n          example: 'a1b2c3d4e5f67890abcdef1234567890abcdef12'\\n    LaboratoryTestResult:\\n      type: object\\n      description: 'Complete laboratory test result including patient demographics, biomarker results, and pathologist signature'\\n      properties:\\n        patient:\\n          $ref: '#/components/schemas/PatientDemographics'\\n        test_results:\\n          type: array\\n          description: 'List of blood biomarker test results'\\n          items:\\n            $ref: '#/components/schemas/BiomarkerResult'\\n        reviewing_pathologist_signature:\\n          $ref: '#/components/schemas/PathologistSignature'\\n\"\n}"
