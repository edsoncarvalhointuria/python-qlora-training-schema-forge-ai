"{\n  \"raw_json\": {\n    \"match_id\": \"match_2024_04\",\n    \"teams\": [\n      {\n        \"name\": \"Red Raptors\",\n        \"score\": 16,\n        \"players\": [\n          {\"player_id\": \"r1\", \"kills\": 20, \"deaths\": 5, \"assists\": 12},\n          {\"player_id\": \"r2\", \"kills\": 15, \"deaths\": 7, \"assists\": 10}\n        ]\n      },\n      {\n        \"name\": \"Blue Barracudas\",\n        \"score\": 14,\n        \"players\": [\n          {\"player_id\": \"b1\", \"kills\": 18, \"deaths\": 8, \"assists\": 9},\n          {\"player_id\": \"b2\", \"kills\": 14, \"deaths\": 10, \"assists\": 15}\n        ]\n      }\n    ],\n    \"timeline\": [\n      {\n        \"timestamp\": \"00:05:32\",\n        \"event\": \"First Blood\",\n        \"description\": \"Player r1 from Red Raptors secured the first kill.\"\n      },\n      {\n        \"timestamp\": \"00:20:10\",\n        \"event\": \"Objective Taken\",\n        \"description\": \"Blue Barracudas captured the central control point.\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Competitive E-sports Match Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PlayerStats:\\n      type: object\\n      description: 'Estatísticas detalhadas de um jogador na partida'\\n      properties:\\n        player_id:\\n          type: string\\n          description: 'Identificador único do jogador'\\n          example: 'r1'\\n        kills:\\n          type: integer\\n          description: 'Número total de abates pelo jogador'\\n          example: 20\\n        deaths:\\n          type: integer\\n          description: 'Número total de mortes do jogador'\\n          example: 5\\n        assists:\\n          type: integer\\n          description: 'Número total de assistências pelo jogador'\\n          example: 12\\n    Team:\\n      type: object\\n      description: 'Informações de uma equipe participante na partida'\\n      properties:\\n        name:\\n          type: string\\n