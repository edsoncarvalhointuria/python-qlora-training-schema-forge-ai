"{\n  \"raw_json\": {\n    \"current_balance\": 2548.75,\n    \"user_profile\": {\n      \"user_id\": \"usr_987654321\",\n      \"full_name\": \"Alice Johnson\",\n      \"email\": \"alice.johnson@example.com\",\n      \"phone_number\": \"+1234567890\",\n      \"account_created\": \"2022-07-15T10:20:30Z\"\n    },\n    \"recent_transactions\": [\n      {\n        \"transaction_id\": \"txn_0001\",\n        \"date\": \"2024-06-20T14:15:00Z\",\n        \"type\": \"debit\",\n        \"amount\": 150.00,\n        \"currency\": \"USD\",\n        \"description\": \"Grocery Store Purchase\",\n        \"merchant\": {\n          \"name\": \"Fresh Market\",\n          \"category\": \"Groceries\",\n          \"location\": \"New York, NY\"\n        }\n      },\n      {\n        \"transaction_id\": \"txn_0002\",\n        \"date\": \"2024-06-19T09:30:00Z\",\n        \"type\": \"credit\",\n        \"amount\": 1200.00,\n        \"currency\": \"USD\",\n        \"description\": \"Salary Deposit\",\n        \"merchant\": null\n      },\n      {\n        \"transaction_id\": \"txn_0003\",\n        \"date\": \"2024-06-18T18:45:00Z\",\n        \"type\": \"debit\",\n        \"amount\": 75.50,\n        \"currency\": \"USD\",\n        \"description\": \"Online Streaming Subscription\",\n        \"merchant\": {\n          \"name\": \"StreamFlix\",\n          \"category\": \"Entertainment\",\n          \"location\": \"San Francisco, CA\"\n        }\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Digital Wallet Statement\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Merchant:\\n      type: object\\n      description: 'Information about the merchant involved in the transaction'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Name of the merchant'\\n          example: 'Fresh Market'\\n        category:\\n          type: string\\n          description: 'Category of goods or services provided by the merchant'\\n          example: 'Groceries'\\n        location:\\n          type: string\\n          description: 'Geographical location of the merchant'\\n          example: 'New York, NY'\\n    Transaction:\\n      type: object\\n      description: 'Details of a wallet transaction'\\n      properties:\\n        transaction_id:\\n          type: string\\n          description: 'Unique identifier for the transaction'\\n          example: 'txn_0001'\\n        date:\\n          type: string\\n          format: date-time\\n          description: 'ISO 8601 date and time when the transaction occurred'\\n          example: '2024-06-20T14:15:00Z'\\n        type:\\n          type: string\\n          description: 'Indicates whether the transaction is a debit or credit'\\n          example: 'debit'\\n        amount:\\n          type: number\\n          format: float\\n          description: 'Monetary value of the transaction'\\n          example: 150.00\\n        currency:\\n          type: string\\n          description: 'Currency code in ISO 4217 format'\\n          example: 'USD'\\n        description:\\n          type: string\\n          description: 'Brief description or memo for the transaction'\\n          example: 'Grocery Store Purchase'\\n        merchant:\\n          oneOf:\\n            - $ref: '#/components/schemas/Merchant'\\n            - type: 'null'\\n          description: 'Details of the merchant involved, or null if not applicable'\\n    UserProfile:\\n      type: object\\n      description: 'Profile information about the wallet user'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_987654321'\\n        full_name:\\n          type: string\\n          description: 'Full name of the user'\\n          example: 'Alice Johnson'\\n        email:\\n          type: string\\n          description: 'Email address of the user'\\n          example: 'alice.johnson@example.com'\\n        phone_number:\\n          type: string\\n          description: 'Phone number of the user in international format'\\n          example: '+1234567890'\\n        account_created:\\n          type: string\\n          format: date-time\\n          description: 'Date and time when the wallet account was created'\\n          example: '2022-07-15T10:20:30Z'\\n    WalletStatement:\\n      type: object\\n      description: 'Digital wallet statement including balance, user profile, and recent transactions'\\n      properties:\\n        current_balance:\\n          type: number\\n          format: float\\n          description: 'Current available balance in the wallet'\\n          example: 2548.75\\n        user_profile:\\n          $ref: '#/components/schemas/UserProfile'\\n        recent_transactions:\\n          type: array\\n          description: 'List of most recent transactions, limited to 3 entries'\\n          items:\\n            $ref: '#/components/schemas/Transaction'\\n\"\n}"
