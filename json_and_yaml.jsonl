"{\n  \"raw_json\": {\n    \"property_id\": \"prop_12345\",\n    \"address\": \"123 Main St, Springfield, IL 62704\",\n    \"architectural_specs\": {\n      \"year_built\": 1995,\n      \"floor_count\": 2,\n      \"total_area_sqft\": 2500,\n      \"bedrooms\": 4,\n      \"bathrooms\": 3,\n      \"has_garage\": true\n    },\n    \"images\": [\n      {\n        \"image_type\": \"exterior\",\n        \"urls\": [\n          \"https://realestate.example.com/images/prop_12345/exterior_1.jpg\",\n          \"https://realestate.example.com/images/prop_12345/exterior_2.jpg\"\n        ]\n      },\n      {\n        \"image_type\": \"interior\",\n        \"urls\": [\n          \"https://realestate.example.com/images/prop_12345/interior_1.jpg\",\n          \"https://realestate.example.com/images/prop_12345/interior_2.jpg\",\n          \"https://realestate.example.com/images/prop_12345/interior_3.jpg\"\n        ]\n      }\n    ],\n    \"realtor\": {\n      \"name\": \"Jane Doe\",\n      \"phone\": \"+1-555-123-4567\",\n      \"email\": \"jane.doe@realtyexample.com\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Real Estate Property Listing\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Architectural specifications of the property'\\n      properties:\\n        year_built:\\n          type: integer\\n          description: 'Year when the property was built'\\n          example: 1995\\n        floor_count:\\n          type: integer\\n          description: 'Number of floors in the property'\\n          example: 2\\n        total_area_sqft:\\n          type: integer\\n          description: 'Total area of the property in square feet'\\n          example: 2500\\n        bedrooms:\\n          type: integer\\n          description: 'Number of bedrooms'\\n          example: 4\\n        bathrooms:\\n          type: integer\\n          description: 'Number of bathrooms'\\n          example: 3\\n        has_garage:\\n          type: boolean\\n          description: 'Whether the property includes a garage'\\n          example: true\\n    ImageUrls:\\n      type: array\\n      description: 'List of high-resolution image URLs'\\n      items:\\n        type: string\\n        format: uri\\n        description: 'URL to an image'\\n        example: 'https://realestate.example.com/images/prop_12345/exterior_1.jpg'\\n    ImageGroup:\\n      type: object\\n      description: 'Grouping of images by type with URLs'\\n      properties:\\n        image_type:\\n          type: string\\n          description: 'Category of the images (e.g., exterior, interior)'\\n          example: 'exterior'\\n        urls:\\n          $ref: '#/components/schemas/ImageUrls'\\n    RealtorContact:\\n      type: object\\n      description: 'Contact information of the assigned realtor'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Full name of the realtor'\\n          example: 'Jane Doe'\\n        phone:\\n          type: string\\n          description: 'Phone number of the realtor'\\n          example: '+1-555-123-4567'\\n        email:\\n          type: string\\n          format: email\\n          description: 'Email address of the realtor'\\n          example: 'jane.doe@realtyexample.com'\\n    PropertyListing:\\n      type: object\\n      description: 'Complete property listing including specs, images, and realtor info'\\n      properties:\\n        property_id:\\n          type: string\\n          description: 'Unique identifier for the property'\\n          example: 'prop_12345'\\n        address:\\n          type: string\\n          description: 'Physical address of the property'\\n          example: '123 Main St, Springfield, IL 62704'\\n        architectural_specs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n          description: 'Array of image groups with URLs'\\n          items:\\n    