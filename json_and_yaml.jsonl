"{\n  \"raw_json\": {\n    \"order_id\": \"ORD123456\",\n    \"status\": \"Out for delivery\",\n    \"courier\": {\n      \"courier_id\": \"CR7890\",\n      \"name\": \"John Doe\",\n      \"location\": {\n        \"latitude\": 40.712776,\n        \"longitude\": -74.005974,\n        \"timestamp\": \"2024-06-01T12:30:45Z\"\n      }\n    },\n    \"restaurant\": {\n      \"restaurant_id\": \"RST4567\",\n      \"name\": \"Pasta Palace\",\n      \"address\": \"1234 Noodle St, Food City\",\n      \"contact_number\": \"+1234567890\",\n      \"rating\": 4.5\n    },\n    \"ordered_dishes\": [\n      {\n        \"dish_id\": \"DISH001\",\n        \"name\": \"Spaghetti Carbonara\",\n        \"quantity\": 2,\n        \"special_dietary_notes\": \"Contains gluten and dairy\"\n      },\n      {\n        \"dish_id\": \"DISH002\",\n        \"name\": \"Vegan Salad\",\n        \"quantity\": 1,\n        \"special_dietary_notes\": \"Gluten-free, vegan\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Food Delivery Order Status\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Location:\\n      type: object\\n      description: Real-time GPS location of the courier\\n      properties:\\n        latitude:\\n          type: number\\n          format: float\\n          description: Latitude coordinate\\n          example: 40.712776\\n        longitude:\\n          type: number\\n          format: float\\n          description: Longitude coordinate\\n          example: -74.005974\\n        timestamp:\\n          type: string\\n          format: date-time\\n          description: ISO 8601 timestamp of location update\\n          example: '2024-06-01T12:30:45Z'\\n    Courier:\\n      type: object\\n      description: Information about the delivery courier\\n      properties:\\n        courier_id:\\n          type: string\\n          description: Unique identifier for the courier\\n          example: 'CR7890'\\n        name:\\n          type: string\\n          description: Courier's full name\\n          example: 'John Doe'\\n        location:\\n          $ref: '#/components/schemas/Location'\\n    Restaurant:\\n      type: object\\n      description: Profile information of the restaurant\\n      properties:\\n        restaurant_id:\\n          type: string\\n          description: Unique identifier for the restaurant\\n          example: 'RST4567'\\n        name:\\n          type: string\\n          description: Name of the restaurant\\n          example: 'Pasta Palace'\\n        address:\\n          type: string\\n          description: Physical address of the restaurant\\n          example: '1234 Noodle St, Food City'\\n        contact_number:\\n          type: string\\n          description: Contact phone number of the restaurant\\n          example: '+1234567890'\\n        rating:\\n          type: number\\n          format: float\\n          description: Average customer rating\\n          example: 4.5\\n    OrderedDish:\\n      type: object\\n      description: Details about a dish ordered in the order\\n      properties:\\n        dish_id:\\n          type: string\\n          description: Unique identifier for the dish\\n          example: 'DISH001'\\n        name:\\n          type: string\\n          description: Name of the dish\\n          example: 'Spaghetti Carbonara'\\n        quantity:\\n          type: integer\\n          description: Number of servings ordered\\n          example: 2\\n        special_dietary_notes:\\n          type: string\\n          description: Notes about any special dietary considerations\\n          example: 'Contains gluten and dairy'\\n    OrderStatus:\\n      type: object\\n      description: Status information of a food delivery order\\n      properties:\\n        order_id:\\n          type: string\\n          description: Unique identifier for the order\\n          example: 'ORD123456'\\n        status:\\n          type: string\\n          description: Current status of the order\\n          example: 'Out for delivery'\\n        courier:\\n          $ref: '#/components/schemas/Courier'\\n        restaurant:\\n          $ref: '#/components/schemas/Restaurant'\\n        ordered_dishes:\\n          type: array\\n          description: List of dishes ordered\\n          items:\\n            $ref: '#/components/schemas/OrderedDish'\"\n}"
