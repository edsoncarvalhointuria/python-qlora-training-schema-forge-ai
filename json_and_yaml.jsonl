    \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Country name\\\",\\n            \\\"example\\\": \\\"USA\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"recipient_name\\\", \\\"street\\\", \\\"city\\\", \\\"state\\\", \\\"postal_code\\\", \\\"country\\\"]\\n      },\\n      \\\"PaymentTransaction\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the payment transaction made for the order\\\",\\n        \\\"properties\\\": {\\n          \\\"transaction_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the payment transaction\\\",\\n            \\\"example\\\": \\\"txn_7890\\\"\\n          },\\n          \\\"payment_method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Method of payment used\\\",\\n            \\\"example\\\": \\\"credit_card\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total amount paid\\\",\\n            \\\"example\\\": 139.97\\n          },\\n          \\\"currency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Currency code of the transaction\\\",\\n            \\\"example\\\": \\\"USD\\\"\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Status of the payment transaction\\\",\\n            \\\"example\\\": \\\"completed\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"transaction_id\\\", \\\"payment_method\\\", \\\"amount\\\", \\\"currency\\\", \\\"status\\\"]\\n      },\\n      \\\"Link\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Hypermedia link for resource navigation\\\",\\n        \\\"properties\\\": {\\n          \\\"href\\\": {\\n            \\\"type\\