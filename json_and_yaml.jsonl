\\\": \\\"Response showing claim status including provider, billed procedures, and cost details\\\",\\n        \\\"properties\\\": {\\n          \\\"provider\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Provider\\\"\\n          },\\n          \\\"procedures\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of medical procedures billed in the claim\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Procedure\\\"\\n            },\\n            \\\"example\\\": [\\n              {\\n                \\\"procedure_code\\\": \\\"PROC001\\\",\\n                \\\"description\\\": \\\"MRI Scan\\\",\\n                \\\"billed_amount\\\": 1500.00\\n              },\\n              {\\n                \\\"procedure_code\\\": \\\"PROC002\\\",\\n                \\\"description\\\": \\\"Blood Test\\\",\\n                \\\"billed_amount\\\": 200.00\\n              }\\n            ]\\n          },\\n          \\\"costs\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Costs\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"tooth_chart\": [\n      { \"tooth_number\": \"11\", \"status\": \"healthy\", \"surface_notes\": \"No cavities\" },\n      { \"tooth_number\": \"26\", \"status\": \"filled\", \"surface_notes\": \"Composite filling on occlusal surface\" }\n    ],\n    \"past_procedures\": [\n      {\n        \"procedure_id\": \"proc_001\",\n        \"procedure_name\": \"Root Canal Treatment\",\n        \"date_performed\": \"2023-01-10\",\n        \"tooths_involved\": [\"26\"],\n        \"notes\": \"Successful treatment with no complications\"\n      },\n      {\n        \"procedure_id\": \"proc_002\",\n        \"procedure_name\": \"Teeth Cleaning\",\n        \"date_performed\": \"2023-03-15\",\n        \"tooths_involved\": [],\n        \"notes\": \"Routine cleaning and polishing\"\n      }\n    ],\n    \"upcoming_cleanings\": {\n      \"next_cleaning_date\": \"2024-07-20\",\n      \"location\": \"Room 3, Main Clinic\",\n      \"contact_info\": {\n        \"phone\": \"+1234567890\",\n        \"email\": \"appointments@dentalclinic.com\"\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Dental Clinic Patient History\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ToothChartItem:\\n      type: object\\n      description: 'Details of an individual tooth in the anatomical tooth chart'\\n      properties:\\n        tooth_number:\\n          type: string\\n          description: 'Universal tooth identifier number'\\n          example: '11'\\n        status:\\n          type: string\\n          description: 'Condition status of the tooth'\\n          example: 'filled'\\n        surface_notes:\\n          type: string\\n          description: 'Notes about the tooth surface condition'\\n          example: 'Composite filling on occlusal surface'\\n    PastProcedure:\\n      type: object\\n      description: 'Record of a previously performed dental procedure'\\n      properties:\\n        procedure_id:\\n          type: string\\n       