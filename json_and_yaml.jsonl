     },\\n      \\\"Officer\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Customs officer responsible for clearance\\\",\\n        \\\"properties\\\": {\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Full name of the customs officer\\\",\\n            \\\"example\\\": \\\"Alice Johnson\\\"\\n          },\\n          \\\"badge_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Badge or identifier number of the officer\\\",\\n            \\\"example\\\": \\\"BZ7890\\\"\\n          }\\n        }\\n      },\\n      \\\"CustomsStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Status information of customs clearance for the container\\\",\\n        \\\"properties\\\": {\\n          \\\"cleared\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indicates if the container has been cleared by customs\\\",\\n            \\\"example\\\": true\\n          },\\n          \\\"clearance_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"ISO 8601 timestamp of when the clearance was granted\\\",\\n            \\\"example\\\": \\\"2024-06-11T08:00:00Z\\\"\\n          },\\n          \\\"officer\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Officer\\\"\\n          }\\n        }\\n      },\\n      \\\"EnvironmentalReading\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"One environmental sensor reading inside the container\\\",\\n        \\\"properties\\\": {\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"ISO 8601 timestamp of the reading\\\",\\n            \\\"example\\\": \\\"2024-06-11T08:10:00Z\\\"\\n          },\\n          \\\"temperature_celsius\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Temperature reading in degrees Celsius\\\",\\n            \\\"example\\\": 5.2\\n          },\\n          \\\"humidity_percent\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Humidity percentage reading inside the container\\\",\\n            \\\"example\\\": 85\\n          }\\n        }\\n      },\\n      \\\"ContainerTrackingResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Comprehensive tracking information for a shipping container\\\",\\n        \\\"properties\\\": {\\n          \\\"container_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the shipping container\\\",\\n            \\\"example\\\": \\\"CONT1234567\\\"\\n          },\\n          \\\"current_location\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Location\\\"\\n          },\\n          \\\"customs_status\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/CustomsStatus\\\"\\n          },\\n          \\\"environmental_readings\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of environmental readings recorded inside the container\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/EnvironmentalReading\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"responses\\\": {},\\n  \\\"root\\\": {\\n    \\\"$ref\\\": \\\"#/components/schemas/ContainerTrackingResponse\\\"\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"order_id\": \"ord_12345\",\n    \"status\": \"en_route\",\n    \"courier\": {\n      \"courier_id\": \"courier_987\",\n      \"name\": \"Alice Johnson\",\n      \"location\": {\n        \"latitude\": 40.712776,\n        \"longitude\": -74.005974,\n        \"last_updated\": \"2024-06-01T14:25:43Z\"\n      }\n    },\n    \"restaurant\": {\n      \"restaurant_id\": \"rest_456\",\n      \"name\": \"Green Garden\",\n      \"address\": \"123 Green St, New York, NY\",\n      \"rating\": 4.5\n    },\n    \"dishes\": [\n      {\n        \"dish_id\": \"dish_1\",\n        \"name\": \"Quinoa Salad\",\n        \"quantity\": 2,\n        \"special_dietary_notes\": [\n          \"gluten_free\",\n          \"vegan\"\n        ]\n      },\n      {\n        \"dish_id\": \"dish_2\",\n        \"name\": \"Grilled Chicken\",\n        \"quantity\": 1,\n        \"special_dietary_notes\": [\n          \"high_protein\"\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Food Delivery Order Status\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Location:\\n      type: object\\n      description: 'Current GPS coordinates and last update timestamp of the courier'\\n      properties:\\n        latitude:\\n          type: number\\n          format: double\\n          description: 'Latitude coordinate'\\n          example: 40.712776\\n        longitude:\\n          type: number\\n          format: double\\n          description: 'Longitude coordinate'\\n          example: -74.005974\\n        last_updated:\\n          type: string\\n          format: date-time\\n          description: 'Timestamp of the last location update in ISO 8601 format'\\n          example: '2024-06-01T14:25:43Z'\\n    Courier:\\n      type: object\\n      description: 'Details about the delivery courier'\\n      properties:\\n        courier_id:\\n          type: string\\n          description: 'Unique identifier for the courier'\\n          example: 'courier_987'\\n        name:\\n          type: string\\n          description: 'Full name of the courier'\\n          example: 'Alice Johnson'\\n        location:\\n          $ref: '#/components/schemas/Location'\\n    Restaurant:\\n      type: object\\n      description: 'Profile information of the restaurant'\\n      properties:\\n        restaurant_id:\\n          type: string\\n          description: 'Unique identifier for the restaurant'\\n          example: 'rest_456'\\n        name:\\n          type: string\\n          description: 'Name of the restaurant'\\n          example: 'Green Garden'\\n        address:\\n          type: string\\n          description: 'Physical address of the restaurant'\\n          example: '123 Green St, New York, NY'\\n        rating:\\n          type: number\\n          format: float\\n          description: 'Average customer rating of the restaurant'\\n          example: 4.5\\n    Dish:\\n      type: object\\n      description: 'Information about a dish in the order'\\n      properties:\\n        dish_id:\\n          type: string\\n          description: 'Unique identifier for the dish'\\n          example: 'dish_1'\\n        name:\\n          type: string\\n          description: 'Name of the dish'\\n          example: 'Quinoa Salad'\\n        quantity:\\n          type: integer\\n          description: 'Quantity of the dish ordered'\\n          example: 2\\n        special_dietary_notes:\\n          type: array\\n          description: 'Special dietary requirements or notes for the dish'\\n          items:\\n            type: string\\n            description: 'A dietary note related to the dish'\\n            example: 'gluten_free'\\n    OrderStatus:\\n      type: object\\n      description: 'Current status and details of a food delivery order'\\n      properties:\\n        order_id:\\n          type: string\\n          description: 'Unique identifier for the order'\\n          example: 'ord_12345'\\n        status:\\n          type: string\\n          description: 'Current status of the order'\\n          example: 'en_route'\\n        courier:\\n          $ref: '#/components/schemas/Courier'\\n        restaurant:\\n          $ref: '#/components/schemas/Restaurant'\\n        dishes:\\n          type: array\\n          description: 'List of dishes included in the order'\\n          items:\\n            $ref: '#/components/schemas/Dish'\"\n}"
"{\n  \"raw_json\": {\n    \"booking_id\": \"BOOK123456\",\n    \"passenger\": {\n      \"first_name\": \"Alice\",\n      \"last_name\": \"Johnson\",\n      \"passport_number\": \"X1234567\",\n      \"contact_email\": \"alice.johnson@example.com\"\n    },\n    \"itinerary\": {\n      \"origin\": \"JFK\",\n      \"destination\": \"LAX\",\n      \"departure_date\": \"2024-07-15T09:30:00Z\",\n      \"arrival_date\": \"2024-07-15T12:15:00Z\",\n      \"layovers\": [\n        {\n          \"location\": \"ORD\",\n          \"arrival_time\": \"2024-07-15T11:00:00Z\",\n          \"departure_time\": \"2024-07-15T11:45:00Z\",\n          \"duration_minutes\": 45\n        }\n      ]\n    },\n    \"seat_upgrades\": [\n      {\n        \"segment\": 1,\n        \"seat_class\": \"Business\",\n        \"additional_cost\": 150.00\n      }\n    ],\n    \"meal_preferences\": [\n      {\n        \"segment\": 1,\n        \"meal_type\": \"Vegetarian\",\n        \"special_notes\": \"No nuts\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Flight Booking Confirmation\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Passenger\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the passenger\\\",\\n        \\\"properties\\\": {\\n          \\\"first_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's first name\\\",\\n            \\\"example\\\": \\\"Alice\\\"\\n          },\\n          \\\"last_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's last name\\\",\\n            \\\"example\\\": \\\"Johnson\\\"\\n          },\\n          \\\"passport_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passport number of the passenger\\\",\\n            \\\"example\\\": \\\"X1234567\\\"\\n          },\\n          \\\"contact_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's contact email address\\\",\\n            \\\"example\\\": \\\"alice.johnson@example.com\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"first_name\\\", \\\"last_name\\\", \\\"passport_number\\\", \\\"contact_email\\\"]\\n      },\\n      \\\"Layover\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a single layover in the itinerary\\\",\\n        \\\"properties\\\": {\\n          \\\"location\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Airport code for the layover location\\\",\\n            \\\"example\\\": \\\"ORD\\\"\\n          },\\n          \\\"arrival_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled arrival time at the layover\\\",\\n            \\\"example\\\": \\\"2024-07-15T11:00:00Z\\\"\\n          },\\n          \\\"departure_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled departure time from the layover\\\",\\n            \\\"example\\\": \\\"2024-07-15T11:45:00Z\\\"\\n          },\\n          \\\"duration_minutes\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Duration of the layover in minutes\\\",\\n            \\\"example\\\": 45\\n          }\\n        },\\n        \\\"required\\\": [\\\"location\\\", \\\"arrival_time\\\", \\\"departure_time\\\", \\\"duration_minutes\\\"]\\n      },\\n      \\\"Itinerary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Flight itinerary details including layovers\\\",\\n        \\\"properties\\\": {\\n          \\\"origin\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Airport code of departure\\\",\\n            \\\"example\\\": \\\"JFK\\\"\\n          },\\n          \\\"destination\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Airport code of arrival\\\",\\n            \\\"example\\\": \\\"LAX\\\"\\n          },\\n          \\\"departure_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled departure date and time\\\",\\n            \\\"example\\\": \\\"2024-07-15T09:30:00Z\\\"\\n          },\\n          \\\"arrival_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled arrival date and time\\\",\\n            \\\"example\\\": \\\"2024-07-15T12:15:00Z\\\"\\n          },\\n          \\\"layovers\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of layovers during the itinerary\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Layover\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"origin\\\", \\\"destination\\\", \\\"departure_date\\\", \\\"arrival_date\\\", \\\"layovers\\\"]\\n      },\\n      \\\"SeatUpgrade\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about seat upgrade for a flight segment\\\",\\n        \\\"properties\\\": {\\n          \\\"segment\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Segment number of the flight\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"seat_class\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Class of the upgraded seat\\\",\\n            \\\"example\\\": \\\"Business\\\"\\n          },\\n          \\\"additional_cost\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Additional cost for the upgrade in USD\\\",\\n            \\\"example\\\": 150.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"segment\\\", \\\"seat_class\\\", \\\"additional_cost\\\"]\\n      },\\n      \\\"MealPreference\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Passenger's meal preference for a flight segment\\\",\\n        \\\"properties\\\": {\\n          \\\"segment\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Segment number of the flight\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"meal_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of meal requested\\\",\\n            \\\"example\\\": \\\"Vegetarian\\\"\\n          },\\n          \\\"special_notes\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Additional meal notes or restrictions\\\",\\n            \\\"example\\\": \\\"No nuts\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"segment\\\", \\\"meal_type\\\"]\\n      },\\n      \\\"BookingConfirmation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Flight booking confirmation details\\\",\\n        \\\"properties\\\": {\\n          \\\"booking_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the booking\\\",\\n            \\\"example\\\": \\\"BOOK123456\\\"\\n          },\\n          \\\"passenger\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Passenger\\\"\\n          },\\n          \\\"itinerary\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Itinerary\\\"\\n          },\\n          \\\"seat_upgrades\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of selected seat upgrades\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/SeatUpgrade\\\"\\n            }\\n          },\\n          \\\"meal_preferences\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of meal preferences\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/MealPreference\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"booking_id\\\", \\\"passenger\\\", \\\"itinerary\\\", \\\"seat_upgrades\\\", \\\"meal_preferences\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"paths\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"info\\\": {},\\n  \\\"servers\\\": [],\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"BookingConfirmation\\\": {\\n        \\\"$ref\\\": \\\"#/components/schemas/BookingConfirmation\\\"\\n      }\\n    }\\n  },\\n  \\\"definitions\\\": {}\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"property\": {\n      \"id\": \"prop_789\",\n      \"title\": \"Modern Family Home\",\n      \"description\": \"A spacious 4-bedroom modern family home with eco-friendly design and open floor plan.\",\n      \"price_usd\": 450000,\n      \"address\": {\n        \"street\": \"1234 Elm Street\",\n        \"city\": \"Springfield\",\n        \"state\": \"IL\",\n        \"zip_code\": \"62704\",\n        \"country\": \"USA\"\n      },\n      \"architectural_specs\": {\n        \"year_built\": 2021,\n        \"square_feet\": 3200,\n        \"floor_count\": 2,\n        \"bedrooms\": 4,\n        \"bathrooms\": 3.5,\n        \"heating\": \"Central Heating\",\n        \"cooling\": \"Central Air Conditioning\",\n        \"energy_efficient\": true,\n        \"material\": \"Brick and Stone\"\n      },\n      \"images\": [\n        {\n          \"url\": \"https://images.example.com/properties/prop_789/front_view_highres.jpg\",\n          \"description\": \"Front view of the property\"\n        },\n        {\n          \"url\": \"https://images.example.com/properties/prop_789/living_room_highres.jpg\",\n          \"description\": \"Spacious living room with natural light\"\n        },\n        {\n          \"url\": \"https://images.example.com/properties/prop_789/kitchen_highres.jpg\",\n          \"description\": \"Modern kitchen area with island\"\n        }\n      ],\n      \"realtor\": {\n        \"id\": \"realtor_456\",\n        \"name\": \"Jessica Stein\",\n        \"phone\": \"+1-555-789-1234\",\n        \"email\": \"jessica.stein@dreamhomes.com\",\n        \"agency\": \"Dream Homes Realty\"\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Real Estate Property Listing API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Address:\\n      type: object\\n      description: 'Physical address details of the property'\\n      properties:\\n        street:\\n          type: string\\n          description: 'Street address'\\n          example: '1234 Elm Street'\\n        city:\\n          type: string\\n          description: 'City name'\\n          example: 'Springfield'\\n        state:\\n          type: string\\n          description: 'State or province'\\n          example: 'IL'\\n        zip_code:\\n          type: string\\n          description: 'Postal or zip code'\\n          example: '62704'\\n        country:\\n          type: string\\n          description: 'Country name'\\n          example: 'USA'\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Architectural specifications of the property'\\n      properties:\\n        year_built:\\n          type: integer\\n          description: 'Year when the property was built'\\n          example: 2021\\n        square_feet:\\n          type: integer\\n          description: 'Total square footage of the property'\\n          example: 3200\\n        floor_count:\\n          type: integer\\n          description: 'Number of floors in the property'\\n          example: 2\\n        bedrooms:\\n          type: integer\\n          description: 'Number of bedrooms'\\n          example: 4\\n        bathrooms:\\n          type: number\\n          description: 'Number of bathrooms including partial'\\n          example: 3.5\\n        heating:\\n          type: string\\n          description: 'Heating system type'\\n          example: 'Central Heating'\\n        cooling:\\n          type: string\\n          description: 'Cooling system type'\\n          example: 'Central Air Conditioning'\\n        energy_efficient:\\n          type: boolean\\n          description: 'Indicates if the property has energy efficient features'\\n          example: true\\n        material:\\n          type: string\\n          description: 'Primary construction materials used'\\n          example: 'Brick and Stone'\\n    Image:\\n      type: object\\n      description: 'High-resolution image with description'\\n      properties:\\n        url:\\n          type: string\\n          format: uri\\n          description: 'URL to the high resolution image'\\n          example: 'https://images.example.com/properties/prop_789/front_view_highres.jpg'\\n        description:\\n          type: string\\n          description: 'Image description'\\n          example: 'Front view of the property'\\n    Realtor:\\n      type: object\\n      description: 'Contact information for the assigned realtor'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier of the realtor'\\n          example: 'realtor_456'\\n        name:\\n          type: string\\n          description: 'Full name of the realtor'\\n          example: 'Jessica Stein'\\n        phone:\\n          type: string\\n          description: 'Phone contact number'\\n          example: '+1-555-789-1234'\\n        email:\\n          type: string\\n          format: email\\n          description: 'Email address of the realtor'\\n          example: 'jessica.stein@dreamhomes.com'\\n        agency:\\n          type: string\\n          description: 'Real estate agency the realtor belongs to'\\n          example: 'Dream Homes Realty'\\n    Property:\\n      type: object\\n      description: 'Detailed real estate property listing'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique property identifier'\\n          example: 'prop_789'\\n        title:\\n          type: string\\n          description: 'Listing title of the property'\\n          example: 'Modern Family Home'\\n        description:\\n          type: string\\n          description: 'Full descriptive text of the property'\\n          example: 'A spacious 4-bedroom modern family home with eco-friendly design and open floor plan.'\\n        price_usd:\\n          type: integer\\n          description: 'Listing price in US dollars'\\n          example: 450000\\n        address:\\n          $ref: '#/components/schemas/Address'\\n        architectural_specs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n          description: 'Collection of high-resolution images of the property'\\n          items:\\n            $ref: '#/components/schemas/Image'\\n        realtor:\\n          $ref: '#/components/schemas/Realtor'\"\n}"
