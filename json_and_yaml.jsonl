00\\n        architectural_specs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n          description: 'Nested array of high-resolution image URLs'\\n          items:\\n            type: array\\n            items:\\n              type: string\\n              description: 'URL of a high-resolution image'\\n              example: https://images.realestate.com/prop123_front_highres.jpg\\n        realtor_contact:\\n          $ref: '#/components/schemas/RealtorContact'\\n\"\n}"
