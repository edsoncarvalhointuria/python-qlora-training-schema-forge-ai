"{\n  \"raw_json\": {\n    \"patient_history\": {\n      \"tooth_chart\": {\n        \"tooth_number\": 12,\n        \"surface\": \"occlusal\",\n        \"condition\": \"cavity\"\n      },\n      \"past_procedures\": [\n        {\n          \"procedure_id\": \"proc_001\",\n          \"procedure_name\": \"filling\",\n          \"date\": \"2023-05-15\",\n          \"tooth_number\": 12,\n          \"notes\": \"Composite resin filling placed\"\n        },\n        {\n          \"procedure_id\": \"proc_002\",\n          \"procedure_name\": \"cleaning\",\n          \"date\": \"2023-01-10\",\n          \"tooth_number\": null,\n          \"notes\": \"Routine cleaning and scaling\"\n        }\n      ],\n      \"scheduled_cleanings\": {\n        \"next_appointment_date\": \"2024-07-20\",\n        \"reminder_sent\": true,\n        \"cleaning_type\": \"prophylaxis\",\n        \"metadata\": {\n          \"reminder_method\": \"email\",\n          \"reminder_sent_date\": \"2024-07-10\"\n        }\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Dental Clinic Patient History\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ToothChart:\\n      type: object\\n      description: 'Detalhes anatômicos do dente no gráfico odontológico'\\n      properties:\\n        tooth_number:\\n          type: integer\\n          description: 'Número do dente conforme notação odontológica'\\n          example: 12\\n        surface:\\n          type: string\\n          description: 'Superfície do dente avaliada'\\n          example: 'occlusal'\\n        condition:\\n          type: string\\n          description: 'Condição clínica observada na superfície do dente'\\n          example: 'cavity'\\n    PastProcedure:\\n      type: object\\n      description: 'Procedimento odontológico realizado anteriormente'\\n      properties:\\n        procedure_id:\\n          type: string\\n          description: 'Identificador único do procedimento'\\n          example: 'proc_001'\\n        procedure_name:\\n          type: string\\n          description: 'Nome do procedimento realizado'\\n          example: 'filling'\\n        date:\\n          type: string\\n          format: date\\n          description: 'Data em que o procedimento foi realizado'\\n          example: '2023-05-15'\\n        tooth_number:\\n          type: integer\\n          nullable: true\\n          description: 'Número do dente tratado, se aplicável'\\n          example: 12\\n        notes:\\n          type: string\\n          description: 'Notas adicionais sobre o procedimento'\\n          example: 'Composite resin filling placed'\\n    ScheduledCleaningMetadata:\\n      type: object\\n      description: 'Metadados detalhados para limpezas agendadas'\\n      properties:\\n        reminder_method:\\n          type: string\\n          description: 'Método usado para enviar o lembrete'\\n          example: 'email'\\n        reminder_sent_date:\\n          type: string\\n          format: date\\n          description: 'Data em que o lembrete foi enviado'\\n          example: '2024-07-10'\\n    ScheduledCleanings:\\n      type: object\\n      description: 'Informações sobre limpezas futuras agendadas'\\n      properties:\\n        next_appointment_date:\\n          type: string\\n          format: date\\n          description: 'Data da próxima consulta de limpeza'\\n          example: '2024-07-20'\\n        reminder_sent:\\n          type: boolean\\n          description: 'Indica se o lembrete foi enviado'\\n          example: true\\n        cleaning_type:\\n          type: string\\n          description: 'Tipo de limpeza programada'\\n          example: 'prophylaxis'\\n        metadata:\\n          $ref: '#/components/schemas/ScheduledCleaningMetadata'\\n    PatientHistory:\\n      type: object\\n      description: 'Histórico completo do paciente odontológico'\\n      properties:\\n        tooth_chart:\\n          $ref: '#/components/schemas/ToothChart'\\n        past_procedur