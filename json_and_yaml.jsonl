ion\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Description of the discount\\\",\\n            \\\"example\\\": \\\"Summer discount promotion\\\"\\n          },\\n          \\\"discount_value\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Monetary value of the discount\\\",\\n            \\\"example\\\": 10.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"coupon_code\\\", \\\"description\\\", \\\"discount_value\\\"]\\n      },\\n      \\\"InvoiceResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Invoice details for a SaaS subscription including billing cycle, company, taxes, discounts, and totals\\\",\\n        \\\"properties\\\": {\\n          \\\"invoice_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the invoice\\\",\\n            \\\"example\\\": \\\"inv_20240615_001\\\"\\n          },\\n          \\\"billing_cycle\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BillingCycle\\\"\\n          },\\n          \\\"company\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Company\\\"\\n          },\\n          \\\"taxes\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of tax breakdown objects\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/TaxBreakdown\\\"\\n            },\\n            \\\"example\\\": [\\n              {\\\"tax_name\\\": \\\"VAT\\\", \\\"tax_rate\\\": 0.12, \\\"tax_amount\\\": 14.40},\\n              {\\\"tax_name\\\": \\\"Service Tax\\\", \\\"tax_rate\\\": 0.05, \\\"tax_amount\\\": 6.00}\\n            ]\\n          },\\n          \\\"discount_coupons\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of discount coupons applied to the invoice\\\",\