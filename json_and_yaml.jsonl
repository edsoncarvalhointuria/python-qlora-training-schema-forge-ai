"{\n  \"raw_json\": {\n    \"match_id\": \"match_12345\",\n    \"teams\": [\n      {\n        \"team_name\": \"Red Dragons\",\n        \"score\": 16,\n        \"players\": [\n          { \"player_name\": \"RDragon1\", \"kills\": 20, \"deaths\": 5, \"assists\": 7 },\n          { \"player_name\": \"RDragon2\", \"kills\": 15, \"deaths\": 8, \"assists\": 10 }\n        ]\n      },\n      {\n        \"team_name\": \"Blue Wolves\",\n        \"score\": 12,\n        \"players\": [\n          { \"player_name\": \"BWolf1\", \"kills\": 13, \"deaths\": 10, \"assists\": 6 },\n          { \"player_name\": \"BWolf2\", \"kills\": 9, \"deaths\": 12, \"assists\": 8 }\n        ]\n      }\n    ],\n    \"timeline\": [\n      {\n        \"minute\": 2,\n        \"event_type\": \"kill\",\n        \"description\": \"RDragon1 eliminated BWolf2\"\n      },\n      {\n        \"minute\": 10,\n        \"event_type\": \"objective\",\n        \"description\": \"Blue Wolves captured the central point\"\n      },\n      {\n        \"minute\": 18,\n        \"event_type\": \"kill\",\n        \"description\": \"BWolf1 eliminated RDragon2\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: E-Sports Match Summary API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PlayerStats:\\n      type: object\\n      description: 'Estatísticas individuais de um jogador na partida'\\n      properties:\\n        player_name:\\n          type: string\\n          description: 'Nome do jogador'\\n          example: 'RDragon1'\\n        kills:\\n          type: integer\\n          description: 'Número de eliminações'\\n          example: 20\\n        deaths:\\n          type: integer\\n          description: 'Número de vezes que o jogador morreu'\\n          example: 5\\n        assists:\\n          type: integer\\n          description: 'Número de assistências em eliminações'\\n          example: 7\\n    TeamStats:\\n      type: object\\n      description: 'Resumo de uma equipe na partida'\\n      properties:\\n        team_name:\\n          type: string\\n          description: 'Nome da equipe'\\n          example: 'Red Dragons'\\n        score:\\n          type: integer\\n          description: 'Pontuação total da equipe'\\n          example: 16\\n        players:\\n          type: array\\n          description: 'Lista de estatísticas dos jogadores da equipe'\\n          items:\\n            $ref: '#/components/schemas/PlayerStats'\\n    MatchEvent:\\n      type: object\\n      description: 'Evento importante ocorrido durante a partida'\\n      properties:\\n        minute:\\n          type: integer\\n          description: 'Minuto em que o evento ocorreu'\\n          example: 2\\n        event_type:\\n          type: string\\n          description: 'Tipo do evento'\\n          example: 'kill'\\n        description:\\n          type: string\\n          description: 'Descrição detalhada do evento'\\n          example: 'RDragon1 eliminated BWolf2'\\n    MatchSummary:\\n      type: object\\n      description: 'Resumo completo da partida competitiva de e-sports'\\n      properties:\\n        match_id:\\n          type: string\\n          description: 'Identificador único da partida'\\n          example: 'match_12345'\\n        teams:\\n          type: array\\n          description: 'Lista das equipes participantes e seus dados'\\n          items:\\n            $ref: '#/components/schemas/TeamStats'\\n        timeline:\\n          type: array\\n          description: 'Linha do tempo contendo eventos chave da partida'\\n          items:\\n            $ref: '#/components/schemas/MatchEvent'\\n\"\n}"
"{\n  \"raw_json\": {\n    \"receipt_id\": \"rcpt_789\",\n    \"virtual_currency\": {\n      \"currency_type\": \"Gems\",\n      \"amount_purchased\": 5000,\n      \"base_amount\": 5000,\n      \"promotional_multiplier\": 1.5,\n      \"total_amount\": 7500\n    },\n    \"unlocked_cosmetics\": [\n      {\n        \"item_id\": \"cos_001\",\n        \"name\": \"Dragon Wings\",\n        \"rarity\": \"Epic\"\n      },\n      {\n        \"item_id\": \"cos_045\",\n        \"name\": \"Golden Sword\",\n        \"rarity\": \"Rare\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Mobile Game Microtransaction Receipt\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"VirtualCurrency\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes da moeda virtual adquirida e aplicacao de multiplicadores promocionais\\\",\\n        \\\"properties\\\": {\\n          \\\"currency_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo da moeda virtual adquirida\\\",\\n            \\\"example\\\": \\\"Gems\\\"\\n          },\\n          \\\"amount_purchased\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantidade base de moeda comprada\\\",\\n            \\\"example\\\": 5000\\n          },\\n          \\\"base_amount\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantidade base da moeda antes do multiplicador\\\",\\n            \\\"example\\\": 5000\\n          },\\n          \\\"promotional_multiplier\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Multiplicador promocional aplicado à moeda\\\",\\n            \\\"example\\\": 1.5\\n          },\\n          \\\"total_amount\\\": {\\n            \\\"t