"{\n  \"raw_json\": {\n    \"daily_active_users\": 1245,\n    \"feature_usage_metrics\": [\n      {\n        \"feature_name\": \"File Upload\",\n        \"usage_count\": 345,\n        \"usage_details\": [\n          {\n            \"device_type\": \"mobile\",\n            \"count\": 180\n          },\n          {\n            \"device_type\": \"desktop\",\n            \"count\": 165\n          }\n        ]\n      },\n      {\n        \"feature_name\": \"Dashboard Views\",\n        \"usage_count\": 789,\n        \"usage_details\": [\n          {\n            \"device_type\": \"mobile\",\n            \"count\": 400\n          },\n          {\n            \"device_type\": \"desktop\",\n            \"count\": 389\n          }\n        ]\n      }\n    ],\n    \"subscription_tier_limits\": {\n      \"tier_name\": \"Pro\",\n      \"max_projects\": 50,\n      \"max_storage_gb\": 100,\n      \"max_users\": 20\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: SaaS Platform User Analytics Report\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UsageDetail:\\n      type: object\\n      description: 'Details of feature usage per device type'\\n      properties:\\n        device_type:\\n          type: string\\n          description: 'Type of device used for the feature usage'\\n          example: 'mobile'\\n        count:\\n          type: integer\\n          description: 'Number of times the feature was used on this device type'\\n          example: 180\\n    FeatureUsageMetric:\\n      type: object\\n      description: 'Metric details of a specific feature''s usage'\\n      properties:\\n        feature_name:\\n          type: string\\n          description: 'Name of the feature whose usage is reported'\\n          example: 'File Upload'\\n        usage_count:\\n          type: integer\\n          description: 'Total number of times the feature was used'\\n          example: 345\\n        usage_details:\\n          type: array\\n          description: 'Breakdown of usage count by device type'\\n          items:\\n            $ref: '#/components/schemas/UsageDetail'\\n    SubscriptionTierLimits:\\n      type: object\\n      description: 'Limits and constraints associated with a subscription tier'\\n      properties:\\n        tier_name:\\n          type: string\\n          description: 'Name of the subscription tier'\\n          example: 'Pro'\\n        max_projects:\\n          type: integer\\n          description: 'Maximum number of projects allowed under this tier'\\n          example: 50\\n        max_storage_gb:\\n          type: integer\\n          description: 'Maximum storage in gigabytes allowed under this tier'\\n          example: 100\\n        max_users:\\n          type: integer\\n          description: 'Maximum number of users allowed under this tier'\\n          example: 20\\n    UserAnalyticsReport:\\n      type: object\\n      description: 'User analytics report for a SaaS platform'\\n      properties:\\n        daily_active_users:\\n          type: integer\\n          description: 'Number of unique users active in the platform on the day'\\n          example: 1245\\n        feature_usage_metrics:\\n          type: array\\n          description: 'List of feature usage metrics with detailed usage breakdown'\\n          items:\\n            $ref: '#/components/schemas/FeatureUsageMetric'\\n        subscription_tier_limits:\\n          $ref: '#/components/schemas/SubscriptionTierLimits'\\n\"\n}"
