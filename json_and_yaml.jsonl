"{\n  \"raw_json\": {\n    \"alert_id\": \"alert_2045\",\n    \"severity_level\": \"High\",\n    \"affected_ips\": [\n      {\n        \"ip_address\": \"192.168.1.15\",\n        \"last_seen\": \"2024-06-10T14:32:00Z\"\n      },\n      {\n        \"ip_address\": \"10.0.0.5\",\n        \"last_seen\": \"2024-06-10T14:45:10Z\"\n      }\n    ],\n    \"mitigation_protocols\": [\n      \"Isolate affected systems from the network\",\n      \"Apply latest security patches\",\n      \"Conduct thorough system scans for malware\",\n      \"Monitor incoming and outgoing network traffic\"\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Cybersecurity Threat Intelligence Alert\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"AffectedIP\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of an affected IP address involved in the threat\\\",\\n        \\\"properties\\\": {\\n          \\\"ip_address\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The IP address detected as affected\\\",\\n            \\\"example\\\": \\\"192.168.1.15\\\"\\n          },\\n          \\\"last_seen\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Timestamp when the affected IP was last observed\\\",\\n            \\\"example\\\": \\\"2024-06-10T14:32:00Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"ip_address\\\", \\\"last_seen\\\"]\\n      },\\n      \\\"ThreatAlert\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"A cybersecurity threat intelligence alert with severity, affected IPs, and mitigation protocols\\\",\\n        \\\"properties\\\": {\\n          \\\"alert_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the alert\\\",\\n            \\\"example\\\": \\\"alert_2045\\\"\\n          },\\n          \\\"severity_level\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Indicates the criticality of the threat\\\",\\n            \\\"example\\\": \\\"High\\\"\\n          },\\n          \\\"affected_ips\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of IP addresses affected by the threat\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/AffectedIP\\\"\\n            }\\n          },\\n          \\\"mitigation_protocols\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Recommended actions to mitigate the threat\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"example\\\": \\\"Isolate affected systems from the network\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"alert_id\\\", \\\"severity_level\\\", \\\"affected_ips\\\", \\\"mitigation_protocols\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {}\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"total_monthly_spend\": 12543.75,\n    \"costs_by_service\": [\n      {\n        \"service_name\": \"Compute\",\n        \"service_id\": \"svc_01\",\n        \"monthly_costs\": [\n          {\n            \"month\": \"2024-04\",\n            \"cost\": 5200.0\n          },\n          {\n            \"month\": \"2024-05\",\n            \"cost\": 5300.5\n          }\n        ]\n      },\n      {\n        \"service_name\": \"Storage\",\n        \"service_id\": \"svc_02\",\n        \"monthly_costs\": [\n          {\n            \"month\": \"2024-04\",\n            \"cost\": 2000.25\n          },\n          {\n            \"month\": \"2024-05\",\n            \"cost\": 2043.0\n          }\n        ]\n      }\n    ],\n    \"projected_forecast\": {\n      \"next_month_estimate\": 13000.0,\n      \"confidence_interval\": {\n        \"lower_bound\": 12500.0,\n        \"upper_bound\": 13500.0\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Cloud Infrastructure Billing Dashboard\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    MonthlyCost:\\n      type: object\\n      description: 'Monthly cost record for a particular month'\\n      properties:\\n        month:\\n          type: string\\n          description: 'Calendar month in YYYY-MM format'\\n          example: '2024-04'\\n        cost:\\n          type: number\\n          format: float\\n          description: 'Cost incurred in the month in USD'\\n          example: 5200.0\\n    ServiceCost:\\n      type: object\\n      description: 'Cost breakdown for a specific cloud service'\\n      properties:\\n        service_name:\\n          type: string\\n          description: 'Name of the cloud service'\\n          example: 'Compute'\\n        service_id:\\n          type: string\\n          description: 'Unique identifier of the cloud service'\\n          example: 'svc_01'\\n        monthly_costs:\\n          type: array\\n          description: 'List of monthly costs for the service'\\n          items:\\n            $ref: '#/components/schemas/MonthlyCost'\\n    ConfidenceInterval:\\n      type: object\\n      description: 'Confidence interval for forecasted costs'\\n      properties:\\n        lower_bound:\\n          type: number\\n          format: float\\n          description: 'Lower bound of the forecast estimate in USD'\\n          example: 12500.0\\n        upper_bound:\\n          type: number\\n          format: float\\n          description: 'Upper bound of the forecast estimate in USD'\\n          example: 13500.0\\n    ProjectedForecast:\\n      type: object\\n      description: 'Forecast details for future cloud spending'\\n      properties:\\n        next_month_estimate:\\n          type: number\\n          format: float\\n          description: 'Estimated spend for the next month in USD'\\n          example: 13000.0\\n        confidence_interval:\\n          $ref: '#/components/schemas/ConfidenceInterval'\\n    BillingDashboardResponse:\\n      type: object\\n      description: 'Root response schema for the cloud billing dashboard'\\n      properties:\\n        total_monthly_spend:\\n          type: number\\n          format: float\\n          description: 'Total cloud spend for the current month in USD'\\n          example: 12543.75\\n        costs_by_service:\\n          type: array\\n          description: 'Array of costs broken down by each cloud service'\\n          items:\\n            $ref: '#/components/schemas/ServiceCost'\\n        projected_forecast:\\n          $ref: '#/components/schemas/ProjectedForecast'\"\n}"
"{\n  \"raw_json\": {\n    \"taxpayer_id\": \"12345678900\",\n    \"declared_income\": 85000.75,\n    \"deductions\": [\n      {\n        \"deduction_type\": \"Health Expenses\",\n        \"valid_entries\": [\n          {\n            \"description\": \"Medical consultation\",\n            \"amount\": 1200.00\n          },\n          {\n            \"description\": \"Hospitalization\",\n            \"amount\": 5000.50\n          }\n        ]\n      },\n      {\n        \"deduction_type\": \"Education Expenses\",\n        \"valid_entries\": [\n          {\n            \"description\": \"Tuition fees\",\n            \"amount\": 3000.00\n          }\n        ]\n      }\n    ],\n    \"final_result\": {\n      \"tax_refund\": 1500.25,\n      \"tax_debt\": 0.0\n    }\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Government Tax Return Assessment Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ValidEntry\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Entrada válida para deduções de imposto\\\",\\n        \\\"properties\\\": {\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Descrição da dedução\\\",\\n            \\\"example\\\": \\\"Medical consultation\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Valor da dedução\\\",\\n            \\\"example\\\": 1200.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"description\\\", \\\"amount\\\"]\\n      },\\n      \\\"Deduction\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Categoria de dedução com entradas válidas\\\",\\n        \\\"properties\\\": {\\n          \\\"deduction_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo de dedução\\\",\\n            \\\"example\\\": \\\"Health Expenses\\\"\\n          },\\n          \\\"valid_entries\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de entradas válidas para a dedução\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/ValidEntry\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"deduction_type\\\", \\\"valid_entries\\\"]\\n      },\\n      \\\"FinalResult\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resultado final do cálculo do imposto\\\",\\n        \\\"properties\\\": {\\n          \\\"tax_refund\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Valor do reembolso de imposto calculado\\\",\\n            \\\"example\\\": 1500.25\\n          },\\n          \\\"tax_debt\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Valor da dívida de imposto calculada\\\",\\n            \\\"example\\\": 0.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"tax_refund\\\", \\\"tax_debt\\\"]\\n      },\\n      \\\"TaxReturnAssessmentResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta detalhada da avaliação da declaração de imposto de renda\\\",\\n        \\\"properties\\\": {\\n          \\\"taxpayer_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificação única do contribuinte\\\",\\n            \\\"example\\\": \\\"12345678900\\\"\\n          },\\n          \\\"declared_income\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Renda declarada pelo contribuinte\\\",\\n            \\\"example\\\": 85000.75\\n          },\\n          \\\"deductions\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de deduções declaradas com entradas válidas\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/Deduction\\\" }\\n          },\\n          \\\"final_result\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/FinalResult\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"taxpayer_id\\\", \\\"declared_income\\\", \\\"deductions\\\", \\\"final_result\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
