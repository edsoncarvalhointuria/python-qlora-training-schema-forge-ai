ents/schemas/TaxDeductions\\\" },\\n          \\\"health_benefits\\\": { \\\"$ref\\\": \\\"#/components/schemas/HealthBenefits\\\" },\\n          \\\"direct_deposit_accounts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de contas bancárias para depósito direto do salário\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/BankAccount\\\" }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"tooth_chart\": {\n      \"tooth_number\": \"14\",\n      \"tooth_surface\": \"occlusal\",\n      \"condition\": \"cavity\",\n      \"last_exam_date\": \"2024-04-15\"\n    },\n    \"past_procedures\": [\n      {\n        \"procedure_name\": \"Root Canal Therapy\",\n        \"date_performed\": \"2023-11-20\",\n        \"tooth_involved\": \"14\",\n        \"notes\": \"Procedure successful without complications\"\n      },\n      {\n        \"procedure_name\": \"Dental Cleaning\",\n        \"date_performed\": \"2024-02-10\",\n        \"tooth_involved\": \"full mouth\",\n        \"notes\": \"Routine cleaning, no issues\"\n      }\n    ],\n    \"upcoming_cleanings_schedule\": {\n      \"next_cleaning_date\": \"2024-08-01\",\n      \"reminder_sent\": true,\n      \"reminder_method\": \"email\",\n      \"metadata\": {\n        \"cleaning_type\": \"standard prophylaxis\",\n        \"duration_minutes\": 45,\n        \"clinic_technician_id\": \"tech_1789\"\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Dental Clinic Patient History\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ToothChart:\\n      type: object\\n      description: 'Anatomical tooth chart detailing specific tooth condition and last exam'\\n      properties:\\n        tooth_number:\\n          type: string\\n          description: 'Identifier number of the tooth'\\n          example: '14'\\n        tooth_surface:\\n          type: string\\n          description: 'Specific surface of the tooth affected or examined'\\n          example: 'occlusal'\\n        condition:\\n          type: string\\n          description: 'Current condition observed on the tooth'\\n          example: 'cavity'\\n        last_exam_date:\\n          type: string\\n          format: date\\n          description: 'Date when the tooth was last examined'\\n          example: '2024-04-15'\\n    Procedure:\\n      type: object\\n      description: 'A dental procedure previously performed on the patient'\\n      properties:\\n        procedure_name:\\n          type: string\\n          description: 'Name of the dental procedure'\\n          example: 'Root Canal Therapy'\\n        date_performed:\\n          type: string\\n          format: date\\n          description: 'Date the procedure was performed'\\n          example: '2023-11-20'\\n        tooth_involved:\\n          type: string\\n          description: 'Tooth or region involved in the procedure'\\n          example: '14'\\n        notes:\\n          type: string\\n          description: 'Additional notes about the procedure'\\n          example: 'Procedure successful without complications'\\n    UpcomingCleaningMetadata:\\n      type: object\\n      description: 'Nested metadata related to the scheduled cleaning appointment'\\n      properties:\\n        cleaning_type:\\n          type: string\\n          description: 'Type of cleaning procedure scheduled'\\n          example: 'standard prophylaxis'\\n        duration_minutes:\\n          type: integer\\n          description: 'Expected duration of the cleaning in minutes'\\n          example: 45\\n        clinic_technician_id:\\n          type: string\\n          description: 'Identifier of the clinic technician assigned to the cleaning'\\n          example: 'tech_1789'\\n    UpcomingCleaningSchedule:\\n      type: object\\n      description: 'Details about upcoming scheduled cleanings with nested metadata'\\n      properties:\\n        next_cleaning_date:\\n          type: string\\n          format: date\\n          description: 'Date of the next scheduled cleaning'\\n          example: '2024-08-01'\\n        reminder_sent:\\n          type: boolean\\n          description: 'Indicates whether a reminder has been sent for the cleaning'\\n          example: true\\n        reminder_method:\\n          type: string\\n          description: 'Method used to send the reminder'\\n          example: 'email'\\n        metadata:\\n          $ref: '#/components/schemas/UpcomingCleaningMetadata'\\n    PatientHistory:\\n      type: object\\n      description: 'Complete patient dental history including tooth chart, past procedures, and upcoming cleanings'\\n      properties:\\n        tooth_chart:\\n          $ref: '#/components/schemas/ToothChart'\\n        past_procedures:\\n          type: array\\n          description: 'Array of past dental procedures performed on patient'\\n          items:\\n            $ref: '#/components/schemas/Procedure'\\n        upcoming_cleanings_schedule:\\n          $ref: '#/components/schemas/UpcomingCleaningSchedule'\\npaths: {}\\n\"\n}"
