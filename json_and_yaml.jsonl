"{\n  \"raw_json\": {\n    \"headline\": \"Inovações Tecnológicas Transformam o Mercado\",\n    \"author\": {\n      \"name\": \"Lucas Silva\",\n      \"email\": \"lucas.silva@noticiasdigitais.com\"\n    },\n    \"multimedia\": [\n      {\n        \"type\": \"image\",\n        \"url\": \"https://noticiasdigitais.com/image1.jpg\",\n        \"caption\": \"Painel de controle futurístico\"\n      },\n      {\n        \"type\": \"video\",\n        \"url\": \"https://noticiasdigitais.com/video1.mp4\",\n        \"caption\": \"Demonstração da nova tecnologia\"\n      }\n    ],\n    \"tags\": [\n      \"tecnologia\",\n      \"inovação\",\n      \"mercado\"\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Digital News Article Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Author:\\n      type: object\\n      description: 'Informações do autor da notícia'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Nome completo do autor'\\n          example: 'Lucas Silva'\\n        email:\\n          type: string\\n          description: 'Email de contato do autor'\\n          example: 'lucas.silva@noticiasdigitais.com'\\n    MultimediaAsset:\\n      type: object\\n      description: 'Detalhes de um recurso multimídia embutido'\\n      properties:\\n        type:\\n          type: string\\n          description: 'Tipo do recurso multimídia (imagem, vídeo, etc)'\\n          example: 'image'\\n        url:\\n          type: string\\n          description: 'URL do recurso multimídia'\\n          example: 'https://noticiasdigitais.com/image1.jpg'\\n        caption:\\n          type: string\\n          description: 'Legenda descritiva do recurso'\\n          example: 'Painel de controle futurístico'\\n    DigitalNewsArticle:\\n      type: object\\n      description: 'Resposta da notícia digital com conteúdo principal e objetos relacionados'\\n      properties:\\n        headline:\\n          type: string\\n          description: 'Título principal da notícia'\\n          example: 'Inovações Tecnológicas Transformam o Mercado'\\n        author:\\n          $ref: '#/components/schemas/Author'\\n        multimedia:\\n          type: array\\n          description: 'Lista de recursos multimídia incorporados na notícia'\\n          items:\\n            $ref: '#/components/schemas/MultimediaAsset'\\n        tags:\\n          type: array\\n          description: 'Tags relacionadas à notícia para categorização'\\n          items:\\n            type: string\\n            description: 'Tag individual relacionada à notícia'\\n            example: 'tecnologia'\\n\"\n}"
