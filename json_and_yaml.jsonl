"{\n  \"raw_json\": {\n    \"soilMoisture\": 32.5,\n    \"weatherForecast\": {\n      \"temperature\": 22.4,\n      \"humidity\": 68,\n      \"precipitationProbability\": 0.15,\n      \"windSpeed\": 5.2,\n      \"forecastTime\": \"2024-06-20T14:00:00Z\"\n    },\n    \"irrigationEvents\": [\n      {\n        \"eventId\": \"evt_101\",\n        \"startTime\": \"2024-06-19T10:00:00Z\",\n        \"durationMinutes\": 30,\n        \"waterVolumeLiters\": 15.0\n      },\n      {\n        \"eventId\": \"evt_102\",\n        \"startTime\": \"2024-06-19T18:00:00Z\",\n        \"durationMinutes\": 45,\n        \"waterVolumeLiters\": 22.5\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Smart Agriculture Sensor Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherForecast:\\n      type: object\\n      description: 'Object containing weather forecast predictions'\\n      properties:\\n        temperature:\\n          type: number\\n          format: float\\n          description: 'Forecasted temperature in degrees Celsius'\\n          example: 22.4\\n        humidity:\\n          type: integer\\n          description: 'Forecasted relative humidity percentage'\\n          example: 68\\n        precipitationProbability:\\n          type: number\\n          format: float\\n          description: 'Probability of precipitation as a value between 0 and 1'\\n          example: 0.15\\n        windSpeed:\\n          type: number\\n          format: float\\n          description: 'Forecasted wind speed in kilometers per hour'\\n          example: 5.2\\n        forecastTime:\\n          type: string\\n          format: date-time\\n          description: 'UTC time of the forecast prediction'\\n          example: '2024-06-20T14:00:00Z'\\n    IrrigationEvent:\\n      type: object\\n      description: 'Details of a single automated irrigation event'\\n      properties:\\n        eventId:\\n          type: string\\n          description: 'Unique identifier for the irrigation event'\\n          example: 'evt_101'\\n        startTime:\\n          type: string\\n          format: date-time\\n          description: 'UTC start time of the irrigation event'\\n          example: '2024-06-19T10:00:00Z'\\n        durationMinutes:\\n          type: integer\\n          description: 'Duration of irrigation in minutes'\\n          example: 30\\n        waterVolumeLiters:\\n          type: number\\n          format: float\\n          description: 'Amount of water used during irrigation in liters'\\n          example: 15.0\\n    SmartAgSensorResponse:\\n      type: object\\n      description: 'Response showing soil moisture, weather forecast, and irrigation events'\\n      properties:\\n        soilMoisture:\\n          type: number\\n          format: float\\n          description: 'Current soil moisture percentage'\\n          example: 32.5\\n        weatherForecast:\\n          $ref: '#/components/schemas/WeatherForecast'\\n        irrigationEvents:\\n          type: array\\n          description: 'List of recent automated irrigation events'\\n          items:\\n            $ref: '#/components/schemas/IrrigationEvent'\"\n}"
