 \\\"Bitcoin\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Amount of this digital asset held in the wallet\\\",\\n            \\\"example\\\": 0.385\\n          },\\n          \\\"current_price_usd\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Current market price of one unit of the asset in USD\\\",\\n            \\\"example\\\": 27943.17\\n          }\\n        },\\n        \\\"required\\\": [\\\"asset_id\\\", \\\"name\\\", \\\"amount\\\", \\\"current_price_usd\\\"]\\n      },\\n      \\\"TransferAsset\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the asset being transferred\\\",\\n        \\\"properties\\\": {\\n          \\\"asset_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identifier of the digital asset\\\",\\n            \\\"example\\\": \\\"btc\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Amount of the asset transferred\\\",\\n            \\\"example\\\": 0.1\\n          }\\n        },\\n        \\\"required\\\": [\\\"asset_id\\\", \\\"amount\\\"]\\n      },\\n      \\\"BlockchainTransfer\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Record of a recent blockchain transfer transaction\\\",\\n        \\\"properties\\\": {\\n          \\\"transfer_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the transfer transaction\\\",\\n            \\\"example\\\": \\\"tx_001\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"ISO 8601 timestamp of when the transfer occurred\\\",\\n            \\\"example\\\": \\\"2024-06-15T13:45:30Z\\\"\\n          },\\n          \\\"from_address\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Blockchain address sending the asset\\\",\\n            \\\"example\\\": \\\"1A2b3C4D5e6F7g8H9j0K\\\"\\n          },\\n          \\\"to_address\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Blockchain address receiving the asset\\\",\\n            \\\"example\\\": \\\"0a1B2c3D4E5f6G7H8i9J\\\"\\n          },\\n          \\\"asset\\\": { \\\"$ref\\\": \\\"#/components/schemas/TransferAsset\\\" },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Current status of the transfer\\\",\\n            \\\"example\\\": \\\"confirmed\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"transfer_id\\\", \\\"timestamp\\\", \\\"from_address\\\", \\\"to_address\\\", \\\"asset\\\", \\\"status\\\"]\\n      },\\n      \\\"WalletDashboard\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Cryptocurrency wallet dashboard overview including fiat balance, digital assets, and recent transfers\\\",\\n        \\\"properties\\\": {\\n          \\\"fiat_balance\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Current fiat currency balance in the wallet\\\",\\n            \\\"example\\\": 2540.75\\n          },\\n          \\\"digital_assets\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of digital assets held in the wallet with prices\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/AssetInfo\\\" }\\n          },\\n          \\\"transfer_history\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"descriptio