 'Detalhes do procedimento agendado'\\n      properties:\\n        procedure_code:\\n          type: string\\n          description: 'Código identificador do procedimento'\\n          example: 'PROC_001'\\n        description:\\n          type: string\\n          description: 'Descrição do procedimento'\\n          example: 'Vaccination - Rabies'\\n        duration_minutes:\\n          type: integer\\n          description: 'Duração esperada do procedimento em minutos'\\n          example: 15\\n    AppointmentResponse:\\n      type: object\\n      description: 'Resposta contendo os detalhes da consulta veterinária'\\n      properties:\\n        appointment_id:\\n          type: string\\n          description: 'Identificador único da consulta'\\n          example: 'appt_12345'\\n        scheduled_date:\\n          type: string\\n          format: date-time\\n          description: 'Data e horário agendados para a consulta'\\n          example: '2024-07-20T14:30:00Z'\\n        pet:\\n          $ref: '#/components/schemas/Pet'\\n        owner:\\n          $ref: '#/components/schemas/Owner'\\n        procedure:\\n          $ref: '#/components/schemas/Procedure'\"\n}"
