n of the track in seconds\\\",\\n            \\\"example\\\": 245\\n          },\\n          \\\"audio_spec\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/AudioSpec\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"track_id\\\", \\\"title\\\", \\\"artist\\\", \\\"album\\\", \\\"duration_seconds\\\", \\\"audio_spec\\\"]\\n      },\\n      \\\"Pagination\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Pagination information for paginated track list\\\",\\n        \\\"properties\\\": {\\n          \\\"page\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Current page number\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"page_size\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of items per page\\\",\\n            \\\"example\\\": 2\\n          },\\n          \\\"total_pages\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Total number of pages available\\\",\\n            \\\"example\\\": 5\\n          },\\n          \\\"total_items\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Total number of tracks in the playlist\\\",\\n            \\\"example\\\": 10\\n          }\\n        },\\n        \\\"required\\\": [\\\"page\\\", \\\"page_size\\\", \\\"total_pages\\\", \\\"total_items\\\"]\\n      },\\n      \\\"PaginatedTracks\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Paginated list of tracks with pagination metadata\\\",\\n        \\\"properties\\\": {\\n          \\\"page\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Current page number\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"page_size\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of tracks per page\\\",\\n            \\\"example\\\": 2\\n          },\\n          \\\"total_pages\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Total pages in the pagination\\\",\\n            \\\"example\\\": 5\\n          },\\n          \\\"total_items\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Total number of tracks available\\\",\\n            \\\"example\\\": 10\\n          },\\n          \\\"items\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of track items on the current page\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Track\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"page\\\", \\\"page_size\\\", \\\"total_pages\\\", \\\"total_items\\\", \\\"items\\\"]\\n      },\\n      \\\"UserSnippet\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Brief user information who created the playlist\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the user\\\",\\n            \\\"example\\\": \\\"user_789\\\"\\n          },\\n          \\\"username\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"User's login or handle\\\",\\n            \\\"example\\\": \\\"music_lover\\\"\\n          },\\n          \\\"display_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Display name of the user\\\",\\n            \\\"example\\\": \\\"Music Lover\\\"\\n          },\\n          \\\"profile_url\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"URL to the user's profile page\\\",\\n            \\\"example\\\": \\\"https://musicapp.com/users/music_lover\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"user_id\\\", \\\"username\\\", \\\"display_name\\\", \\\"profile_url\\\"]\\n      },\\n      \\\"PlaylistMetadata\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Metadata about a music playlist\\\",\\n        \\\"properties\\\": {\\n          \\\"id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the playlist\\\",\\n            \\\"example\\\": \\\"pl_12345\\\"\\n          },\\n          \\\"title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Title of the playlist\\\",\\n            \\\"example\\\": \\\"Chill Vibes\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Description about the playlist\\\",\\n            \\\"example\\\": \\\"A collection of relaxing and mellow tracks\\\"\\n          },\\n          \\\"creation_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"ISO 8601 date and time when playlist was created\\\",\\n            \\\"example\\\": \\\"2024-04-20T15:30:00Z\\\"\\n          },\\n          \\\"creator\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n          },\\n          \\\"tracks\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/PaginatedTracks\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"id\\\", \\\"title\\\", \\\"description\\\", \\\"creation_date\\\", \\\"creator\\\", \\\"tracks\\\"]\\n      },\\n      \\\"PlaylistResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Root schema for the music library playlist response\\\",\\n        \\\"properties\\\": {\\n          \\\"playlist\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/PlaylistMetadata\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"playlist\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"paths\\\": {},\\n  \\\"description\\\": \\\"Schema representing the response containing music playlist metadata, creator info, and paginated tracks with audio specs.\\\",\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"$schema\\\": \\\"http://json-schema.org/draft-07/schema#\\\",\\n  \\\"type\\\": \\\"object\\\",\\n  \\\"properties\\\": {\\n    \\\"playlist\\\": {\\n      \\\"$ref\\\": \\\"#/components/schemas/PlaylistMetadata\\\"\\n    }\\n  },\\n  \\\"required\\\": [\\\"playlist\\\"]\\n}\"\n}"
