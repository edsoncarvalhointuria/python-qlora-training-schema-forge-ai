   },\\n          \\\"out_of_pocket\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Amount to be paid by the patient\\\",\\n            \\\"example\\\": 75.00\\n          },\\n          \\\"currency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Currency code for the amounts\\\",\\n            \\\"example\\\": \\\"USD\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"covered_amount\\\", \\\"out_of_pocket\\\", \\\"currency\\\"]\\n      },\\n      \\\"ClaimStatusResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response showing claim status with provider, procedures, and cost details\\\",\\n        \\\"properties\\\": {\\n          \\\"provider\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Provider\\\"\\n          },\\n          \\\"procedures\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of medical procedures billed in the claim\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Procedure\\\"\\n            }\\n          },\\n          \\\"costs\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Costs\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"provider\\\", \\\"procedures\\\", \\\"costs\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"patient_id\": \"12345\",\n    \"tooth_chart\": {\n      \"tooth_11\": \"healthy\",\n      \"tooth_12\": \"cavity\",\n      \"tooth_13\": \"filled\",\n      \"tooth_14\": \"missing\"\n    },\n    \"past_procedures\": [\n      {\n        \"procedure_date\": \"2023-05-10\",\n        \"procedure_type\": \"filling\",\n        \"tooth\": \"12\",\n        \"notes\": \"Composite filling on tooth 12\"\n      },\n      {\n        \"procedure_date\": \"2022-11-15\",\n        \"procedure_type\": \"cleaning\",\n        \"tooth\": \"all\",\n        \"notes\": \"Routine cleaning, no issues\"\n      }\n    ],\n    \"upcoming_cleanings\": {\n      \"next_date\": \"2024-07-20\",\n      \"clinic_location\": \"Downtown Dental Clinic\",\n      \"notes\": \"Patient advised to bring x-rays\",\n      \"reminder_set\": true\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Patient History API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ToothChart:\\n      type: object\\n      description: 'Mapa anatômico dos dentes do paciente com seu status'\\n      properties:\\n        tooth_11:\\n          type: string\\n          description: 'Status do dente 11'\\n          example: 'healthy'\\n        tooth_12:\\n          type: string\\n          description: 'Status do dente 12'\\n          example: 'cavity'\\n        tooth_13:\\n          type: string\\n          description: 'Status do dente 13'\\n          example: 'filled'\\n        tooth_14:\\n          type: string\\n          description: 'Status do dente 14'\\n          example: 'missing'\\n    Procedure:\\n      type: object\\n      description: 'Detalhes dos procedimentos odontológicos realizados'\\n      properties:\\n        procedure_date:\\n          type: string\\n          format: date\\n          description: 'Data em que o procedimento foi realizado'\\n          example: '2023-05-10'\\n        procedure_type:\\n          type: string\\n          description: 'Tipo do procedimento realizado'\\n          example: 'filling'\\n        tooth:\\n          type: string\\n          description: 'Dente relacionado ao procedimento'\\n          example: '12'\\n        notes:\\n          type: string\\n          description: 'Notas adicionais sobre o procedimento'\\n          example: 'Composite filling on tooth 12'\\n    UpcomingCleanings:\\n      type: object\\n      description: 'Metadados sobre limpezas futuras agendadas'\\n      properties:\\n        next_date:\\n          type: string\\n          format: date\\n          description: 'Data agendada para a próxima limpeza'\\n          example: '2024-07-20'\\n        clinic_location:\\n          type: string\\n          description: 'Local da clínica para a próxima limpeza'\\n          example: 'Downtown Dental Clinic'\\n        notes:\\n          type: string\\n          description: 'Notas adicionais para a limpeza agendada'\\n          example: 'Patient advised to bring x-rays'\\n        reminder_set:\\n          type: boolean\\n          description: 'Indica se o lembrete para a limpeza está configurado'\\n          example: true\\n    PatientHistory:\\n      type: object\\n      description: 'Histórico completo do paciente na clínica dental'\\n      properties:\\n        patient_id:\\n          type: string\\n          description: 'Identificador único do paciente'\\n          example: '12345'\\n        tooth_chart:\\n          $ref: '#/components/schemas/ToothChart'\\n        past_procedures:\\n          type: array\\n          description: 'Lista de procedimentos realizados no passado'\\n          items:\\n            $ref: '#/components/schemas/Procedure'\\n        upcoming_cleanings:\\n          $ref: '#/components/schemas/UpcomingCleanings'\\n\"\n}"
