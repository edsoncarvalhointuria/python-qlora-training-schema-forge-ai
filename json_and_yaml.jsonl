untry\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Country of the shipping address\\\",\\n            \\\"example\\\": \\\"USA\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"recipient_name\\\", \\\"street\\\", \\\"city\\\", \\\"state\\\", \\\"zip_code\\\", \\\"country\\\"]\\n      },\\n      \\\"PaymentTransaction\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the payment transaction for the order\\\",\\n        \\\"properties\\\": {\\n          \\\"transaction_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique payment transaction identifier\\\",\\n            \\\"example\\\": \\\"txn_7890\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"double\\\",\\n            \\\"description\\\": \\\"Total amount paid\\\",\\n            \\\"example\\\": 127.47\\n          },\\n          \\\"currency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Currency used for payment\\\",\\n            \\\"example\\\": \\\"USD\\\"\\n          },\\n          \\\"payment_method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Method used for payment\\\",\\n            \\\"example\\\": \\\"Credit Card\\\"\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Current status of the payment transaction\\\",\\n            \\\"example\\\": \\\"Completed\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"transaction_id\\\", \\\"amount\\\", \\\"currency\\\", \\\"payment_method\\\", \\\"status\\\"]\\n      },\\n      \\\"HalLink\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"HAL hypermedia link object\\\",\\n        \\\"properties\\\": {\\n          \\\"href\\\": {\\n  