tring\\\",\\n            \\\"description\\\": \\\"Additional terms and conditions for freight\\\",\\n            \\\"example\\\": \\\"Delivery within 5 business days. Buyer liable for import duties.\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"carrier_name\\\", \\\"service_level\\\", \\\"freight_cost\\\", \\\"terms_conditions\\\"]\\n      },\\n      \\\"WholesaleOrderInvoice\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Complete invoice for a B2B wholesale order\\\",\\n        \\\"properties\\\": {\\n          \\\"invoice_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique invoice identifier\\\",\\n            \\\"example\\\": \\\"inv_789\\\"\\n          },\\n          \\\"buyer_company\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BuyerCompany\\\"\\n          },\\n          \\\"bulk_items\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of bulk items ordered\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/BulkItem\\\"\\n            }\\n          },\\n          \\\"freight_terms\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/FreightTerms\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"invoice_id\\\", \\\"buyer_company\\\", \\\"bulk_items\\\", \\\"freight_terms\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"daily_active_users\": 1250,\n    \"feature_usage_metrics\": [\n      {\n        \"feature_name\": \"Dashboard\",\n        \"usage_count\": 4300,\n        \"usage_sessions\": [\n          {\n            \"session_id\": \"sess_1001\",\n            \"duration_seconds\": 300,\n            \"user_id\": \"user_789\"\n          },\n          {\n            \"session_id\": \"sess_1002\",\n            \"duration_seconds\": 240,\n            \"user_id\": \"user_456\"\n          }\n        ]\n      },\n      {\n        \"feature_name\": \"Reports\",\n        \"usage_count\": 2100,\n        \"usage_sessions\": [\n          {\n            \"session_id\": \"sess_1003\",\n            \"duration_seconds\": 180,\n            \"user_id\": \"user_123\"\n          }\n        ]\n      }\n    ],\n    \"subscription_tier_limits\": {\n      \"tier_name\": \"Pro\",\n      \"max_users\": 5000,\n      \"max_storage_gb\": 100,\n      \"features_enabled\": [\n        \"Dashboard\",\n        \"Reports\",\n        \"API Access\"\n      ]\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: SaaS Platform User Analytics Report\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UsageSession:\\n      type: object\\n      description: 'Details of a single usage session for a feature'\\n      properties:\\n        session_id:\\n          type: string\\n          description: 'Unique identifier of the session'\\n          example: 'sess_1001'\\n        duration_seconds:\\n          type: integer\\n          description: 'Duration of the session in seconds'\\n          example: 300\\n        user_id:\\n          type: string\\n          description: 'Unique identifier of the user in the session'\\n          example: 'user_789'\\n    FeatureUsageMetric:\\n      type: object\\n      description: 'Usage metrics for a single feature'\\n      properties:\\n        feature_name:\\n          type: string\\n          description: 'Name of the feature'\\n          example: 'Dashboard'\\n        usage_count:\\n          type: integer\\n          description: 'Total usage count for the feature'\\n          example: 4300\\n        usage_sessions:\\n          type: array\\n          description: 'List of usage sessions for the feature'\\n          items:\\n            $ref: '#/components/schemas/UsageSession'\\n    SubscriptionTierLimits:\\n      type: object\\n      description: 'Limits and available features for the subscription tier'\\n      properties:\\n        tier_name:\\n          type: string\\n          description: 'Name of the subscription tier'\\n          example: 'Pro'\\n        max_users:\\n          type: integer\\n          description: 'Maximum allowed users for the tier'\\n          example: 5000\\n        max_storage_gb:\\n          type: integer\\n          description: 'Maximum storage in gigabytes for the tier'\\n          example: 100\\n        features_enabled:\\n          type: array\\n          description: 'List of enabled features in the tier'\\n          items:\\n            type: string\\n            example: 'Dashboard'\\n    UserAnalyticsReport:\\n      type: object\\n      description: 'User analytics report including activity, feature usage, and subscription limits'\\n      properties:\\n        daily_active_users:\\n          type: integer\\n          description: 'Count of users active on the platform daily'\\n          example: 1250\\n        feature_usage_metrics:\\n          type: array\\n          description: 'Collection of usage metrics per feature'\\n          items:\\n            $ref: '#/components/schemas/FeatureUsageMetric'\\n        subscription_tier_limits:\\n          $ref: '#/components/schemas/SubscriptionTierLimits'\"\n}"
"{\n  \"raw_json\": {\n    \"alert_id\": \"alert_202406\",\n    \"severity_level\": \"High\",\n    \"affected_ips\": [\n      {\n        \"subnet\": \"192.168.1.0/24\",\n        \"ips\": [\"192.168.1.10\", \"192.168.1.15\", \"192.168.1.22\"]\n      },\n      {\n        \"subnet\": \"10.0.0.0/28\",\n        \"ips\": [\"10.0.0.3\", \"10.0.0.7\"]\n      }\n    ],\n    \"mitigation_protocols\": [\n      {\n        \"protocol_name\": \"Network Isolation\",\n        \"description\": \"Isolate affected subnets from the network to prevent further intrusion.\",\n        \"steps\": [\n          \"Identify vulnerable devices.\",\n          \"Apply network segmentation.\",\n          \"Monitor traffic for anomalies.\"\n        ]\n      },\n      {\n        \"protocol_name\": \"Patch Management\",\n        \"description\": \"Ensure all affected systems are updated with the latest security patches.\",\n        \"steps\": [\n          \"Check patch status.\",\n          \"Deploy security updates.\",\n          \"Validate patch installation.\"\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Cybersecurity Threat Intelligence Alert\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"AffectedIPGroup\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Group of affected IP addresses within a subnet.\\\",\\n        \\\"properties\\\": {\\n          \\\"subnet\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"CIDR notation of the affected subnet.\\\",\\n            \\\"example\\\": \\\"192.168.1.0/24\\\"\\n          },\\n          \\\"ips\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of affected IP addresses within the subnet.\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"An affected IP address.\\\",\\n              \\\"example\\\": \\\"192.168.1.10\\\"\\n            }\\n          }\\n        }\\n      },\\n      \\\"MitigationProtocol\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Recommended mitigation protocol with detailed steps.\\\",\\n        \\\"properties\\\": {\\n          \\\"protocol_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the mitigation protocol.\\\",\\n            \\\"example\\\": \\\"Network Isolation\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Detailed description of the protocol.\\\",\\n            \\\"example\\\": \\\"Isolate affected subnets from the network to prevent further intrusion.\\\"\\n          },\\n          \\\"steps\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Step-by-step actions to implement the protocol.\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"A single mitigation step.\\\",\\n              \\\"example\\\": \\\"Identify vulnerable devices.\\\"\\n            }\\n          }\\n        }\\n      },\\n      \\\"ThreatAlert\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"A cybersecurity threat intelligence alert containing severity, affected IPs, and mitigation protocols.\\\",\\n        \\\"properties\\\": {\\n          \\\"alert_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the alert.\\\",\\n            \\\"example\\\": \\\"alert_202406\\\"\\n          },\\n          \\\"severity_level\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Level of severity for the threat.\\\",\\n            \\\"example\\\": \\\"High\\\"\\n          },\\n          \\\"affected_ips\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of groups of affected IP addresses.\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/AffectedIPGroup\\\"\\n            }\\n          },\\n          \\\"mitigation_protocols\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Recommended mitigation protocols for the threat.\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/MitigationProtocol\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n}"
