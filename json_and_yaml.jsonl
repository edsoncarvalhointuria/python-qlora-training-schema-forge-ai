\\\"properties\\\": {\\n          \\\"is_ebook_available\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indica se o livro está disponível em formato digital\\\",\\n            \\\"example\\\": true\\n          },\\n          \\\"borrowing_url\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"uri\\\",\\n            \\\"description\\\": \\\"URL para empréstimo do livro digital\\\",\\n            \\\"example\\\": \\\"https://library.example.com/ebooks/9788535902775\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"is_ebook_available\\\", \\\"borrowing_url\\\"]\\n      },\\n      \\\"BookSearchResult\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resultado de busca detalhado de um livro na biblioteca\\\",\\n        \\\"properties\\\": {\\n          \\\"isbn\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Número padrão internacional do livro\\\",\\n            \\\"example\\\": \\\"978-85-359-0277-5\\\"\\n          },\\n          \\\"title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Título do livro\\\",\\n            \\\"example\\\": \\\"Introdução à Programação\\\"\\n          },\\n          \\\"author\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome do autor do livro\\\",\\n            \\\"example\\\": \\\"Carlos Silva\\\"\\n          },\\n          \\\"publication_year\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Ano de publicação do livro\\\",\\n            \\\"example\\\": 2021\\n          },\\n          \\\"copies\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de cópias físicas disponíveis do livro\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Copy\\\"\\n            }\\n          },\\n          \\\"digital_availability\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DigitalAvailability\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"isbn\\\", \\\"title\\\", \\\"author\\\", \\\"publication_year\\\", \\\"copies\\\", \\\"digital_availability\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"artistProfile\": {\n      \"artistId\": \"12345\",\n      \"name\": \"Luna Waves\",\n      \"biography\": \"Luna Waves is an indie pop band known for ethereal soundscapes and heartfelt lyrics.\",\n      \"debutYear\": 2012,\n      \"genre\": \"Indie Pop\"\n    },\n    \"topStreamedTracks\": [\n      {\n        \"trackId\": \"t001\",\n        \"title\": \"Moonlit Shore\",\n        \"durationSeconds\": 215,\n        \"streamsCount\": 3200000\n      },\n      {\n        \"trackId\": \"t002\",\n        \"title\": \"Echoes in the Dark\",\n        \"durationSeconds\": 198,\n        \"streamsCount\": 2750000\n      },\n      {\n        \"trackId\": \"t003\",\n        \"title\": \"Starlight Reverie\",\n        \"durationSeconds\": 242,\n        \"streamsCount\": 2550000\n      }\n    ],\n    \"upcomingTour\": {\n      \"tourName\": \"Ethereal Horizons\",\n      \"startDate\": \"2024-09-15\",\n      \"endDate\": \"2024-11-20\",\n      \"concertDates\": [\n        {\n          \"city\": \"New York\",\n          \"venue\": \"The Grand Arena\",\n          \"date\": \"2024-09-20\"\n        },\n        {\n          \"city\": \"Los Angeles\",\n          \"venue\": \"Sunshine Amphitheater\",\n          \"date\": \"2024-10-05\"\n        },\n        {\n          \"city\": \"Chicago\",\n          \"venue\": \"Lakeview Theater\",\n          \"date\": \"2024-11-10\"\n        }\n      ]\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Artist Profile API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ArtistProfile:\\n      type: object\\n      description: 'Biographical and basic information about the artist'\\n      properties:\\n        artistId:\\n          type: string\\n          description: 'Unique identifier of the artist'\\n          example: '12345'\\n        name:\\n          type: string\\n          description: 'Full artist or band name'\\n          example: 'Luna Waves'\\n        biography:\\n          type: string\\n          description: 'Short biography describing the artist''s background and style'\\n          example: 'Luna Waves is an indie pop band known for ethereal soundscapes and heartfelt lyrics.'\\n        debutYear:\\n          type: integer\\n          description: 'Year the artist debuted professionally'\\n          example: 2012\\n        genre:\\n          type: string\\n          description: 'Primary musical genre of the artist'\\n          example: 'Indie Pop'\\n    Track:\\n      type: object\\n      description: 'Information about a single music track'\\n      properties:\\n        trackId:\\n          type: string\\n          description: 'Unique identifier of the track'\\n          example: 't001'\\n        title:\\n          type: string\\n          description: 'Title of the track'\\n          example: 'Moonlit Shore'\\n        durationSeconds:\\n          type: integer\\n          description: 'Duration of the track in seconds'\\n          example: 215\\n        streamsCount:\\n          type: integer\\n          description: 'Number of times the track has been streamed'\\n          example: 3200000\\n    ConcertDate:\\n      type: object\\n      description: 'Details of a single concert date and venue information'\\n      properties:\\n        city:\\n          type: string\\n          description: 'City where the concert will take place'\\n          example: 'New York'\\n        venue:\\n          type: string\\n          description: 'Venue name for the concert'\\n          example: 'The Grand Arena'\\n        date:\\n          type: string\\n          format: date\\n          description: 'Scheduled date of the concert'\\n          example: '2024-09-20'\\n    UpcomingTour:\\n      type: object\\n      description: 'Information about upcoming concert tour dates for the artist'\\n      properties:\\n        tourName:\\n          type: string\\n          description: 'Name of the concert tour'\\n          example: 'Ethereal Horizons'\\n        startDate:\\n          type: string\\n          format: date\\n          description: 'Start date of the tour'\\n          example: '2024-09-15'\\n        endDate:\\n          type: string\\n          format: date\\n          description: 'End date of the tour'\\n          example: '2024-11-20'\\n        concertDates:\\n          type: array\\n          description: 'List of scheduled concert dates with city and venue information'\\n          items:\\n            $ref: '#/components/schemas/ConcertDate'\\n    ArtistStreamingResponse:\\n      type: object\\n      description: 'Full response object with artist profile, top streamed tracks, and upcoming tour details'\\n      properties:\\n        artistProfile:\\n          $ref: '#/components/schemas/ArtistProfile'\\n        topStreamedTracks:\\n          type: array\\n          description: 'Array of the artist''s top streamed tracks'\\n          items:\\n            $ref: '#/components/schemas/Track'\\n        upcomingTour:\\n          $ref: '#/components/schemas/UpcomingTour'\\n\"\n}"
