o item\\\",\\n            \\\"example\\\": \\\"Legendary\\\"\\n          },\\n          \\\"acquisition_method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Método de aquisição do item\\\",\\n            \\\"example\\\": \\\"purchase\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Descrição visual do item cosmético\\\",\\n            \\\"example\\\": \\\"Asas de dragão lendárias que brilham\\\"\\n          },\\n          \\\"unlock_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data em que o item foi desbloqueado\\\",\\n            \\\"example\\\": \\\"2024-06-01T15:20:30Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"item_id\\\", \\\"name\\\", \\\"rarity\\\", \\\"acquisition_method\\\", \\\"description\\\", \\\"unlock_date\\\"]\\n      },\\n      \\\"MicrotransactionReceipt\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Recibo detalhado de microtransação para compra de moedas virtuais e itens cosméticos\\\",\\n        \\\"properties\\\": {\\n          \\\"receipt_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do recibo\\\",\\n            \\\"example\\\": \\\"rec_123456789\\\"\\n          },\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do usuário que realizou a compra\\\",\\n            \\\"example\\\": \\\"user_98765\\\"\\n          },\\n          \\\"purchase_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora da compra\\\",\\n            \\\"example\\\": \\\"2024-06-01T15:20:30Z\\\"\\n          },\\n          \\\"virtual_currency\\