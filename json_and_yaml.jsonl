cription\\\": \\\"Passenger's first name\\\",\\n            \\\"example\\\": \\\"Alice\\\"\\n          },\\n          \\\"last_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's last name\\\",\\n            \\\"example\\\": \\\"Johnson\\\"\\n          },\\n          \\\"passport_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passport number of the passenger\\\",\\n            \\\"example\\\": \\\"X12345678\\\"\\n          },\\n          \\\"contact_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Email address for passenger contact\\\",\\n            \\\"example\\\": \\\"alice.johnson@example.com\\\"\\n          }\\n        }\\n      },\\n      \\\"Layover\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a layover stop in the itinerary\\\",\\n        \\\"properties\\\": {\\n          \\\"airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"IATA code of the layover airport\\\",\\n            \\\"example\\\": \\\"BOS\\\"\\n          },\\n          \\\"arrival_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Arrival time at the layover airport in ISO 8601 format\\\",\\n            \\\"example\\\": \\\"2024-08-01T20:00:00Z\\\"\\n          },\\n          \\\"departure_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Departure time from the layover airport in ISO 8601 format\\\",\\n            \\\"example\\\": \\\"2024-08-01T21:30:00Z\\\"\\n          }\\n        }\\n      },\\n      \\\"Itinerary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Flight itinerary details including main route and layovers\\\",\\n        \\\"properties\\\": {\\n          \\\"flight_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Airline flight number\\\",\\n            \\\"example\\\": \\\"AB1234\\\"\\n          },\\n          \\\"departure_airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"IATA code of the departure airport\\\",\\n            \\\"example\\\": \\\"JFK\\\"\\n          },\\n          \\\"arrival_airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"IATA code of the arrival airport\\\",\\n            \\\"example\\\": \\\"LHR\\\"\\n          },\\n          \\\"departure_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled departure time in ISO 8601 format\\\",\\n            \\\"example\\\": \\\"2024-08-01T18:45:00Z\\\"\\n          },\\n          \\\"arrival_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled arrival time in ISO 8601 format\\\",\\n            \\\"example\\\": \\\"2024-08-02T06:55:00Z\\\"\\n          },\\n          \\\"layovers\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of layovers in the itinerary\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Layover\\\"\\n            },\\n            \\\"example\\\": [\\n              {\\n                \\\"airport\\\": \\\"BOS\\\",\\n                \\\"arrival_time\\\": \\\"2024-08-01T20:00:00Z\\\",\\n                \\\"departure_time\\\": \\\"2024-08-01T21:30:00Z\\\"\\n              },\\n              {\\n                \\\"airport\\\": \\\"DUB\\\",\\n                \\\"arrival_time\\\": \\\"2024-08-02T01:45:00Z\\\",\\n                \\\"departure_time\\\": \\\"2024-08-02T03:00:00Z\\\"\\n              }\\n            ]\\n          }\\n        }\\n      },\\n      \\\"SeatUpgrade\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a seat upgrade selected by the passenger\\\",\\n        \\\"properties\\\": {\\n          \\\"seat_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Seat number upgraded\\\",\\n            \\\"example\\\": \\\"12A\\\"\\n          },\\n          \\\"upgrade_class\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Class of the seat upgrade\\\",\\n            \\\"example\\\": \\\"Business\\\"\\n          },\\n          \\\"price_usd\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Price paid for the seat upgrade in US dollars\\\",\\n            \\\"example\\\": 150.00\\n          }\\n        }\\n      },\\n      \\\"MealPreference\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Meal preference chosen by the passenger\\\",\\n        \\\"properties\\\": {\\n          \\\"meal_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of meal selected\\\",\\n            \\\"example\\\": \\\"Vegetarian\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Description providing details of the meal\\\",\\n            \\\"example\\\": \\\"A vegetarian meal with fresh vegetables and grains.\\\"\\n          }\\n        }\\n      },\\n      \\\"BookingConfirmation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Complete booking confirmation details\\\",\\n        \\\"properties\\\": {\\n          \\\"confirmation_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique confirmation identifier for the booking\\\",\\n            \\\"example\\\": \\\"CONF123456789\\\"\\n          },\\n          \\\"passenger\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Passenger\\\"\\n          },\\n          \\\"itinerary\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Itinerary\\\"\\n          },\\n          \\\"seat_upgrades\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of seat upgrades selected by the passenger\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/SeatUpgrade\\\"\\n            },\\n            \\\"example\\\": [\\n              {\\n                \\\"seat_number\\\": \\\"12A\\\",\\n                \\\"upgrade_class\\\": \\\"Business\\\",\\n                \\\"price_usd\\\": 150.00\\n              },\\n              {\\n                \\\"seat_number\\\": \\\"12B\\\",\\n                \\\"upgrade_class\\\": \\\"Business\\\",\\n                \\\"price_usd\\\": 150.00\\n              }\\n            ]\\n          },\\n          \\\"meal_preferences\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Meal preferences selected by the passenger\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/MealPreference\\\"\\n            },\\n            \\\"example\\\": [\\n              {\\n                \\\"meal_type\\\": \\\"Vegetarian\\\",\\n                \\\"description\\\": \\\"A vegetarian meal with fresh vegetables and grains.\\\"\\n              },\\n              {\\n                \\\"meal_type\\\": \\\"Gluten-Free\\\",\\n                \\\"description\\\": \\\"A meal free from gluten ingredients.\\\"\\n              }\\n            ]\\n          }\\n        }\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {}\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"property_id\": \"prop123456\",\n    \"address\": \"123 Maple Street, Springfield, IL 62704\",\n    \"architectural_specs\": {\n      \"year_built\": 1998,\n      \"square_feet\": 2500,\n      \"bedrooms\": 4,\n      \"bathrooms\": 3,\n      \"flooring\": \"hardwood\",\n      \"has_basement\": true\n    },\n    \"images\": [\n      {\n        \"url\": \"https://example.com/images/property123_front.jpg\",\n        \"resolution\": \"4000x3000\"\n      },\n      {\n        \"url\": \"https://example.com/images/property123_backyard.jpg\",\n        \"resolution\": \"4000x3000\"\n      },\n      {\n        \"url\": \"https://example.com/images/property123_kitchen.jpg\",\n        \"resolution\": \"4000x3000\"\n      }\n    ],\n    \"realtor_contact\": {\n      \"name\": \"Jane Doe\",\n      \"phone\": \"+1-217-555-0199\",\n      \"email\": \"janedoe@realestateco.com\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Real Estate Property Listing\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Architectural and structural specifications of the property'\\n      properties:\\n        year_built:\\n          type: integer\\n          description: 'Year the property was built'\\n          example: 1998\\n        square_feet:\\n          type: integer\\n          description: 'Total living area in square feet'\\n          example: 2500\\n        bedrooms:\\n          type: integer\\n          description: 'Number of bedrooms in the property'\\n          example: 4\\n        bathrooms:\\n          type: integer\\n          description: 'Number of bathrooms in the property'\\n          example: 3\\n        flooring:\\n          type: string\\n          description: 'Type of flooring used in the property'\\n          example: 'hardwood'\\n        has_basement:\\n          type: boolean\\n          description: 'Indicates if the property has a basement'\\n          example: true\\n    Image:\\n      type: object\\n      description: 'High-resolution image information for the property'\\n      properties:\\n        url:\\n          type: string\\n          format: uri\\n          description: 'URL to the high-resolution image'\\n          example: 'https://example.com/images/property123_front.jpg'\\n        resolution:\\n          type: string\\n          description: 'Image resolution in width x height format'\\n          example: '4000x3000'\\n    RealtorContact:\\n      type: object\\n      description: 'Contact information for the assigned realtor'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Full name of the realtor'\\n          example: 'Jane Doe'\\n        phone:\\n          type: string\\n          description: 'Realtor phone number with country code'\\n          example: '+1-217-555-0199'\\n        email:\\n          type: string\\n          format: email\\n          description: 'Email address of the realtor'\\n          example: 'janedoe@realestateco.com'\\n    PropertyListing:\\n      type: object\\n      description: 'Complete real estate property listing containing specs, images, and realtor info'\\n      properties:\\n        property_id:\\n          type: string\\n          description: 'Unique identifier for the property'\\n          example: 'prop123456'\\n        address:\\n          type: string\\n          description: 'Full property address'\\n          example: '123 Maple Street, Springfield, IL 62704'\\n        architectural_specs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n          description: 'List of high-resolution images of the property'\\n          items:\\n            $ref: '#/components/schemas/Image'\\n        realtor_contact:\\n          $ref: '#/components/schemas/RealtorContact'\\n\"\n}"
"{\n  \"raw_json\": {\n    \"room_type\": \"Deluxe Suite\",\n    \"pricing\": {\n      \"base_rate\": 350.00,\n      \"taxes\": 52.50,\n      \"total_per_night\": 402.50\n    },\n    \"requested_amenities\": [\n      {\n        \"amenity\": \"Crib\",\n        \"quantity\": 1\n      },\n      {\n        \"amenity\": \"Extra Bed\",\n        \"quantity\": 2\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Sistema de Reservas de Hotel\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Pricing\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhamento dos preços por noite\\\",\\n        \\\"properties\\\": {\\n          \\\"base_rate\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Taxa base sem impostos para a diária\\\",\\n            \\\"example\\\": 350.00\\n          },\\n          \\\"taxes\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Valor total de impostos aplicados\\\",\\n            \\\"example\\\": 52.50\\n          },\\n          \\\"total_per_night\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Preço total da diária incluindo impostos\\\",\\n            \\\"example\\\": 402.50\\n          }\\n        }\\n      },\\n      \\\"Amenity\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Amenidade solicitada pelo hóspede\\\",\\n        \\\"properties\\\": {\\n          \\\"amenity\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome da amenidade solicitada\\\",\\n            \\\"example\\\": \\\"Crib\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantidade solicitada da amenidade\\\",\\n            \\\"example\\\": 1\\n          }\\n        }\\n      },\\n      \\\"HotelReservationResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta do sistema com detalhes da reserva de hotel\\\",\\n        \\\"properties\\\": {\\n          \\\"room_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo do quarto reservado\\\",\\n            \\\"example\\\": \\\"Deluxe Suite\\\"\\n          },\\n          \\\"pricing\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Pricing\\\"\\n          },\\n          \\\"requested_amenities\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de amenidades adicionais solicitadas\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Amenity\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"floor_plans\": [\n      {\n        \"floor_id\": \"1A\",\n        \"floor_name\": \"Ground Floor\",\n        \"description\": \"Floor illustrating the layout of hot-desks and meeting rooms.\",\n        \"hot_desks\": [\n          {\n            \"desk_id\": \"HD101\",\n            \"occupied\": true,\n            \"occupant\": {\n              \"user_id\": \"U1001\",\n              \"name\": \"Alice Johnson\",\n              \"email\": \"alice.johnson@example.com\"\n            }\n          },\n          {\n            \"desk_id\": \"HD102\",\n            \"occupied\": false,\n            \"occupant\": null\n          }\n        ],\n        \"meeting_rooms\": [\n          {\n            \"room_id\": \"MR1\",\n            \"room_name\": \"Ocean View\",\n            \"capacity\": 8\n          }\n        ]\n      },\n      {\n        \"floor_id\": \"2B\",\n        \"floor_name\": \"Second Floor\",\n        \"description\": \"Primarily dedicated to quiet zones and meeting rooms.\",\n        \"hot_desks\": [\n          {\n            \"desk_id\": \"HD201\",\n            \"occupied\": true,\n            \"occupant\": {\n              \"user_id\": \"U1022\",\n              \"name\": \"Raj Patel\",\n              \"email\": \"raj.patel@example.com\"\n            }\n          }\n        ],\n        \"meeting_rooms\": [\n          {\n            \"room_id\": \"MR4\",\n            \"room_name\": \"Sunset Room\",\n            \"capacity\": 10\n          }\n        ]\n      }\n    ],\n    \"occupied_hot_desks\": [\n      {\n        \"desk_id\": \"HD101\",\n        \"floor_id\": \"1A\",\n        \"occupant\": {\n          \"user_id\": \"U1001\",\n          \"name\": \"Alice Johnson\",\n          \"email\": \"alice.johnson@example.com\"\n        }\n      },\n      {\n        \"desk_id\": \"HD201\",\n        \"floor_id\": \"2B\",\n        \"occupant\": {\n          \"user_id\": \"U1022\",\n          \"name\": \"Raj Patel\",\n          \"email\": \"raj.patel@example.com\"\n        }\n      }\n    ],\n    \"upcoming_meeting_room_reservations\": [\n      {\n        \"reservation_id\": \"R5001\",\n        \"room_id\": \"MR1\",\n        \"room_name\": \"Ocean View\",\n        \"start_time\": \"2024-06-05T10:00:00Z\",\n        \"end_time\": \"2024-06-05T11:00:00Z\",\n        \"reserved_by\": {\n          \"user_id\": \"U2005\",\n          \"name\": \"Martha Simmons\",\n          \"email\": \"martha.simmons@example.com\"\n        },\n        \"purpose\": \"Team Sync\"\n      },\n      {\n        \"reservation_id\": \"R5002\",\n        \"room_id\": \"MR4\",\n        \"room_name\": \"Sunset Room\",\n        \"start_time\": \"2024-06-05T14:00:00Z\",\n        \"end_time\": \"2024-06-05T15:30:00Z\",\n        \"reserved_by\": {\n          \"user_id\": \"U2011\",\n          \"name\": \"Kevin Lee\",\n          \"email\": \"kevin.lee@example.com\"\n        },\n        \"purpose\": \"Client Presentation\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Co-working Space Desk Availability Report\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    User:\\n      type: object\\n      description: 'Information about a user or occupant'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'U1001'\\n        name:\\n          type: string\\n          description: 'Full name of the user'\\n          example: 'Alice Johnson'\\n        email:\\n          type: string\\n          description: 'Email address of the user'\\n          example: 'alice.johnson@example.com'\\n    HotDesk:\\n      type: object\\n      description: 'Information about a hot-desk including occupancy status'\\n      properties:\\n        desk_id:\\n          type: string\\n          description: 'Unique identifier for the hot-desk'\\n          example: 'HD101'\\n        occupied:\\n          type: boolean\\n          description: 'Indicates if the hot-desk is currently occupied'\\n          example: true\\n        occupant:\\n          anyOf:\\n            - $ref: '#/components/schemas/User'\\n            - type: 'null'\\n          description: 'Occupant details if desk is occupied, otherwise null'\\n          example:\\n            user_id: 'U1001'\\n            name: 'Alice Johnson'\\n            email: 'alice.johnson@example.com'\\n    MeetingRoom:\\n      type: object\\n      description: 'Information about a meeting room available on a floor'\\n      properties:\\n        room_id:\\n          type: string\\n          description: 'Unique identifier for the meeting room'\\n          example: 'MR1'\\n        room_name:\\n          type: string\\n          description: 'Name of the meeting room'\\n          example: 'Ocean View'\\n        capacity:\\n          type: integer\\n          description: 'Maximum occupancy of the meeting room'\\n          example: 8\\n    FloorPlan:\\n      type: object\\n      description: 'Details of a floor plan including hot-desks and meeting rooms'\\n      properties:\\n        floor_id:\\n          type: string\\n          description: 'Unique identifier of the floor'\\n          example: '1A'\\n        floor_name:\\n          type: string\\n          description: 'Name of the floor'\\n          example: 'Ground Floor'\\n        description:\\n          type: string\\n          description: 'Description of the floor layout and usage'\\n          example: 'Floor illustrating the layout of hot-desks and meeting rooms.'\\n        hot_desks:\\n          type: array\\n          description: 'List of hot-desks on the floor with occupancy status'\\n          items:\\n            $ref: '#/components/schemas/HotDesk'\\n        meeting_rooms:\\n          type: array\\n          description: 'Meeting rooms located on this floor'\\n          items:\\n            $ref: '#/components/schemas/MeetingRoom'\\n    OccupiedHotDesk:\\n      type: object\\n      description: 'Currently occupied hot-desk details with occupant info'\\n      properties:\\n        desk_id:\\n          type: string\\n          description: 'Identifier for the occupied hot-desk'\\n          example: 'HD101'\\n        floor_id:\\n          type: string\\n          description: 'Identifier of the floor where the hot-desk is located'\\n          example: '1A'\\n        occupant:\\n          $ref: '#/components/schemas/User'\\n    MeetingRoomReservation:\\n      type: object\\n      description: 'Details of an upcoming meeting room reservation'\\n      properties:\\n        reservation_id:\\n          type: string\\n          description: 'Unique identifier for the reservation'\\n          example: 'R5001'\\n        room_id:\\n          type: string\\n          description: 'Meeting room identifier for the reservation'\\n          example: 'MR1'\\n        room_name:\\n          type: string\\n          description: 'Name of the meeting room reserved'\\n          example: 'Ocean View'\\n        start_time:\\n          type: string\\n          format: date-time\\n          description: 'Reservation start timestamp in ISO 8601 format'\\n          example: '2024-06-05T10:00:00Z'\\n        end_time:\\n          type: string\\n          format: date-time\\n          description: 'Reservation end timestamp in ISO 8601 format'\\n          example: '2024-06-05T11:00:00Z'\\n        reserved_by:\\n          $ref: '#/components/schemas/User'\\n        purpose:\\n          type: string\\n          description: 'Purpose or title of the meeting'\\n          example: 'Team Sync'\\n    DeskAvailabilityReport:\\n      type: object\\n      description: 'Co-working space desk availability including floor plans, occupied desks, and meeting reservations'\\n      properties:\\n        floor_plans:\\n          type: array\\n          description: 'Collection of floor plans with hot-desks and meeting rooms'\\n          items:\\n            $ref: '#/components/schemas/FloorPlan'\\n        occupied_hot_desks:\\n          type: array\\n          description: 'List of currently occupied hot-desks with occupant details'\\n          items:\\n            $ref: '#/components/schemas/OccupiedHotDesk'\\n        upcoming_meeting_room_reservations:\\n          type: array\\n          description: 'Scheduled meeting room reservations in the near future'\\n          items:\\n            $ref: '#/components/schemas/MeetingRoomReservation'\\n  schemas:\\n    DeskAvailabilityReport: {}\\npaths: {}\\ncomponents:\\n  schemas:\\n    User: {}\\n    HotDesk: {}\\n    MeetingRoom: {}\\n    FloorPlan: {}\\n    OccupiedHotDesk: {}\\n    MeetingRoomReservation: {}\\n\"\n}"
"{\n  \"raw_json\": {\n    \"course_id\": \"CSCI101\",\n    \"course_title\": \"Introduction to Computer Science\",\n    \"professor\": {\n      \"name\": \"Dr. Alice Smith\",\n      \"academic_background\": \"Ph.D. in Computer Science from MIT, specializing in Artificial Intelligence\",\n      \"email\": \"alice.smith@university.edu\"\n    },\n    \"weekly_modules\": [\n      {\n        \"week\": 1,\n        \"topic\": \"Foundations of Computing\",\n        \"modules\": [\n          {\n            \"module_title\": \"History of Computing\",\n            \"description\": \"Overview of historical milestones in computing\"\n          },\n          {\n            \"module_title\": \"Binary Systems\",\n            \"description\": \"Understanding binary numbers and data representation\"\n          }\n        ]\n      },\n      {\n        \"week\": 2,\n        \"topic\": \"Programming Basics\",\n        \"modules\": [\n          {\n            \"module_title\": \"Introduction to Programming Languages\",\n            \"description\": \"Basics of programming languages and syntax\"\n          },\n          {\n            \"module_title\": \"Control Structures\",\n            \"description\": \"Conditional statements and loops\"\n          }\n        ]\n      }\n    ],\n    \"textbooks\": [\n      {\n        \"title\": \"Computer Science: An Overview\",\n        \"authors\": [\"J. Glenn Brookshear\", \"Dennis Brylow\"],\n        \"edition\": \"12th\",\n        \"year\": 2018\n      },\n      {\n        \"title\": \"Introduction to Programming in Python\",\n        \"authors\": [\"Robert Sedgewick\", \"Kevin Wayne\"],\n        \"edition\": \"1st\",\n        \"year\": 2016\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"University Course Syllabus API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Professor\\\": {\\n        \\\"type\\\