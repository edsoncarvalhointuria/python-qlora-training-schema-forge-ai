"{\n  \"raw_json\": {\n    \"matchSummary\": {\n      \"teamScores\": {\n        \"teamA\": 16,\n        \"teamB\": 12\n      },\n      \"playerStatistics\": [\n        {\n          \"playerId\": \"player_001\",\n          \"playerName\": \"Carlos\",\n          \"kills\": 20,\n          \"deaths\": 5,\n          \"assists\": 7\n        },\n        {\n          \"playerId\": \"player_002\",\n          \"playerName\": \"Fernanda\",\n          \"kills\": 15,\n          \"deaths\": 8,\n          \"assists\": 10\n        }\n      ],\n      \"matchTimeline\": [\n        {\n          \"eventType\": \"Kill\",\n          \"timestamp\": \"00:05:23\",\n          \"description\": \"Carlos eliminou o jogador adversário com um headshot\"\n        },\n        {\n          \"eventType\": \"ObjectiveCaptured\",\n          \"timestamp\": \"00:12:47\",\n          \"description\": \"Barras de captura tomadas pela equipe A\"\n        }\n      ]\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Competitive E-sports Match Summary API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    TeamScores:\\n      type: object\\n      description: 'Pontuação das equipes na partida'\\n      properties:\\n        teamA:\\n          type: integer\\n          description: 'Pontuação da equipe A'\\n          example: 16\\n        teamB:\\n          type: integer\\n          description: 'Pontuação da equipe B'\\n          example: 12\\n    PlayerStatistics:\\n      type: object\\n      description: 'Estatísticas individuais de um jogador'\\n      properties:\\n        playerId:\\n          type: string\\n          description: 'Identificador único do jogador'\\n          example: 'player_001'\\n        playerName:\\n          type: string\\n          description: 'Nome do jogador'\\n          example: 'Carlos'\\n        kills:\\n          type: integer\\n          description: 'Número de eliminações feitas pelo jogador'\\n          example: 20\\n        deaths:\\n          type: integer\\n          description: 'Número de mortes sofridas pelo jogador'\\n          example: 5\\n        assists:\\n          type: integer\\n          description: 'Número de assistências em eliminações'\\n          example: 7\\n    MatchEvent:\\n      type: object\\n      description: 'Evento chave que ocorreu durante a partida'\\n      properties:\\n        eventType:\\n          type: string\\n          description: 'Tipo do evento na partida'\\n          example: 'Kill'\\n        timestamp:\\n          type: string\\n          description: 'Momento em que o evento ocorreu (mm:ss)'\\n          example: '00:05:23'\\n        description:\\n          type: string\\n          description: 'Descrição detalhada do evento'\\n          example: 'Carlos eliminou o jogador adversário com um headshot'\\n    MatchTimeline:\\n      type: array\\n      description: 'Lista de eventos que ocorreram durante a partida'\\n      items:\\n        $ref: '#/components/schemas/MatchEvent'\\n    MatchSummary:\\n      type: object\\n      description: 'Resumo completo da partida e-sports com pontuações, estatísticas e timeline de eventos'\\n      properties:\\n        teamScores:\\n          $ref: '#/components/schemas/TeamScores'\\n        playerStatistics:\\n          type: array\\n          description: 'Lista de estatísticas dos jogadores'\\n          items:\\n            $ref: '#/components/schemas/PlayerStatistics'\\n        matchTimeline:\\n          $ref: '#/components/schemas/MatchTimeline'\\n\"\n}"
