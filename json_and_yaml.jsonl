ay\\n          description: 'Detailed breakdown of feature actions and counts'\\n          items:\\n            $ref: '#/components/schemas/UsageDetail'\\n    SubscriptionTierLimits:\\n      type: object\\n      description: 'Limits and specifications of the subscription tier'\\n      properties:\\n        tier_name:\\n          type: string\\n          description: 'Name of the subscription tier'\\n          example: 'Pro'\\n        max_users:\\n          type: integer\\n          description: 'Maximum number of users allowed under the tier'\\n          example: 50\\n        max_projects:\\n          type: integer\\n          description: 'Maximum number of projects allowed'\\n          example: 100\\n        max_storage_gb:\\n          type: integer\\n          description: 'Maximum storage capacity in gigabytes'\\n          example: 500\\n    UserAnalyticsReport:\\n      type: object\\n      description: 'Daily user analytics report for the SaaS platform'\\n      properties:\\n        date:\\n          type: string\\n          format: date\\n          description: 'Date of the analytics report'\\n          example: '2024-04-24'\\n        daily_active_users:\\n          type: integer\\n          description: 'The number of active users on the report date'\\n          example: 1234\\n        feature_usage:\\n          type: array\\n          description: 'List of features with usage metrics'\\n          items:\\n            $ref: '#/components/schemas/FeatureUsage'\\n        subscription_tier_limits:\\n          $ref: '#/components/schemas/SubscriptionTierLimits'\\n\"\n}"
