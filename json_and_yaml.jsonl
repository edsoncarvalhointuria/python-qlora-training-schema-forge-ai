    \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Nível atual de carga da bateria em porcentagem\\\",\\n            \\\"example\\\": 87\\n          },\\n          \\\"temperature_celsius\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Temperatura atual da bateria em grau Celsius\\\",\\n            \\\"example\\\": 36.5\\n          },\\n          \\\"voltage_volts\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Voltagem atual da bateria em volts\\\",\\n            \\\"example\\\": 400\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Status geral da bateria\\\",\\n            \\\"example\\\": \\\"nominal\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"charge_level_percent\\\", \\\"temperature_celsius\\\", \\\"voltage_volts\\\", \\\"status\\\"]\\n      },\\n      \\\"DrivingAnomaly\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Evento anômalo registrado durante a condução\\\",\\n        \\\"properties\\\": {\\n          \\\"type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo de anomalia de direção detectada\\\",\\n            \\\"example\\\": \\\"hard_brake\\\"\\n          },\\n          \\\"severity\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nível de severidade da anomalia\\\",\\n            \\\"example\\\": \\\"medium\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Momento exato da ocorrência da anomalia\\\",\\n            \\\"example\\\": \\\"2024-06-15T14:25:10Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"type\\\", \\\"severity\\\", \\\"timestamp\\\"]\\n      },\\n      \\\"TelemetryPing\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Ping de telemetria contendo informações de localização, velocidade, estado da bateria e anomalias\\\",\\n        \\\"properties\\\": {\\n          \\\"vehicle_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do veículo autônomo\\\",\\n            \\\"example\\\": \\\"auto_5234\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Carimbo de data/hora do ping de telemetria\\\",\\n            \\\"example\\\": \\\"2024-06-15T14:28:30Z\\\"\\n          },\\n          \\\"gps_coordinates\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/GPSCoordinates\\\"\\n          },\\n          \\\"current_speed_kmh\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Velocidade atual do veículo em quilômetros por hora\\\",\\n            \\\"example\\\": 58.7\\n          },\\n          \\\"battery_health\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BatteryHealth\\\"\\n          },\\n          \\\"recent_driving_anomalies\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista recente de eventos anômalos durante a condução\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/DrivingAnomaly\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"vehicle_id\\\", \\\"timestamp\\\", \\\"gps_coordinates\\\", \\\"current_speed_kmh\\\", \\\"battery_health\\\", \\\"recent_driving_anomalies\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
