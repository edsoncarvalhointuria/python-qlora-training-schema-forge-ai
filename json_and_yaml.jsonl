ype: integer\\n          description: 'Volume de água utilizado na irrigação em litros'\\n          example: 120\\n    AgricultureSensorResponse:\\n      type: object\\n      description: 'Resposta dos sensores inteligentes para agricultura'\\n      properties:\\n        sensor_id:\\n          type: string\\n          description: 'Identificador único do sensor de agricultura'\\n          example: 'agri_sensor_001'\\n        soil_moisture:\\n          type: number\\n          description: 'Nível atual de umidade do solo em porcentagem'\\n          example: 23.7\\n        weather_forecast:\\n          $ref: '#/components/schemas/WeatherForecast'\\n        irrigation_events:\\n          type: array\\n          description: 'Lista de eventos recentes de irrigação automática'\\n          items:\\n            $ref: '#/components/schemas/IrrigationEvent'\\n\"\n}"
