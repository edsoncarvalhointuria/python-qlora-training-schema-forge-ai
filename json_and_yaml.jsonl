           \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of seat upgrades selected by the passenger\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/SeatUpgrade\\\"\\n            },\\n            \\\"example\\\": [\\n              {\\n                \\\"seat_class\\\": \\\"Business\\\",\\n                \\\"price_paid\\\": 450.00\\n              },\\n              {\\n                \\\"seat_class\\\": \\\"Extra Legroom\\\",\\n                \\\"price_paid\\\": 75.00\\n              }\\n            ]\\n          },\\n          \\\"meal_preferences\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of meal preferences selected by the passenger\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"A meal preference option\\\",\\n              \\\"example\\\": \\\"Vegetarian\\\"\\n            },\\n            \\\"example\\\": [\\\"Vegetarian\\\", \\\"Gluten-Free\\\"]\\n          }\\n        },\\n        \\\"required\\\": [\\\"booking_reference\\\", \\\"passenger\\\", \\\"itinerary\\\", \\\"seat_upgrades\\\", \\\"meal_preferences\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
