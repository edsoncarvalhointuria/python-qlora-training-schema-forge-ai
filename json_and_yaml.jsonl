"{\n  \"raw_json\": {\n    \"container_id\": \"CONT1234567\",\n    \"current_port\": {\n      \"port_name\": \"Port of Hamburg\",\n      \"country\": \"Germany\",\n      \"arrival_time\": \"2024-06-15T08:30:00Z\"\n    },\n    \"customs_clearance\": {\n      \"status\": \"Cleared\",\n      \"clearance_date\": \"2024-06-16T10:15:00Z\",\n      \"inspector\": {\n        \"name\": \"Anna Schmidt\",\n        \"badge_number\": \"INS78910\"\n      }\n    },\n    \"environmental_readings\": [\n      {\n        \"timestamp\": \"2024-06-15T08:00:00Z\",\n        \"temperature_celsius\": 5.2,\n        \"humidity_percentage\": 75\n      },\n      {\n        \"timestamp\": \"2024-06-15T14:00:00Z\",\n        \"temperature_celsius\": 5.8,\n        \"humidity_percentage\": 72\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Container Tracking Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PortLocation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details about the current port location of the container\\\",\\n        \\\"properties\\\": {\\n          \\\"port_name\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Name of the port where the container is currently located\\\", \\\"example\\\": \\\"Port of Hamburg\\\" },\\n          \\\"country\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Country where the port is located\\\", \\\"example\\\": \\\"Germany\\\" },\\n          \\\"arrival_time\\\": { \\\"type\\\": \\\"string\\\", \\\"format\\\": \\\"date-time\\\", \\\"description\\\": \\\"Arrival date and time at the port in ISO 8601 format\\\", \\\"example\\\": \\\"2024-06-15T08:30:00Z\\\" }\\n        },\\n        \\\"required\\\": [\\\"port_name\\\", \\\"country\\\", \\\"arrival_time\\\"]\\n      },\\n      \\\"Inspector\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n    