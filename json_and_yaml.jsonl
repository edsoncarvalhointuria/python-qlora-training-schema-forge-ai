"{\n  \"raw_json\": {\n    \"date\": \"2024-04-25\",\n    \"daily_active_users\": 1250,\n    \"feature_usage\": [\n      {\n        \"feature_name\": \"File Upload\",\n        \"usage_count\": 540,\n        \"average_session_time_sec\": 120\n      },\n      {\n        \"feature_name\": \"Real-time Collaboration\",\n        \"usage_count\": 320,\n        \"average_session_time_sec\": 300\n      }\n    ],\n    \"subscription_tier\": {\n      \"tier_name\": \"Pro\",\n      \"user_limit\": 50,\n      \"storage_limit_gb\": 500,\n      \"api_call_limit_per_minute\": 1000\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: SaaS User Analytics Report\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FeatureUsage:\\n      type: object\\n      description: 'Usage metrics of a single software feature'\\n      properties:\\n        feature_name:\\n          type: string\\n          description: 'Name of the feature being used'\\n          example: 'File Upload'\\n        usage_count:\\n          type: integer\\n          description: 'Number of times this feature was used on the given day'\\n          example: 540\\n        average_session_time_sec:\\n          type: integer\\n          description: 'Average session time in seconds when using this feature'\\n          example: 120\\n    SubscriptionTier:\\n      type: object\\n      description: 'Limits and details of the user subscription tier'\\n      properties:\\n        tier_name:\\n          type: string\\n          description: 'Name of the subscription tier'\\n          example: 'Pro'\\n        user_limit:\\n          type: integer\\n          description: 'Maximum number of users allowed under this tier'\\n          example: 50\\n        storage_limit_gb:\\n          type: integer\\n          description: 'Storage limit in gigabytes allocated for this tier'\\n          example: 500\\n        api_call_limit_per_minute:\\n          type: integer\\n          description: 'Maximum allowed API calls per minute for this tier'\\n          example: 1000\\n    UserAnalyticsReport:\\n      type: object\\n      description: 'Daily user analytics report for the SaaS platform'\\n      properties:\\n        date:\\n          type: string\\n          format: date\\n          description: 'Date for the analytics report in YYYY-MM-DD format'\\n          example: '2024-04-25'\\n        daily_active_users:\\n          type: integer\\n          description: 'Count of unique active users on the platform for the given day'\\n          example: 1250\\n        feature_usage:\\n          type: array\\n          description: 'List of feature usage metrics for the day'\\n          items:\\n            $ref: '#/components/schemas/FeatureUsage'\\n        subscription_tier:\\n          $ref: '#/components/schemas/SubscriptionTier'\\n\"\n}"
