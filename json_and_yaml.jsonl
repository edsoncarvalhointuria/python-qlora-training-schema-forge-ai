\n}"
"{\n  \"raw_json\": {\n    \"credit_score\": 720,\n    \"property_valuation\": {\n      \"estimated_value\": 350000,\n      \"valuation_date\": \"2024-05-15\",\n      \"valuation_company\": \"Avalia Imóveis Ltda\"\n    },\n    \"required_compliance_documents\": [\n      {\n        \"document_name\": \"Proof of Income\",\n        \"document_required\": true\n      },\n      {\n        \"document_name\": \"ID Verification\",\n        \"document_required\": true\n      },\n      {\n        \"document_name\": \"Credit Report Authorization\",\n        \"document_required\": true\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Resposta de Aplicação de Empréstimo Hipotecário\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PropertyValuation:\\n      type: object\\n      description: 'Informações detalhadas da avaliação do imóvel'\\n      properties:\\n        estimated_value:\\n          type: integer\\n          description: 'Valor estimado do imóvel em moeda local'\\n          example: 350000\\n        valuation_date:\\n          type: string\\n          format: date\\n          description: 'Data em que a avaliação foi realizada'\\n          example: '2024-05-15'\\n        valuation_company:\\n          type: string\\n          description: 'Nome da empresa responsável pela avaliação'\\n          example: 'Avalia Imóveis Ltda'\\n    ComplianceDocument:\\n      type: object\\n      description: 'Documento requerido para conformidade na aplicação do empréstimo'\\n      properties:\\n        document_name:\\n          type: string\\n          description: 'Nome do documento requerido'\\n          example: 'Proof of Income'\\n        document_required:\\n          type: boolean\\n          description: 'Indica se o documento é obrigatório'\\n          example: true\\n    MortgageApplicationResponse:\\n      type: object\\n      description: 'Resposta detalhada da aplicação de empréstimo hipotecário'\\n      properties:\\n        credit_scor