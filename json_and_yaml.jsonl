ype\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes da transação de pagamento\\\",\\n        \\\"properties\\\": {\\n          \\\"transaction_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único da transação\\\",\\n            \\\"example\\\": \\\"txn_7890\\\"\\n          },\\n          \\\"method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Método de pagamento utilizado\\\",\\n            \\\"example\\\": \\\"credit_card\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Valor total da transação\\\",\\n            \\\"example\\\": 419.97\\n          },\\n          \\\"currency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Moeda da transação\\\",\\n            \\\"example\\\": \\\"BRL\\\"\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Status atual do pagamento\\\",\\n            \\\"example\\\": \\\"approved\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"transaction_id\\\", \\\"method\\\", \\\"amount\\\", \\\"currency\\\", \\\"status\\\"]\\n      },\\n      \\\"Link\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Representação de um link HAL para navegação ou ações\\\",\\n        \\\"properties\\\": {\\n          \\\"href\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"uri\\\",\\n            \\\"description\\\": \\\"URL do recurso ou ação\\\",\\n            \\\"example\\\": \\\"https://api.example.com/orders/ord_12345\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"href\\\"]\\n      },\\n      \\\"Links\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Coleção de links HAL relacionados ao pedido\\\",\\n        \\\"properties\\\": {\\n          \\\"self\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Link\\\",\\n            \\\"description\\\": \\\"Link para o próprio recurso de pedido\\\"\\n          },\\n          \\\"tracking\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Link\\\",\\n            \\\"description\\\": \\\"Link para o acompanhamento do pedido\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"self\\\", \\\"tracking\\\"]\\n      },\\n      \\\"OrderResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta com detalhes do pedido de e-commerce\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do pedido\\\",\\n            \\\"example\\\": \\\"ord_12345\\\"\\n          },\\n          \\\"items\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de itens físicos no pedido\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Item\\\"\\n            }\\n          },\\n          \\\"shipping_address\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/ShippingAddress\\\"\\n          },\\n          \\\"payment\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Payment\\\"\\n          },\\n          \\\"_links\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Links\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"order_id\\\", \\\"items\\\", \\\"shipping_address\\\", \\\"payment\\\", \\\"_links\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"tags\\\": [],\\n  \\\"servers\\\": []\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"current_balance\": 4520.75,\n    \"user_profile\": {\n      \"user_id\": \"usr_789\",\n      \"full_name\": \"Jane Doe\",\n      \"email\": \"jane.doe@example.com\",\n      \"phone_number\": \"+1234567890\"\n    },\n    \"recent_transactions\": [\n      {\n        \"transaction_id\": \"tx_001\",\n        \"date\": \"2024-06-15T14:20:00Z\",\n        \"type\": \"debit\",\n        \"amount\": 120.00,\n        \"currency\": \"USD\",\n        \"description\": \"Grocery shopping\",\n        \"merchant\": {\n          \"name\": \"Fresh Market\",\n          \"category\": \"Groceries\",\n          \"location\": \"123 Main St, Anytown\"\n        }\n      },\n      {\n        \"transaction_id\": \"tx_002\",\n        \"date\": \"2024-06-14T10:05:00Z\",\n        \"type\": \"credit\",\n        \"amount\": 300.00,\n        \"currency\": \"USD\",\n        \"description\": \"Salary deposit\",\n        \"merchant\": null\n      },\n      {\n        \"transaction_id\": \"tx_003\",\n        \"date\": \"2024-06-13T18:30:00Z\",\n        \"type\": \"debit\",\n        \"amount\": 45.50,\n        \"currency\": \"USD\",\n        \"description\": \"Online subscription\",\n        \"merchant\": {\n          \"name\": \"StreamFlix\",\n          \"category\": \"Entertainment\",\n          \"location\": \"Online\"\n        }\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Digital Wallet Statement\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UserProfile:\\n      type: object\\n      description: 'Details of the user profile'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_789'\\n        full_name:\\n          type: string\\n          description: 'Full name of the user'\\n          example: 'Jane Doe'\\n        email:\\n          type: string\\n          description: 'Email address of the user'\\n          example: 'jane.doe@example.com'\\n        phone_number:\\n          type: string\\n          description: 'Contact phone number of the user'\\n          example: '+1234567890'\\n    Merchant:\\n      type: object\\n      description: 'Information about the merchant involved in a transaction'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Name of the merchant'\\n          example: 'Fresh Market'\\n        category:\\n          type: string\\n          description: 'Business category of the merchant'\\n          example: 'Groceries'\\n        location:\\n          type: string\\n          description: 'Physical or online location of the merchant'\\n          example: '123 Main St, Anytown'\\n    Transaction:\\n      type: object\\n      description: 'Single transaction record in the wallet statement'\\n      properties:\\n        transaction_id:\\n          type: string\\n          description: 'Unique identifier for the transaction'\\n          example: 'tx_001'\\n        date:\\n          type: string\\n          format: date-time\\n          description: 'ISO 8601 date and time when the transaction occurred'\\n          example: '2024-06-15T14:20:00Z'\\n        type:\\n          type: string\\n          description: 'Type of the transaction, debit or credit'\\n          example: 'debit'\\n        amount:\\n          type: number\\n          format: float\\n          description: 'Amount of money involved in the transaction'\\n          example: 120.00\\n        currency:\\n          type: string\\n          description: 'Currency code of the transaction amount'\\n          example: 'USD'\\n        description:\\n          type: string\\n          description: 'Brief description or memo for the transaction'\\n          example: 'Grocery shopping'\\n        merchant:\\n          oneOf:\\n            - $ref: '#/components/schemas/Merchant'\\n            - type: 'null'\\n          description: 'Merchant information if applicable, null otherwise'\\n          example: {\\\"name\\\": \\\"Fresh Market\\\", \\\"category\\\": \\\"Groceries\\\", \\\"location\\\": \\\"123 Main St, Anytown\\\"}\\n    DigitalWalletStatement:\\n      type: object\\n      description: 'Digital wallet statement including user profile, balance, and recent transactions'\\n      properties:\\n        current_balance:\\n          type: number\\n          format: float\\n          description: 'Current balance in the digital wallet'\\n          example: 4520.75\\n        user_profile:\\n          $ref: '#/components/schemas/UserProfile'\\n        recent_transactions:\\n          type: array\\n          description: 'List of the most recent transactions'\\n          items:\\n            $ref: '#/components/schemas/Transaction'\"\n}"
