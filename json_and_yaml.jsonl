"{\n  \"raw_json\": {\n    \"patient\": {\n      \"id\": \"P123456789\",\n      \"name\": \"John Doe\",\n      \"age\": 45,\n      \"gender\": \"Male\",\n      \"date_of_birth\": \"1978-02-17\"\n    },\n    \"test_results\": [\n      {\n        \"biomarker_name\": \"Hemoglobin\",\n        \"value\": 13.8,\n        \"unit\": \"g/dL\",\n        \"normal_range\": {\n          \"min\": 13.5,\n          \"max\": 17.5\n        },\n        \"flag\": \"Normal\"\n      },\n      {\n        \"biomarker_name\": \"White Blood Cell Count\",\n        \"value\": 6.2,\n        \"unit\": \"x10^3/uL\",\n        \"normal_range\": {\n          \"min\": 4.0,\n          \"max\": 11.0\n        },\n        \"flag\": \"Normal\"\n      },\n      {\n        \"biomarker_name\": \"Platelet Count\",\n        \"value\": 250,\n        \"unit\": \"x10^3/uL\",\n        \"normal_range\": {\n          \"min\": 150,\n          \"max\": 450\n        },\n        \"flag\": \"Normal\"\n      }\n    ],\n    \"pathologist_signature\": {\n      \"name\": \"Dr. Jane Smith\",\n      \"sign_date\": \"2023-11-30T14:23:05Z\",\n      \"signature_id\": \"SIG-987654321\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Hospital Laboratory Test Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Patient:\\n      type: object\\n      description: 'Demographic information of the patient'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier for the patient'\\n          example: 'P123456789'\\n        name:\\n          type: string\\n          description: 'Full name of the patient'\\n          example: 'John Doe'\\n        age:\\n          type: integer\\n          description: 'Age of the patient in years'\\n          example: 45\\n        gender:\\n          type: string\\n          description: 'Gender of the patient'\\n          example: 'Male'\\n        date_of_birth:\\n          type: string\\n          format: date\\n          description: 'Patient date of birth in ISO 8601 format'\\n          example: '1978-02-17'\\n    NormalRange:\\n      type: object\\n      description: 'Specifies the normal range values for a biomarker'\\n      properties:\\n        min:\\n          type: number\\n          description: 'Minimum normal value'\\n          example: 13.5\\n        max:\\n          type: number\\n          description: 'Maximum normal value'\\n          example: 17.5\\n    BiomarkerResult:\\n      type: object\\n      description: 'Result details for a single blood biomarker'\\n      properties:\\n        biomarker_name:\\n          type: string\\n          description: 'Name of the biomarker tested'\\n          example: 'Hemoglobin'\\n        value:\\n          type: number\\n          description: 'Measured value of the biomarker'\\n          example: 13.8\\n        unit:\\n          type: string\\n          description: 'Unit of measurement for the biomarker value'\\n          example: 'g/dL'\\n        normal_range:\\n          $ref: '#/components/schemas/NormalRange'\\n        flag:\\n          type: string\\n          description: 'Flag indicating if the value is normal or abnormal'\\n          example: 'Normal'\\n    PathologistSignature:\\n      type: object\\n      description: 'Digital signature details of the reviewing pathologist'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Full name of the pathologist'\\n          example: 'Dr. Jane Smith'\\n        sign_date:\\n          type: string\\n          format: date-time\\n          description: 'Date and time when the signature was made (ISO 8601 format)'\\n          example: '2023-11-30T14:23:05Z'\\n        signature_id:\\n          type: string\\n          description: 'Unique identifier for the digital signature'\\n          example: 'SIG-987654321'\\n    LabTestResult:\\n      type: object\\n      description: 'Complete laboratory test result including patient info, biomarker results, and pathologist signature'\\n      properties:\\n        patient:\\n          $ref: '#/components/schemas/Patient'\\n        test_results:\\n          type: array\\n          description: 'List of blood biomarker test results'\\n          items:\\n            $ref: '#/components/schemas/BiomarkerResult'\\n        pathologist_signature:\\n          $ref: '#/components/schemas/PathologistSignature'\\n\"\n}"
"{\n  \"raw_json\": {\n    \"provider\": {\n      \"provider_id\": \"prov_456\",\n      \"name\": \"Sunrise Health Clinic\",\n      \"address\": \"123 Wellness Ave, Healthy City, HC 54321\",\n      \"phone\": \"+1-555-123-4567\"\n    },\n    \"procedures\": [\n      {\n        \"procedure_code\": \"99213\",\n        \"description\": \"Office visit, established patient\",\n        \"date_performed\": \"2024-06-10\",\n        \"billed_amount\": 125.00\n      },\n      {\n        \"procedure_code\": \"80050\",\n        \"description\": \"General health panel lab test\",\n        \"date_performed\": \"2024-06-10\",\n        \"billed_amount\": 230.00\n      }\n    ],\n    \"costs\": {\n      \"covered_amount\": 280.00,\n      \"out_of_pocket\": 75.00,\n      \"currency\": \"USD\"\n    }\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Health Insurance Claim Status Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Provider\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the healthcare provider processing the claim\\\",\\n        \\\"properties\\\": {\\n          \\\"provider_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the provider\\\",\\n            \\\"example\\\": \\\"prov_456\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the healthcare provider\\\",\\n            \\\"example\\\": \\\"Sunrise Health Clinic\\\"\\n          },\\n          \\\"address\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Physical address of the provider\\\",\\n            \\\"example\\\": \\\"123 Wellness Ave, Healthy City, HC 54321\\\"\\n          },\\n          \\\"phone\\\": {\\n            \\\"type\\\": \\\"string\