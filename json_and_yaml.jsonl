 of breaths per minute\\\",\\n            \\\"example\\\": 16\\n          }\\n        }\\n      },\\n      \\\"Medication\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about a current medication\\\",\\n        \\\"properties\\\": {\\n          \\\"medication_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the medication\\\",\\n            \\\"example\\\": \\\"Lisinopril\\\"\\n          },\\n          \\\"dosage\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Dosage amount and unit\\\",\\n            \\\"example\\\": \\\"10 mg\\\"\\n          },\\n          \\\"frequency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"How often the medication is taken\\\",\\n            \\\"example\\\": \\\"Once daily\\\"\\n          }\\n        }\\n      },\\n      \\\"DoctorProfile\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Profile information for the attending doctor\\\",\\n        \\\"properties\\\": {\\n          \\\"doctor_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the doctor\\\",\\n            \\\"example\\\": \\\"doc_789\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Full name of the doctor\\\",\\n            \\\"example\\\": \\\"Dr. Sarah Thompson\\\"\\n          },\\n          \\\"specialty\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Medical specialty of the doctor\\\",\\n            \\\"example\\\": \\\"Cardiology\\\"\\n          },\\n          \\\"contact_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Email address to contact the doctor\\\",\\n            \\\"example\\\": \\\"sarah.thompson@hospital.org\\\"\\n          }\\n        }\\n      },\\n      \\\"PatientMedicalRecordSummary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Summary of the patient's medical record including vital signs, current medications, and attending doctor\\\",\\n        \\\"properties\\\": {\\n          \\\"patient_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the patient\\\",\\n            \\\"example\\\": \\\"pat_456\\\"\\n          },\\n          \\\"vital_signs\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/VitalSigns\\\"\\n          },\\n          \\\"current_medications\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of current medications prescribed to the patient\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Medication\\\"\\n            }\\n          },\\n          \\\"attending_doctor\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DoctorProfile\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n}"
