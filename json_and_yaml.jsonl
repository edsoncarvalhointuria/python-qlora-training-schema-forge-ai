\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"User's username\\\",\\n            \\\"example\\\": \\\"music_lover\\\"\\n          },\\n          \\\"display_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"User's display name\\\",\\n            \\\"example\\\": \\\"Music Lover\\\"\\n          },\\n          \\\"profile_url\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"URL to the user's profile\\\",\\n            \\\"example\\\": \\\"https://music.example.com/users/music_lover\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"user_id\\\", \\\"username\\\", \\\"display_name\\\", \\\"profile_url\\\"]\\n      },\\n      \\\"AudioSpecs\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Technical audio specifications of a track\\\",\\n        \\\"properties\\\": {\\n          \\\"bitrate_kbps\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Audio bitrate in kilobits per second\\\",\\n            \\\"example\\\": 320\\n          },\\n          \\\"sample_rate_hz\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Sampling rate in Hertz\\\",\\n            \\\"example\\\": 44100\\n          },\\n          \\\"channels\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of audio channels\\\",\\n            \\\"example\\\": 2\\n          },\\n          \\\"format\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Audio file format\\\",\\n            \\\"example\\\": \\\"mp3\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"bitrate_kbps\\\", \\\"sample_rate_hz\\\", \\\"channels\\\", \\\"format\\\"]\\n      },\\n      \\\"Track\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a music track in the playlist\\\",\\n        \\\"properties\\\": {\\n          \\\"track_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the track\\\",\\n            \\\"example\\\": \\\"track_001\\\"\\n          },\\n          \\\"title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Title of the track\\\",\\n            \\\"example\\\": \\\"Sunset Memories\\\"\\n          },\\n          \\\"album\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Album name the track belongs to\\\",\\n            \\\"example\\\": \\\"Evening Glow\\\"\\n          },\\n          \\\"artist\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the artist\\\",\\n            \\\"example\\\": \\\"DJ Chill\\\"\\n          },\\n          \\\"duration_seconds\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Duration of the track in seconds\\\",\\n            \\\"example\\\": 245\\n          },\\n          \\\"audio_specs\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/AudioSpecs\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"track_id\\\", \\\"title\\\", \\\"album\\\", \\\"artist\\\", \\\"duration_seconds\\\", \\\"audio_specs\\\"]\\n      },\\n      \\\"Pagination\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Pagination details for list responses\\\",\\n        \\\"properties\\\": {\\n          \\\"page\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Current page number\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"per_page\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of items per page\\\",\\n            \\\"example\\\": 2\\n          },\\n          \\\"total_pages\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Total number of pages available\\\",\\n            \\\"example\\\": 5\\n          },\\n          \\\"total_items\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Total number of items available\\\",\\n            \\\"example\\\": 10\\n          }\\n        },\\n        \\\"required\\\": [\\\"page\\\", \\\"per_page\\\", \\\"total_pages\\\", \\\"total_items\\\"]\\n      },\\n      \\\"PlaylistResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response schema for a music playlist with metadata, creator info and tracks\\\",\\n        \\\"properties\\\": {\\n          \\\"playlist_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the playlist\\\",\\n            \\\"example\\\": \\\"pl_12345\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the playlist\\\",\\n            \\\"example\\\": \\\"Chill Vibes\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Description of the playlist\\\",\\n            \\\"example\\\": \\\"Relaxing chillout tunes for evening listening\\\"\\n          },\\n          \\\"created_at\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"ISO 8601 timestamp when the playlist was created\\\",\\n            \\\"example\\\": \\\"2024-05-20T18:30:00Z\\\"\\n          },\\n          \\\"creator\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n          },\\n          \\\"pagination\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Pagination\\\"\\n          },\\n          \\\"tracks\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"