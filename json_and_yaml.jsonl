\\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Week number in the course\\\",\\n            \\\"example\\\": 1\\n          },\\n          \\\"topic\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Main topic of the week\\\",\\n            \\\"example\\\": \\\"Foundations of Computing\\\"\\n          },\\n          \\\"modules\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of modules covered during the week\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/ModuleDetail\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"week\\\", \\\"topic\\\", \\\"modules\\\"]\\n      },\\n      \\\"Textbook\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about a required textbook\\\",\\n        \\\"properties\\\": {\\n          \\\"title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Title of the textbook\\\",\\n            \\\"example\\\": \\\"Computer Science: An Overview\\\"\\n          },\\n          \\\"authors\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of textbook authors\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"example\\\": \\\"J. Glenn Brookshear\\\"\\n            }\\n          },\\n          \\\"edition\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Edition number or identifier\\\",\\n            \\\"example\\\": \\\"12th\\\"\\n          },\\n          \\\"year\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Year of publication\\\",\\n            \\\"example\\\": 2018\\n          }\\n        },\\n        \\\"required\\\": [\\\"title\\\", \\\"authors\\\", \\\"edition\\\", \\\"year\\\"]\\n      },\\n      \\\"CourseSyllabus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Complete syllabus for a university course\\\",\\n        \\\"properties\\\": {\\n          \\\"course_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the course\\\",\\n            \\\"example\\\": \\\"CSCI101\\\"\\n          },\\n          \\\"course_title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Official title of the course\\\",\\n            \\\"example\\\": \\\"Introduction to Computer Science\\\"\\n          },\\n          \\\"professor\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Professor\\\"\\n          },\\n          \\\"weekly_modules\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of weekly modules and their details\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/WeeklyModule\\\"\\n            }\\n          },\\n          \\\"textbooks\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Required textbooks for the course\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Textbook\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"course_id\\\", \\\"course_title\\\", \\\"professor\\\", \\\"weekly_modules\\\", \\\"textbooks\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"root_schema\\\": {\\n    \\\"$ref\\\": \\\"#/components/schemas/CourseSyllabus\\\"\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"student_id\": \"stu_12345\",\n    \"course_progress\": 78.5,\n    \"quizzes\": [\n      {\n        \"quiz_id\": \"quiz_01\",\n        \"score\": 85,\n        \"max_score\": 100\n      },\n      {\n        \"quiz_id\": \"quiz_02\",\n        \"score\": 90,\n        \"max_score\": 100\n      }\n    ],\n    \"certificates\": [\n      {\n        \"certificate_id\": \"cert_001\",\n        \"name\": \"Introduction to Programming\",\n        \"date_unlocked\": \"2024-04-15\"\n      },\n      {\n        \"certificate_id\": \"cert_002\",\n        \"name\": \"Advanced Algorithms\",\n        \"date_unlocked\": \"2024-05-02\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Student Progress Report\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    QuizScore:\\n      type: object\\n      description: 'The score details for a single quiz attempt'\\n      properties:\\n        quiz_id:\\n          type: string\\n          description: 'Unique identifier for the quiz'\\n          example: 'quiz_01'\\n        score:\\n          type: integer\\n          description: 'Score obtained in the quiz'\\n          example: 85\\n        max_score:\\n          type: integer\\n          description: 'Maximum possible score for the quiz'\\n          example: 100\\n    Certificate:\\n      type: object\\n      description: 'Details of a digital certificate unlocked by the student'\\n      properties:\\n        certificate_id:\\n          type: string\\n          description: 'Unique identifier for the certificate'\\n          example: 'cert_001'\\n        name:\\n          type: string\\n          description: 'Name of the certificate course or achievement'\\n          example: 'Introduction to Programming'\\n        date_unlocked:\\n          type: string\\n          format: date\\n          description: 'ISO 8601 date the certificate was unlocked'\\n          example: '2024-04-15'\\n    StudentProgressReport:\\n      type: object\\n   