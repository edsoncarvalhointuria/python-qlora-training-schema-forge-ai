\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of the payment transaction\\\",\\n        \\\"properties\\\": {\\n          \\\"transaction_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the payment transaction\\\",\\n            \\\"example\\\": \\\"txn_7890\\\"\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Status of the payment\\\",\\n            \\\"example\\\": \\\"Completed\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total amount paid\\\",\\n            \\\"example\\\": 136.48\\n          },\\n          \\\"currency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Currency code in ISO 4217 format\\\",\\n            \\\"example\\\": \\\"USD\\\"\\n          },\\n          \\\"payment_method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Payment method used\\\",\\n            \\\"example\\\": \\\"Credit Card\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"transaction_id\\\", \\\"status\\\", \\\"amount\\\", \\\"currency\\\", \\\"payment_method\\\"]\\n      },\\n      \\\"Link\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"HATEOAS link object\\\",\\n        \\\"properties\\\": {\\n          \\\"href\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"URL of the linked resource\\\",\\n            \\\"example\\\": \\\"https://api.shop.com/orders/ord_12345\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"href\\\"]\\n      },\\n      \\\"Links\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Collection of HATEOAS links for the order\\\