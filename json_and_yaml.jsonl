\": \\\"date\\\",\\n            \\\"description\\\": \\\"Billing cycle end date\\\",\\n            \\\"example\\\": \\\"2024-05-31\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"start_date\\\", \\\"end_date\\\"]\\n      },\\n      \\\"TaxBreakdownItem\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Individual tax component of invoice\\\",\\n        \\\"properties\\\": {\\n          \\\"tax_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the tax\\\",\\n            \\\"example\\\": \\\"VAT\\\"\\n          },\\n          \\\"tax_rate\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Tax rate as decimal\\\",\\n            \\\"example\\\": 0.2\\n          },\\n          \\\"tax_amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Amount of tax applied\\\",\\n            \\\"example\\\": 40.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"tax_name\\\", \\\"tax_rate\\\", \\\"tax_amount\\\"]\\n      },\\n      \\\"DiscountCoupon\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Discount coupon applied to the invoice\\\",\\n        \\\"properties\\\": {\\n          \\\"coupon_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique code of the discount coupon\\\",\\n            \\\"example\\\": \\\"SPRING23\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Description of the discount\\\",\\n            \\\"example\\\": \\\"Spring discount 20%\\\"\\n          },\\n          \\\"discount_amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"