\\"Discount subtracted from the nightly rate\\\",\\n            \\\"example\\\": 15.0\\n          },\\n          \\\"total_for_night\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Final total price for this single night\\\",\\n            \\\"example\\\": 260.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"date\\\", \\\"nightly_rate\\\", \\\"taxes\\\", \\\"discount\\\", \\\"total_for_night\\\"]\\n      },\\n      \\\"PricingBreakdown\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Complete pricing details including breakdown per night and total\\\",\\n        \\\"properties\\\": {\\n          \\\"nights\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of pricing details for each night\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/NightlyPricing\\\" },\\n            \\\"example\\\": [\\n              {\\n                \\\"date\\\": \\\"2024-07-01\\\",\\n                \\\"nightly_rate\\\": 250.0,\\n                \\\"taxes\\\": 25.0,\\n                \\\"discount\\\": 15.0,\\n                \\\"total_for_night\\\": 260.0\\n              },\\n              {\\n                \\\"date\\\": \\\"2024-07-02\\\",\\n                \\\"nightly_rate\\\": 250.0,\\n                \\\"taxes\\\": 25.0,\\n                \\\"discount\\\": 0.0,\\n                \\\"total_for_night\\\": 275.0\\n              }\\n            ]\\n          },\\n          \\\"total_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Aggregate total price for entire stay\\\",\\n            \\\"example\\\": 535.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"nights\\\", \\\"total_price\\\"]\\n      },\\n      \\\"HotelReservationResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response containing reservation details including room and pricing\\\",\\n        \\\"properties\\\": {\\n          \\\"reservation_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the reservation\\\",\\n            \\\"example\\\": \\\"res_12345\\\"\\n          },\\n          \\\"room_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type or category of the reserved room\\\",\\n            \\\"example\\\": \\\"Deluxe Suite\\\"\\n          },\\n          \\\"pricing_breakdown\\\": { \\\"$ref\\\": \\\"#/components/schemas/PricingBreakdown\\\" },\\n          \\\"requested_amenities\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of additional requested amenities\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Amenity requested by the guest\\\",\\n              \\\"example\\\": \\\"crib\\\"\\n            },\\n            \\\"example\\\": [\\\"crib\\\", \\\"extra_bed\\\"]\\n          }\\n        },\\n        \\\"required\\\": [\\\"reservation_id\\\", \\\"room_type\\\", \\\"pricing_breakdown\\\", \\\"requested_amenities\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
