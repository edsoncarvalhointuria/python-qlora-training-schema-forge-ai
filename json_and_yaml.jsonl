\\"\\n          },\\n          \\\"passport_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's passport number\\\",\\n            \\\"example\\\": \\\"M12345678\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"passenger_id\\\", \\\"first_name\\\", \\\"last_name\\\", \\\"passport_number\\\"]\\n      },\\n      \\\"Layover\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a layover stop in the itinerary\\\",\\n        \\\"properties\\\": {\\n          \\\"location\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Airport code of the layover location\\\",\\n            \\\"example\\\": \\\"ORD\\\"\\n          },\\n          \\\"arrival_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Arrival time at the layover airport\\\",\\n            \\\"example\\\": \\\"2024-07-15T10:30:00Z\\\"\\n          },\\n          \\\"departure_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Departure time from the layover airport\\\",\\n            \\\"example\\\": \\\"2024-07-15T11:15:00Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"location\\\", \\\"arrival_time\\\", \\\"departure_time\\\"]\\n      },\\n      \\\"Itinerary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Flight itinerary details including layovers\\\",\\n        \\\"properties\\\": {\\n          \\\"origin\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Starting airport code\\\",\\n            \\\"example\\\": \\\"JFK\\\"\\n          },\\n          \\\"destination\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Final destination airport code\\\",\\n            \\\"example\\\": \\\"LAX\\\"\\n          },\\n          \\\"departure_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled departure date and time\\\",\\n            \\\"example\\\": \\\"2024-07-15T08:00:00Z\\\"\\n          },\\n          \\\"arrival_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled arrival date and time\\\",\\n            \\\"example\\\": \\\"2024-07-15T14:30:00Z\\\"\\n          },\\n          \\\"layovers\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of layover stops on the flight\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/Layover\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"origin\\\", \\\"destination\\\", \\\"departure_date\\\", \\\"arrival_date\\\", \\\"layovers\\\"]\\n      },\\n      \\\"SeatUpgrade\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a seat upgrade selection\\\",\\n        \\\"properties\\\": {\\n          \\\"segment\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Flight segment for the seat upgrade\\\",\\n            \\\"example\\\": \\\"JFK to ORD\\\"\\n          },\\n          \\\"seat_class\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Class of the upgraded seat\\\",\\n            \\\"example\\\": \\\"Business\\\"\\n          },\\n          \\\"price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Cost of the seat upgrade\\\",\\n            \\\"example\\\": 150.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"segment\\\", \\\"seat_class\\\", \\\"price\\\"]\\n      },\\n      \\\"FlightBookingConfirmation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Complete flight booking confirmation details\\\",\\n        \\\"properties\\\": {\\n          \\\"booking_reference\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique booking reference code\\\",\\n            \\\"example\\\": \\\"ABC123XYZ\\\"\\n          },\\n          \\\"passenger\\\": { \\\"$ref\\\": \\\"#/components/schemas/Passenger\\\" },\\n          \\\"itinerary\\\": { \\\"$ref\\\": \\\"#/components/schemas/Itinerary\\\" },\\n          \\\"seat_upgrades\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of selected seat upgrades\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/SeatUpgrade\\\" }\\n          },\\n          \\\"meal_preferences\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of selected meal preferences\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Meal preference option\\\",\\n              \\\"example\\\": \\\"Vegetarian\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"booking_reference\\\", \\\"passenger\\\", \\\"itinerary\\\", \\\"seat_upgrades\\\", \\\"meal_preferences\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"property_id\": \"PROP123456\",\n    \"address\": {\n      \"street\": \"1234 Elm Street\",\n      \"city\": \"Springfield\",\n      \"state\": \"IL\",\n      \"zip_code\": \"62704\"\n    },\n    \"architectural_specs\": {\n      \"year_built\": 1998,\n      \"square_feet\": 2850,\n      \"bedrooms\": 4,\n      \"bathrooms\": 3,\n      \"has_fireplace\": true,\n      \"heating_type\": \"Central\",\n      \"cooling_type\": \"Central Air\"\n    },\n    \"images\": [\n      {\n        \"description\": \"Front view of the property\",\n        \"urls\": [\n          \"https://example.com/images/property123_front_1.jpg\",\n          \"https://example.com/images/property123_front_2.jpg\"\n        ]\n      },\n      {\n        \"description\": \"Living room interior\",\n        \"urls\": [\n          \"https://example.com/images/property123_livingroom_1.jpg\",\n          \"https://example.com/images/property123_livingroom_2.jpg\"\n        ]\n      }\n    ],\n    \"realtor_contact\": {\n      \"name\": \"Jane Doe\",\n      \"phone\": \"+1-555-123-4567\",\n      \"email\": \"jane.doe@realestateco.com\",\n      \"license_number\": \"RE123456789\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Real Estate Property Listing\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Address:\\n      type: object\\n      description: 'Physical address of the property'\\n      properties:\\n        street:\\n          type: string\\n          description: 'Street address'\\n          example: '1234 Elm Street'\\n        city:\\n          type: string\\n          description: 'City where the property is located'\\n          example: 'Springfield'\\n        state:\\n          type: string\\n          description: 'State of the property location'\\n          example: 'IL'\\n        zip_code:\\n          type: string\\n          description: 'Postal code'\\n          example: '62704'\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Architectural specifications of the property'\\n      properties:\\n        year_built:\\n          type: integer\\n          description: 'The year the property was built'\\n          example: 1998\\n        square_feet:\\n          type: integer\\n          description: 'Total living space area in square feet'\\n          example: 2850\\n        bedrooms:\\n          type: integer\\n          description: 'Number of bedrooms'\\n          example: 4\\n        bathrooms:\\n          type: integer\\n          description: 'Number of bathrooms'\\n          example: 3\\n        has_fireplace:\\n          type: boolean\\n          description: 'Indicates if the property has a fireplace'\\n          example: true\\n        heating_type:\\n          type: string\\n          description: 'Type of heating system'\\n          example: 'Central'\\n        cooling_type:\\n          type: string\\n          description: 'Type of cooling system'\\n          example: 'Central Air'\\n    ImageUrls:\\n      type: object\\n      description: 'High-resolution image URLs and description'\\n      properties:\\n        description:\\n          type: string\\n          description: 'Description of the image subject'\\n          example: 'Front view of the property'\\n        urls:\\n          type: array\\n          description: 'Array of URLs to high-resolution images'\\n          items:\\n            type: string\\n            format: uri\\n            example: 'https://example.com/images/property123_front_1.jpg'\\n    RealtorContact:\\n      type: object\\n      description: 'Contact information of the assigned realtor'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Full name of the realtor'\\n          example: 'Jane Doe'\\n        phone:\\n          type: string\\n          description: 'Phone number with country code'\\n          example: '+1-555-123-4567'\\n        email:\\n          type: string\\n          format: email\\n          description: 'Email address of the realtor'\\n          example: 'jane.doe@realestateco.com'\\n        license_number:\\n          type: string\\n          description: 'Real estate license number'\\n          example: 'RE123456789'\\n    PropertyListing:\\n      type: object\\n      description: 'Comprehensive real estate property listing'\\n      properties:\\n        property_id:\\n          type: string\\n          description: 'Unique identifier for the property'\\n          example: 'PROP123456'\\n        address:\\n          $ref: '#/components/schemas/Address'\\n        architectural_specs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n          description: 'Array of image groups with descriptions and URLs'\\n          items:\\n            $ref: '#/components/schemas/ImageUrls'\\n        realtor_contact:\\n          $ref: '#/components/schemas/RealtorContact'\\n\"\n}"
