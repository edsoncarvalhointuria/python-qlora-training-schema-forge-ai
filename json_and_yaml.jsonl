\\\"]\\n      },\\n      \\\"CustomsClearance\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Status do despacho aduaneiro do contêiner\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Status atual da liberação na alfândega\\\",\\n            \\\"example\\\": \\\"Cleared\\\"\\n          },\\n          \\\"inspection_required\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indica se uma inspeção adicional foi requisitada\\\",\\n            \\\"example\\\": false\\n          },\\n          \\\"inspection_details\\\": {\\n            \\\"type\\\": [\\\"string\\\", \\\"null\\\"],\\n            \\\"description\\\": \\\"Detalhes da inspeção, se aplicável\\\",\\n            \\\"example\\\": null\\n          }\\n        },\\n        \\\"required\\\": [\\\"status\\\", \\\"inspection_required\\\", \\\"inspection_details\\\"]\\n      },\\n      \\\"EnvironmentalReading\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Leitura ambiental registrada dentro do contêiner\\\",\\n        \\\"properties\\\": {\\n          \\\"type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo de leitura ambiental\\\",\\n            \\\"example\\\": \\\"temperature\\\"\\n          },\\n          \\\"value\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"description\\\": \\\"Valor da leitura ambiental\\\",\\n            \\\"example\\\": 5.5\\n          },\\n          \\\"unit\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unidade de medida da leitura\\\",\\n            \\\"example\\\": \\\"Celsius\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora em que a leitura foi registrada\\\",\\n            \\\"example\\\": \\\"2024-06-16T10:00:00Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"type\\\", \\\"value\\\", \\\"unit\\\", \\\"timestamp\\\"]\\n      },\\n      \\\"ContainerTrackingResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta contendo informações de rastreamento do contêiner\\\",\\n        \\\"properties\\\": {\\n          \\\"container_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do contêiner\\\",\\n            \\\"example\\\": \\\"CONT1234567\\\"\\n          },\\n          \\\"current_location\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Location\\\"\\n          },\\n          \\\"customs_clearance\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/CustomsClearance\\\"\\n          },\\n          \\\"environmental_readings\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de leituras ambientais registradas dentro do contêiner\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/EnvironmentalReading\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"container_id\\\", \\\"current_location\\\", \\\"customs_clearance\\\", \\\"environmental_readings\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"order_id\": \"ORD123456\",\n    \"status\": \"Out for delivery\",\n    \"courier\": {\n      \"courier_id\": \"CR7890\",\n      \"name\": \"John Doe\",\n      \"real_time_location\": {\n        \"latitude\": 40.712776,\n        \"longitude\": -74.005974,\n        \"timestamp\": \"2024-06-01T14:30:00Z\"\n      }\n    },\n    \"restaurant\": {\n      \"restaurant_id\": \"RST4567\",\n      \"name\": \"Green Garden\",\n      \"address\": \"123 Healthy Ave, New York, NY\",\n      \"rating\": 4.5,\n      \"phone_number\": \"+1-555-123-4567\"\n    },\n    \"ordered_dishes\": [\n      {\n        \"dish_id\": \"DISH001\",\n        \"name\": \"Quinoa Salad\",\n        \"quantity\": 1,\n        \"special_dietary_notes\": \"Gluten-free, Vegan\"\n      },\n      {\n        \"dish_id\": \"DISH002\",\n        \"name\": \"Grilled Chicken Wrap\",\n        \"quantity\": 2,\n        \"special_dietary_notes\": \"High protein\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Food Delivery Order Status\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Location:\\n      type: object\\n      description: 'Real-time location data with coordinates and timestamp'\\n      properties:\\n        latitude:\\n          type: number\\n          format: float\\n          description: 'Latitude coordinate of the courier location'\\n          example: 40.712776\\n        longitude:\\n          type: number\\n          format: float\\n          description: 'Longitude coordinate of the courier location'\\n          example: -74.005974\\n        timestamp:\\n          type: string\\n          format: date-time\\n          description: 'Timestamp when the location was recorded in UTC'\\n          example: '2024-06-01T14:30:00Z'\\n    Courier:\\n      type: object\\n      description: 'Details about the courier handling the order'\\n      properties:\\n        courier_id:\\n          type: string\\n          description: 'Unique identifier for the courier'\\n          example: 'CR7890'\\n        name:\\n          type: string\\n          description: 'Full name of the courier'\\n          example: 'John Doe'\\n        real_time_location:\\n          $ref: '#/components/schemas/Location'\\n    Restaurant:\\n      type: object\\n      description: 'Profile details of the restaurant fulfilling the order'\\n      properties:\\n        restaurant_id:\\n          type: string\\n          description: 'Unique identifier of the restaurant'\\n          example: 'RST4567'\\n        name:\\n          type: string\\n          description: 'Name of the restaurant'\\n          example: 'Green Garden'\\n        address:\\n          type: string\\n          description: 'Physical address of the restaurant'\\n          example: '123 Healthy Ave, New York, NY'\\n        rating:\\n          type: number\\n          format: float\\n          description: 'Average customer rating of the restaurant'\\n          example: 4.5\\n        phone_number:\\n          type: string\\n          description: 'Contact phone number of the restaurant'\\n          example: '+1-555-123-4567'\\n    Dish:\\n      type: object\\n      description: 'Details of a single ordered dish including special dietary notes'\\n      properties:\\n        dish_id:\\n          type: string\\n          description: 'Unique identifier for the dish'\\n          example: 'DISH001'\\n        name:\\n          type: string\\n          description: 'Name of the dish ordered'\\n          example: 'Quinoa Salad'\\n        quantity:\\n          type: integer\\n          description: 'Quantity of this dish ordered'\\n          example: 1\\n        special_dietary_notes:\\n          type: string\\n          description: 'Special dietary information or notes regarding the dish'\\n          example: 'Gluten-free, Vegan'\\n    OrderStatus:\\n      type: object\\n      description: 'Current status of a food delivery order including courier location, restaurant profile, and ordered dishes'\\n      properties:\\n        order_id:\\n          type: string\\n          description: 'Unique identifier for the order'\\n          example: 'ORD123456'\\n        status:\\n          type: string\\n          description: 'Current status of the order'\\n          example: 'Out for delivery'\\n        courier:\\n          $ref: '#/components/schemas/Courier'\\n        restaurant:\\n          $ref: '#/components/schemas/Restaurant'\\n        ordered_dishes:\\n          type: array\\n          description: 'List of dishes ordered'\\n          items:\\n            $ref: '#/components/schemas/Dish'\"\n}"
