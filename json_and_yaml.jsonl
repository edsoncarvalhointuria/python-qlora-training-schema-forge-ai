ct\\\",\\n        \\\"description\\\": \\\"Estado detalhado da bateria do veículo\\\",\\n        \\\"properties\\\": {\\n          \\\"voltage\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Tensão atual da bateria em volts\\\",\\n            \\\"example\\\": 367.5\\n          },\\n          \\\"temperature_celsius\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Temperatura da bateria em graus Celsius\\\",\\n            \\\"example\\\": 35\\n          },\\n          \\\"charge_percentage\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Porcentagem de carga restante na bateria\\\",\\n            \\\"example\\\": 87\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Status atual da bateria\\\",\\n            \\\"example\\\": \\\"Normal\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"voltage\\\", \\\"temperature_celsius\\\", \\\"charge_percentage\\\", \\\"status\\\"]\\n      },\\n      \\\"DrivingAnomaly\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Registro de uma anomalia detectada durante a condução\\\",\\n        \\\"properties\\\": {\\n          \\\"anomaly_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único da anomalia\\\",\\n            \\\"example\\\": \\\"anom_001\\\"\\n          },\\n          \\\"type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo da anomalia\\\",\\n            \\\"example\\\": \\\"Sudden Braking\\\"\\n          },\\n          \\\"severity\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nível de gravidade da anomalia\\\",\\n            \\\"example\\\": \\\"Moderate\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Momento em que a anomalia foi detectada\\\",\\n            \\\"example\\\": \\\"2024-06-20T15:44:10Z\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Descrição detalhada da anomalia\\\",\\n            \\\"example\\\": \\\"Veículo freou bruscamente para evitar colisão\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"anomaly_id\\\", \\\"type\\\", \\\"severity\\\", \\\"timestamp\\\", \\\"description\\\"]\\n      },\\n      \\\"TelemetryPing\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Pacote de telemetria enviado pelo veículo autônomo\\\",\\n        \\\"properties\\\": {\\n          \\\"vehicle_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do veículo\\\",\\n            \\\"example\\\": \\\"veh_987\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Momento do registro do ping\\\",\\n            \\\"example\\\": \\\"2024-06-20T15:45:30Z\\\"\\n          },\\n          \\\"location\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Location\\\"\\n          },\\n          \\\"speed_kmh\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Velocidade atual do veículo em km/h\\\",\\n            \\\"example\\\": 65.5\\n          },\\n          \\\"battery_health\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BatteryHealth\\\"\\n          },\\n          \\\"driving_anomalies\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista recente de anomalias detectadas na condução\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/DrivingAnomaly\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"vehicle_id\\\", \\\"timestamp\\\", \\\"location\\\", \\\"speed_kmh\\\", \\\"battery_health\\\", \\\"driving_anomalies\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
