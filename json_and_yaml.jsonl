"{\n  \"raw_json\": {\n    \"anatomicalToothChart\": {\n      \"toothNumber\": \"14\",\n      \"status\": \"filled\",\n      \"notes\": \"Large filling on occlusal surface\"\n    },\n    \"pastProcedures\": [\n      {\n        \"procedureType\": \"root_canal\",\n        \"datePerformed\": \"2023-11-15\",\n        \"dentist\": \"Dr. Alice Smith\",\n        \"notes\": \"Procedure successful with no complications\"\n      },\n      {\n        \"procedureType\": \"crown_placement\",\n        \"datePerformed\": \"2024-01-10\",\n        \"dentist\": \"Dr. Bob Lee\",\n        \"notes\": \"Temporary crown replaced with permanent\"\n      }\n    ],\n    \"upcomingScheduledCleanings\": {\n      \"nextCleaningDate\": \"2024-07-20\",\n      \"reminderSent\": true,\n      \"metadata\": {\n        \"cleaningType\": \"deep_cleaning\",\n        \"estimatedDurationMinutes\": 60,\n        \"location\": \"Room 3\"\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Dental Clinic Patient History\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AnatomicalToothChart:\\n      type: object\\n      description: 'Details about a specific tooth in the anatomical tooth chart'\\n      properties:\\n        toothNumber:\\n          type: string\\n          description: 'The number identifier of the tooth'\\n          example: '14'\\n        status:\\n          type: string\\n          description: 'The current condition or status of the tooth'\\n          example: 'filled'\\n        notes:\\n          type: string\\n          description: 'Additional notes related to the tooth'\\n          example: 'Large filling on occlusal surface'\\n    PastProcedure:\\n      type: object\\n      description: 'Information about a past dental procedure performed on the patient'\\n      properties:\\n        procedureType:\\n          type: string\\n          description: 'The type of dental procedure'\\n          example: 'root_canal'\\n        datePerformed:\\n          type: string\\n          format: date\\n          description: 'The date when the procedure was performed'\\n          example: '2023-11-15'\\n        dentist:\\n          type: string\\n          description: 'Name of the dentist who performed the procedure'\\n          example: 'Dr. Alice Smith'\\n        notes:\\n          type: string\\n          description: 'Additional notes about the procedure'\\n          example: 'Procedure successful with no complications'\\n    UpcomingCleaningMetadata:\\n      type: object\\n      description: 'Additional information regarding the upcoming scheduled cleaning'\\n      properties:\\n        cleaningType:\\n          type: string\\n          description: 'Type of cleaning scheduled'\\n          example: 'deep_cleaning'\\n        estimatedDurationMinutes:\\n          type: integer\\n          description: 'Estimated duration of the cleaning in minutes'\\n          example: 60\\n        location:\\n          type: string\\n          description: 'Location where the cleaning will take place'\\n          example: 'Room 3'\\n    UpcomingScheduledCleanings:\\n      type: object\\n      description: 'Information about upcoming scheduled dental cleanings with metadata'\\n      properties:\\n        nextCleaningDate:\\n          type: string\\n          format: date\\n          description: 'Date of the next scheduled cleaning'\\n          example: '2024-07-20'\\n        reminderSent:\\n          type: boolean\\n          description: 'Indicator if a reminder has been sent for the cleaning'\\n          example: true\\n        metadata:\\n          $ref: '#/components/schemas/UpcomingCleaningMetadata'\\n    PatientHistory:\\n      type: object\\n      description: 'Complete patient history for dental clinic'\\n      properties:\\n        anatomicalToothChart:\\n          $ref: '#/components/schemas/AnatomicalToothChart'\\n        pastProcedures:\\n          type: array\\n          description: 'List of past dental procedures performed on the patient'\\n          items:\\n            $ref: '#/components/schemas/PastProcedure'\\n        upcomingScheduledCleanings:\\n          $ref: '#/components/schemas/UpcomingScheduledCleanings'\\n\"\n}"
