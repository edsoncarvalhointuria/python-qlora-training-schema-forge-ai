   description: 'Identificador do mapa de piso do local de coworking'\\n          example: 'fp_12'\\n        occupied_hot_desks:\\n          type: array\\n          description: 'Lista de hot-desks atualmente ocupadas'\\n          items:\\n            $ref: '#/components/schemas/OccupiedHotDesk'\\n        meeting_room_reservations:\\n          type: array\\n          description: 'Lista de reservas futuras para salas de reunião'\\n          items:\\n            $ref: '#/components/schemas/MeetingRoomReservation'\\n  \"\n}"
"{\n  \"raw_json\": {\n    \"course_title\": \"Introduction to Computer Science\",\n    \"professor\": {\n      \"name\": \"Dr. Ana Pereira\",\n      \"academic_background\": \"Ph.D. in Computer Science, Universidade de São Paulo\",\n      \"email\": \"ana.pereira@univ.br\"\n    },\n    \"weekly_modules\": [\n      {\n        \"week\": 1,\n        \"title\": \"Foundations of Computing\",\n        \"topics\": [\n          \"History of computing\",\n          \"Basic computer architecture\"\n        ],\n        \"reading_list\": [\n          {\n            \"title\": \"Computer Science: An Overview\",\n            \"author\": \"J. Glenn Brookshear\",\n            \"edition\": \"12th\",\n            \"isbn\": \"9780134875460\"\n          }\n        ]\n      },\n      {\n        \"week\": 2,\n        \"title\": \"Programming Basics\",\n        \"topics\": [\n          \"Variables and data types\",\n          \"Control structures\"\n        ],\n        \"reading_list\": [\n          {\n            \"title\": \"Programming in C\",\n            \"author\": \"Stephen G. Kochan\",\n            \"edition\": \"4th\",\n            \"isbn\": \"9780321776418\"\n          }\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"University Course Syllabus Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Professor\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações acadêmicas e contato do professor\\\",\\n        \\\"properties\\\": {\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome completo do professor\\\",\\n            \\\"example\\\": \\\"Dr. Ana Pereira\\\"\\n          },\\n          \\\"academic_background\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Formação acadêmica detalhada do professor\\\",\\n            \\\"example\\\": \\\"Ph.D. in Computer Science, Universidade de São Paulo\\\"\\n          },\\n          \\\"email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Endereço de e-mail para contato\\\",\\n            \\\"example\\\": \\\"ana.pereira@univ.br\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"name\\\", \\\"academic_background\\\", \\\"email\\\"]\\n      },\\n      \\\"Textbook\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes do livro didático requerido para o módulo\\\",\\n        \\\"properties\\\": {\\n          \\\"title\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Título do livro\\\",\\n            \\\"example\\\": \\\"Computer Science: An Overview\\\"\\n          },\\n          \\\"author\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome do autor do livro\\\",\\n            \\\"example\\\": \\\"J. Glenn Brookshear\\\"\\n          },\\n          \\\"edition\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Edição do livro\\\",\\n            \\\"example\\\": \\\"12th\\\"\\n          },\\n          \\\"isbn\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código ISBN para identificação do livro\\\",\\n            \\\"example\\\": \\\"9780134875460\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"title\\\", \\\"author\\\", \\\"edition\\\", \\\"isbn\\\"]\\n      },\\n      \\\"WeeklyModule\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações detalhadas do módulo semanal do curso\\\",\\n        \\\"properties\\\": {\\n          \\\"week\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Número da semana no cronograma\\\",\\n            \\\"example\\\": 1\\n  