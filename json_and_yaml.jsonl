          \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's first name\\\",\\n            \\\"example\\\": \\\"Emily\\\"\\n          },\\n          \\\"last_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's last name\\\",\\n            \\\"example\\\": \\\"Smith\\\"\\n          },\\n          \\\"email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"Passenger's email address\\\",\\n            \\\"example\\\": \\\"emily.smith@example.com\\\"\\n          },\\n          \\\"phone\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's phone number\\\",\\n            \\\"example\\\": \\\"+14155551234\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"first_name\\\", \\\"last_name\\\", \\\"email\\\", \\\"phone\\\"]\\n      },\\n      \\\"Layover\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about a flight layover\\\",\\n        \\\"properties\\\": {\\n          \\\"airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"IATA code of the layover airport\\\",\\n            \\\"example\\\": \\\"ORD\\\"\\n          },\\n          \\\"arrival_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled arrival time at layover airport\\\",\\n            \\\"example\\\": \\\"2024-07-01T10:30:00-05:00\\\"\\n          },\\n          \\\"departure_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled departure time from layover airport\\\",\\n            \\\"example\\\": \\\"2024-07-01T11:00:00-05:00\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"airport\\\", \\\"arrival_time\\\", \\\"departure_time\\\"]\\n      },\\n      \\\"Flight\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Flight details including times and layovers\\\",\\n        \\\"properties\\\": {\\n          \\\"flight_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique flight identifier\\\",\\n            \\\"example\\\": \\\"AA123\\\"\\n          },\\n          \\\"departure_airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"IATA code of departure airport\\\",\\n            \\\"example\\\": \\\"JFK\\\"\\n          },\\n          \\\"arrival_airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"IATA code of arrival airport\\\",\\n            \\\"example\\\": \\\"LAX\\\"\\n          },\\n          \\\"departure_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled flight departure time\\\",\\n            \\\"example\\\": \\\"2024-07-01T09:00:00-04:00\\\"\\n          },\\n          \\\"arrival_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled flight arrival time\\\",\\n            \\\"example\\\": \\\"2024-07-01T12:00:00-07:00\\\"\\n          },\\n          \\\"layovers\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of layover stops during this flight segment\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Layover\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"flight_number\\\", \\\"departure_airport\\\", \\\"arrival_airport\\\", \\\"departure_time\\\", \\\"arrival_time\\\", \\\"layovers\\\"]\\n      },\\n      \\\"Itinerary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Overall flight itinerary including multiple flights\\\",\\n        \\\"properties\\\": {\\n          \\\"flights\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of flight segments in the itinerary\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Flight\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"flights\\\"]\\n      },\\n      \\\"SeatUpgrade\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Selected seat upgrade information for a flight\\\",\\n        \\\"properties\\\": {\\n          \\\"flight_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Flight number the seat upgrade applies to\\\",\\n            \\\"example\\\": \\\"AA123\\\"\\n          },\\n          \\\"seat_class\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Class of the upgraded seat\\\",\\n            \\\"example\\\": \\\"Business\\\"\\n          },\\n          \\\"seat_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Assigned seat number for the upgrade\\\",\\n            \\\"example\\\": \\\"3A\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"flight_number\\\", \\\"seat_class\\\", \\\"seat_number\\\"]\\n      },\\n      \\\"MealPreference\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Meal preference selected by the passenger for a flight\\\",\\n        \\\"properties\\\": {\\n          \\\"flight_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Flight number the meal preference applies to\\\",\\n            \\\"example\\\": \\\"AA123\\\"\\n          },\\n          \\\"meal_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of meal chosen\\\",\\n            \\\"example\\\": \\\"Vegetarian\\\"\\n          },\\n          \\\"notes\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Additional notes or dietary restrictions\\\",\\n            \\\"example\\\": \\\"No nuts\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"flight_number\\\", \\\"meal_type\\\", \\\"notes\\\"]\\n      },\\n      \\\"FlightBookingConfirmation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Airline flight booking confirmation response\\\",\\n        \\\"properties\\\": {\\n          \\\"booking_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique booking identifier\\\",\\n            \\\"example\\\": \\\"BK20240615XY\\\"\\n          },\\n          \\\"passenger\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Passenger\\\"\\n          },\\n          \\\"itinerary\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Itinerary\\\"\\n          },\\n          \\\"seat_upgrades\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of seat upgrades selected\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/SeatUpgrade\\\"\\n            }\\n          },\\n          \\\"meal_preferences\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of meal preferences selected\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/MealPreference\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"booking_id\\\", \\\"passenger\\\", \\\"itinerary\\\", \\\"seat_upgrades\\\", \\\"meal_preferences\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"property_id\": \"PR123456\",\n    \"title\": \"Modern Family Home\",\n    \"description\": \"A spacious and modern 4-bedroom family home with an open floor plan.\",\n    \"architectural_specs\": {\n      \"area_sq_meters\": 250,\n      \"num_bedrooms\": 4,\n      \"num_bathrooms\": 3,\n      \"has_garage\": true,\n      \"year_built\": 2019,\n      \"materials\": [\"brick\", \"glass\", \"steel\"]\n    },\n    \"images\": [\n      {\n        \"type\": \"exterior\",\n        \"urls\": [\n          \"https://example.com/images/property123/exterior1_hr.jpg\",\n          \"https://example.com/images/property123/exterior2_hr.jpg\"\n        ]\n      },\n      {\n        \"type\": \"interior\",\n        \"urls\": [\n          \"https://example.com/images/property123/interior1_hr.jpg\",\n          \"https://example.com/images/property123/interior2_hr.jpg\",\n          \"https://example.com/images/property123/interior3_hr.jpg\"\n        ]\n      }\n    ],\n    \"realtor\": {\n      \"name\": \"Carlos Silva\",\n      \"phone\": \"+55 11 91234-5678\",\n      \"email\": \"carlos.silva@realestate.com.br\",\n      \"office_address\": {\n        \"street\": \"Av. Paulista, 1000\",\n        \"city\": \"São Paulo\",\n        \"state\": \"SP\",\n        \"postal_code\": \"01310-100\"\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Propriedade Imobiliária\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Especificações arquitetônicas detalhadas da propriedade'\\n      properties:\\n        area_sq_meters:\\n          type: integer\\n          description: 'Área total da propriedade em metros quadrados'\\n          example: 250\\n        num_bedrooms:\\n          type: integer\\n          description: 'Número de quartos'\\n          example: 4\\n        num_bathrooms:\\n          type: integer\\n          description: 'Número de banheiros'\\n          example: 3\\n        has_garage:\\n          type: boolean\\n          description: 'Indica se a propriedade possui garagem'\\n          example: true\\n        year_built:\\n          type: integer\\n          description: 'Ano de construção da propriedade'\\n          example: 2019\\n        materials:\\n          type: array\\n          description: 'Materiais predominantes usados na construção'\\n          items:\\n            type: string\\n            example: 'brick'\\n    ImageGroup:\\n      type: object\\n      description: 'Grupo de imagens categorizadas por tipo com URLs de alta resolução'\\n      properties:\\n        type:\\n          type: string\\n          description: 'Categoria ou tipo das imagens'\\n          example: 'exterior'\\n        urls:\\n          type: array\\n          description: 'URLs das imagens em alta resolução'\\n          items:\\n            type: string\\n            format: uri\\n            example: 'https://example.com/images/property123/exterior1_hr.jpg'\\n    OfficeAddress:\\n      type: object\\n      description: 'Endereço do escritório imobiliário'\\n      properties:\\n        street:\\n          type: string\\n          description: 'Logradouro e número'\\n          example: 'Av. Paulista, 1000'\\n        city:\\n          type: string\\n          description: 'Cidade do endereço'\\n          example: 'São Paulo'\\n        state:\\n          type: string\\n          description: 'Estado'\\n          example: 'SP'\\n        postal_code:\\n          type: string\\n          description: 'Código postal'\\n          example: '01310-100'\\n    Realtor:\\n      type: object\\n      description: 'Informações de contato do corretor de imóveis'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Nome completo do corretor'\\n          example: 'Carlos Silva'\\n        phone:\\n          type: string\\n          description: 'Número de telefone do corretor'\\n          example: '+55 11 91234-5678'\\n        email:\\n          type: string\\n          format: email\\n          description: 'Email do corretor'\\n          example: 'carlos.silva@realestate.com.br'\\n        office_address:\\n          $ref: '#/components/schemas/OfficeAddress'\\n    PropertyListing:\\n      type: object\\n      description: 'Detalhes completos da lista de propriedades'\\n      properties:\\n        property_id:\\n          type: string\\n          description: 'Identificador único da propriedade'\\n          example: 'PR123456'\\n        title:\\n          type: string\\n          description: 'Título resumido da propriedade'\\n          example: 'Modern Family Home'\\n        description:\\n          type: string\\n          description: 'Descrição detalhada da propriedade'\\n          example: 'A spacious and modern 4-bedroom family home with an open floor plan.'\\n        architectural_specs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n          description: 'Coleção de grupos de imagens por categoria'\\n          items:\\n            $ref: '#/components/schemas/ImageGroup'\\n        realtor:\\n          $ref: '#/components/schemas/Realtor'\\n\"\n}"
