"{\n  \"raw_json\": {\n    \"patientId\": \"P123456\",\n    \"toothChart\": {\n      \"teeth\": [\n        {\n          \"toothNumber\": 11,\n          \"condition\": \"Cavity\",\n          \"notes\": \"Needs filling on occlusal surface\"\n        },\n        {\n          \"toothNumber\": 26,\n          \"condition\": \"Healthy\",\n          \"notes\": \"No problems detected\"\n        }\n      ]\n    },\n    \"pastProcedures\": [\n      {\n        \"procedureDate\": \"2023-06-15\",\n        \"procedureType\": \"Filling\",\n        \"toothNumber\": 11,\n        \"dentist\": \"Dr. Alice Smith\"\n      },\n      {\n        \"procedureDate\": \"2022-10-20\",\n        \"procedureType\": \"Cleaning\",\n        \"toothNumber\": null,\n        \"dentist\": \"Dr. Bob Johnson\"\n      }\n    ],\n    \"upcomingSchedules\": {\n      \"nextCleaning\": {\n        \"scheduledDate\": \"2024-07-10\",\n        \"location\": \"Clinic Room 3\",\n        \"reminderSent\": true,\n        \"notes\": \"Patient requested afternoon appointment\"\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Dental Clinic Patient History\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Tooth:\\n      type: object\\n      description: 'Details about an individual tooth and its condition'\\n      properties:\\n        toothNumber:\\n          type: integer\\n          description: 'The numerical identifier of the tooth following dental notation'\\n          example: 11\\n        condition:\\n          type: string\\n          description: 'Current condition or status of the tooth'\\n          example: 'Cavity'\\n        notes:\\n          type: string\\n          description: 'Additional notes about the tooth condition'\\n          example: 'Needs filling on occlusal surface'\\n    ToothChart:\\n      type: object\\n      description: 'Anatomical chart showing details of multiple teeth'\\n      properties:\\n        teeth:\\n          type: array\\n          description: 'Array of teeth with conditions and notes'\\n          items:\\n            $ref: '#/components/schemas/Tooth'\\n    Procedure:\\n      type: object\\n      description: 'Information for a single dental procedure performed in the past'\\n      properties:\\n        procedureDate:\\n          type: string\\n          format: date\\n          description: 'Date when the procedure was performed'\\n          example: '2023-06-15'\\n        procedureType:\\n          type: string\\n          description: 'Type or name of the dental procedure'\\n          example: 'Filling'\\n        toothNumber:\\n          type: integer\\n          nullable: true\\n          description: 'The tooth number involved in the procedure; null if procedure applies generally'\\n          example: 11\\n        dentist:\\n          type: string\\n          description: 'Name of the dentist who performed the procedure'\\n          example: 'Dr. Alice Smith'\\n    UpcomingCleaning:\\n      type: object\\n      description: 'Metadata for the patient\\\\'s next scheduled cleaning'\\n      properties:\\n        scheduledDate:\\n          type: string\\n          format: date\\n          description: 'Date when the cleaning is scheduled'\\n          example: '2024-07-10'\\n        location:\\n          type: string\\n          description: 'Location or room where the cleaning will take place'\\n          example: 'Clinic Room 3'\\n        reminderSent:\\n          type: boolean\\n          description: 'Indicates whether a reminder has been sent to the patient'\\n          example: true\\n        notes:\\n          type: string\\n          description: 'Additional notes or requests related to the upcoming cleaning'\\n          example: 'Patient requested afternoon appointment'\\n    UpcomingSchedules:\\n      type: object\\n      description: 'Container for future scheduled dental appointments'\\n      properties:\\n        nextCleaning:\\n          $ref: '#/components/schemas/UpcomingCleaning'\\n    PatientHistory:\\n      type: object\\n      description: 'Root schema for the dental clinic patient history'\\n      properties:\\n        patientId:\\n          type: string\\n          description: 'Unique identifier for the patient'\\n          example: 'P123456'\\n        toothChart:\\n          $ref: '#/components/schemas/ToothChart'\\n        pastProcedures:\\n          type: array\\n          description: 'List of past dental procedures for the patient'\\n          items:\\n            $ref: '#/components/schemas/Procedure'\\n        upcomingSchedules:\\n          $ref: '#/components/schemas/UpcomingSchedules'\\npaths: {}\\n\"\n}"
