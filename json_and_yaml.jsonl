      format: uri\\n          description: 'URL para o recurso do vídeo'\\n          example: 'https://news.example.com/videos/renewable_intro.mp4'\\n        caption:\\n          type: string\\n          description: 'Legenda do vídeo'\\n          example: 'Entrevista com especialistas em energia'\\n        duration_seconds:\\n          type: integer\\n          description: 'Duração do vídeo em segundos'\\n          example: 240\\n    MultimediaAsset:\\n      oneOf:\\n        - $ref: '#/components/schemas/MultimediaImage'\\n        - $ref: '#/components/schemas/MultimediaVideo'\\n      description: 'Ativo multimídia, que pode ser imagem ou vídeo'\\n    Article:\\n      type: object\\n      description: 'Estrutura completa do artigo da publicação digital'\\n      properties:\\n        headline:\\n          type: string\\n          description: 'Título principal do artigo'\\n          example: 'Innovations in Renewable Energy in 2024'\\n        author_byline:\\n          type: string\\n          description: 'Nome do autor do artigo'\\n          example: 'Carlos Silva'\\n        multimedia_assets:\\n          type: array\\n          description: 'Lista de ativos multimídia incorporados no artigo'\\n          items:\\n            $ref: '#/components/schemas/MultimediaAsset'\\n        related_tags:\\n          type: array\\n          description: 'Etiquetas relacionadas ao conteúdo do artigo'\\n          items:\\n            type: string\\n            example: 'renewable energy'\\n\"\n}"
