ero de identificação do cidadão\\\",\\n            \\\"example\\\": \\\"12345678900\\\"\\n          },\\n          \\\"declared_income\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Rendimento declarado pelo cidadão\\\",\\n            \\\"example\\\": 85000.75\\n          },\\n          \\\"deductions\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista das deduções válidas declaradas\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Deduction\\\"\\n            }\\n          },\\n          \\\"final_tax_status\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/TaxStatus\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"citizen_id\\\", \\\"declared_income\\\", \\\"deductions\\\", \\\"final_tax_status\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
