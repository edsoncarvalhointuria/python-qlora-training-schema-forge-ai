tion, and pedestrian alerts'\\n      properties:\\n        intersection_id:\\n          type: string\\n          description: 'Unique identifier for the intersection being monitored'\\n          example: 'INT_1024'\\n        congestion_level:\\n          type: string\\n          description: 'Current congestion level at the intersection'\\n          example: 'High'\\n        vehicles_detected:\\n          type: array\\n          description: 'List of vehicle types detected at the intersection with counts'\\n          items:\\n            $ref: '#/components/schemas/VehicleDetection'\\n        pedestrian_crossing_alerts:\\n          type: array\\n          description: 'Active pedestrian crossing alerts for crosswalks at the intersection'\\n          items:\\n            $ref: '#/components/schemas/PedestrianCrossingAlert'\\n\"\n}"
