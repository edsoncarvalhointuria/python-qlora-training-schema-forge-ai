rature\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Temperatura registrada naquele momento em graus Celsius\\\",\\n            \\\"example\\\": 21.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"timestamp\\\", \\\"temperature\\\"]\\n      },\\n      \\\"ThermostatStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Status atual do termostato inteligente incluindo temperaturas e estado do dispositivo\\\",\\n        \\\"properties\\\": {\\n          \\\"current_temperature\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Temperatura atual medida pelo termostato em graus Celsius\\\",\\n            \\\"example\\\": 22.5\\n          },\\n          \\\"target_temperature\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Temperatura alvo configurada para o termostato\\\",\\n            \\\"example\\\": 24.0\\n          },\\n          \\\"device_health\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DeviceHealth\\\"\\n          },\\n          \\\"usage_history\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de registros históricos de temperatura\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/UsageEntry\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"current_temperature\\\", \\\"target_temperature\\\", \\\"device_health\\\", \\\"usage_history\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
