    \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"Billing cycle start date\\\",\\n            \\\"example\\\": \\\"2024-06-01\\\"\\n          },\\n          \\\"end_date\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date\\\",\\n            \\\"description\\\": \\\"Billing cycle end date\\\",\\n            \\\"example\\\": \\\"2024-06-30\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"start_date\\\", \\\"end_date\\\"]\\n      },\\n      \\\"TaxBreakdown\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Tax details applied on invoice\\\",\\n        \\\"properties\\\": {\\n          \\\"tax_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of tax\\\",\\n            \\\"example\\\": \\\"VAT\\\"\\n          },\\n          \\\"tax_rate\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Tax rate as a decimal\\\",\\n            \\\"example\\\": 0.2\\n          },\\n          \\\"tax_amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Calculated tax amount\\\",\\n            \\\"example\\\": 40.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"tax_type\\\", \\\"tax_rate\\\", \\\"tax_amount\\\"]\\n      },\\n      \\\"DiscountCoupon\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of discount coupons applied\\\",\\n        \\\"properties\\\": {\\n          \\\"code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Coupon code\\\",\\n            \\\"example\\\": \\\"WELCOME10\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Description of the discount\\\",\\n            \\\"example\\\": \\\"10% off for new customers\\\"\\n          },\\n          \\\"amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Discount amount applied\\\",\\n            \\\"example\\\": 20.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"code\\\", \\\"description\\\", \\\"amount\\\"]\\n      },\\n      \\\"SubscriptionInvoice\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Structure representing a SaaS subscription invoice\\\",\\n        \\\"properties\\\": {\\n          \\\"invoice_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique invoice identifier\\\",\\n            \\\"example\\\": \\\"inv_20240601_001\\\"\\n          },\\n          \\\"billing_cycle\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BillingCycle\\\"\\n          },\\n          \\\"company\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Company\\\"\\n          },\\n          \\\"taxes\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of tax breakdowns applied\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/TaxBreakdown\\\"\\n            },\\n            \\\"example\\\": [\\n              { \\\"tax_type\\\": \\\"VAT\\\", \\\"tax_rate\\\": 0.2, \\\"tax_amount\\\": 40.00 },\\n              { \\\"tax_type\\\": \\\"Service Tax\\\", \\\"tax_rate\\\": 0.05, \\\"tax_amount\\\": 10.00 }\\n            ]\\n          },\\n          \\\"discount_coupons\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Applied discount coupons\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/DiscountCoupon\\\"\\n            },\\n            \\\"example\\\": [\\n              { \\\"code\\\": \\\"WELCOME10\\\", \\\"description\\\": \\\"10% off for new customers\\\", \\\"amount\\\": 20.00 },\\n              { \\\"code\\\": \\\"SUMMER5\\\", \\\"description\\\": \\\"5 dollars summer discount\\\", \\\"amount\\\": 5.00 }\\n            ]\\n          },\\n          \\\"total_amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total amount after taxes and discounts\\\",\\n            \\\"example\\\": 235.00\\n          },\\n          \\\"currency\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Currency code according to ISO 4217\\\",\\n            \\\"example\\\": \\\"USD\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"invoice_id\\\", \\\"billing_cycle\\\", \\\"company\\\", \\\"taxes\\\", \\\"discount_coupons\\\", \\\"total_amount\\\", \\\"currency\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"title\": \"Inception\",\n    \"runtime_minutes\": 148,\n    \"director\": {\n      \"name\": \"Christopher Nolan\",\n      \"birth_year\": 1970\n    },\n    \"cast\": [\n      {\n        \"name\": \"Leonardo DiCaprio\",\n        \"character\": \"Dom Cobb\"\n      },\n      {\n        \"name\": \"Joseph Gordon-Levitt\",\n        \"character\": \"Arthur\"\n      },\n      {\n        \"name\": \"Ellen Page\",\n        \"character\": \"Ariadne\"\n      }\n    ],\n    \"_links\": {\n      \"self\": {\n        \"href\": \"/movies/inception\"\n      },\n      \"related\": [\n        {\n          \"href\": \"/movies/interstellar\",\n          \"rel\": \"related\"\n        },\n        {\n          \"href\": \"/movies/the_prestige\",\n          \"rel\": \"related\"\n        }\n      ]\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Streaming Platform Movie API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Director:\\n      type: object\\n      description: 'Information about the movie director'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Full name of the director'\\n          example: 'Christopher Nolan'\\n        birth_year:\\n          type: integer\\n          description: 'Year when the director was born'\\n          example: 1970\\n    CastMember:\\n      type: object\\n      description: 'Details about a cast member'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Name of the cast member'\\n          example: 'Leonardo DiCaprio'\\n        character:\\n          type: string\\n          description: 'Character played by the cast member'\\n          example: 'Dom Cobb'\\n    Link:\\n      type: object\\n      description: 'A HATEOAS link object'\\n      properties:\\n        href:\\n          type: string\\n          description: 'URL of the linked resource'\\n          example: '/movies/inception'\\n        rel:\\n          type: string\\n          description: 'Relationship type of the link'\\n          example: 'related'\\n    MovieLinks:\\n      type: object\\n      description: 'HATEOAS links related to the movie'\\n      properties:\\n        self:\\n          $ref: '#/components/schemas/Link'\\n        related:\\n          type: array\\n          description: 'List of related movie links'\\n          items:\\n            $ref: '#/components/schemas/Link'\\n    Movie:\\n      type: object\\n      description: 'Complete movie information including director, cast, and links'\\n      properties:\\n        title:\\n          type: string\\n          description: 'Title of the movie'\\n          example: 'Inception'\\n        runtime_minutes:\\n          type: integer\\n          description: 'Total runtime of the movie in minutes'\\n          example: 148\\n        director:\\n          $ref: '#/components/schemas/Director'\\n        cast:\\n          type: array\\n          description: 'List of cast members in the movie'\\n          items:\\n            $ref: '#/components/schemas/CastMember'\\n        _links:\\n          $ref: '#/components/schemas/MovieLinks'\\n\"\n}"
