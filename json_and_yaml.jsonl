01'\\n        start_time:\\n          type: string\\n          format: date-time\\n          description: 'ISO 8601 start time of the irrigation event'\\n          example: '2024-06-10T08:00:00Z'\\n        duration_minutes:\\n          type: integer\\n          description: 'Duration of irrigation in minutes'\\n          example: 30\\n        water_volume_liters:\\n          type: number\\n          format: float\\n          description: 'Volume of water used in liters'\\n          example: 50.5\\n    SmartAgSensorResponse:\\n      type: object\\n      description: 'Response from a smart agriculture sensor including soil moisture, weather forecast, and irrigation history'\\n      properties:\\n        soil_moisture:\\n          type: number\\n          format: float\\n          description: 'Current soil moisture percentage'\\n          example: 35.7\\n        weather_forecast:\\n          $ref: '#/components/schemas/WeatherForecast'\\n        irrigation_events:\\n          type: array\\n          description: 'Recent automated irrigation events'\\n          items:\\n            $ref: '#/components/schemas/IrrigationEvent'\"\n}"
