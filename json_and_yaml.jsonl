 \\\"example\\\": \\\"Johnson\\\"\\n          },\\n          \\\"passport_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's passport number\\\",\\n            \\\"example\\\": \\\"X1234567\\\"\\n          },\\n          \\\"nationality\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Passenger's nationality\\\",\\n            \\\"example\\\": \\\"USA\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"first_name\\\", \\\"last_name\\\", \\\"passport_number\\\", \\\"nationality\\\"]\\n      },\\n      \\\"Layover\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a layover during the flight itinerary\\\",\\n        \\\"properties\\\": {\\n          \\\"airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"IATA code of the layover airport\\\",\\n            \\\"example\\\": \\\"CDG\\\"\\n          },\\n          \\\"arrival_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Arrival time at the layover airport\\\",\\n            \\\"example\\\": \\\"2024-08-11T06:00:00Z\\\"\\n          },\\n          \\\"departure_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Departure time from the layover airport\\\",\\n            \\\"example\\\": \\\"2024-08-11T06:45:00Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"airport\\\", \\\"arrival_time\\\", \\\"departure_time\\\"]\\n      },\\n      \\\"Itinerary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Flight itinerary including departure, arrival, and layovers\\\",\\n        \\\"properties\\\": {\\n          \\\"departure_airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"IATA code of the departure airport\\\",\\n            \\\"example\\\": \\\"JFK\\\"\\n          },\\n          \\\"arrival_airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"IATA code of the arrival airport\\\",\\n            \\\"example\\\": \\\"LHR\\\"\\n          },\\n          \\\"departure_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled departure time\\\",\\n            \\\"example\\\": \\\"2024-08-10T19:45:00Z\\\"\\n          },\\n          \\\"arrival_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Scheduled arrival time\\\",\\n            \\\"example\\\": \\\"2024-08-11T07:30:00Z\\\"\\n          },\\n          \\\"layovers\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of layovers in the itinerary\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/Layover\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"departure_airport\\\", \\\"arrival_airport\\\", \\\"departure_time\\\", \\\"arrival_time\\\", \\\"layovers\\\"]\\n      },\\n      \\\"SeatUpgrade\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details of a seat upgrade for a flight segment\\\",\\n        \\\"properties\\\": {\\n          \\\"segment\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Flight segment for which the upgrade is applied\\\",\\n            \\\"example\\\": \\\"JFK-CDG\\\"\\n          },\\n          \\\"seat_class\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Class of the upgraded seat\\\",\\n            \\\"example\\\": \\\"Business\\\"\\n          },\\n          \\\"price_usd\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Price paid for the upgrade in USD\\\",\\n            \\\"example\\\": 450\\n          }\\n        },\\n        \\\"required\\\": [\\\"segment\\\", \\\"seat_class\\\", \\\"price_usd\\\"]\\n      },\\n      \\\"MealPreference\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Passenger meal preferences for a flight segment\\\",\\n        \\\"properties\\\": {\\n          \\\"segment\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Flight segment for the meal preference\\\",\\n            \\\"example\\\": \\\"JFK-CDG\\\"\\n          },\\n          \\\"meal_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of meal requested\\\",\\n            \\\"example\\\": \\\"Vegetarian\\\"\\n          },\\n          \\\"notes\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Additional notes or restrictions\\\",\\n            \\\"example\\\": \\\"No nuts\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"segment\\\", \\\"meal_type\\\", \\\"notes\\\"]\\n      },\\n      \\\"BookingConfirmation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Full flight booking confirmation including passenger, itinerary, seat upgrades, and meal preferences\\\",\\n        \\\"properties\\\": {\\n          \\\"booking_reference\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique booking reference code\\\",\\n            \\\"example\\\": \\\"BR123456789\\\"\\n          },\\n          \\\"passenger\\\": { \\\"$ref\\\": \\\"#/components/schemas/PassengerDetails\\\" },\\n          \\\"itinerary\\\": { \\\"$ref\\\": \\\"#/components/schemas/Itinerary\\\" },\\n          \\\"seat_upgrades\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of selected seat upgrades\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/SeatUpgrade\\\" }\\n          },\\n          \\\"meal_preferences\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of meal preferences\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/MealPreference\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"booking_reference\\\", \\\"passenger\\\", \\\"itinerary\\\", \\\"seat_upgrades\\\", \\\"meal_preferences\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"property\": {\n      \"id\": \"prop_12345\",\n      \"title\": \"Modern Family Home with Ocean View\",\n      \"description\": \"A beautiful 4-bedroom modern house overlooking the ocean.\",\n      \"price\": 950000,\n      \"architecturalSpecs\": {\n        \"yearBuilt\": 2020,\n        \"squareFeet\": 3500,\n        \"numBedrooms\": 4,\n        \"numBathrooms\": 3,\n        \"flooring\": \"Hardwood\",\n        \"heating\": \"Central\",\n        \"cooling\": \"Central Air\"\n      },\n      \"images\": [\n        {\n          \"url\": \"https://example.com/images/prop_12345/front_view.jpg\",\n          \"resolution\": \"4000x3000\",\n          \"description\": \"Front elevation showing modern facade\"\n        },\n        {\n          \"url\": \"https://example.com/images/prop_12345/living_room.jpg\",\n          \"resolution\": \"4000x3000\",\n          \"description\": \"Spacious living room with ocean view\"\n        }\n      ],\n      \"realtor\": {\n        \"id\": \"realtor_6789\",\n        \"name\": \"Jane Doe\",\n        \"phone\": \"+1-555-123-4567\",\n        \"email\": \"jane.doe@example.com\",\n        \"agency\": \"Oceanview Realty\"\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Real Estate Property Listing API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Architectural specifications of the property'\\n      properties:\\n        yearBuilt:\\n          type: integer\\n          description: 'Year the property was built'\\n          example: 2020\\n        squareFeet:\\n          type: integer\\n          description: 'Total living area in square feet'\\n          example: 3500\\n        numBedrooms:\\n          type: integer\\n          description: 'Number of bedrooms'\\n          example: 4\\n        numBathrooms:\\n          type: integer\\n          description: 'Number of bathrooms'\\n          example: 3\\n        flooring:\\n          type: string\\n          description: 'Type of flooring used in the property'\\n          example: 'Hardwood'\\n        heating:\\n          type: string\\n          description: 'Heating system description'\\n          example: 'Central'\\n        cooling:\\n          type: string\\n          description: 'Cooling system description'\\n          example: 'Central Air'\\n    Image:\\n      type: object\\n      description: 'High-resolution image details for the property'\\n      properties:\\n        url:\\n          type: string\\n          format: uri\\n          description: 'Direct URL to the image resource'\\n          example: 'https://example.com/images/prop_12345/front_view.jpg'\\n        resolution:\\n          type: string\\n          description: 'Image resolution in width x height format'\\n          example: '4000x3000'\\n        description:\\n          type: string\\n          description: 'Brief description of the image content'\\n          example: 'Front elevation showing modern facade'\\n    Realtor:\\n      type: object\\n      description: 'Contact information for the realtor assigned to the property'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier for the realtor'\\n          example: 'realtor_6789'\\n        name:\\n          type: string\\n          description: 'Full name of the realtor'\\n          example: 'Jane Doe'\\n        phone:\\n          type: string\\n          description: 'Contact phone number for the realtor'\\n          example: '+1-555-123-4567'\\n        email:\\n          type: string\\n          format: email\\n          description: 'Email address of the realtor'\\n          example: 'jane.doe@example.com'\\n        agency:\\n          type: string\\n          description: 'Real estate agency name'\\n          example: 'Oceanview Realty'\\n    Property:\\n      type: object\\n      description: 'Real estate property listing including specs, images, and realtor info'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique property identifier'\\n          example: 'prop_12345'\\n        title:\\n          type: string\\n          description: 'Title summarizing the property'\\n          example: 'Modern Family Home with Ocean View'\\n        description:\\n          type: string\\n          description: 'Detailed description of the property'\\n          example: 'A beautiful 4-bedroom modern house overlooking the ocean.'\\n        price:\\n          type: integer\\n          description: 'Listing price in USD'\\n          example: 950000\\n        architecturalSpecs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n          description: 'Array of high-resolution images related to the property'\\n          items:\\n            $ref: '#/components/schemas/Image'\\n        realtor:\\n          $ref: '#/components/schemas/Realtor'\\n    PropertyListingResponse:\\n      type: object\\n      description: 'Response object containing the property listing'\\n      properties:\\n        property:\\n          $ref: '#/components/schemas/Property'\"\n}"
"{\n  \"raw_json\": {\n    \"reservation_id\": \"res_98765\",\n    \"room_type\": \"Deluxe Suite\",\n    \"pricing_breakdown\": {\n      \"base_price_per_night\": 200.0,\n      \"taxes_per_night\": 30.0,\n      \"fees_per_night\": 15.0,\n      \"total_per_night\": 245.0,\n      \"nights\": 3,\n      \"total_price\": 735.0\n    },\n    \"requested_amenities\": [\n      {\n        \"amenity_name\": \"Crib\",\n        \"quantity\": 1\n      },\n      {\n        \"amenity_name\": \"Extra Bed\",\n        \"quantity\": 2\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Hotel Reservation Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Amenity\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"An additional amenity requested for the room\\\",\\n        \\\"properties\\\": {\\n          \\\"amenity_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the requested amenity\\\",\\n            \\\"example\\\": \\\"Crib\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of units requested for the amenity\\\",\\n            \\\"example\\\": 1\\n          }\\n        },\\n        \\\"required\\\": [\\\"amenity_name\\\", \\\"quantity\\\"]\\n      },\\n      \\\"PricingBreakdown\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detailed pricing breakdown per night\\\",\\n        \\\"properties\\\": {\\n          \\\"base_price_per_night\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Base price charged per night before taxes and fees\\\",\\n            \\\"example\\\": 200.0\\n          },\\n          \\\"taxes_per_night\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Tax amount applied per night\\\",\\n            \\\"example\\\": 30.0\\n          },\\n          \\\"fees_per_night\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Additional fees applied per night\\\",\\n            \\\"example\\\": 15.0\\n          },\\n          \\\"total_per_night\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total cost per night including taxes and fees\\\",\\n            \\\"example\\\": 245.0\\n          },\\n          \\\"nights\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of nights for the reservation\\\",\\n            \\\"example\\\": 3\\n          },\\n          \\\"total_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total price for the entire stay\\\",\\n            \\\"example\\\": 735.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"base_price_per_night\\\", \\\"taxes_per_night\\\", \\\"fees_per_night\\\", \\\"total_per_night\\\", \\\"nights\\\", \\\"total_price\\\"]\\n      },\\n      \\\"HotelReservationResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Hotel reservation details with room type, pricing, and amenities\\\",\\n        \\\"properties\\\": {\\n          \\\"reservation_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the hotel reservation\\\",\\n            \\\"example\\\": \\\"res_98765\\\"\\n          },\\n          \\\"room_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type or category of the reserved room\\\",\\n            \\\"example\\\": \\\"Deluxe Suite\\\"\\n          },\\n          \\\"pricing_breakdown\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/PricingBreakdown\\\"\\n          },\\n          \\\"requested_amenities\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of additional amenities requested for the room\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Amenity\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"reservation_id\\\", \\\"room_type\\\", \\\"pricing_breakdown\\\", \\\"requested_amenities\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"floor_plan_id\": \"fp_12\",\n    \"occupied_hot_desks\": [\n      {\n        \"desk_id\": \"hd_101\",\n        \"user\": {\n          \"user_id\": \"u_9876\",\n          \"name\": \"João Silva\",\n          \"department\": \"Marketing\"\n        },\n        \"occupied_since\": \"2024-06-25T09:30:00Z\"\n      },\n      {\n        \"desk_id\": \"hd_103\",\n        \"user\": {\n          \"user_id\": \"u_8765\",\n          \"name\": \"Maria Oliveira\",\n          \"department\": \"Desenvolvimento\"\n        },\n        \"occupied_since\": \"2024-06-25T10:00:00Z\"\n      }\n    ],\n    \"meeting_room_reservations\": [\n      {\n        \"room_id\": \"mr_204\",\n        \"room_name\": \"Sala Alfa\",\n        \"start_time\": \"2024-06-25T14:00:00Z\",\n        \"end_time\": \"2024-06-25T15:30:00Z\",\n        \"reserved_by\": {\n          \"user_id\": \"u_1234\",\n          \"name\": \"Carlos Pereira\"\n        }\n      },\n      {\n        \"room_id\": \"mr_305\",\n        \"room_name\": \"Sala Beta\",\n        \"start_time\": \"2024-06-25T16:00:00Z\",\n        \"end_time\": \"2024-06-25T17:00:00Z\",\n        \"reserved_by\": {\n          \"user_id\": \"u_5678\",\n          \"name\": \"Ana Costa\"\n        }\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Relatório de Disponibilidade de Mesas em Coworking\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    User:\\n      type: object\\n      description: 'Informações do usuário que ocupa a mesa ou reservou a sala'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário'\\n          example: 'u_9876'\\n        name:\\n          type: string\\n          description: 'Nome completo do usuário'\\n          example: 'João Silva'\\n        department:\\n          type: string\\n          description: 'Departamento ao qual o usuário pertence'\\n          example: 'Marketing'\\n    OccupiedHotDesk:\\n      ty