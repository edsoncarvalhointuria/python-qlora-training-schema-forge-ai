com'\\n        phone_number:\\n          type: string\\n          description: 'Phone number of the user in international format'\\n          example: '+1234567890'\\n    Merchant:\\n      type: object\\n      description: 'Merchant information involved in the transaction'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Name of the merchant'\\n          example: 'SuperMart'\\n        category:\\n          type: string\\n          description: 'Category or type of the merchant business'\\n          example: 'Groceries'\\n    Transaction:\\n      type: object\\n      description: 'Details of a single transaction in the digital wallet'\\n      properties:\\n        transaction_id:\\n          type: string\\n          description: 'Unique identifier for the transaction'\\n          example: 'tx1001'\\n        date:\\n          type: string\\n          format: date-time\\n          description: 'ISO 8601 date and time when the transaction occurred'\\n          example: '2024-06-20T14:35:00Z'\\n        type:\\n          type: string\\n          description: 'Type of transaction, debit or credit'\\n          example: 'debit'\\n        amount:\\n          type: number\\n          format: float\\n          description: 'Amount of money involved in the transaction'\\n          example: 45.00\\n        currency:\\n          type: string\\n          description: 'Currency code in ISO 4217 format'\\n          example: 'USD'\\n        description:\\n          type: string\\n          description: 'Brief description or notes about the transaction'\\n          example: 'Grocery Shopping'\\n        merchant:\\n          oneOf:\\n            - $ref: '#/components/schemas/Merchant'\\n            - type: 'null'\\n          description: 'Merchant information or null if not applicable'\\n          example:\\n            name: 'SuperMart'\\n            category: 'Groceries'\\n    DigitalWalletStatement:\\n      type: object\\n      description: 'Statement data for a digital wallet including balance, user profile, and recent transactions'\\n      properties:\\n        current_balance:\\n          type: number\\n          format: float\\n          description: 'Current balance available in the wallet'\\n          example: 1532.75\\n        currency:\\n          type: string\\n          description: 'Currency code for the wallet balance in ISO 4217 format'\\n          example: 'USD'\\n        user_profile:\\n          $ref: '#/components/schemas/UserProfile'\\n        recent_transactions:\\n          type: array\\n          description: 'List of the most recent transactions in the wallet'\\n          items:\\n            $ref: '#/components/schemas/Transaction'\\n          example:\\n            - transaction_id: 'tx1001'\\n              date: '2024-06-20T14:35:00Z'\\n              type: 'debit'\\n              amount: 45.00\\n              currency: 'USD'\\n              description: 'Grocery Shopping'\\n              merchant:\\n                name: 'SuperMart'\\n                category: 'Groceries'\\n            - transaction_id: 'tx1002'\\n              date: '2024-06-19T10:15:00Z'\\n              type: 'credit'\\n              amount: 200.00\\n              currency: 'USD'\\n              description: 'Salary Deposit'\\n              merchant: null\\n            - transaction_id: 'tx1003'\\n              date: '2024-06-18T18:20:00Z'\\n              type: 'debit'\\n              amount: 15.50\\n              currency: 'USD'\\n              description: 'Coffee with friends'\\n              merchant:\\n                name: 'Cafe Central'\\n                category: 'Beverages'\\n\"\n}"
