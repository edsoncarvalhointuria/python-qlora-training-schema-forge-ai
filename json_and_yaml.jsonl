           \\\"example\\\": 999\\n          },\\n          \\\"discount_percentage\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Discount percentage applied for this tier\\\",\\n            \\\"example\\\": 5.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"min_quantity\\\", \\\"discount_percentage\\\"]\\n      },\\n      \\\"BulkItem\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"An item ordered in bulk with associated tiered discounts\\\",\\n        \\\"properties\\\": {\\n          \\\"item_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the item\\\",\\n            \\\"example\\\": \\\"itm_1001\\\"\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Description or name of the item\\\",\\n            \\\"example\\\": \\\"Industrial Widget\\\"\\n          },\\n          \\\"quantity\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantity of the item ordered\\\",\\n            \\\"example\\\": 1500\\n          },\\n          \\\"unit_price\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Price per unit of the item in USD\\\",\\n            \\\"example\\\": 2.75\\n          },\\n          \\\"tiered_discounts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of tiered discount brackets applied based on quantity\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/TieredDiscount\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"item_id\\\", \\\"description\\\", \\\"quantity\\\", \\\"unit_price\\\", \\\"tiered_discounts\\\"]\\n      },\\n      \\\"FreightShippingTerms\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Terms and details related to freight shipping of the order\\\",\\n        \\\"properties\\\": {\\n          \\\"carrier\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Freight carrier company name\\\",\\n            \\\"example\\\": \\\"Fast Freight Express\\\"\\n          },\\n          \\\"service_level\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Shipping service level or speed\\\",\\n            \\\"example\\\": \\\"Priority Overnight\\\"\\n          },\\n          \\\"freight_cost\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total freight cost in USD\\\",\\n            \\\"example\\\": 350.75\\n          },\\n          \\\"incoterm\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"International commercial term defining responsibility and risk\\\",\\n            \\\"example\\\": \\\"FOB Origin\\\"\\n          },\\n          \\\"estimated_delivery_days\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Estimated number of days for delivery\\\",\\n            \\\"example\\\": 2\\n          }\\n        },\\n        \\\"required\\\": [\\\"carrier\\\", \\\"service_level\\\", \\\"freight_cost\\\", \\\"incoterm\\\", \\\"estimated_delivery_days\\\"]\\n      },\\n      \\\"WholesaleOrderInvoice\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Invoice detailing a B2B wholesale order with buyer profile, bulk items, and shipping terms\\\",\\n        \\\"properties\\\": {\\n          \\\"invoice_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the invoice\\\",\\n            \\\"example\\\": \\\"inv_20240612_001\\\"\\n          },\\n          \\\"buyer_company\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/BuyerCompany\\\"\\n          },\\n          \\\"bulk_items\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of bulk ordered items with tiered discounts\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/BulkItem\\\"\\n            }\\n          },\\n          \\\"freight_shipping_terms\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/FreightShippingTerms\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"invoice_id\\\", \\\"buyer_company\\\", \\\"bulk_items\\\", \\\"freight_shipping_terms\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n},\\n  \\\"schema\\\": {\\n    \\\"$ref\\\": \\\"#/components/schemas/WholesaleOrderInvoice\\\"\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"date\": \"2024-06-01\",\n    \"daily_active_users\": 1250,\n    \"feature_usage_metrics\": [\n      {\n        \"feature_name\": \"Dashboard\",\n        \"usage_count\": 980,\n        \"unique_users\": 870\n      },\n      {\n        \"feature_name\": \"Reports\",\n        \"usage_count\": 650,\n        \"unique_users\": 600\n      },\n      {\n        \"feature_name\": \"Notifications\",\n        \"usage_count\": 1100,\n        \"unique_users\": 1050\n      }\n    ],\n    \"subscription_tier_limits\": {\n      \"tier_name\": \"Pro\",\n      \"max_users\": 2000,\n      \"max_projects\": 50,\n      \"features_enabled\": [\n        \"Dashboard\",\n        \"Reports\",\n        \"Notifications\",\n        \"Priority Support\"\n      ]\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: SaaS User Analytics Report\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FeatureUsageMetric:\\n      type: object\\n      description: 'Métricas de uso para uma funcionalidade específica'\\n      properties:\\n        feature_name:\\n          type: string\\n          description: 'Nome da funcionalidade'\\n          example: 'Dashboard'\\n        usage_count:\\n          type: integer\\n          description: 'Total de usos dessa funcionalidade no dia'\\n          example: 980\\n        unique_users:\\n          type: integer\\n          description: 'Número de usuários distintos que usaram a funcionalidade'\\n          example: 870\\n    SubscriptionTierLimits:\\n      type: object\\n      description: 'Limites e configurações do plano de assinatura'\\n      properties:\\n        tier_name:\\n          type: string\\n          description: 'Nome do plano de assinatura'\\n          example: 'Pro'\\n        max_users:\\n          type: integer\\n          description: 'Número máximo de usuários permitidos no plano'\\n          example: 2000\\n        max_projects:\\n          type: integer\\n          description: 'Número máximo de projetos permitidos no plano'\\n          example: 50\\n        features_enabled:\\n          type: array\\n          description: 'Lista de funcionalidades ativadas no plano'\\n          items:\\n            type: string\\n          example: ['Dashboard', 'Reports', 'Notifications', 'Priority Support']\\n    UserAnalyticsReport:\\n      type: object\\n      description: 'Relatório diário de análise de usuários da plataforma SaaS'\\n      properties:\\n        date:\\n          type: string\\n          format: date\\n          description: 'Data do relatório no formato AAAA-MM-DD'\\n          example: '2024-06-01'\\n        daily_active_users:\\n          type: integer\\n          description: 'Quantidade de usuários ativos no dia'\\n          example: 1250\\n        feature_usage_metrics:\\n          type: array\\n          description: 'Lista das métricas de uso por funcionalidade'\\n          items:\\n            $ref: '#/components/schemas/FeatureUsageMetric'\\n        subscription_tier_limits:\\n          $ref: '#/components/schemas/SubscriptionTierLimits'\\n\"\n}"
"{\n  \"raw_json\": {\n    \"alert_id\": \"alert_20240601_001\",\n    \"severity_level\": \"High\",\n    \"affected_entities\": [\n      {\n        \"entity_type\": \"IP Address\",\n        \"addresses\": [\n          \"192.168.1.100\",\n          \"10.0.0.5\"\n        ]\n      },\n      {\n        \"entity_type\": \"IP Address\",\n        \"addresses\": [\n          \"172.16.0.7\"\n        ]\n      }\n    ],\n    \"mitigation_protocols\": [\n      {\n        \"protocol_id\": \"mitigation_001\",\n        \"description\": \"Block the affected IP addresses at the firewall level\",\n        \"steps\": [\n          \"Identify affected IP ranges\",\n          \"Apply firewall rules to block traffic\",\n          \"Monitor traffic for suspicious activity\"\n        ]\n      },\n      {\n        \"protocol_id\": \"mitigation_002\",\n        \"description\": \"Update antivirus signatures and run a full system scan\",\n        \"steps\": [\n          \"Ensure antivirus definitions are up to date\",\n          \"Perform a comprehensive scan on all endpoints\",\n          \"Isolate any infected systems\"\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Cybersecurity Threat Intelligence Alert\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"AffectedEntity\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about affected entities involved in the alert\\\",\\n        \\\"properties\\\": {\\n          \\\"entity_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of the affected entity\\\",\\n            \\\"example\\\": \\\"IP Address\\\"\\n          },\\n          \\\"addresses\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of affected IP addresses\\\",\\n            \\\"items\\\": {\\n       