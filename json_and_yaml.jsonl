     description: 'Informações sobre um time participante'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Nome do time'\\n          example: 'Dragons'\\n        score:\\n          type: integer\\n          description: 'Pontuação total do time na partida'\\n          example: 24\\n    PlayerStats:\\n      type: object\\n      description: 'Estatísticas individuais do jogador'\\n      properties:\\n        kills:\\n          type: integer\\n          description: 'Número de eliminações realizadas pelo jogador'\\n          example: 9\\n        deaths:\\n          type: integer\\n          description: 'Número de vezes que o jogador foi eliminado'\\n          example: 3\\n        assists:\\n          type: integer\\n          description: 'Número de assistências do jogador'\\n          example: 7\\n    Player:\\n      type: object\\n      description: 'Detalhes e estatísticas de um jogador'\\n      properties:\\n        player_id:\\n          type: string\\n          description: 'Identificador único do jogador'\\n          example: 'p1001'\\n        name:\\n          type: string\\n          description: 'Nome do jogador'\\n          example: 'Luna'\\n        team:\\n          type: string\\n          description: 'Nome do time ao qual o jogador pertence'\\n          example: 'Dragons'\\n        stats:\\n          $ref: '#/components/schemas/PlayerStats'\\n    TimelineEvent:\\n      type: object\\n      description: 'Evento importante ocorrido durante a partida'\\n      properties:\\n        timestamp:\\n          type: string\\n          description: 'Momento do evento na linha do tempo da partida no formato mm:ss'\\n          example: '00:03:45'\\n        event_type:\\n          type: string\\n          description: 'Tipo do evento, por exemplo: Kill, Assist, Objective'\\n          example: 'Kill'\\n        description:\\n          type: string\\n          description: 'Descrição detalhada do evento'\\n          example: 'Luna