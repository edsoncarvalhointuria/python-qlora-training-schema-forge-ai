\\"billing_cycle\\\", \\\"company\\\", \\\"tax_breakdown\\\", \\\"discount_coupons\\\", \\\"total_amount\\\", \\\"currency\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"title\": \"Inception\",\n    \"runtime_minutes\": 148,\n    \"director\": {\n      \"name\": \"Christopher Nolan\",\n      \"birth_year\": 1970\n    },\n    \"cast\": [\n      {\n        \"name\": \"Leonardo DiCaprio\",\n        \"role\": \"Dom Cobb\"\n      },\n      {\n        \"name\": \"Joseph Gordon-Levitt\",\n        \"role\": \"Arthur\"\n      }\n    ],\n    \"links\": {\n      \"related_movies\": [\n        {\n          \"rel\": \"sequel\",\n          \"href\": \"/movies/inception-2\"\n        },\n        {\n          \"rel\": \"prequel\",\n          \"href\": \"/movies/memento\"\n        }\n      ]\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Movie Endpoint\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Director:\\n      type: object\\n      description: 'Informações sobre o diretor do filme'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Nome completo do diretor'\\n          example: 'Christopher Nolan'\\n        birth_year:\\n          type: integer\\n          description: 'Ano de nascimento do diretor'\\n          example: 1970\\n    CastMember:\\n      type: object\\n      description: 'Ator ou atriz com o papel no filme'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Nome do ator ou atriz'\\n          example: 'Leonardo DiCaprio'\\n        role:\\n          type: string\\n          description: 'Nome do personagem interpretado'\\n          example: 'Dom Cobb'\\n    Link:\\n      type: object\\n      description: 'Link HATEOAS para recursos relacionados'\\n      properties:\\n        rel:\\n          type: string\\n          description: 'Tipo de relacionamento do link'\\n          example: 'sequel'\\n        href:\\n          type: string\\n          description: 'URL para o recurso relacionado'\\n          example: '/movies/inception-2'\\n    Links:\\n      type: object\\n      description: 'Coleção de links HATEO