": \\\"987654321\\\"\\n          },\\n          \\\"routing_number\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Bank routing number\\\",\\n            \\\"example\\\": \\\"111000025\\\"\\n          },\\n          \\\"deposit_amount\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Amount deposited into this bank account\\\",\\n            \\\"example\\\": 3500.00\\n          }\\n        },\\n        \\\"required\\\": [\\\"bank_name\\\", \\\"account_number\\\", \\\"routing_number\\\", \\\"deposit_amount\\\"]\\n      },\\n      \\\"PayrollSlip\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Complete payroll slip data including salary, deductions, benefits, and deposits\\\",\\n        \\\"properties\\\": {\\n          \\\"gross_salary\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total gross salary before deductions\\\",\\n            \\\"example\\\": 7500.75\\n          },\\n          \\\"tax_deductions\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/TaxDeductions\\\"\\n          },\\n          \\\"health_benefits\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/HealthBenefits\\\"\\n          },\\n          \\\"direct_deposits\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of bank accounts receiving direct deposits\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/DirectDeposit\\\"\\n            },\\n            \\\"example\\\": [\\n              {\\n                \\\"bank_name\\\": \\\"First National Bank\\\",\\n                \\\"account_number\\\": \\\"987654321\\\",\\n                \\\"routing_number\\\": \\\"111000025\\\",\\n                \\\"deposit_amount\\\": 3500.00\\n              },\\n              {\\n                \\\"bank_name\\\": \\\"City Credit Union\\\",\\n                \\\"account_number\\\": \\\"123456789\\\",\\n                \\\"routing_number\\\": \\\"222000111\\\",\\n                \\\"deposit_amount\\\": 4000.75\\n              }\\n            ]\\n          }\\n        },\\n        \\\"required\\\": [\\\"gross_salary\\\", \\\"tax_deductions\\\", \\\"health_benefits\\\", \\\"direct_deposits\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"definitions\\\": {},\\n  \\\"root\\\": {\\n    \\\"$ref\\\": \\\"#/components/schemas/PayrollSlip\\\"\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"patient\": {\n      \"id\": \"P123456\",\n      \"name\": \"John Doe\",\n      \"age\": 45,\n      \"gender\": \"Male\"\n    },\n    \"test_results\": [\n      {\n        \"biomarker\": \"Hemoglobin\",\n        \"value\": 13.5,\n        \"unit\": \"g/dL\",\n        \"normal_range\": {\n          \"min\": 13.0,\n          \"max\": 17.0,\n          \"unit\": \"g/dL\"\n        }\n      },\n      {\n        \"biomarker\": \"White Blood Cell Count\",\n        \"value\": 6.2,\n        \"unit\": \"x10^9/L\",\n        \"normal_range\": {\n          \"min\": 4.0,\n          \"max\": 11.0,\n          \"unit\": \"x10^9/L\"\n        }\n      },\n      {\n        \"biomarker\": \"Platelet Count\",\n        \"value\": 250,\n        \"unit\": \"x10^9/L\",\n        \"normal_range\": {\n          \"min\": 150,\n          \"max\": 450,\n          \"unit\": \"x10^9/L\"\n        }\n      }\n    ],\n    \"pathologist_signature\": {\n      \"name\": \"Dr. Alice Smith\",\n      \"signature_image_url\": \"https://hospital.example.com/signatures/dr-alice-smith.png\",\n      \"date_signed\": \"2024-04-25T15:30:00Z\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Hospital Laboratory Test Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Patient:\\n      type: object\\n      description: 'Demographic information for the patient'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique identifier of the patient'\\n          example: 'P123456'\\n        name:\\n          type: string\\n          description: 'Full name of the patient'\\n          example: 'John Doe'\\n        age:\\n          type: integer\\n          description: 'Age of the patient in years'\\n          example: 45\\n        gender:\\n          type: string\\n          description: 'Biological gender of the patient'\\n          example: 'Male'\\n    NormalRange:\\n      type: object\\n      description: 'Normal range for a biomarker value'\\n      properties:\\n        min:\\n          type: number\\n          format: float\\n          description: 'Minimum normal value for the biomarker'\\n          example: 13.0\\n        max:\\n          type: number\\n          format: float\\n          description: 'Maximum normal value for the biomarker'\\n          example: 17.0\\n        unit:\\n          type: string\\n          description: 'Measurement unit for the biomarker'\\n          example: 'g/dL'\\n    BiomarkerResult:\\n      type: object\\n      description: 'Result data for a single blood biomarker'\\n      properties:\\n        biomarker:\\n          type: string\\n          description: 'Name of the blood biomarker'\\n          example: 'Hemoglobin'\\n        value:\\n          type: number\\n          format: float\\n          description: 'Measured biomarker value'\\n          example: 13.5\\n        unit:\\n          type: string\\n          description: 'Unit of measurement for the value'\\n          example: 'g/dL'\\n        normal_range:\\n          $ref: '#/components/schemas/NormalRange'\\n    PathologistSignature:\\n      type: object\\n      description: 'Digital signature details of the reviewing pathologist'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Full name of the pathologist'\\n          example: 'Dr. Alice Smith'\\n        signature_image_url:\\n          type: string\\n          format: uri\\n          description: 'URL pointing to the digital signature image'\\n          example: 'https://hospital.example.com/signatures/dr-alice-smith.png'\\n        date_signed:\\n          type: string\\n          format: date-time\\n          description: 'ISO 8601 timestamp when the signature was made'\\n          example: '2024-04-25T15:30:00Z'\\n    LaboratoryTestResult:\\n      type: object\\n      description: 'Complete laboratory test result with patient and test details'\\n      properties:\\n        patient:\\n          $ref: '#/components/schemas/Patient'\\n        test_results:\\n          type: array\\n          description: 'List of blood biomarker test results'\\n          items:\\n            $ref: '#/components/schemas/BiomarkerResult'\\n        pathologist_signature:\\n          $ref: '#/components/schemas/PathologistSignature'\\n\"\n}"
