e:\\n          type: integer\\n          description: 'Pontuação atual da equipe'\\n          example: 16\\n    PlayerStats:\\n      type: object\\n      description: 'Estatísticas individuais de um jogador'\\n      properties:\\n        player_id:\\n          type: string\\n          description: 'Identificador único do jogador'\\n          example: p1\\n        name:\\n          type: string\\n          description: 'Nome do jogador'\\n          example: Ace\\n        team:\\n          type: string\\n          description: 'Equipe a qual o jogador pertence'\\n          example: Dragons\\n        kills:\\n          type: integer\\n          description: 'Número de eliminações realizadas pelo jogador'\\n          example: 20\\n        deaths:\\n          type: integer\\n          description: 'Número de vezes que o jogador foi eliminado'\\n          example: 5\\n        assists:\\n          type: integer\\n          description: 'Número de assistências dadas pelo jogador'\\n          example: 7\\n    MatchEvent:\\n      type: object\\n      description: 'Evento chave na linha do tempo da partida'\\n      properties:\\n        timestamp_ms:\\n          type: integer\\n          description: 'Tempo do evento em milissegundos desde o início da partida'\\n          example: 30000\\n        event_type:\\n          type: string\\n          description: 'Tipo do evento (ex: kill, objective)'\\n          example: kill\\n        description:\\n          type: string\\n          description: 'Descrição detalhada do evento'\\n          example: Ace eliminou Fang\\n        involved_players:\\n          type: array\\n          description: 'Lista de IDs dos jogadores envolvidos no evento'\\n          items:\\n            type: string\\n            example: p1\\n    Teams:\\n      type: object\\n      description: 'Conjunto das duas equipes com suas pontuações'\\n      properties:\\n        team_a:\\n          $ref: '#/components/schemas/TeamScore'\\n        team_b:\\n          $