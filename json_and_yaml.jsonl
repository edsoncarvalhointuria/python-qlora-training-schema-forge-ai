"{\n  \"raw_json\": {\n    \"user\": {\n      \"id\": \"user_789\",\n      \"name\": \"Alice Johnson\",\n      \"email\": \"alice.johnson@example.com\",\n      \"phone\": \"+1234567890\"\n    },\n    \"current_balance\": 2540.75,\n    \"currency\": \"USD\",\n    \"recent_transactions\": [\n      {\n        \"transaction_id\": \"txn_1001\",\n        \"date\": \"2024-06-15T14:30:00Z\",\n        \"type\": \"deposit\",\n        \"amount\": 500.00,\n        \"status\": \"completed\",\n        \"description\": \"Salary payment\"\n      },\n      {\n        \"transaction_id\": \"txn_1002\",\n        \"date\": \"2024-06-14T09:15:00Z\",\n        \"type\": \"purchase\",\n        \"amount\": -120.50,\n        \"status\": \"completed\",\n        \"description\": \"Grocery shopping\"\n      },\n      {\n        \"transaction_id\": \"txn_1003\",\n        \"date\": \"2024-06-13T18:45:00Z\",\n        \"type\": \"transfer\",\n        \"amount\": -50.00,\n        \"status\": \"pending\",\n        \"description\": \"Transfer to savings account\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Digital Wallet Statement\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UserProfile:\\n      type: object\\n      description: 'Details of the wallet user profile'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Unique user identifier'\\n          example: 'user_789'\\n        name:\\n          type: string\\n          description: 'Full name of the user'\\n          example: 'Alice Johnson'\\n        email:\\n          type: string\\n          description: 'User email address'\\n          example: 'alice.johnson@example.com'\\n        phone:\\n          type: string\\n          description: 'User phone number in international format'\\n          example: '+1234567890'\\n    Transaction:\\n      type: object\\n      description: 'A single wallet transaction record'\\n      properties:\\n        transaction_id:\\n          type: string\\n          description: 'Unique identifier for the transaction'\\n          example: 'txn_1001'\\n        date:\\n          type: string\\n          format: date-time\\n          description: 'ISO 8601 date and time when transaction occurred'\\n          example: '2024-06-15T14:30:00Z'\\n        type:\\n          type: string\\n          description: 'Type of transaction, e.g., deposit, purchase, transfer'\\n          example: 'deposit'\\n        amount:\\n          type: number\\n          format: float\\n          description: 'Transaction amount; positive for incoming, negative for outgoing'\\n          example: 500.00\\n        status:\\n          type: string\\n          description: 'Current status of the transaction'\\n          example: 'completed'\\n        description:\\n          type: string\\n          description: 'Short explanation or note about the transaction'\\n          example: 'Salary payment'\\n    WalletStatement:\\n      type: object\\n      description: 'Digital wallet statement containing profile, balance, and recent transactions'\\n      properties:\\n        user:\\n          $ref: '#/components/schemas/UserProfile'\\n        current_balance:\\n          type: number\\n          format: float\\n          description: 'Current available balance in the wallet'\\n          example: 2540.75\\n        currency:\\n          type: string\\n          description: 'Currency code for the balance'\\n          example: 'USD'\\n        recent_transactions:\\n          type: array\\n          description: 'List of the last three wallet transactions'\\n          items:\\n            $ref: '#/components/schemas/Transaction'\\n\"\n}"
