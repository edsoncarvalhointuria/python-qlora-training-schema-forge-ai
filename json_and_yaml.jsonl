und\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Amount to be refunded to the citizen if overpaid\\\",\\n            \\\"example\\\": 844.94\\n          },\\n          \\\"tax_debt\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Outstanding tax amount owed by the citizen if underpaid\\\",\\n            \\\"example\\\": 0.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"taxable_income\\\", \\\"tax_rate_percent\\\", \\\"tax_amount\\\", \\\"tax_paid\\\", \\\"tax_refund\\\", \\\"tax_debt\\\"]\\n      },\\n      \\\"TaxReturnAssessmentResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Government response detailing the tax return assessment\\\",\\n        \\\"properties\\\": {\\n          \\\"tax_return_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the tax return\\\",\\n            \\\"example\\\": \\\"TR202406001\\\"\\n          },\\n          \\\"citizen\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Citizen\\\"\\n          },\\n          \\\"declared_income\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total income declared by the citizen\\\",\\n            \\\"example\\\": 58000.75\\n          },\\n          \\\"deductions\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of valid deductions claimed\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Deduction\\\"\\n            }\\n          },\\n          \\\"tax_assessment\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/TaxAssessment\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"tax_return_id\\\", \\\"citizen\\\