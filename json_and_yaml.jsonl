tion\\\": \\\"Unique identifier for the player\\\",\\n            \\\"example\\\": \\\"player123\\\"\\n          },\\n          \\\"username\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Player's in-game username\\\",\\n            \\\"example\\\": \\\"DragonSlayer\\\"\\n          },\\n          \\\"current_level\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Current level of the player\\\",\\n            \\\"example\\\": 42\\n          },\\n          \\\"equipped_gear\\\": { \\\"$ref\\\": \\\"#/components/schemas/EquippedGear\\\" },\\n          \\\"unlocked_achievements\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of achievements unlocked by the player\\\",\\n            \\\"items\\\": { \\\"$ref\\\": \\\"#/components/schemas/Achievement\\\" }\\n          }\\n        },\\n        \\\"required\\\": [\\\"player_id\\\", \\\"username\\\", \\\"current_level\\\", \\\"equipped_gear\\\", \\\"unlocked_achievements\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
