"{\n  \"raw_json\": {\n    \"property_id\": \"prop_12345\",\n    \"address\": \"123 Maple Street, Springfield, IL, 62704\",\n    \"price\": 350000,\n    \"architectural_specs\": {\n      \"style\": \"Colonial\",\n      \"year_built\": 1995,\n      \"square_feet\": 2200,\n      \"bedrooms\": 4,\n      \"bathrooms\": 2.5,\n      \"features\": [\n        \"Fireplace\",\n        \"Hardwood floors\",\n        \"Central air conditioning\"\n      ]\n    },\n    \"images\": [\n      {\n        \"url\": \"https://realestate.example.com/images/prop_12345/front_view_hr.jpg\",\n        \"description\": \"Front exterior view of the property\"\n      },\n      {\n        \"url\": \"https://realestate.example.com/images/prop_12345/kitchen_hr.jpg\",\n        \"description\": \"Modern kitchen with stainless steel appliances\"\n      },\n      {\n        \"url\": \"https://realestate.example.com/images/prop_12345/backyard_hr.jpg\",\n        \"description\": \"Spacious backyard with patio\"\n      }\n    ],\n    \"realtor\": {\n      \"id\": \"realtor_789\",\n      \"name\": \"Anna Thompson\",\n      \"phone\": \"+1-555-123-4567\",\n      \"email\": \"anna.thompson@realestateco.com\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Real Estate Property Listing\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Architectural specifications of the property'\\n      properties:\\n        style:\\n          type: string\\n          description: 'Architectural style of the property'\\n          example: 'Colonial'\\n        year_built:\\n          type: integer\\n          description: 'Year the property was built'\\n          example: 1995\\n        square_feet:\\n          type: integer\\n          description: 'Total area of the property in square feet'\\n          example: 2200\\n        bedrooms:\\n          type: integer\\n          description: 'Number of bedrooms in the property'\\n          exampl