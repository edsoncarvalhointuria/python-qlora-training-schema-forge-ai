"{\n  \"raw_json\": {\n    \"headline\": \"Global Climate Initiatives Gain Momentum\",\n    \"author_byline\": \"Jane Doe, Senior Environmental Correspondent\",\n    \"multimedia_assets\": [\n      {\n        \"type\": \"image\",\n        \"url\": \"https://news.example.com/images/climate.jpg\",\n        \"caption\": \"Activists rallying for climate change policies\",\n        \"dimensions\": {\n          \"width\": 1920,\n          \"height\": 1080\n        }\n      },\n      {\n        \"type\": \"video\",\n        \"url\": \"https://news.example.com/videos/climate_march.mp4\",\n        \"caption\": \"Highlights from the global climate march\",\n        \"duration_seconds\": 120\n      }\n    ],\n    \"related_tags\": [\n      \"Climate Change\",\n      \"Environment\",\n      \"Global Policy\"\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Digital News Article Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Dimensions:\\n      type: object\\n      description: 'Dimensions of a multimedia asset in pixels'\\n      properties:\\n        width:\\n          type: integer\\n          description: 'Width in pixels'\\n          example: 1920\\n        height:\\n          type: integer\\n          description: 'Height in pixels'\\n          example: 1080\\n    MultimediaAsset:\\n      type: object\\n      description: 'Embedded multimedia asset associated with the article'\\n      properties:\\n        type:\\n          type: string\\n          description: 'Type of multimedia asset (e.g., image, video)'\\n          example: 'image'\\n        url:\\n          type: string\\n          format: uri\\n          description: 'URL to access the multimedia content'\\n          example: 'https://news.example.com/images/climate.jpg'\\n        caption:\\n          type: string\\n          description: 'Caption describing the multimedia content'\\n          example: 'Activists rallying for climate change policies'\\n        dimensions:\\n         