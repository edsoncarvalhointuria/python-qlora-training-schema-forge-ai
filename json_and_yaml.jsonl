r of the courier'\\n          example: 'CR7890'\\n        name:\\n          type: string\\n          description: 'Full name of the courier'\\n          example: 'John Doe'\\n        real_time_location:\\n          $ref: '#/components/schemas/RealTimeLocation'\\n    Restaurant:\\n      type: object\\n      description: 'Profile information of the restaurant'\\n      properties:\\n        restaurant_id:\\n          type: string\\n          description: 'Unique identifier of the restaurant'\\n          example: 'REST1001'\\n        name:\\n          type: string\\n          description: 'Name of the restaurant'\\n          example: 'Gourmet Bites'\\n        address:\\n          type: string\\n          description: 'Physical address of the restaurant'\\n          example: '123 Food St, Flavor Town, FT 45678'\\n        phone:\\n          type: string\\n          description: 'Contact phone number of the restaurant'\\n          example: '+1-234-567-8900'\\n        rating:\\n          type: number\\n          format: float\\n          description: 'Average customer rating of the restaurant'\\n          example: 4.7\\n        cuisine_types:\\n          type: array\\n          description: 'Types of cuisine served'\\n          items:\\n            type: string\\n            example: 'Italian'\\n    OrderedDish:\\n      type: object\\n      description: 'Details of each dish ordered'\\n      properties:\\n        dish_id:\\n          type: string\\n          description: 'Unique identifier for the dish'\\n          example: 'DISH500'\\n        name:\\n          type: string\\n          description: 'Name of the dish'\\n          example: 'Margherita Pizza'\\n        quantity:\\n          type: integer\\n          description: 'Number of units ordered'\\n          example: 1\\n        special_dietary_notes:\\n          type: string\\n          description: 'Special dietary instructions or notes for the dish'\\n          example: 'Gluten-Free Crust'\\n    OrderStatus:\\n      type: object\\n      description: 'Status and details of the food delivery order'\\n      properties:\\n        order_id:\\n          type: string\\n          description: 'Unique identifier for the order'\\n          example: 'ORD123456'\\n        status:\\n          type: string\\n          description: 'Current status of the order'\\n          example: 'Out for Delivery'\\n        courier:\\n          $ref: '#/components/schemas/Courier'\\n        restaurant:\\n          $ref: '#/components/schemas/Restaurant'\\n        ordered_dishes:\\n          type: array\\n          description: 'List of dishes included in the order'\\n          items:\\n            $ref: '#/components/schemas/OrderedDish'\\npaths: {}\\n\"\n}"
