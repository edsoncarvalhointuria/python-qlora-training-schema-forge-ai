tion\\\": \\\"Physical dimensions of the product\\\",\\n        \\\"properties\\\": {\\n          \\\"length\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Length in centimeters\\\",\\n            \\\"example\\\": 15.0\\n          },\\n          \\\"width\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Width in centimeters\\\",\\n            \\\"example\\\": 4.5\\n          },\\n          \\\"height\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Height in centimeters\\\",\\n            \\\"example\\\": 3.0\\n          }\\n        },\\n        \\\"required\\\": [\\\"length\\\", \\\"width\\\", \\\"height\\\"]\\n      },\\n      \\\"TechnicalSpecs\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Technical specifications detailing product attributes\\\",\\n        \\\"properties\\\": {\\n          \\\"weight_kg\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Weight in kilograms\\\",\\n            \\\"example\\\": 0.75\\n          },\\n          \\\"dimensions_cm\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Dimensions\\\"\\n          },\\n          \\\"material\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Primary material of the product\\\",\\n            \\\"example\\\": \\\"Stainless Steel\\\"\\n          },\\n          \\\"warranty_months\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Warranty duration in months\\\",\\n            \\\"example\\\": 24\\n          }\\n        },\\n        \\\"required\\\": [\\\"weight_kg\\\", \\\"dimensions_cm\\\", \\\"material\\\", \\\"warranty_months\\\"]\\n      },\\n      \\\"StockLevels\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Stock availability counts across multiple regions\\\",\\n        \\\"properties\\\": {\\n          \\\"north_america\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Stock count in North America\\\",\\n            \\\"example\\\": 150\\n          },\\n          \\\"europe\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Stock count in Europe\\\",\\n            \\\"example\\\": 80\\n          },\\n          \\\"asia\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Stock count in Asia\\\",\\n            \\\"example\\\": 120\\n          }\\n        },\\n        \\\"required\\\": [\\\"north_america\\\", \\\"europe\\\", \\\"asia\\\"]\\n      },\\n      \\\"ProductInventory\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Inventory details per product\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the product\\\",\\n            \\\"example\\\": \\\"prd_1001\\\"\\n          },\\n          \\\"product_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Official product name\\\",\\n            \\\"example\\\": \\\"MultiTool Pro\\\"\\n          },\\n          \\\"technical_specs\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/TechnicalSpecs\\\"\\n          },\\n          \\\"stock_levels\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/StockLevels\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"product_id\\\", \\\"product_name\\\", \\\"technical_specs\\\", \\\"stock_levels\\\"]\\n      },\\n      \\\"InventoryResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Root response containing warehouse info and product inventories\\\",\\n        \\\"properties\\\": {\\n          \\\"warehouse\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Warehouse\\\"\\n          },\\n          \\\"inventory\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of products with inventory details\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/ProductInventory\\\"\\n            },\\n            \\\"example\\\": [\\n              {\\n                \\\"product_id\\\": \\\"prd_1001\\\",\\n                \\\"product_name\\\": \\\"MultiTool Pro\\\",\\n                \\\"technical_specs\\\": {\\n                  \\\"weight_kg\\\": 0.75,\\n                  \\\"dimensions_cm\\\": {\\n                    \\\"length\\\": 15.0,\\n                    \\\"width\\\": 4.5,\\n                    \\\"height\\\": 3.0\\n                  },\\n                  \\\"material\\\": \\\"Stainless Steel\\\",\\n                  \\\"warranty_months\\\": 24\\n                },\\n                \\\"stock_levels\\\": {\\n                  \\\"north_america\\\": 150,\\n                  \\\"europe\\\": 80,\\n                  \\\"asia\\\": 120\\n                }\\n              },\\n              {\\n                \\\"product_id\\\": \\\"prd_1002\\\",\\n                \\\"product_name\\\": \\\"UltraFast SSD 1TB\\\",\\n                \\\"technical_specs\\\": {\\n                  \\\"weight_kg\\\": 0.05,\\n                  \\\"dimensions_cm\\\": {\\n                    \\\"length\\\": 7.0,\\n                    \\\"width\\\": 5.0,\\n                    \\\"height\\\": 0.7\\n                  },\\n                  \\\"material\\\": \\\"Aluminum\\\",\\n                  \\\"warranty_months\\\": 36\\n                },\\n                \\\"stock_levels\\\": {\\n                  \\\"north_america\\\": 300,\\n                  \\\"europe\\\": 220,\\n                  \\\