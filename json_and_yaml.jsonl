"{\n  \"raw_json\": {\n    \"daily_active_users\": 1243,\n    \"feature_usage\": [\n      {\n        \"feature_name\": \"Dashboard\",\n        \"usage_count\": 875,\n        \"unique_users\": 450\n      },\n      {\n        \"feature_name\": \"Reports\",\n        \"usage_count\": 623,\n        \"unique_users\": 378\n      }\n    ],\n    \"subscription_tier_limits\": {\n      \"max_users\": 1000,\n      \"max_projects\": 50,\n      \"max_storage_gb\": 500\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: SaaS User Analytics Report\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FeatureUsageMetric:\\n      type: object\\n      description: 'Metrics related to a specific feature usage'\\n      properties:\\n        feature_name:\\n          type: string\\n          description: 'Name of the SaaS platform feature'\\n          example: 'Dashboard'\\n        usage_count:\\n          type: integer\\n          description: 'Total times the feature was used on the given day'\\n          example: 875\\n        unique_users:\\n          type: integer\\n          description: 'Number of unique users who used the feature'\\n          example: 450\\n    SubscriptionTierLimits:\\n      type: object\\n      description: 'Limits related to the subscription tier of the user account'\\n      properties:\\n        max_users:\\n          type: integer\\n          description: 'Maximum number of users allowed under the subscription'\\n          example: 1000\\n        max_projects:\\n          type: integer\\n          description: 'Maximum number of projects allowed under the subscription'\\n          example: 50\\n        max_storage_gb:\\n          type: integer\\n          description: 'Maximum storage space allowed (in GB) under the subscription'\\n          example: 500\\n    UserAnalyticsReport:\\n      type: object\\n      description: 'Daily user analytics report for the SaaS platform'\\n      properties:\\n        daily_active_users:\\n          type: in