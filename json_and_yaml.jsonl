"{\n  \"raw_json\": {\n    \"receipt_id\": \"rcpt_7890\",\n    \"virtual_currency\": {\n      \"currency_type\": \"Gems\",\n      \"amount_purchased\": 500,\n      \"base_price_usd\": 4.99\n    },\n    \"promotional_multiplier\": {\n      \"multiplier\": 1.5,\n      \"description\": \"Holiday season bonus\"\n    },\n    \"cosmetic_items_unlocked\": [\n      {\n        \"item_id\": \"cos_1001\",\n        \"name\": \"Dragon Slayer Sword\",\n        \"rarity\": \"Epic\",\n        \"unlock_method\": \"direct_purchase\"\n      },\n      {\n        \"item_id\": \"cos_1002\",\n        \"name\": \"Festive Hat\",\n        \"rarity\": \"Rare\",\n        \"unlock_method\": \"bonus_reward\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Mobile Game Microtransaction Receipt\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"VirtualCurrency\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details about the purchased virtual currency\\\",\\n        \\\"properties\\\": {\\n          \\\"currency_type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Type of virtual currency purchased\\\",\\n            \\\"example\\\": \\\"Gems\\\"\\n          },\\n          \\\"amount_purchased\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of virtual currency units purchased\\\",\\n            \\\"example\\\": 500\\n          },\\n          \\\"base_price_usd\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Base price paid in USD before any multipliers\\\",\\n            \\\"example\\\": 4.99\\n          }\\n        },\\n        \\\"required\\\": [\\\"currency_type\\\", \\\"amount_purchased\\\", \\\"base_price_usd\\\"]\\n      },\\n      \\\"PromotionalMultiplier\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Promotional multiplier applied to the purchase\\\",\\n        \\\"properties\\\": {\\n          \\\"multiplier\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Factor by which the purchased currency amount is multiplied\\\",\\n            \\\"example\\\": 1.5\\n          },\\n          \\\"description\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Explanation or name of the promotional multiplier\\\",\\n            \\\"example\\\": \\\"Holiday season bonus\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"multiplier\\\", \\\"description\\\"]\\n      },\\n      \\\"CosmeticItem\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Unlocked cosmetic item details\\\",\\n        \\\"properties\\\": {\\n          \\\"item_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier of the cosmetic item\\\",\\n            \\\"example\\\": \\\"cos_1001\\\"\\n          },\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Name of the cosmetic item\\\",\\n            \\\"example\\\": \\\"Dragon Slayer Sword\\\"\\n          },\\n          \\\"rarity\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Rarity level of the cosmetic item\\\",\\n            \\\"example\\\": \\\"Epic\\\"\\n          },\\n          \\\"unlock_method\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Method through which the cosmetic item was unlocked\\\",\\n            \\\"example\\\": \\\"direct_purchase\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"item_id\\\", \\\"name\\\", \\\"rarity\\\", \\\"unlock_method\\\"]\\n      },\\n      \\\"MicrotransactionReceipt\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detailed receipt of a mobile game microtransaction\\\",\\n        \\\"properties\\\": {\\n          \\\"receipt_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique receipt identifier\\\",\\n            \\\"example\\\": \\\"rcpt_7890\\\"\\n          },\\n          \\\"virtual_currency\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/VirtualCurrency\\\"\\n          },\\n          \\\"promotional_multiplier\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/PromotionalMultiplier\\\"\\n          },\\n          \\\"cosmetic_items_unlocked\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of cosmetic items unlocked by this purchase\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/CosmeticItem\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"receipt_id\\\", \\\"virtual_currency\\\", \\\"promotional_multiplier\\\", \\\"cosmetic_items_unlocked\\\"]\\n      }\\n    }\\n  }\\n}\"\n}"
