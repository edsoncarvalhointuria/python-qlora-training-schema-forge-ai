lected\\\",\\n            \\\"example\\\": \\\"Vegetarian\\\"\\n          },\\n          \\\"special_requests\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Additional meal requests or restrictions\\\",\\n            \\\"example\\\": \\\"No nuts\\\"\\n          }\\n        }\\n      },\\n      \\\"FlightBookingConfirmation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Airline flight booking confirmation details\\\",\\n        \\\"properties\\\": {\\n          \\\"confirmation_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique booking confirmation identifier\\\",\\n            \\\"example\\\": \\\"CONF123456\\\"\\n          },\\n          \\\"passenger\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Passenger\\\"\\n          },\\n          \\\"itinerary\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/Itinerary\\\"\\n          },\\n          \\\"seat_upgrades\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of selected seat upgrades\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/SeatUpgrade\\\"\\n            }\\n          },\\n          \\\"meal_preferences\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of meal preferences\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/MealPreference\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {},\\n  \\\"schemas\\\": {},\\n  \\\"paths\\\": {},\\n  \\\"servers\\\": []\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"property\": {\n      \"id\": \"prop_12345\",\n      \"title\": \"Spacious Modern Apartment\",\n      \"description\": \"A beautifully designed modern apartment located in the city center.\",\n      \"price\": 850000,\n      \"architecturalSpecs\": {\n        \"area\": 120.5,\n        \"bedrooms\": 3,\n        \"bathrooms\": 2,\n        \"flooring\": \"Hardwood\",\n        \"yearBuilt\": 2019\n      },\n      \"images\": [\n        {\n          \"url\": \"https://example.com/images/property1_img1_highres.jpg\",\n          \"description\": \"Front view of the apartment\"\n        },\n        {\n          \"url\": \"https://example.com/images/property1_img2_highres.jpg\",\n          \"description\": \"Living room\"\n        },\n        {\n          \"url\": \"https://example.com/images/property1_img3_highres.jpg\",\n          \"description\": \"Master bedroom\"\n        }\n      ],\n      \"realtor\": {\n        \"id\": \"realtor_987\",\n        \"name\": \"Carlos Souza\",\n        \"phone\": \"+55 11 91234-5678\",\n        \"email\": \"carlos.souza@realestate.com.br\"\n      }\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Property Listing API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Especificações arquitetônicas da propriedade'\\n      properties:\\n        area:\\n          type: number\\n          description: 'Área total em metros quadrados'\\n          example: 120.5\\n        bedrooms:\\n          type: integer\\n          description: 'Número de quartos'\\n          example: 3\\n        bathrooms:\\n          type: integer\\n          description: 'Número de banheiros'\\n          example: 2\\n        flooring:\\n          type: string\\n          description: 'Tipo de piso'\\n          example: Hardwood\\n        yearBuilt:\\n          type: integer\\n          description: 'Ano de construção'\\n          example: 2019\\n    Image:\\n      type: object\\n      description: 'Imagem de alta resolução da propriedade'\\n      properties:\\n        url:\\n          type: string\\n          format: uri\\n          description: 'URL da imagem em alta resolução'\\n          example: 'https://example.com/images/property1_img1_highres.jpg'\\n        description:\\n          type: string\\n          description: 'Descrição da imagem'\\n          example: 'Front view of the apartment'\\n    Realtor:\\n      type: object\\n      description: 'Informações de contato do corretor'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Identificador único do corretor'\\n          example: 'realtor_987'\\n        name:\\n          type: string\\n          description: 'Nome completo do corretor'\\n          example: 'Carlos Souza'\\n        phone:\\n          type: string\\n          description: 'Número de telefone do corretor'\\n          example: '+55 11 91234-5678'\\n        email:\\n          type: string\\n          format: email\\n          description: 'E-mail do corretor'\\n          example: 'carlos.souza@realestate.com.br'\\n    Property:\\n      type: object\\n      description: 'Informações detalhadas da propriedade'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Identificador único da propriedade'\\n          example: 'prop_12345'\\n        title:\\n          type: string\\n          description: 'Título ou nome da propriedade'\\n          example: 'Spacious Modern Apartment'\\n        description:\\n          type: string\\n          description: 'Descrição detalhada da propriedade'\\n          example: 'A beautifully designed modern apartment located in the city center.'\\n        price:\\n          type: number\\n          description: 'Preço da propriedade em reais'\\n          example: 850000\\n        architecturalSpecs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n     