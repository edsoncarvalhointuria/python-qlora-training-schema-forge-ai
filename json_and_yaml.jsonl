           \\\"example\\\": \\\"GRU\\\"\\n          },\\n          \\\"arrival_airport\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código IATA do aeroporto de chegada\\\",\\n            \\\"example\\\": \\\"JFK\\\"\\n          },\\n          \\\"departure_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora de partida\\\",\\n            \\\"example\\\": \\\"2024-07-05T14:30:00-03:00\\\"\\n          },\\n          \\\"arrival_time\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Data e hora de chegada\\\",\\n            \\\"example\\\": \\\"2024-07-05T20:15:00-04:00\\\"\\n          },\\n          \\\"layovers\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de escalas para o trecho\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Layover\\\"\\n            }\\n          }\\n        }\\n      },\\n      \\\"Itinerary\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações completas do itinerário\\\",\\n        \\\"properties\\\": {\\n          \\\"segments\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de trechos do voo\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/ItinerarySegment\\\"\\n            }\\n          }\\n        }\\n      },\\n      \\\"SeatUpgrade\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes de uma melhoria de assento selecionada\\\",\\n        \\\"properties\\\": {\\n          \\\"type\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Tipo de melhoria de assento\\\",\\n            \\\"example\\\": \\\"Extra Legroom\\\"\\