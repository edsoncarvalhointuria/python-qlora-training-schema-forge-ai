         \\\"recent_anomalies\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista das anomalias recentes identificadas durante a condução.\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Anomaly\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {}\\n}\"\n}"
