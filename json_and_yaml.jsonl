"{\n  \"raw_json\": {\n    \"property_id\": \"A12345\",\n    \"title\": \"Modern Family Home with Garden\",\n    \"address\": \"123 Rua das Flores, São Paulo, SP, 04567-890\",\n    \"price\": 1250000.00,\n    \"architectural_specs\": {\n      \"area_sq_meters\": 180,\n      \"bedrooms\": 4,\n      \"bathrooms\": 3,\n      \"has_garage\": true,\n      \"year_built\": 2019,\n      \"flooring\": \"Porcelain tiles\"\n    },\n    \"images\": [\n      {\n        \"description\": \"Front view during daylight\",\n        \"urls\": [\n          \"https://realestate.example.com/images/property_A12345/front_day_small.jpg\",\n          \"https://realestate.example.com/images/property_A12345/front_day_medium.jpg\",\n          \"https://realestate.example.com/images/property_A12345/front_day_large.jpg\"\n        ]\n      },\n      {\n        \"description\": \"Backyard and garden area\",\n        \"urls\": [\n          \"https://realestate.example.com/images/property_A12345/backyard_small.jpg\",\n          \"https://realestate.example.com/images/property_A12345/backyard_medium.jpg\",\n          \"https://realestate.example.com/images/property_A12345/backyard_large.jpg\"\n        ]\n      }\n    ],\n    \"realtor\": {\n      \"name\": \"Carla Souza\",\n      \"phone\": \"+55 11 91234-5678\",\n      \"email\": \"carla.souza@imoveisbr.com\",\n      \"license_number\": \"CREA-SP 123456\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Property Listing API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ArchitecturalSpecs:\\n      type: object\\n      description: 'Especificações arquitetônicas detalhadas da propriedade'\\n      properties:\\n        area_sq_meters:\\n          type: integer\\n          description: 'Área total da propriedade em metros quadrados'\\n          example: 180\\n        bedrooms:\\n          type: integer\\n          description: 'Número de quartos disponíveis'\\n          example: 4\\n        bathrooms:\\n          type: integer\\n          description: 'Número de banheiros disponíveis'\\n          example: 3\\n        has_garage:\\n          type: boolean\\n          description: 'Indica se a propriedade possui garagem'\\n          example: true\\n        year_built:\\n          type: integer\\n          description: 'Ano de construção da propriedade'\\n          example: 2019\\n        flooring:\\n          type: string\\n          description: 'Tipo de piso instalado na propriedade'\\n          example: 'Porcelain tiles'\\n    ImageURLs:\\n      type: object\\n      description: 'URLs de imagens em diferentes resoluções associadas a uma descrição'\\n      properties:\\n        description:\\n          type: string\\n          description: 'Descrição da imagem ou do ângulo da foto'\\n          example: 'Front view during daylight'\\n        urls:\\n          type: array\\n          description: 'Lista de URLs das imagens em múltiplas resoluções'\\n          items:\\n            type: string\\n            format: uri\\n            description: 'URL da imagem'\\n            example: 'https://realestate.example.com/images/property_A12345/front_day_small.jpg'\\n    RealtorContact:\\n      type: object\\n      description: 'Informações de contato do corretor responsável pela propriedade'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Nome completo do corretor'\\n          example: 'Carla Souza'\\n        phone:\\n          type: string\\n          description: 'Número de telefone para contato'\\n          example: '+55 11 91234-5678'\\n        email:\\n          type: string\\n          format: email\\n          description: 'Endereço de email profissional do corretor'\\n          example: 'carla.souza@imoveisbr.com'\\n        license_number:\\n          type: string\\n          description: 'Número da licença profissional do corretor'\\n          example: 'CREA-SP 123456'\\n    PropertyListing:\\n      type: object\\n      description: 'Representa uma listagem completa de propriedade imobiliária'\\n      properties:\\n        property_id:\\n          type: string\\n          description: 'Identificador único da propriedade'\\n          example: 'A12345'\\n        title:\\n          type: string\\n          description: 'Título resumido da listagem da propriedade'\\n          example: 'Modern Family Home with Garden'\\n        address:\\n          type: string\\n          description: 'Endereço completo da propriedade'\\n          example: '123 Rua das Flores, São Paulo, SP, 04567-890'\\n        price:\\n          type: number\\n          format: double\\n          description: 'Preço atual de venda ou locação da propriedade'\\n          example: 1250000.00\\n        architectural_specs:\\n          $ref: '#/components/schemas/ArchitecturalSpecs'\\n        images:\\n          type: array\\n          description: 'Conjunto de imagens associadas à propriedade organizadas por descrições'\\n          items:\\n            $ref: '#/components/schemas/ImageURLs'\\n        realtor:\\n          $ref: '#/components/schemas/RealtorContact'\\n\"\n}"
"{\n  \"raw_json\": {\n    \"reservation_id\": \"res_789\",\n    \"room_type\": \"Deluxe Suite\",\n    \"pricing_breakdown\": {\n      \"base_rate_per_night\": 250.00,\n      \"taxes\": 37.50,\n      \"service_fees\": 20.00,\n      \"total_per_night\": 307.50,\n      \"nights\": 3,\n      \"total_price\": 922.50\n    },\n    \"requested_amenities\": [\n      {\n        \"amenity_type\": \"crib\",\n        \"quantity\": 1,\n        \"additional_cost\": 0.00\n      },\n      {\n        \"amenity_type\": \"extra_bed\",\n        \"quantity\": 1,\n        \"additional_cost\": 50.00\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Hotel Reservation Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PricingBreakdown\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detailed pricing information per night\\\",\\n        \\\"properties\\\": {\\n          \\\"base_rate_per_night\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Base price per night in USD\\\",\\n            \\\"example\\\": 250.00\\n          },\\n          \\\"taxes\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Applicable taxes per night in USD\\\",\\n            \\\"example\\\": 37.50\\n          },\\n          \\\"service_fees\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Service fees per night in USD\\\",\\n            \\\"example\\\": 20.00\\n          },\\n          \\\"total_per_night\\\": {\\n            \\\"type\\\": \\\"number\\\",\\n            \\\"format\\\": \\\"float\\\",\\n            \\\"description\\\": \\\"Total price per night in USD including base rate, t