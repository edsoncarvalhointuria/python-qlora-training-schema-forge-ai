igo'\\n          example: 'New Advances in Renewable Energy Technology'\\n        author:\\n          $ref: '#/components/schemas/Author'\\n        multimedia:\\n          type: array\\n          description: 'Lista de assets multimídia incorporados no artigo'\\n          items:\\n            $ref: '#/components/schemas/MultimediaAsset'\\n        tags:\\n          type: array\\n          description: 'Etiquetas relacionadas ao artigo para categorização'\\n          items:\\n            type: string\\n            example: 'Renewable Energy'\"\n}"
