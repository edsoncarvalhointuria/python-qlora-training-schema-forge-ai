"{\n  \"raw_json\": {\n    \"patient\": {\n      \"patient_id\": \"P123456\",\n      \"name\": \"John Doe\",\n      \"age\": 45,\n      \"gender\": \"Male\",\n      \"date_of_birth\": \"1978-03-25\"\n    },\n    \"blood_biomarkers\": [\n      {\n        \"biomarker_name\": \"Hemoglobin\",\n        \"result_value\": 13.5,\n        \"unit\": \"g/dL\",\n        \"normal_range\": {\n          \"min\": 13.0,\n          \"max\": 17.0\n        }\n      },\n      {\n        \"biomarker_name\": \"White Blood Cell Count\",\n        \"result_value\": 6.8,\n        \"unit\": \"10^3/µL\",\n        \"normal_range\": {\n          \"min\": 4.0,\n          \"max\": 11.0\n        }\n      },\n      {\n        \"biomarker_name\": \"Platelets\",\n        \"result_value\": 250,\n        \"unit\": \"10^3/µL\",\n        \"normal_range\": {\n          \"min\": 150,\n          \"max\": 400\n        }\n      }\n    ],\n    \"pathologist_signature\": {\n      \"name\": \"Dr. Alice Smith\",\n      \"signature_date\": \"2024-06-15T10:30:00Z\",\n      \"digital_signature_hash\": \"a3f5e9b4c7d01e2f3a59b7e8d9c4f6a1\"\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Hospital Laboratory Test Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PatientDemographics:\\n      type: object\\n      description: 'The patient's demographic details'\\n      properties:\\n        patient_id:\\n          type: string\\n          description: 'Unique identifier for the patient'\\n          example: 'P123456'\\n        name:\\n          type: string\\n          description: 'Full name of the patient'\\n          example: 'John Doe'\\n        age:\\n          type: integer\\n          description: 'Age of the patient in years'\\n          example: 45\\n        gender:\\n          type: string\\n          description: 'Gender of the patient'\\n          example: 'Male'\\n        date_of_birth:\\n          type: string\\n          format: date\\n          description: 'The date when the patient was born'\\n          example: '1978-03-25'\\n    NormalRange:\\n      type: object\\n      description: 'Defines the normal range for a biomarker'\\n      properties:\\n        min:\\n          type: number\\n          description: 'Minimum normal value for the biomarker'\\n          example: 13.0\\n        max:\\n          type: number\\n          description: 'Maximum normal value for the biomarker'\\n          example: 17.0\\n    BloodBiomarker:\\n      type: object\\n      description: 'Individual blood biomarker test result with unit and normal range'\\n      properties:\\n        biomarker_name:\\n          type: string\\n          description: 'Name of the blood biomarker'\\n          example: 'Hemoglobin'\\n        result_value:\\n          type: number\\n          description: 'Measured value of the biomarker in the test'\\n          example: 13.5\\n        unit:\\n          type: string\\n          description: 'Unit of measurement for the biomarker'\\n          example: 'g/dL'\\n        normal_range:\\n          $ref: '#/components/schemas/NormalRange'\\n    PathologistSignature:\\n      type: object\\n      description: 'Digital signature details of the reviewing pathologist'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Name of the pathologist reviewing the test results'\\n          example: 'Dr. Alice Smith'\\n        signature_date:\\n          type: string\\n          format: date-time\\n          description: 'Date and time when the pathologist signed the results'\\n          example: '2024-06-15T10:30:00Z'\\n        digital_signature_hash:\\n          type: string\\n          description: 'Hash representing the digital signature of the pathologist'\\n          example: 'a3f5e9b4c7d01e2f3a59b7e8d9c4f6a1'\\n    LabTestResult:\\n      type: object\\n      description: 'Complete laboratory test result including patient info, biomarker results, and digital signature'\\n      properties:\\n        patient: