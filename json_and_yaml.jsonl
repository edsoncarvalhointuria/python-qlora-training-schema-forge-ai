": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Author of the book\\\",\\n            \\\"example\\\": \\\"Jane Doe\\\"\\n          },\\n          \\\"publication_year\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Year when the book was published\\\",\\n            \\\"example\\\": 2022\\n          },\\n          \\\"copies\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of physical copies with location and status\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Copy\\\"\\n            }\\n          },\\n          \\\"digital_borrowing\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DigitalBorrowing\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"isbn\\\", \\\"title\\\", \\\"author\\\", \\\"publication_year\\\", \\\"copies\\\", \\\"digital_borrowing\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {}\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"artist_id\": \"artist_102\",\n    \"name\": \"Echo Harmony\",\n    \"biography\": \"Echo Harmony is an indie pop artist known for her ethereal vocals and poetic lyrics.\",\n    \"top_streamed_tracks\": [\n      {\n        \"track_id\": \"track_501\",\n        \"title\": \"Whispers in the Wind\",\n        \"duration_seconds\": 215,\n        \"streams\": 1250000\n      },\n      {\n        \"track_id\": \"track_502\",\n        \"title\": \"Silent Echoes\",\n        \"duration_seconds\": 189,\n        \"streams\": 980000\n      }\n    ],\n    \"upcoming_tour\": {\n      \"tour_name\": \"Echoes of Summer\",\n      \"dates\": [\n        {\n          \"city\": \"New York\",\n          \"date\": \"2024-08-15\",\n          \"venue\": \"Madison Square Garden\"\n        },\n        {\n          \"city\": \"Los Angeles\",\n          \"date\": \"2024-08-22\",\n          \"venue\": \"Hollywood Bowl\"\n        }\n      ]\n    }\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: Artist Profile API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Track:\\n      type: object\\n      description: 'Details of a single music track'\\n      properties:\\n        track_id:\\n          type: string\\n          description: 'Unique identifier for the track'\\n          example: 'track_501'\\n        title:\\n          type: string\\n          description: 'Title of the track'\\n          example: 'Whispers in the Wind'\\n        duration_seconds:\\n          type: integer\\n          description: 'Duration of the track in seconds'\\n          example: 215\\n        streams:\\n          type: integer\\n          description: 'Number of times the track has been streamed'\\n          example: 1250000\\n    TourDate:\\n      type: object\\n      description: 'Individual concert date details in a tour'\\n      properties:\\n        city:\\n          type: string\\n          description: 'City where the concert is held'\\n          example: 'New York'\\n        date:\\n          type: string\\n          format: date\\n          description: 'Date of the concert in YYYY-MM-DD format'\\n          example: '2024-08-15'\\n        venue:\\n          type: string\\n          description: 'Venue name of the concert'\\n          example: 'Madison Square Garden'\\n    UpcomingTour:\\n      type: object\\n      description: 'Information about upcoming tour including name and dates'\\n      properties:\\n        tour_name:\\n          type: string\\n          description: 'Name of the upcoming tour'\\n          example: 'Echoes of Summer'\\n        dates:\\n          type: array\\n          description: 'List of dates and locations of concerts within the tour'\\n          items:\\n            $ref: '#/components/schemas/TourDate'\\n    ArtistProfile:\\n      type: object\\n      description: 'Comprehensive profile data of a music artist'\\n      properties:\\n        artist_id:\\n          type: string\\n          description: 'Unique identifier for the artist'\\n          example: 'artist_102'\\n        name:\\n          type: string\\n          description: 'Full name of the artist or band'\\n          example: 'Echo Harmony'\\n        biography:\\n          type: string\\n          description: 'Biographical summary of the artist'\\n          example: 'Echo Harmony is an indie pop artist known for her ethereal vocals and poetic lyrics.'\\n        top_streamed_tracks:\\n          type: array\\n          description: 'List of the artist’s top streamed tracks'\\n          items:\\n            $ref: '#/components/schemas/Track'\\n        upcoming_tour:\\n          $ref: '#/components/schemas/UpcomingTour'\\npaths: {}\"\n}"
"{\n  \"raw_json\": {\n    \"posts\": [\n      {\n        \"post_id\": \"post_001\",\n        \"author\": {\n          \"user_id\": \"user_123\",\n          \"username\": \"john_doe\"\n        },\n        \"content\": \"Enjoying the sunny weather at the beach!\",\n        \"timestamp\": \"2024-06-12T10:15:30Z\",\n        \"comments\": [\n          {\n            \"comment_id\": \"comm_1001\",\n            \"user\": {\n              \"user_id\": \"user_234\",\n              \"username\": \"jane_smith\"\n            },\n            \"comment_text\": \"Looks great! Wish I was there.\",\n            \"timestamp\": \"2024-06-12T10:45:00Z\"\n          },\n          {\n            \"comment_id\": \"comm_1002\",\n            \"user\": {\n              \"user_id\": \"user_345\",\n              \"username\": \"bobby88\"\n            },\n            \"comment_text\": \"Have fun and stay safe!\",\n            \"timestamp\": \"2024-06-12T11:00:00Z\"\n          }\n        ],\n        \"liked_by\": [\n          {\n            \"user_id\": \"user_876\",\n            \"username\": \"alice_w\"\n          },\n          {\n            \"user_id\": \"user_432\",\n            \"username\": \"charlie_p\"\n          }\n        ]\n      },\n      {\n        \"post_id\": \"post_002\",\n        \"author\": {\n          \"user_id\": \"user_789\",\n          \"username\": \"emma.k\"\n        },\n        \"content\": \"Just finished a marathon, feeling accomplished!\",\n        \"timestamp\": \"2024-06-11T07:20:00Z\",\n        \"comments\": [],\n        \"liked_by\": [\n          {\n            \"user_id\": \"user_123\",\n            \"username\": \"john_doe\"\n          }\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Social Media User Feed\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"UserSnippet\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Basic information about a user\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the user\\\",\\n            \\\"example\\\": \\\"user_123\\\"\\n          },\\n          \\\"username\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"User's username handle\\\",\\n            \\\"example\\\": \\\"john_doe\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"user_id\\\", \\\"username\\\"]\\n      },\\n      \\\"Comment\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"A comment on a post\\\",\\n        \\\"properties\\\": {\\n          \\\"comment_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the comment\\\",\\n            \\\"example\\\": \\\"comm_1001\\\"\\n          },\\n          \\\"user\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n          },\\n          \\\"comment_text\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Text content of the comment\\\",\\n            \\\"example\\\": \\\"Looks great! Wish I was there.\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Timestamp when the comment was posted\\\",\\n            \\\"example\\\": \\\"2024-06-12T10:45:00Z\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"comment_id\\\", \\\"user\\\", \\\"comment_text\\\", \\\"timestamp\\\"]\\n      },\\n      \\\"Post\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"A single post in the user feed\\\",\\n        \\\"properties\\\": {\\n          \\\"post_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the post\\\",\\n            \\\"example\\\": \\\"post_001\\\"\\n          },\\n          \\\"author\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n          },\\n          \\\"content\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Main content text of the post\\\",\\n            \\\"example\\\": \\\"Enjoying the sunny weather at the beach!\\\"\\n          },\\n          \\\"timestamp\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Timestamp when the post was created\\\",\\n            \\\"example\\\": \\\"2024-06-12T10:15:30Z\\\"\\n          },\\n          \\\"comments\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of comments associated with the post\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Comment\\\"\\n            }\\n          },\\n          \\\"liked_by\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of users who liked the post\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/UserSnippet\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"post_id\\\", \\\"author\\\", \\\"content\\\", \\\"timestamp\\\", \\\"comments\\\", \\\"liked_by\\\"]\\n      },\\n      \\\"UserFeedResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response object containing a list of posts for a user's feed\\\",\\n        \\\"properties\\\": {\\n          \\\"posts\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of posts in the user feed\\\",\\n            \\\"items\\\": {\\n              \\\"$ref\\\": \\\"#/components/schemas/Post\\\"\\n            }\\n          }\\n        },\\n        \\\"required\\\": [\\\"posts\\\"]\\n      }\\n    }\\n  },\\n  \\\"paths\\\": {},\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {}\\n  },\\n  \\\"definitions\\\": {},\\n  \\\"$schema\\\": \\\"http://json-schema.org/draft-07/schema#\\\",\\n  \\\"example\\\": {\\n    \\\"$ref\\\": \\\"#/components/schemas/UserFeedResponse\\\"\\n  }\\n}\"\n}"
"{\n  \"raw_json\": {\n    \"headline\": \"Breaking Innovation in Renewable Energy\",\n    \"author\": {\n      \"name\": \"Jane Smith\",\n      \"email\": \"jane.smith@example.com\"\n    },\n    \"multimedia\": [\n      {\n        \"type\": \"image\",\n        \"url\": \"https://example.com/images/renewable-energy.jpg\",\n        \"caption\": \"Solar panels under bright sunlight\"\n      },\n      {\n        \"type\": \"video\",\n        \"url\": \"https://example.com/videos/solar-installation.mp4\",\n        \"caption\": \"Installation process overview\"\n      }\n    ],\n    \"tags\": [\"energy\", \"renewables\", \"sustainability\", \"innovation\"]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: News Article API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Author:\\n      type: object\\n      description: 'Information about the article author'\\n      properties:\\n        name:\\n          type: string\\n          description: 'Full name of the article author'\\n          example: 'Jane Smith'\\n        email:\\n          type: string\\n          description: 'Email address of the author'\\n          example: 'jane.smith@example.com'\\n    MultimediaAsset:\\n      type: object\\n      description: 'Represents an embedded multimedia asset in the article'\\n      properties:\\n        type:\\n          type: string\\n          description: 'Type of multimedia, e.g., image, video'\\n          example: 'image'\\n        url:\\n          type: string\\n          format: uri\\n          description: 'URL to the multimedia asset'\\n          example: 'https://example.com/images/renewable-energy.jpg'\\n        caption:\\n          type: string\\n          description: 'Caption describing the multimedia asset'\\n          example: 'Solar panels under bright sunlight'\\n    NewsArticle:\\n      type: object\\n      description: 'Digital news publication article response'\\n      properties:\\n        headline:\\n          type: string\\n          description: 'The main headline of the news article'\\n          example: 'Breaking Innovation in Renewable Energy'\\n        author:\\n          $ref: '#/components/schemas/Author'\\n        multimedia:\\n          type: array\\n          description: 'List of embedded multimedia assets in the article'\\n          items:\\n            $ref: '#/components/schemas/MultimediaAsset'\\n        tags:\\n          type: array\\n          description: 'Related article tags for categorization'\\n          items:\\n            type: string\\n            example: 'energy'\\n\"\n}"
