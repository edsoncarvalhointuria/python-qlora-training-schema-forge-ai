"{\n  \"raw_json\": {\n    \"course_title\": \"Advanced Software Engineering\",\n    \"professor\": {\n      \"name\": \"Dr. Ana Silva\",\n      \"academic_background\": \"Ph.D. em Ciência da Computação pela USP, 10 anos de pesquisa em engenharia de software.\"\n    },\n    \"weekly_modules\": [\n      {\n        \"week\": 1,\n        \"topic\": \"Introdução à Engenharia de Software\",\n        \"subtopics\": [\n          \"Histórico e evolução\",\n          \"Modelos de processo\",\n          \"Princípios básicos\"\n        ],\n        \"reading_list\": [\n          {\n            \"title\": \"Software Engineering (10th Edition)\",\n            \"author\": \"Ian Sommerville\",\n            \"isbn\": \"978-1292156138\"\n          }\n        ]\n      },\n      {\n        \"week\": 2,\n        \"topic\": \"Levantamento e Análise de Requisitos\",\n        \"subtopics\": [\n          \"Coleta de requisitos\",\n          \"Modelagem UML\",\n          \"Especificação\"\n        ],\n        \"reading_list\": [\n          {\n            \"title\": \"Requirements Engineering: Fundamentals, Principles, and Techniques\",\n            \"author\": \"Klaus Pohl\",\n            \"isbn\": \"978-3642027124\"\n          }\n        ]\n      }\n    ]\n  },\n  \"openapi_spec\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Resumo da Ementa do Curso\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"Professor\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações acadêmicas do professor responsável pelo curso\\\",\\n        \\\"properties\\\": {\\n          \\\"name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Nome completo do professor\\\",\\n            \\\"example\\\": \\\"Dr. Ana Silva\\\"\\n          },\\n          \\\"academic_background\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n           