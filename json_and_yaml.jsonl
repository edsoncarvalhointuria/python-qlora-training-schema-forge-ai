"{\n  \"raw_json\": {\n    \"team_scores\": {\n      \"team_a\": 16,\n      \"team_b\": 14\n    },\n    \"players\": [\n      {\n        \"player_id\": \"player_123\",\n        \"kills\": 20,\n        \"deaths\": 5,\n        \"assists\": 7\n      },\n      {\n        \"player_id\": \"player_456\",\n        \"kills\": 15,\n        \"deaths\": 8,\n        \"assists\": 10\n      }\n    ],\n    \"match_timeline\": [\n      {\n        \"timestamp\": \"00:05:23\",\n        \"event_type\": \"First Blood\",\n        \"description\": \"Player player_123 secured first kill\"\n      },\n      {\n        \"timestamp\": \"00:12:10\",\n        \"event_type\": \"Objective Captured\",\n        \"description\": \"Team A captured the central control point\"\n      }\n    ]\n  },\n  \"openapi_spec\": \"openapi: 3.0.0\\ninfo:\\n  title: E-sports Match Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    TeamScores:\\n      type: object\\n      description: 'Scores of the competing teams'\\n      properties:\\n        team_a:\\n          type: integer\\n          description: 'Score for Team A'\\n          example: 16\\n        team_b:\\n          type: integer\\n          description: 'Score for Team B'\\n          example: 14\\n    PlayerStats:\\n      type: object\\n      description: 'Statistics for a single player in the match'\\n      properties:\\n        player_id:\\n          type: string\\n          description: 'Unique identifier of the player'\\n          example: 'player_123'\\n        kills:\\n          type: integer\\n          description: 'Number of kills by the player'\\n          example: 20\\n        deaths:\\n          type: integer\\n          description: 'Number of deaths of the player'\\n          example: 5\\n        assists:\\n          type: integer\\n          description: 'Number of assists by the player'\\n          example: 7\\n    MatchEvent:\\n      type: object\\n      description: 'Key event occurred during the match timeline'\\n      properties:\\n        timestamp:\\n          type: string\\n          description: 'Time offset in the match when the event happened'\\n          example: '00:05:23'\\n        event_type:\\n          type: string\\n          description: 'Type of the event'\\n          example: 'First Blood'\\n        description:\\n          type: string\\n          description: 'Detailed description of the event'\\n          example: 'Player player_123 secured first kill'\\n    MatchSummary:\\n      type: object\\n      description: 'Summary of the competitive e-sports match results and events'\\n      properties:\\n        team_scores:\\n          $ref: '#/components/schemas/TeamScores'\\n        players:\\n          type: array\\n          description: 'Array of player statistics'\\n          items:\\n            $ref: '#/components/schemas/PlayerStats'\\n        match_timeline:\\n          type: array\\n          description: 'Chronological list of key events in the match timeline'\\n          items:\\n            $ref: '#/components/schemas/MatchEvent'\"\n}"
